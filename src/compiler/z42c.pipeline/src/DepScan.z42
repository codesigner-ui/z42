// libs 目录扫描（port-z42c-import CI-2）。镜像 C# PackageCompiler.Helpers.BuildDepIndex +
// BuildTarget.ScanLibsForNamespaces。z42c 运行期 Z42_LIBS 是单目录（flat），扫描该目录全部
// lib-kind zpkg：**prelude-first + Ordinal 排序**（common-pitfalls §1 + fix-depindex 同款），
// 一次扫描产出三件：DependencyIndex（签名键表）/ nsMap（ns→zpkg basename，DEPS 用）/
// TSIG ExportedModuleZ 池（ImportedSymbolLoader 输入）。
namespace Z42.Pipeline;

using Std;
using Std.IO;
using Z42.IR;
using Z42.Project;

// 一次扫描的产物束。
public sealed class DepScanResult {
    public DependencyIndex   Index;
    public string[]          NsNames;      public int NsCount;       // nsMap 平行数组
    public string[]          NsFiles;
    public ExportedModuleZ[] Exported;     public int ExportedCount; // 全部 TSIG 模块
    public string[]          ExportedPkg;                            // 平行：每模块来源包名
    public DepScanResult(DependencyIndex index,
                         string[] nsNames, string[] nsFiles, int nsCount,
                         ExportedModuleZ[] exported, string[] exportedPkg, int exportedCount) {
        this.Index = index;
        this.NsNames = nsNames; this.NsFiles = nsFiles; this.NsCount = nsCount;
        this.Exported = exported; this.ExportedPkg = exportedPkg; this.ExportedCount = exportedCount;
    }
    // ns → zpkg basename（未知 → ""）。
    public string FileOf(string ns) {
        int i = 0;
        while (i < this.NsCount) {
            if (this.NsNames[i] == ns) { return this.NsFiles[i]; }
            i = i + 1;
        }
        return "";
    }
}

public static class DepScan {
    // prelude 包名单（镜像 C# PreludePackages.Names）。
    public static bool IsPrelude(string pkgName) { return pkgName == "z42.core"; }

    // declaredDeps/declaredCount = 本工程 manifest 声明的依赖包名（z42c.* 等）。declaredCount>0 时
    // **DepIndex 只索引 stdlib(z42.* 前缀) + 声明依赖**（镜像 C# BuildDepIndex allowedPkgs 过滤），
    // 否则非声明的同名 instance 方法（如 flat 目录里 z42c.semantics 的 IrGen.Intern 撞 z42c.ir 的
    // ZbcStringPool.Intern）会让键歧义被 Seal 剔除 → bare VCall（应 FQ call）。nsMap/TSIG 不过滤
    // （DEPS 用全名单 first-wins；ImportedSymbols 由 using 激活过滤）。
    public static DepScanResult Scan(string libsDir, string excludeName, string[] declaredDeps, int declaredCount) {
        // 单目录 = 多目录的退化形态（Milestone 1 flat dist / 单工程 Z42_LIBS 走这里）。
        string[] one = new string[1];
        one[0] = libsDir;
        return DepScan.ScanDirs(one, 1, excludeName, declaredDeps, declaredCount);
    }

    // Milestone 2（per-member 布局）：成员产物落各自 dist 目录，故兄弟解析需扫**多个** libsDir。
    // dirs[0..dirCount) 全部 *.zpkg 合并后**prelude-first + Ordinal**（按 basename）排序——
    // first-wins 跨目录确定（common-pitfalls §1：成员名唯一，无跨目录同名碰撞）。单目录调用方
    // 经 Scan 退化到此（dirCount=1），扫描序与旧 _sortedZpkgs 一致 → 产物 byte-identical。
    public static DepScanResult ScanDirs(string[] dirs, int dirCount, string excludeName, string[] declaredDeps, int declaredCount) {
        var index = new DependencyIndex();
        string[] nsNames = new string[8];
        string[] nsFiles = new string[8];
        int nsCount = 0;
        ExportedModuleZ[] exported = new ExportedModuleZ[8];
        string[] exportedPkg = new string[8];
        int exportedCount = 0;
        // 包不导入自己：构建某包时把它自己的 .zpkg 排除出扫描（flat libs 含 self 时——
        // 否则同包符号经 DepIndex 解析 → 自依赖 DEPS + FQ 调用，与 C#[libs 不含 self]不一致）。
        string excludeZpkg = excludeName + ".zpkg";
        string[] paths = DepScan._sortedZpkgsMulti(dirs, dirCount);
        if (paths.Length == 0) {
            return new DepScanResult(index, nsNames, nsFiles, 0, exported, exportedPkg, 0);
        }
        int pi = 0;
        while (pi < paths.Length) {
            ZpkgInfo z = ZpkgReader.Open(File.ReadAllBytes(paths[pi]));
            string basename = Path.GetFileName(paths[pi]);
            if (z != null && !z.IsExe) {  // lib-kind only
                // nsMap：NSPC 全名单 first-wins（**含 self**；BuildDependencyMap 用 selfZpkgFile 过滤自依赖
                // 镜像 C# ScanLibsForNamespaces 不排除 self → BuildDependencyMap 排除——确保 self
                // namespace 映射到 self.zpkg 而非被其他声明同 ns 的包抢占）
                string[] nss = ZpkgReader.ReadNamespaces(z);
                int i = 0;
                while (i < nss.Length) {
                    if (DepScan._nsIndexOf(nsNames, nsCount, nss[i]) < 0) {
                        if (nsCount == nsNames.Length) {
                            string[] b1 = new string[nsNames.Length * 2];
                            string[] b2 = new string[nsNames.Length * 2];
                            int k = 0;
                            while (k < nsCount) { b1[k] = nsNames[k]; b2[k] = nsFiles[k]; k = k + 1; }
                            nsNames = b1; nsFiles = b2;
                        }
                        nsNames[nsCount] = nss[i];
                        nsFiles[nsCount] = basename;
                        nsCount = nsCount + 1;
                    }
                    i = i + 1;
                }
                // DepIndex 和 TSIG：排除 self（避免自引用；镜像 C# BuildDepIndex excludeName 语义）
                if (basename != excludeZpkg) {
                    // DepIndex：每模块 SIGS 签名（声明依赖过滤——镜像 C# BuildDepIndex allowedPkgs）
                    if (declaredCount == 0 || DepScan._allowedForIndex(z.Name, declaredDeps, declaredCount)) {
                        ZpkgModuleSigs[] mods = ZpkgReader.ReadModuleSigs(z);
                        i = 0;
                        while (i < mods.Length) {
                            index.AddModule(mods[i].Functions, mods[i].FuncCount, mods[i].Namespace);
                            i = i + 1;
                        }
                    }
                    // TSIG 模块池
                    ExportedModuleZ[] tsig = ZpkgReader.ReadTsig(z);
                    i = 0;
                    while (i < tsig.Length) {
                        if (exportedCount == exported.Length) {
                            ExportedModuleZ[] b1 = new ExportedModuleZ[exported.Length * 2];
                            string[] b2 = new string[exported.Length * 2];
                            int k = 0;
                            while (k < exportedCount) { b1[k] = exported[k]; b2[k] = exportedPkg[k]; k = k + 1; }
                            exported = b1; exportedPkg = b2;
                        }
                        exported[exportedCount] = tsig[i];
                        exportedPkg[exportedCount] = z.Name;
                        exportedCount = exportedCount + 1;
                        i = i + 1;
                    }
                }
            }
            pi = pi + 1;
        }
        index.Seal();
        return new DepScanResult(index, nsNames, nsFiles, nsCount, exported, exportedPkg, exportedCount);
    }

    // 多目录合并 + prelude-first（"0_"+name）+ Ordinal 排序（按 basename）。
    // 不存在的目录跳过（per-member 布局下后续成员 dist 在建本成员时尚空）。
    private static string[] _sortedZpkgsMulti(string[] dirs, int dirCount) {
        // 第一遍：统计总数。
        int total = 0;
        int di = 0;
        while (di < dirCount) {
            if (Directory.Exists(dirs[di])) { total = total + Path.Glob(dirs[di], "*.zpkg").Length; }
            di = di + 1;
        }
        // 第二遍：合并到 flat 数组。
        string[] paths = new string[total];
        int pc = 0;
        di = 0;
        while (di < dirCount) {
            if (Directory.Exists(dirs[di])) {
                string[] hits = Path.Glob(dirs[di], "*.zpkg");
                int hi = 0;
                while (hi < hits.Length) { paths[pc] = hits[hi]; pc = pc + 1; hi = hi + 1; }
            }
            di = di + 1;
        }
        // 同名包跨目录去重（first-wins）：某包同时在成员 dist 与 Z42_LIBS（外部 stdlib
        // 种子）出现时只扫一次，避免 DepIndex 重复 AddModule → 歧义键被 Seal 剔除。
        // 单目录调用方无重名（一目录不会有两份同名文件）→ 此步 no-op，Milestone 1 byte-identical 不变。
        return DepScan._dedupByBasename(DepScan._sortZpkgKeys(paths));
    }

    // 排序后的 paths 中，每个 basename 仅保留首次出现（first-wins）。
    private static string[] _dedupByBasename(string[] paths) {
        string[] seen = new string[paths.Length];
        int seenCount = 0;
        string[] kept = new string[paths.Length];
        int keptCount = 0;
        int i = 0;
        while (i < paths.Length) {
            string b = Path.GetFileName(paths[i]);
            if (DepScan._nsIndexOf(seen, seenCount, b) < 0) {
                seen[seenCount] = b; seenCount = seenCount + 1;
                kept[keptCount] = paths[i]; keptCount = keptCount + 1;
            }
            i = i + 1;
        }
        if (keptCount == paths.Length) { return kept; }
        string[] r = new string[keptCount];
        i = 0;
        while (i < keptCount) { r[i] = kept[i]; i = i + 1; }
        return r;
    }

    // prelude-first（"0_"+name）+ Ordinal 排序（镜像 C# BuildDepIndex 的 sortedPaths）。
    private static string[] _sortZpkgKeys(string[] paths) {
        // 排序键并行数组 + 插入排序
        string[] keys = new string[paths.Length];
        int i = 0;
        while (i < paths.Length) {
            string name = Path.GetFileNameWithoutExtension(paths[i]);
            if (DepScan.IsPrelude(name)) { keys[i] = "0_" + name; }
            else { keys[i] = "1_" + name; }
            i = i + 1;
        }
        i = 1;
        while (i < paths.Length) {
            string k = keys[i];
            string p = paths[i];
            int j = i - 1;
            bool more = j >= 0;
            while (more) {
                if (keys[j].CompareTo(k) > 0) {
                    keys[j + 1] = keys[j]; paths[j + 1] = paths[j];
                    j = j - 1; more = j >= 0;
                } else { more = false; }
            }
            keys[j + 1] = k;
            paths[j + 1] = p;
            i = i + 1;
        }
        return paths;
    }

    // DepIndex 准入：stdlib（z42. 前缀；z42c.X 不匹配）∨ 声明依赖名（镜像 C# isStdlib || allowedPkgs.Contains）。
    private static bool _allowedForIndex(string pkgName, string[] declaredDeps, int declaredCount) {
        if (pkgName.StartsWith("z42.")) { return true; }
        int i = 0;
        while (i < declaredCount) {
            if (declaredDeps[i] == pkgName) { return true; }
            i = i + 1;
        }
        return false;
    }

    private static int _nsIndexOf(string[] a, int n, string s) {
        int i = 0;
        while (i < n) {
            if (a[i] == s) { return i; }
            i = i + 1;
        }
        return 0 - 1;
    }
}
