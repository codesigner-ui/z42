// z42c driver — 自举编译器 CLI 入口（= z42c）。增量解锁命令；绝不 fallback 到 C# z42c.dll。
// 已实现：
//   z42c --dump-tokens <file.z42>          词法 token 流（z42c 自有格式）
//   z42c --dump-ast    <file.z42>          AST s-expression
//   z42c --dump-bound  <file.z42>          类型检查后的 Bound 树（含类型注解 + 诊断数）
//   z42c --emit-zbc    <file.z42> <out>    编译到 .zbc（ZW-1A/1B opcode 子集；无 DBUG）
//   z42c build         <project.z42.toml>  编译整包 → dist/<name>.zpkg
// 注：z42c 只编译，不跑测试。`test` / `bench` 是构建编排（build+run+report），宿主 = z42b
//     （编排器），runner 逻辑住 z42.test 库。见 docs/design/toolchain/build-orchestrator.md
//     Decision #9 + retire-test-runner spec。
namespace Z42.Driver;

using Std;
using Std.IO;
using Z42.Syntax;
using Z42.Semantics;
using Z42.Project;
using Z42.IR;
using Z42.Pipeline;

void Main() {
    string[] argv = Environment.GetCommandLineArgs();
    if (argv.Length < 2) {
        _usage();
        return;
    }
    string cmd  = argv[0];
    string file = argv[1];
    if (cmd == "build") {
        bool isRelease = false;
        bool isWorkspace = false;
        string outputDir = "";
        // ai from 1: `build --workspace` 时 argv[1] 是 flag 不是 toml 路径。
        int ai = 1;
        while (ai < argv.Length) {
            if (argv[ai] == "--release") { isRelease = true; }
            else if (argv[ai] == "--workspace") { isWorkspace = true; }
            else if (argv[ai] == "--output-dir" && ai + 1 < argv.Length) { outputDir = argv[ai + 1]; ai = ai + 1; }
            ai = ai + 1;
        }
        if (isWorkspace) {
            Environment.Exit(_buildWorkspace(isRelease, outputDir));
            return;
        }
        Environment.Exit(_build(file, isRelease, outputDir, new string[0], 0));
        return;
    }
    if (cmd == "clean") {
        string target = (argv.Length >= 2 && !file.StartsWith("--")) ? file : ".";
        Environment.Exit(_clean(target));
        return;
    }
    if (cmd == "--emit-zbc") {
        if (argv.Length < 3) {
            ConsoleError.WriteLine("z42c: --emit-zbc requires <file.z42> <out.zbc>");
            Environment.Exit(2);
            return;
        }
        string ezText = File.ReadAllText(file);
        // replace-csharp Phase C：跨包 dep 解析（Z42_LIBS）→ 调 stdlib 的源（golden 等）emit 正确 FQ
        // 函数名（否则 `<error>` → 运行期 undefined function）。无 Z42_LIBS → 回落无依赖单文件 emit。
        string ezEnv = Environment.GetEnvironmentVariable("Z42_LIBS") ?? "";
        if (ezEnv.Length > 0) {
            string[] ezDirs = new string[1]; ezDirs[0] = ezEnv;
            DepScanResult ezScan = DepScan.ScanDirs(ezDirs, 1, "", new string[0], 0);
            string[] ezUsings = IrDump.ExtractUsings(ezText, file);
            ImportedSymbols ezImported = ImportedSymbolLoader.Load(
                ezScan.Exported, ezScan.ExportedPkg, ezScan.ExportedCount, ezUsings, ezUsings.Length);
            File.WriteAllBytes(argv[2], IrDump.ZbcBytesD(ezText, file, ezScan.Index, ezImported));
        } else {
            File.WriteAllBytes(argv[2], IrDump.ZbcBytes(ezText, file));
        }
        return;
    }
    if (cmd == "--dump-ir") { Console.WriteLine(IrDump.DumpModule(File.ReadAllText(file))); return; }
    if (cmd != "--dump-tokens" && cmd != "--dump-ast" && cmd != "--dump-bound") {
        ConsoleError.WriteLine("z42c: unknown command '" + cmd + "'");
        _usage();
        Environment.Exit(2);
        return;
    }
    string src = File.ReadAllText(file);
    if (cmd == "--dump-tokens")     { Console.WriteLine(DumpTool.DumpTokens(src)); }
    else if (cmd == "--dump-ast")   { Console.WriteLine(DumpTool.DumpAst(src)); }
    else                            { Console.WriteLine(SemanticDump.DumpAll(src)); }
}

// `z42c build <toml>`：manifest → 源发现 → 逐文件编译 → packed zpkg → dist/<name>.zpkg。
// MVP：单工程/packed/无增量（镜像 C# PackageCompiler.BuildTarget 关键路径）。
int _build(string tomlPath, bool isRelease, string outputDirOverride, string[] libsDirsOverride, int libsDirsCount) {
    ProjectManifest pm = ManifestLoader.Load(tomlPath);
    string projectDir = Path.GetDirectoryName(tomlPath);
    if (projectDir == "") { projectDir = "."; }
    string[] srcs = SourceDiscovery.Discover(projectDir, pm.IncludeGlobs, pm.IncludeCount);
    if (srcs.Length == 0) {
        ConsoleError.WriteLine("z42c build: no sources matched [sources].include");
        return 1;
    }
    // ── 跨包依赖（CI-4）：libsDirs 扫描 → DepIndex + nsMap + TSIG 池；usings 聚合决定激活集 ──
    // workspace build 传 libsDirsOverride：Milestone 1 = [flat dist]（单元素）；
    // Milestone 2 = 全成员 dist 列表（per-member 布局，解析兄弟）+ Z42_LIBS（外部 stdlib）。
    // 单工程留空 → 回落 Z42_LIBS env（单目录）。
    string[] libsDirs;
    int libsDirsN;
    if (libsDirsCount > 0) {
        libsDirs = libsDirsOverride;
        libsDirsN = libsDirsCount;
    } else {
        string env = Environment.GetEnvironmentVariable("Z42_LIBS") ?? "";
        if (env.Length > 0) { libsDirs = new string[1]; libsDirs[0] = env; libsDirsN = 1; }
        else { libsDirs = new string[0]; libsDirsN = 0; }
    }
    DepScanResult scan = null;
    ImportedSymbols imported = null;
    DependencyIndex depIndex = null;
    if (libsDirsN > 0) {
        // 声明依赖名（DepIndex 过滤：只索引 stdlib + 声明依赖，镜像 C# BuildDepIndex allowedPkgs）
        string[] declaredDeps = new string[pm.DepCount];
        int ddi = 0;
        while (ddi < pm.DepCount) { declaredDeps[ddi] = pm.Deps[ddi].Name; ddi = ddi + 1; }
        scan = DepScan.ScanDirs(libsDirs, libsDirsN, pm.Name, declaredDeps, pm.DepCount);   // 排除 self-zpkg（包不导入自己）
        depIndex = scan.Index;
        // 全工程 usings 聚合（镜像 C# LoadExternalImported 的跨文件聚合）
        string[] allUsings = new string[8];
        int auc = 0;
        int ui = 0;
        while (ui < srcs.Length) {
            string[] us = IrDump.ExtractUsings(File.ReadAllText(srcs[ui]), srcs[ui]);
            int j = 0;
            while (j < us.Length) {
                bool seen = false;
                int k = 0;
                while (k < auc) { if (allUsings[k] == us[j]) { seen = true; } k = k + 1; }
                if (!seen) {
                    if (auc == allUsings.Length) {
                        string[] b = new string[allUsings.Length * 2];
                        int m2 = 0; while (m2 < auc) { b[m2] = allUsings[m2]; m2 = m2 + 1; }
                        allUsings = b;
                    }
                    allUsings[auc] = us[j]; auc = auc + 1;
                }
                j = j + 1;
            }
            ui = ui + 1;
        }
        imported = ImportedSymbolLoader.Load(scan.Exported, scan.ExportedPkg, scan.ExportedCount,
                                             allUsings, auc);
    }
    // 包级编译（PS-1）：全文件先 parse 合并收集符号，再逐文件产物——同包跨文件互引可见
    string[] texts = new string[srcs.Length];
    int i = 0;
    while (i < srcs.Length) { texts[i] = File.ReadAllText(srcs[i]); i = i + 1; }
    CompiledModuleZ[] cms = IrDump.BuildPackage(texts, srcs, srcs.Length, depIndex, imported, isRelease);
    ZbcFileZ[] mods = new ZbcFileZ[srcs.Length];
    i = 0;
    while (i < srcs.Length) {
        string text = texts[i];
        CompiledModuleZ cm = cms[i];
        if (cm.ErrorCount > 0) {
            ConsoleError.WriteLine("z42c build: " + cm.ErrorCount.ToString() + " error(s) in " + srcs[i]);
            int di = 0;
            while (di < cm.DiagCount) { ConsoleError.WriteLine("  " + cm.DiagMsgs[di]); di = di + 1; }
            return 1;
        }
        IrModule irm = cm.Module;
        // SourceFile = 发现到的完整路径原样（真 C# CLI 字节实测；fixture 的相对化是测试合成形态）
        string rel = srcs[i];
        string[] exports = new string[irm.FuncCount];
        int e = 0;
        while (e < irm.FuncCount) { exports[e] = irm.Functions[e].Name; e = e + 1; }
        string modNs = cm.Namespace;
        if (modNs == "") { modNs = "main"; }   // C# build 路径字节实证：no-ns 单元 ns="main"（EXPT=main.Main / MODS ns=main）
        mods[i] = new ZbcFileZ(rel, ZpkgBuilder.Sha256Hex(text), modNs,
                               exports, irm.FuncCount, irm);
        mods[i].Usings = cm.Usings;       mods[i].UsingCount = cm.UsingCount;
        mods[i].UsedDepNs = cm.UsedDepNs; mods[i].UsedDepNsCount = cm.UsedDepNsCount;
        i = i + 1;
    }
    // TSIG：BuildPackage 已产 per-file Exported（PS-1）
    ExportedModuleZ[] exported = new ExportedModuleZ[srcs.Length];
    i = 0;
    while (i < srcs.Length) { exported[i] = cms[i].Exported; i = i + 1; }
    bool isExe = pm.Kind == "exe";
    // DEPS 条目（usings ∪ usedDepNs → nsMap）
    ZpkgDepList depList = new ZpkgDepList(new ZpkgDepZ[0], 0);
    if (scan != null) {
        depList = ZpkgBuilder.BuildDependencyMap(mods, srcs.Length, scan.NsNames, scan.NsFiles, scan.NsCount, pm.Name + ".zpkg");
    }
    ZpkgFileZ z = ZpkgBuilder.BuildPackedD(pm.Name, pm.Version, isExe, pm.HasEntry, pm.Entry, mods, srcs.Length,
                                           depList.Items, depList.Count);
    z.Exported = exported;
    z.ExportedCount = srcs.Length;
    if (isExe && z.Entry == "<ambiguous>") {
        ConsoleError.WriteLine("z42c build: multiple Main candidates; set [project].entry explicitly");
        return 1;
    }
    if (isExe && z.Entry == "") {
        ConsoleError.WriteLine("z42c build: kind=exe but no Main() found");
        return 1;
    }
    string distDir = outputDirOverride.Length > 0 ? outputDirOverride : _resolveDistDir(pm, projectDir, isRelease);
    Directory.Create(distDir);
    string outPath = Path.Join(distDir, pm.Name + ".zpkg");
    // release → strip-symbols：主 zpkg（MODS dbug_len=0 + BLID）+ .zsym sidecar（split-debug）。
    ZpkgWriteResult wres = ZpkgWriterZ.WritePackedWithSidecar(z, isRelease);
    File.WriteAllBytes(outPath, wres.Main);
    Console.WriteLine("wrote -> " + outPath);
    if (wres.HasSidecar) {
        string symPath = Path.Join(distDir, pm.Name + ".zsym");
        File.WriteAllBytes(symPath, wres.Sidecar);
        Console.WriteLine("wrote -> " + symPath);
    }
    return 0;
}

// 解析无 --output-dir override 时的有效 dist 目录。
//
// 当 toml **显式**设 [build].output_dir 或 dist_dir 时，按 C#
// CentralizedBuildLayout.ResolveSingleProject 级联解析（workloads / launcher /
// xtask / 测试单元靠它把产物重定向到镜像目录）：
//   output_dir = build.output_dir ?? "${workspace_dir}/artifacts/${profile}"
//   dist_dir   = build.dist_dir   ?? "${output_dir}/dist"
// 单工程模式 ${workspace_dir} = projectDir（toml 所在目录）。projectDir 先转绝对，
// 使 ${output_dir} 替换后保持 rooted（避免相对 dist 模板被二次 Join 重复前缀）。
//
// 当 toml **没有** [build] output_dir/dist_dir 时，保留 z42c 历史默认
// `<projectDir>/dist`：大量内部调用方（e2e / 临时工程 build 后读 <dir>/dist）硬编码
// 该路径。此处刻意不切到 C# 的 artifacts/<profile>/dist 默认——那会破坏这些调用方，
// 且无调用方依赖「经 z42c 得到 C# 默认路径」。本函数的目的只是兑现*显式*配置。
string _resolveDistDir(ProjectManifest pm, string projectDir, bool isRelease) {
    if (!pm.HasOutputDir && !pm.HasDistDir) {
        return Path.Join(projectDir, "dist");
    }
    string profile = isRelease ? "release" : "debug";
    string absProj = Path.IsRooted(projectDir) ? projectDir
        : Path.Join(Environment.GetCurrentDirectory(), projectDir);
    // output_dir
    TemplateContext octx = new TemplateContext(absProj, absProj, pm.Name, profile, "");
    string outputRaw = pm.HasOutputDir ? pm.OutputDir : "${workspace_dir}/artifacts/${profile}";
    string outputExp = PathTemplate.Expand(outputRaw, octx);
    string outputAbs = Path.IsRooted(outputExp) ? outputExp : Path.Join(absProj, outputExp);
    // dist_dir（${output_dir} → outputAbs；rooted 直接透传）
    TemplateContext dctx = new TemplateContext(absProj, absProj, pm.Name, profile, outputAbs);
    string distRaw = pm.HasDistDir ? pm.DistDir : "${output_dir}/dist";
    string distExp = PathTemplate.Expand(distRaw, dctx);
    return Path.IsRooted(distExp) ? distExp : Path.Join(absProj, distExp);
}

// `z42c build --workspace [--output-dir <flat>] [--release]`：从 CWD 向上找
// z42.workspace.toml → 成员拓扑序 → 逐成员 build。
// Milestone 1（显式 --output-dir <flat>）：全成员产物落该 flat dir（= 各成员 libsDir，
// deps-first 解析兄弟）。产物 zpkg 与 C# `build --workspace` byte-identical（字节与
// 目录无关）。注意：flat dir 须含 stdlib 依赖（调用方 seed Z42_LIBS 内容）。
// Milestone 2（drop-in，无 --output-dir）：按 [workspace.build].output_dir 模板展开
// per-member 布局（artifacts/.../<name>/<profile>/dist），各成员产物落各自 dist；
// 兄弟解析扫全成员 dist 列表 + Z42_LIBS（外部 stdlib）。镜像 C# WorkspaceBuildOrchestrator
// 的 workspaceLibDirs（成员 EffectiveDistDir 透传）。
int _buildWorkspace(bool isRelease, string outputDir) {
    string cwd = Environment.GetCurrentDirectory();
    string wsToml = _findWorkspaceToml(cwd);
    if (wsToml == "") {
        ConsoleError.WriteLine("z42c build --workspace: no z42.workspace.toml from CWD upward (" + cwd + ")");
        return 2;
    }
    if (outputDir != "") {
        return _buildWorkspaceFlat(wsToml, isRelease, outputDir);
    }
    return _buildWorkspacePerMember(wsToml, isRelease);
}

// Milestone 1：flat dist（显式 --output-dir）。
int _buildWorkspaceFlat(string wsToml, bool isRelease, string outputDir) {
    Directory.Create(outputDir);
    string[] flat = new string[1];
    flat[0] = outputDir;
    string[] ordered = WorkspaceBuild.Plan(wsToml);
    Console.WriteLine("workspace: " + wsToml + " (" + ordered.Length.ToString() + " members, topo order, flat)");
    int i = 0;
    while (i < ordered.Length) {
        Console.WriteLine("  [" + (i + 1).ToString() + "/" + ordered.Length.ToString() + "] " + ordered[i]);
        int rc = _build(ordered[i], isRelease, outputDir, flat, 1);
        if (rc != 0) {
            ConsoleError.WriteLine("z42c build --workspace: member build failed: " + ordered[i]);
            return rc;
        }
        i = i + 1;
    }
    Console.WriteLine("workspace build OK -> " + outputDir);
    return 0;
}

// Milestone 2：per-member 布局（drop-in 替代 C# stdlib build）。
int _buildWorkspacePerMember(string wsToml, bool isRelease) {
    string profile = isRelease ? "release" : "debug";
    WsPlan plan = WorkspaceBuild.PlanLayout(wsToml, profile);
    if (plan == null) {
        ConsoleError.WriteLine("z42c build --workspace: no --output-dir and no [workspace.build].output_dir in " + wsToml);
        return 2;
    }
    // libsDirs = 全成员 dist + Z42_LIBS（外部 stdlib，如 z42c.* → z42.core）。
    string env = Environment.GetEnvironmentVariable("Z42_LIBS") ?? "";
    int extra = (env.Length > 0) ? 1 : 0;
    string[] libsDirs = new string[plan.Count + extra];
    int i = 0;
    while (i < plan.Count) { libsDirs[i] = plan.DistDirs[i]; i = i + 1; }
    if (extra == 1) { libsDirs[plan.Count] = env; }
    int libsN = plan.Count + extra;
    // 先建全部成员 dist（空目录）→ DepScan 多目录扫描可见（后续成员 dist 在建本成员时尚空）。
    i = 0;
    while (i < plan.Count) { Directory.Create(plan.DistDirs[i]); i = i + 1; }
    Console.WriteLine("workspace: " + wsToml + " (" + plan.Count.ToString() + " members, topo order, per-member " + profile + ")");
    i = 0;
    while (i < plan.Count) {
        Console.WriteLine("  [" + (i + 1).ToString() + "/" + plan.Count.ToString() + "] " + plan.Tomls[i] + " -> " + plan.DistDirs[i]);
        int rc = _build(plan.Tomls[i], isRelease, plan.DistDirs[i], libsDirs, libsN);
        if (rc != 0) {
            ConsoleError.WriteLine("z42c build --workspace: member build failed: " + plan.Tomls[i]);
            return rc;
        }
        i = i + 1;
    }
    Console.WriteLine("workspace build OK (per-member layout)");
    return 0;
}

// 从 startDir 向上找 z42.workspace.toml；返回路径或 ""（镜像 C# DiscoverWorkspaceRoot）。
string _findWorkspaceToml(string startDir) {
    string dir = startDir;
    while (dir.Length > 0) {
        string cand = Path.Join(dir, "z42.workspace.toml");
        if (File.Exists(cand)) { return cand; }
        string parent = Path.GetDirectoryName(dir);
        if (parent == dir || parent == "") { break; }
        dir = parent;
    }
    return "";
}

// `z42c clean [<dir>]`：删 <dir>/dist 与 <dir>/cache 产物子树（默认 CWD）。
int _clean(string dir) {
    int removed = 0;
    string[] subs = new string[2];
    subs[0] = Path.Join(dir, "dist");
    subs[1] = Path.Join(dir, "cache");
    int i = 0;
    while (i < subs.Length) {
        if (Directory.Exists(subs[i])) {
            Directory.Delete(subs[i], true);
            Console.WriteLine("removed " + subs[i]);
            removed = removed + 1;
        }
        i = i + 1;
    }
    if (removed == 0) { Console.WriteLine("clean: nothing to remove under " + dir); }
    return 0;
}

void _usage() {
    Console.WriteLine("z42c (self-host) 0.1.0 — bootstrap (lex/parse/typecheck front-end)");
    Console.WriteLine("usage:");
    Console.WriteLine("  z42c --dump-tokens <file.z42>          token stream");
    Console.WriteLine("  z42c --dump-ast    <file.z42>          AST s-expression");
    Console.WriteLine("  z42c --dump-bound  <file.z42>          type-checked Bound tree");
    Console.WriteLine("  z42c --dump-ir     <file.z42>          .zasm-like IR text");
    Console.WriteLine("  z42c --emit-zbc    <file.z42> <out>    compile to .zbc (subset)");
    Console.WriteLine("  z42c build         <project.z42.toml>  build packed .zpkg -> dist/");
    Console.WriteLine("  z42c build --workspace [--output-dir <d>] build all members (topo order);");
    Console.WriteLine("                                          omit --output-dir for per-member layout");
    Console.WriteLine("  z42c clean         [<dir>]             remove <dir>/{dist,cache}");
    Console.WriteLine("  (test / bench are run by z42b, not z42c — the compiler only compiles)");
}
