// z42c.syntax 骨架（B0）。占位 —— Lexer / Parser / AST（class 继承 + 抽象 Visitor，
// 受限写法，不用 record+match）由 0.3.3 syntax spec 落地。
// 此处引用 z42c.core 以验证跨包编译/链接（driver→pipeline→…→core 全链路）。
namespace Z42.Syntax;

using Z42.Core;

public sealed class SyntaxSkeleton {
    public string Name() {
        var core = new CoreSkeleton();
        return "z42c.syntax(" + core.Name() + ")";
    }
}
