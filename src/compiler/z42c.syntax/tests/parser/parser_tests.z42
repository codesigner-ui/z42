// z42c.syntax Parser（Pratt 表达式）单测：用 Dump() 的 s-expression 断言结构 + 优先级。
namespace Z42cSyntaxParserTests;

using Std;
using Std.Test;
using Z42.Syntax;

// 辅助：解析表达式并返回其 s-expression dump。
string parse(string src) {
    var p = new Parser(src, "t.z42");
    var e = p.ParseExpression();
    return e.Dump();
}

[Test]
void test_literal_and_ident() {
    Assert.Equal("42", parse("42"));
    Assert.Equal("3.14", parse("3.14"));
    Assert.Equal("true", parse("true"));
    Assert.Equal("false", parse("false"));
    Assert.Equal("null", parse("null"));
    Assert.Equal("foo", parse("foo"));
    Assert.Equal("\"hi\"", parse("\"hi\""));
}

[Test]
void test_simple_binary() {
    Assert.Equal("(+ 1 2)", parse("1 + 2"));
    Assert.Equal("(* a b)", parse("a * b"));
}

[Test]
void test_precedence_mul_over_add() {
    Assert.Equal("(+ 1 (* 2 3))", parse("1 + 2 * 3"));
    Assert.Equal("(+ (* 1 2) 3)", parse("1 * 2 + 3"));
}

[Test]
void test_parens_override_precedence() {
    Assert.Equal("(* (+ 1 2) 3)", parse("(1 + 2) * 3"));
}

[Test]
void test_left_associativity() {
    Assert.Equal("(- (- a b) c)", parse("a - b - c"));
    Assert.Equal("(/ (/ a b) c)", parse("a / b / c"));
}

[Test]
void test_logical_precedence() {
    // && 绑定紧于 ||
    Assert.Equal("(|| (&& a b) c)", parse("a && b || c"));
    Assert.Equal("(|| a (&& b c))", parse("a || b && c"));
}

[Test]
void test_comparison_and_arithmetic() {
    // + 紧于 ==
    Assert.Equal("(== 1 (+ 2 3))", parse("1 == 2 + 3"));
    Assert.Equal("(< (+ a b) c)", parse("a + b < c"));
}

[Test]
void test_unary() {
    Assert.Equal("(- x)", parse("-x"));
    Assert.Equal("(! a)", parse("!a"));
    // 一元紧于二元：!a && b → (&& (! a) b)
    Assert.Equal("(&& (! a) b)", parse("!a && b"));
    // -a * b → (* (- a) b)
    Assert.Equal("(* (- a) b)", parse("-a * b"));
}

[Test]
void test_mixed_complex() {
    Assert.Equal("(|| (== (+ 1 (* 2 3)) 7) done)", parse("1 + 2 * 3 == 7 || done"));
}

[Test]
void test_member_access() {
    Assert.Equal("(. a b)", parse("a.b"));
    Assert.Equal("(. (. a b) c)", parse("a.b.c"));   // 左结合
}

[Test]
void test_call() {
    Assert.Equal("(call f)", parse("f()"));
    Assert.Equal("(call f 1 2)", parse("f(1, 2)"));
    Assert.Equal("(call (. a b) c)", parse("a.b(c)"));   // 调用作用于成员
}

[Test]
void test_index() {
    Assert.Equal("(index a 0)", parse("a[0]"));
    Assert.Equal("(index (. a items) i)", parse("a.items[i]"));
}

[Test]
void test_assign_right_assoc() {
    Assert.Equal("(= x 1)", parse("x = 1"));
    Assert.Equal("(= a (= b c))", parse("a = b = c"));        // 右结合
    Assert.Equal("(= x (+ 1 2))", parse("x = 1 + 2"));        // = 最松
}

[Test]
void test_ternary() {
    Assert.Equal("(?: a b c)", parse("a ? b : c"));
    Assert.Equal("(?: (> x 0) 1 2)", parse("x > 0 ? 1 : 2"));   // 条件含比较
    Assert.Equal("(?: a b (?: c d e))", parse("a ? b : c ? d : e"));  // 右结合
    Assert.Equal("(= x (?: a b c))", parse("x = a ? b : c"));   // = 比 ?: 更松
}

[Test]
void test_bitwise_precedence() {
    Assert.Equal("(| (& a b) c)", parse("a & b | c"));   // & (48) 紧于 | (44)
    Assert.Equal("(| a (& b c))", parse("a | b & c"));
    Assert.Equal("(<< a (+ 2 1))", parse("a << 2 + 1"));  // + (70) 紧于 << (65)
    Assert.Equal("(^ (& a b) c)", parse("a & b ^ c"));   // & (48) 紧于 ^ (46)
}

[Test]
void test_null_coalescing() {
    Assert.Equal("(?? a b)", parse("a ?? b"));
    Assert.Equal("(?? a (?? b c))", parse("a ?? b ?? c"));      // 右结合
    Assert.Equal("(?: (?? a b) c d)", parse("a ?? b ? c : d")); // ?? (25) 紧于 ?: (20)
}

[Test]
void test_is_as() {
    Assert.Equal("(is x Foo)", parse("x is Foo"));
    Assert.Equal("(as x Bar)", parse("x as Bar"));
    Assert.Equal("(is (+ a b) int)", parse("a + b is int"));    // + (70) 紧于 is (60)
    Assert.Equal("(is x List<int>)", parse("x is List<int>"));  // 泛型类型
}

[Test]
void test_compound_assign() {
    Assert.Equal("(+= x 1)", parse("x += 1"));
    Assert.Equal("(*= (. a b) c)", parse("a.b *= c"));
    Assert.Equal("(|= flags mask)", parse("flags |= mask"));
}

[Test]
void test_new() {
    Assert.Equal("(new Foo 1 2)", parse("new Foo(1, 2)"));
    Assert.Equal("(new List<int>)", parse("new List<int>()"));
    Assert.Equal("(call (. (new Point x y) Dist))", parse("new Point(x, y).Dist()"));
}

// incr 6d-1：TypeExpr 结构化（经 is/as/new）。验证嵌套泛型 >>/>>> 拆分、限定名、数组、nullable。
[Test]
void test_type_expr_forms() {
    Assert.Equal("(is x Dict<string,int>)", parse("x is Dict<string, int>"));   // 空格归一
    Assert.Equal("(as y List<List<int>>)", parse("y as List<List<int>>"));      // 嵌套 >>
    Assert.Equal("(is z Map<K,List<V>>)", parse("z is Map<K, List<V>>"));       // 内层 List 与外层 Map 共享 >>
    Assert.Equal("(is a A<B<C<int>>>)", parse("a is A<B<C<int>>>"));            // 三层 >>>（GtGt+Gt 拆分）
    Assert.Equal("(new Foo.Bar<int>)", parse("new Foo.Bar<int>()"));           // 限定名 + 泛型
    Assert.Equal("(is b int[])", parse("b is int[]"));                          // 数组
    Assert.Equal("(as c T?)", parse("c as T?"));                               // nullable
    Assert.Equal("(is d List<int>[])", parse("d is List<int>[]"));             // 泛型 + 数组
}
