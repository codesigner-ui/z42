// 导出类型签名提取（port-z42c-tsig TS-2）。镜像 C# ExportedTypeExtractor + SymbolCollector 内建注入。
//
// 确定性铁律：用户类/成员/函数一律按 **CU 声明序** 遍历（Z42ClassType.Fields/Methods 是 hashed
// StrMap，迭代非确定——只做按名查询）。
//
// 内建面（C# 同源 1199B 字节实测，编译器级固定 prelude，与用户源无关）：
//   ① 每用户类的方法表前置 Object 四方法（ToString/Equals/GetHashCode/GetType——C# SymbolCollector
//      在建类时注入，故 TSIG 里它们出现在用户方法之前）
//   ② 11 个内建接口 + GCHandleType 枚举 + Action×5/Func×5/Predicate 共 11 个委托定义
//   参数名规则：方法/函数 "p{i}"、委托 "arg{i}"；无修饰成员可见性 = "internal"；
//   类基名用短名（"Object"，区别于 TYPE 段的 "Std.Object"）。
namespace Z42.Semantics;

using Z42.Syntax;
using Z42.IR;

public static class ExportedTypeExtractor {

    // 全包自由函数版（PS-1 镜像 C#：sem.Funcs 含兄弟合并 → 每模块 TSIG functions 全包泄漏；
    // classes 有 imported/intra 过滤故不重复——字节实证 13B/条）。
    public static ExportedModuleZ ExtractP(CompilationUnit cu, SymbolTable symbols, string ns,
                                           ExportedFuncZ[] allFuncs, int allFuncCount) {
        ExportedModuleZ em = ExportedTypeExtractor.Extract(cu, symbols, ns, null);
        return new ExportedModuleZ(em.Namespace,
            em.Classes, em.ClassCount,
            em.Interfaces, em.InterfaceCount,
            em.Enums, em.EnumCount,
            allFuncs, allFuncCount,
            em.Delegates, em.DelegateCount);
    }

    // 带全包 classMap 的版本（G18 部分修复：同包跨文件 base 类构造器继承）。
    // classNs：短类名→声明 ns 图（imported + 同包跨-ns），用于 impl target/trait FQ 化。
    public static ExportedModuleZ ExtractP(CompilationUnit cu, SymbolTable symbols, string ns,
                                           ExportedFuncZ[] allFuncs, int allFuncCount, StrMap pkgClassMap, StrMap classNs) {
        ExportedModuleZ em = ExportedTypeExtractor.Extract(cu, symbols, ns, pkgClassMap, classNs);
        ExportedModuleZ r = new ExportedModuleZ(em.Namespace,
            em.Classes, em.ClassCount,
            em.Interfaces, em.InterfaceCount,
            em.Enums, em.EnumCount,
            allFuncs, allFuncCount,
            em.Delegates, em.DelegateCount);
        r.Impls = em.Impls; r.ImplCount = em.ImplCount;   // L3-Impl2：保留提取的 impls
        return r;
    }

    public static ExportedModuleZ Extract(CompilationUnit cu, SymbolTable symbols, string ns) {
        return ExportedTypeExtractor.Extract(cu, symbols, ns, null, null);
    }

    public static ExportedModuleZ Extract(CompilationUnit cu, SymbolTable symbols, string ns, StrMap pkgClassMap) {
        return ExportedTypeExtractor.Extract(cu, symbols, ns, pkgClassMap, null);
    }

    public static ExportedModuleZ Extract(CompilationUnit cu, SymbolTable symbols, string ns, StrMap pkgClassMap, StrMap classNs) {
        // 短类名 → ClassDecl（本 CU 内；TSIG 继承方法合并走 base 链需祖先 ClassDecl 取自有方法 AST 序+签名）。
        // z42c.syntax/ir 继承均同文件（Expr+子类 / IrInstr+子类）→ per-CU 图足够；跨文件继承待扩展为包级图。G18。
        // arity-mangle 检测（同 SymbolCollector._passClassStubs）：泛型类以 Name$N 键存入 classMap。
        StrMap etFirstArityMap = new StrMap();
        StrMap etMultiArityMap = new StrMap();
        int mi = 0;
        while (mi < cu.DeclCount) {
            Decl etd = ExportedTypeExtractor._unwrap(cu.Decls[mi]);
            if (etd is ClassDecl) {
                ClassDecl etcm = etd as ClassDecl;
                if (etcm.Kind == "class" || etcm.Kind == "struct" || etcm.Kind == "record") {
                    string etarStr = etcm.TypeParams.Count.ToString();
                    if (etFirstArityMap.ContainsKey(etcm.Name)) {
                        StrBox etfa = etFirstArityMap.Get(etcm.Name) as StrBox;
                        if (etfa.Value != etarStr) { etMultiArityMap.Put(etcm.Name, "1"); }
                    } else { etFirstArityMap.Put(etcm.Name, new StrBox(etarStr)); }
                }
            }
            mi = mi + 1;
        }
        StrMap classMap = new StrMap();
        mi = 0;
        while (mi < cu.DeclCount) {
            Decl dm = ExportedTypeExtractor._unwrap(cu.Decls[mi]);
            if (dm is ClassDecl) {
                ClassDecl cm = dm as ClassDecl;
                if (cm.Kind == "class" || cm.Kind == "struct" || cm.Kind == "record") {
                    bool cmMangle = cm.TypeParams.Count > 0 && etMultiArityMap.ContainsKey(cm.Name);
                    string cmKey = cmMangle ? cm.Name + "$" + cm.TypeParams.Count.ToString() : cm.Name;
                    classMap.Put(cmKey, cm);
                }
            }
            mi = mi + 1;
        }
        // ── 用户类（CU 声明序）──
        ExportedClassZ[] classes = new ExportedClassZ[4];
        int cc = 0;
        ExportedFuncZ[] funcs = new ExportedFuncZ[4];
        int fc = 0;
        int i = 0;
        while (i < cu.DeclCount) {
            Decl d = ExportedTypeExtractor._unwrap(cu.Decls[i]);
            if (d is ClassDecl) {
                ClassDecl c = d as ClassDecl;
                if (c.Kind == "class" || c.Kind == "struct" || c.Kind == "record") {
                    // 镜像 C# ExtractClasses：合成 Object stub 不导出（自举包 + stdlib 均有 Object 声明，但 TSIG 里不出现）。
                    if (c.Name == "Object") { i = i + 1; continue; }
                    if (cc == classes.Length) {
                        ExportedClassZ[] b = new ExportedClassZ[classes.Length * 2];
                        int k = 0; while (k < cc) { b[k] = classes[k]; k = k + 1; }
                        classes = b;
                    }
                    classes[cc] = ExportedTypeExtractor._extractClass(c, symbols, classMap, pkgClassMap);
                    cc = cc + 1;
                }
            } else if (d is MethodDecl) {
                MethodDecl md = d as MethodDecl;
                if (md.HasBody) {
                    if (fc == funcs.Length) {
                        ExportedFuncZ[] b = new ExportedFuncZ[funcs.Length * 2];
                        int k = 0; while (k < fc) { b[k] = funcs[k]; k = k + 1; }
                        funcs = b;
                    }
                    funcs[fc] = ExportedTypeExtractor._extractFunc(md, symbols);
                    fc = fc + 1;
                }
            }
            i = i + 1;
        }
        // 本地接口（声明序）+ 内建接口（C# sem.Interfaces 插入序：内建先注入、本地后注册——校准制）
        ExportedInterfaceZ[] localIfs = new ExportedInterfaceZ[4];
        int lic = 0;
        i = 0;
        while (i < cu.DeclCount) {
            Decl d2 = ExportedTypeExtractor._unwrap(cu.Decls[i]);
            if (d2 is ClassDecl) {
                ClassDecl c2 = d2 as ClassDecl;
                if (c2.Kind == "interface") {
                    if (lic == localIfs.Length) {
                        ExportedInterfaceZ[] b2 = new ExportedInterfaceZ[localIfs.Length * 2];
                        int k2 = 0; while (k2 < lic) { b2[k2] = localIfs[k2]; k2 = k2 + 1; }
                        localIfs = b2;
                    }
                    localIfs[lic] = ExportedTypeExtractor._extractInterface(c2, symbols);
                    lic = lic + 1;
                }
            }
            i = i + 1;
        }
        ExportedInterfaceZ[] builtins = ExportedTypeExtractor._builtinInterfaces();
        // 合并：本地接口替换同名内建（镜像 C# sem.Interfaces 单条目——本地定义 = 权威）；
        // 非内建的本地接口追加。避免 z42.core 编译 ISubscription 等自定义 stdlib 接口时重复输出。
        ExportedInterfaceZ[] allIfs = new ExportedInterfaceZ[11 + lic];
        i = 0;
        while (i < 11) { allIfs[i] = builtins[i]; i = i + 1; }
        int allIfCount = 11;
        i = 0;
        while (i < lic) {
            bool foundBuiltin = false;
            int bi = 0;
            while (bi < 11) {
                if (allIfs[bi].Name == localIfs[i].Name) { allIfs[bi] = localIfs[i]; foundBuiltin = true; break; }
                bi = bi + 1;
            }
            if (!foundBuiltin) { allIfs[allIfCount] = localIfs[i]; allIfCount = allIfCount + 1; }
            i = i + 1;
        }
        ExportedModuleZ emr = new ExportedModuleZ(ns,
            classes, cc,
            allIfs, allIfCount,
            ExportedTypeExtractor._builtinEnums(), 1,
            funcs, fc,
            ExportedTypeExtractor._builtinDelegates(), 11);
        // ── impl 块（L3-Impl2 跨 zpkg `impl Trait for Type`；CU 声明序）──
        ExportedImplZ[] impls = ExportedTypeExtractor._extractImpls(cu, ns, classNs);
        emr.Impls = impls; emr.ImplCount = impls.Length;
        return emr;
    }

    // 提取 `impl Trait for Target { methods }`（镜像 C# ExtractImpls）。
    // target/trait 短名经 classNs FQ 化：命中 imported/同包跨-ns 图 → "<declNs>.<name>"，否则 "<currentNs>.<name>"。
    private static ExportedImplZ[] _extractImpls(CompilationUnit cu, string currentNs, StrMap classNs) {
        ExportedImplZ[] result = new ExportedImplZ[4];
        int rc = 0;
        int i = 0;
        while (i < cu.DeclCount) {
            Decl d = ExportedTypeExtractor._unwrap(cu.Decls[i]);
            if (d is ImplDecl) {
                ImplDecl implD = d as ImplDecl;
                string targetName = ExportedTypeExtractor._typeShortName(implD.TargetType);
                string traitName = ExportedTypeExtractor._typeShortName(implD.TraitType);
                if (targetName != "" && traitName != "") {
                    string targetFq = ExportedTypeExtractor._fqOf(targetName, currentNs, classNs);
                    string traitFq = ExportedTypeExtractor._fqOf(traitName, currentNs, classNs);
                    // trait 泛型实参（NamedType.Args → TsigTypeName）
                    string[] argStrs = new string[0];
                    int argc = 0;
                    if (implD.TraitType is NamedType) {
                        NamedType tnt = implD.TraitType as NamedType;
                        argStrs = new string[tnt.ArgCount];
                        while (argc < tnt.ArgCount) { argStrs[argc] = ExportedTypeExtractor.TsigTypeName(tnt.Args[argc]); argc = argc + 1; }
                    }
                    // impl 方法签名（AST 直取，镜像 C#：types via TsigTypeName，vis/static/virtual/abstract via mods）
                    ExportedMethodZ[] ms = new ExportedMethodZ[implD.MethodCount];
                    int mc = 0;
                    int mj = 0;
                    while (mj < implD.MethodCount) {
                        Decl mem = ExportedTypeExtractor._unwrap(implD.Methods[mj]);
                        if (mem is MethodDecl) {
                            MethodDecl md = mem as MethodDecl;
                            ExportedParamZ[] ps = new ExportedParamZ[md.ParamCount];
                            int pi = 0;
                            while (pi < md.ParamCount) { ps[pi] = new ExportedParamZ(md.Params[pi].Name, ExportedTypeExtractor.TsigTypeName(md.Params[pi].Type)); pi = pi + 1; }
                            string ret = "void";
                            if (!md.IsCtor) { ret = ExportedTypeExtractor.TsigTypeName(md.RetType); }
                            string vis = ExportedTypeExtractor._visFromMods(md.Mods);
                            bool isStatic = ExportedTypeExtractor._hasWord(md.Mods, "static");
                            bool isVirtual = ExportedTypeExtractor._hasWord(md.Mods, "virtual");
                            bool isAbstract = ExportedTypeExtractor._hasWord(md.Mods, "abstract");
                            int reqd = ExportedTypeExtractor._requiredCount(md.Params, md.ParamCount);
                            ms[mc] = new ExportedMethodZ(md.Name, ret, vis, isStatic, isVirtual, isAbstract, reqd, ps, md.ParamCount);
                            mc = mc + 1;
                        }
                        mj = mj + 1;
                    }
                    if (rc == result.Length) {
                        ExportedImplZ[] b = new ExportedImplZ[result.Length * 2];
                        int k = 0; while (k < rc) { b[k] = result[k]; k = k + 1; }
                        result = b;
                    }
                    result[rc] = new ExportedImplZ(targetFq, traitFq, argStrs, argc, ms, mc);
                    rc = rc + 1;
                }
            }
            i = i + 1;
        }
        ExportedImplZ[] trimmed = new ExportedImplZ[rc];
        int t = 0; while (t < rc) { trimmed[t] = result[t]; t = t + 1; }
        return trimmed;
    }

    // 短名 FQ 化：classNs 命中 → "<declNs>.<name>"，否则 "<currentNs>.<name>"（镜像 C# ImportedClassNamespaces 回落）。
    private static string _fqOf(string name, string currentNs, StrMap classNs) {
        if (classNs != null && classNs.ContainsKey(name)) {
            StrBox b = classNs.Get(name) as StrBox;
            return b.Value + "." + name;
        }
        return currentNs + "." + name;
    }

    // TypeExpr → 短名（NamedType.Name；非 Named 形态 → ""，镜像 C# ExtractTypeName 返回 null）。
    private static string _typeShortName(TypeExpr t) {
        if (t is NamedType) { return (t as NamedType).Name; }
        return "";
    }

    // impl 方法可见性：mods 显式声明取之，无修饰默认 "public"（镜像 C# AST Visibility 默认）。
    private static string _visFromMods(string mods) {
        if (ExportedTypeExtractor._hasWord(mods, "public"))    { return "public"; }
        if (ExportedTypeExtractor._hasWord(mods, "private"))   { return "private"; }
        if (ExportedTypeExtractor._hasWord(mods, "protected")) { return "protected"; }
        if (ExportedTypeExtractor._hasWord(mods, "internal"))  { return "internal"; }
        return "public";
    }

    // 本地接口导出（方法 flags=virtual|abstract，p{i} 参名——内建接口同形态）。
    private static ExportedInterfaceZ _extractInterface(ClassDecl c, SymbolTable symbols) {
        Z42InterfaceType it = symbols.GetInterface(c.Name);
        ExportedMethodZ[] ms = new ExportedMethodZ[c.MemberCount + 4];
        int mc = 0;
        int j = 0;
        while (j < c.MemberCount) {
            Decl mem = ExportedTypeExtractor._unwrap(c.Members[j]);
            if (mem is MethodDecl) {
                MethodDecl md = mem as MethodDecl;
                MethodSymbol sym = null;
                if (it != null) { sym = it.Methods.Get(md.Name) as MethodSymbol; }
                if (sym != null) {
                    Z42FuncType sig = sym.Signature;
                    string[] pts = new string[sig.ParamCount];
                    int x = 0;
                    while (x < sig.ParamCount) { pts[x] = ExportedTypeExtractor._hybridTypeName(md.Params[x].Type, sig.ParamTypes[x]); x = x + 1; }
                    string iret = ExportedTypeExtractor._hybridTypeName(md.RetType, sig.Ret);
                    ms[mc] = ExportedTypeExtractor._im(md.Name, iret, pts, sig.ParamCount);   // 接口方法无重载，bare Name
                    mc = mc + 1;
                }
            } else if (mem is PropertyDecl) {
                // 接口属性 getter → "get_PropName"（镜像 C# PropertyDecl lowering）
                PropertyDecl pd = mem as PropertyDecl;
                if (pd.HasGet) {
                    string gkey = "get_" + pd.Name;
                    MethodSymbol gsym = null;
                    if (it != null) { gsym = it.Methods.Get(gkey) as MethodSymbol; }
                    if (gsym != null) {
                        Z42FuncType gsig = gsym.Signature;
                        string gret = ExportedTypeExtractor._resolvedTypeName(gsig.Ret);
                        ms[mc] = ExportedTypeExtractor._im(gkey, gret, new string[0], 0);
                        mc = mc + 1;
                    }
                }
            }
            j = j + 1;
        }
        return new ExportedInterfaceZ(c.Name, ms, mc, c.TypeParams.Names, c.TypeParams.Count);
    }

    private static Decl _unwrap(Decl d) {
        if (d is AttributedDecl) { return (d as AttributedDecl).Inner; }
        return d;
    }

    // ── 用户类：字段（继承实例 → 自有实例 → 自有 static）+ 方法（Object 四方法 → base 链合并实例 → 自有 static）──
    // pkgClassMap：全包 className→ClassDecl，用于跨文件 base 类方法继承（G18 部分修复）。
    private static ExportedClassZ _extractClass(ClassDecl c, SymbolTable symbols, StrMap classMap, StrMap pkgClassMap) {
        // Arity-mangle：泛型类以 Name$N 键注册时从 Name$N 取 CT。
        string ecCtKey = c.Name;
        if (c.TypeParams.Count > 0 && symbols != null) {
            string ecmk = c.Name + "$" + c.TypeParams.Count.ToString();
            if (symbols.HasClass(ecmk)) { ecCtKey = ecmk; }
        }
        Z42ClassType ct = symbols == null ? null : (symbols.GetClass(ecCtKey) as Z42ClassType);
        // struct 不继承 Object（镜像 C# ExcludeFromImplicitObject：IsStruct→effectiveBase=null）。
        bool isStruct = c.Kind == "struct";
        string baseName = "Object";
        if (ct != null && ct.HasBase) { baseName = ct.BaseName; }   // 基表判别后的真基类（接口已剔除）

        ExportedFieldZ[] fields = new ExportedFieldZ[4];
        int fldc = 0;
        // ── 实例字段：base 链展开（topmost 祖先在前 → 本类自有），镜像 C# SymbolCollector 第二趟
        //    mergedFields = new Dict(base.Fields) ∪ own。z42c Fields 是 hashed StrMap 不可按序迭代，
        //    故走 Z42ClassType.OwnField* 有序元数据 + base 链（imported/Object 祖先 OwnFieldCount=0 → 不贡献，
        //    imported base 字段继承延后；syntax base 均本地）。G18。
        Z42ClassType[] chain = new Z42ClassType[32];
        int chainLen = 0;
        Z42ClassType walk = ct;
        int chops = 0;
        while (walk != null && chops < 32) {
            chain[chainLen] = walk; chainLen = chainLen + 1;
            if (!walk.HasBase || walk.BaseName == "") { walk = null; }
            else { walk = symbols.GetClass(walk.BaseName); }
            chops = chops + 1;
        }
        int ci = chainLen - 1;          // 反向：topmost 祖先先
        while (ci >= 0) {
            Z42ClassType anc = chain[ci];
            int fi = 0;
            while (fi < anc.OwnFieldCount) {
                // OwnFieldNames 包含：普通实例字段（原名）+ auto-property 后备字段（__prop_X）。
                // 镜像 C# ct.Fields 全量导出（不过滤 __prop_X）。
                if (fldc == fields.Length) {
                    ExportedFieldZ[] b = new ExportedFieldZ[fields.Length * 2];
                    int k = 0; while (k < fldc) { b[k] = fields[k]; k = k + 1; }
                    fields = b;
                }
                fields[fldc] = new ExportedFieldZ(anc.OwnFieldNames[fi], anc.OwnFieldSpellings[fi], anc.OwnFieldVis[fi], false);
                fldc = fldc + 1;
                fi = fi + 1;
            }
            ci = ci - 1;
        }
        // ── static 字段：本类自有（声明序；C# StaticFields 段不做继承合并）──
        int j = 0;
        while (j < c.MemberCount) {
            Decl mem = ExportedTypeExtractor._unwrap(c.Members[j]);
            if (mem is FieldDecl) {
                FieldDecl fd = mem as FieldDecl;
                if (ExportedTypeExtractor._hasWord(fd.Mods, "static")) {
                    FieldSymbol fs = ct.Fields.Get(fd.Name) as FieldSymbol;
                    string tn = "unknown";
                    string vis = "internal";
                    if (fs != null) { tn = ExportedTypeExtractor._resolvedTypeName(fs.FieldType); vis = fs.Visibility; }
                    if (fldc == fields.Length) {
                        ExportedFieldZ[] b = new ExportedFieldZ[fields.Length * 2];
                        int k = 0; while (k < fldc) { b[k] = fields[k]; k = k + 1; }
                        fields = b;
                    }
                    fields[fldc] = new ExportedFieldZ(fd.Name, tn, vis, true);
                    fldc = fldc + 1;
                }
            }
            j = j + 1;
        }

        // ── 实例方法：Object 四方法 + base 链 topmost→self 合并（override 保留祖先位、新方法追加）──
        //    镜像 C# SymbolCollector 第二趟 mergedMethods = new Dict(base.Methods) ∪ own（override 同名替换、
        //    保留首次插入位）。Object 四方法是 C# Object stub 注入的根。seenName/seenAt 平行表做名→位查找。G18。
        ExportedMethodZ[] methods = new ExportedMethodZ[16];
        string[] seenName = new string[16];
        int[]    seenAt   = new int[16];
        int mc = 0; int seenc = 0;
        // struct 不从 Object 继承方法（镜像 C# ExcludeFromImplicitObject：struct/record 不注入 Object 四方法）。
        if (!isStruct) {
            methods[0] = ExportedTypeExtractor._m0("ToString", "string", true);
            methods[1] = ExportedTypeExtractor._m1("Equals", "bool", "p0", "object", true);
            methods[2] = ExportedTypeExtractor._m0("GetHashCode", "int", true);
            // GetType ret：C# Object stub 构建时查 _classes["Type"]（反射类，prelude 可见）→ "Type"（2026-06-10 起）。
            methods[3] = ExportedTypeExtractor._m0("GetType", "Type", false);
            seenName[0] = "ToString"; seenName[1] = "Equals"; seenName[2] = "GetHashCode"; seenName[3] = "GetType";
            seenAt[0] = 0; seenAt[1] = 1; seenAt[2] = 2; seenAt[3] = 3;
            mc = 4; seenc = 4;
        }
        int mci = chainLen - 1;        // topmost 祖先 → self（反向）
        while (mci >= 0) {
            // per-CU classMap 先查；miss 时用全包 pkgClassMap 回退（G18 部分修复：跨文件 base 类方法继承）。
            ClassDecl ancd = null;
            if (symbols != null) {
                ancd = classMap.Get(chain[mci].IrName()) as ClassDecl;
                if (ancd == null && pkgClassMap != null) { ancd = pkgClassMap.Get(chain[mci].IrName()) as ClassDecl; }
            }
            if (ancd == null && chain[mci].OwnMethodCount > 0) {
                // G18-import：imported 祖先（无 ClassDecl）→ 按 OwnMethod* 有序元数据贡献实例方法，
                // 镜像本地 ClassDecl 路径的 seenName dedup/override 语义（skip Object4 已注册键）。
                int omi = 0;
                while (omi < chain[mci].OwnMethodCount) {
                    string omkey = chain[mci].OwnMethodNames[omi];
                    MethodSymbol oms = chain[mci].Methods.Get(omkey) as MethodSymbol;
                    if (oms != null) {
                        ExportedMethodZ omem = ExportedTypeExtractor._fromImportedMethod(omkey, oms, chain[mci].OwnMethodIsVirtual[omi], chain[mci].OwnMethodIsAbstract[omi]);
                        int omat = ExportedTypeExtractor._indexOf(seenName, seenc, omkey);
                        if (omat >= 0) { methods[seenAt[omat]] = omem; }
                        else {
                            if (mc == methods.Length) {
                                ExportedMethodZ[] b = new ExportedMethodZ[methods.Length * 2];
                                int k = 0; while (k < mc) { b[k] = methods[k]; k = k + 1; }
                                methods = b;
                            }
                            if (seenc == seenName.Length) {
                                string[] sn = new string[seenName.Length * 2]; int[] sa = new int[seenAt.Length * 2];
                                int k = 0; while (k < seenc) { sn[k] = seenName[k]; sa[k] = seenAt[k]; k = k + 1; }
                                seenName = sn; seenAt = sa;
                            }
                            methods[mc] = omem; seenName[seenc] = omkey; seenAt[seenc] = mc;
                            seenc = seenc + 1; mc = mc + 1;
                        }
                    }
                    omi = omi + 1;
                }
            }
            if (ancd != null) {
                int aj = 0;
                while (aj < ancd.MemberCount) {
                    Decl amem = ExportedTypeExtractor._unwrap(ancd.Members[aj]);
                    if (amem is MethodDecl) {
                        MethodDecl amd = amem as MethodDecl;
                        if (!ExportedTypeExtractor._hasWord(amd.Mods, "static")) {     // 实例方法（含 ctor，G11）
                            // GS3：重载方法以 Name$arity 键存，查找先试 Name$arity，再 bare（unique 方法）。
                            // seenName 用 amkey（重载时含 $）做去重键，使 F$1/F$2 互不干扰（各自新增而非 override 替换）。
                            string amkey = amd.Name + "$" + amd.ParamCount.ToString();
                            if (!chain[mci].Methods.ContainsKey(amkey)) { amkey = amd.Name; }
                            MethodSymbol ams = chain[mci].Methods.Get(amkey) as MethodSymbol;
                            if (ams != null) {
                                ExportedMethodZ em = ExportedTypeExtractor._fromSymbol(amd, ams, false, amkey);
                                int at = ExportedTypeExtractor._indexOf(seenName, seenc, amkey);
                                if (at >= 0) { methods[seenAt[at]] = em; }            // override：替换祖先位
                                else {
                                    if (mc == methods.Length) {
                                        ExportedMethodZ[] b = new ExportedMethodZ[methods.Length * 2];
                                        int k = 0; while (k < mc) { b[k] = methods[k]; k = k + 1; }
                                        methods = b;
                                    }
                                    if (seenc == seenName.Length) {
                                        string[] sn = new string[seenName.Length * 2]; int[] sa = new int[seenAt.Length * 2];
                                        int k = 0; while (k < seenc) { sn[k] = seenName[k]; sa[k] = seenAt[k]; k = k + 1; }
                                        seenName = sn; seenAt = sa;
                                    }
                                    methods[mc] = em; seenName[seenc] = amkey; seenAt[seenc] = mc;
                                    seenc = seenc + 1; mc = mc + 1;
                                }
                            }
                        }
                    } else if (amem is PropertyDecl) {
                        // auto-property getter → TSIG method "get_PropName"（镜像 C# ExportedTypeExtractor）
                        PropertyDecl apd = amem as PropertyDecl;
                        if (!ExportedTypeExtractor._hasWord(apd.Mods, "static") && apd.HasGet) {
                            string gkey = "get_" + apd.Name;
                            if (chain[mci].Methods.ContainsKey(gkey)) {
                                MethodSymbol gms = chain[mci].Methods.Get(gkey) as MethodSymbol;
                                string gret = ExportedTypeExtractor.TsigTypeName(apd.Type);
                                bool gVirt = ExportedTypeExtractor._hasWord(apd.Mods, "virtual");
                                bool gAbs = ExportedTypeExtractor._hasWord(apd.Mods, "abstract");
                                ExportedMethodZ gem = new ExportedMethodZ(gkey, gret, gms.Visibility, false, gVirt, gAbs, 0, new ExportedParamZ[0], 0);
                                int gat = ExportedTypeExtractor._indexOf(seenName, seenc, gkey);
                                if (gat >= 0) { methods[seenAt[gat]] = gem; }
                                else {
                                    if (mc == methods.Length) {
                                        ExportedMethodZ[] b = new ExportedMethodZ[methods.Length * 2];
                                        int k = 0; while (k < mc) { b[k] = methods[k]; k = k + 1; }
                                        methods = b;
                                    }
                                    if (seenc == seenName.Length) {
                                        string[] sn = new string[seenName.Length * 2]; int[] sa = new int[seenAt.Length * 2];
                                        int k = 0; while (k < seenc) { sn[k] = seenName[k]; sa[k] = seenAt[k]; k = k + 1; }
                                        seenName = sn; seenAt = sa;
                                    }
                                    methods[mc] = gem; seenName[seenc] = gkey; seenAt[seenc] = mc;
                                    seenc = seenc + 1; mc = mc + 1;
                                }
                            }
                        }
                    } else if (amem is IndexerDecl) {
                        // indexer get_Item / set_Item → TSIG methods（镜像 C# ct.Methods 含 IndexerDecl lowering）
                        IndexerDecl id = amem as IndexerDecl;
                        if (!ExportedTypeExtractor._hasWord(id.Mods, "static")) {
                            if (id.HasGet) {
                                string gkey = "get_Item";
                                if (chain[mci].Methods.ContainsKey(gkey)) {
                                    MethodSymbol gms = chain[mci].Methods.Get(gkey) as MethodSymbol;
                                    string gret = ExportedTypeExtractor.TsigTypeName(id.RetType);
                                    bool gVirt = ExportedTypeExtractor._hasWord(id.Mods, "virtual");
                                    bool gAbs = ExportedTypeExtractor._hasWord(id.Mods, "abstract");
                                    int gpc = id.ParamCount;
                                    ExportedParamZ[] gps = new ExportedParamZ[gpc];
                                    int qi = 0;
                                    while (qi < gpc) { gps[qi] = new ExportedParamZ("p" + qi.ToString(), ExportedTypeExtractor.TsigTypeName(id.Params[qi].Type)); qi = qi + 1; }
                                    ExportedMethodZ gem = new ExportedMethodZ(gkey, gret, gms.Visibility, false, gVirt, gAbs, gpc, gps, gpc);
                                    int gat = ExportedTypeExtractor._indexOf(seenName, seenc, gkey);
                                    if (gat >= 0) { methods[seenAt[gat]] = gem; }
                                    else {
                                        if (mc == methods.Length) {
                                            ExportedMethodZ[] b = new ExportedMethodZ[methods.Length * 2];
                                            int k = 0; while (k < mc) { b[k] = methods[k]; k = k + 1; }
                                            methods = b;
                                        }
                                        if (seenc == seenName.Length) {
                                            string[] sn = new string[seenName.Length * 2]; int[] sa = new int[seenAt.Length * 2];
                                            int k = 0; while (k < seenc) { sn[k] = seenName[k]; sa[k] = seenAt[k]; k = k + 1; }
                                            seenName = sn; seenAt = sa;
                                        }
                                        methods[mc] = gem; seenName[seenc] = gkey; seenAt[seenc] = mc;
                                        seenc = seenc + 1; mc = mc + 1;
                                    }
                                }
                            }
                            if (id.HasSet) {
                                string skey = "set_Item";
                                if (chain[mci].Methods.ContainsKey(skey)) {
                                    MethodSymbol sms = chain[mci].Methods.Get(skey) as MethodSymbol;
                                    bool sVirt = ExportedTypeExtractor._hasWord(id.Mods, "virtual");
                                    bool sAbs = ExportedTypeExtractor._hasWord(id.Mods, "abstract");
                                    int spc = id.ParamCount + 1;
                                    ExportedParamZ[] sps = new ExportedParamZ[spc];
                                    int qi = 0;
                                    while (qi < id.ParamCount) { sps[qi] = new ExportedParamZ("p" + qi.ToString(), ExportedTypeExtractor.TsigTypeName(id.Params[qi].Type)); qi = qi + 1; }
                                    sps[id.ParamCount] = new ExportedParamZ("p" + id.ParamCount.ToString(), ExportedTypeExtractor.TsigTypeName(id.RetType));
                                    ExportedMethodZ sem = new ExportedMethodZ(skey, "void", sms.Visibility, false, sVirt, sAbs, spc, sps, spc);
                                    int sat = ExportedTypeExtractor._indexOf(seenName, seenc, skey);
                                    if (sat >= 0) { methods[seenAt[sat]] = sem; }
                                    else {
                                        if (mc == methods.Length) {
                                            ExportedMethodZ[] b = new ExportedMethodZ[methods.Length * 2];
                                            int k = 0; while (k < mc) { b[k] = methods[k]; k = k + 1; }
                                            methods = b;
                                        }
                                        if (seenc == seenName.Length) {
                                            string[] sn = new string[seenName.Length * 2]; int[] sa = new int[seenAt.Length * 2];
                                            int k = 0; while (k < seenc) { sn[k] = seenName[k]; sa[k] = seenAt[k]; k = k + 1; }
                                            seenName = sn; seenAt = sa;
                                        }
                                        methods[mc] = sem; seenName[seenc] = skey; seenAt[seenc] = mc;
                                        seenc = seenc + 1; mc = mc + 1;
                                    }
                                }
                            }
                        }
                    }
                    aj = aj + 1;
                }
            }
            mci = mci - 1;
        }
        // ── static 方法：本类自有（C# StaticMethods 段不继承合并）──
        // GS3：静态重载方法以 Name$arity 键存，先试 Name$arity，再 bare（unique 方法）。
        // seenStatic 去重：同名不同 arity 的两个 MethodDecl 可能 map 到同一 smkey（bare 或 $N 共享）→ 只取首次。
        string[] seenStatic = new string[16]; int seenStaticCount = 0;
        int sj = 0;
        while (sj < c.MemberCount) {
            Decl smem = ExportedTypeExtractor._unwrap(c.Members[sj]);
            if (smem is MethodDecl) {
                MethodDecl smd = smem as MethodDecl;
                if (ExportedTypeExtractor._hasWord(smd.Mods, "static")) {
                    string smkey = smd.Name + "$" + smd.ParamCount.ToString();
                    if (smd.RegKey != "") { smkey = smd.RegKey; }                       // type-based 重载：注册键
                    else if (!ct.Methods.ContainsKey(smkey)) { smkey = smd.Name; }
                    MethodSymbol sms = ct.Methods.Get(smkey) as MethodSymbol;
                    if (sms != null && ExportedTypeExtractor._indexOf(seenStatic, seenStaticCount, smkey) < 0) {
                        if (seenStaticCount == seenStatic.Length) {
                            string[] ssn = new string[seenStatic.Length * 2];
                            int k = 0; while (k < seenStaticCount) { ssn[k] = seenStatic[k]; k = k + 1; }
                            seenStatic = ssn;
                        }
                        seenStatic[seenStaticCount] = smkey; seenStaticCount = seenStaticCount + 1;
                        if (mc == methods.Length) {
                            ExportedMethodZ[] b = new ExportedMethodZ[methods.Length * 2];
                            int k = 0; while (k < mc) { b[k] = methods[k]; k = k + 1; }
                            methods = b;
                        }
                        methods[mc] = ExportedTypeExtractor._fromSymbol(smd, sms, true, smkey);
                        mc = mc + 1;
                    }
                }
            }
            sj = sj + 1;
        }
        // 导出名用裸名（镜像 C# ExportedClassDef：ct.Name，非 IrName()）。
        string ecExportName = c.Name;
        ExportedClassZ ez = new ExportedClassZ(ecExportName, !isStruct, isStruct ? "" : baseName, fields, fldc, methods, mc, c.TypeParams.Names, c.TypeParams.Count);
        if (ct != null && ct.InterfaceCount > 0) {                  // 类接口表（port-z42c-interface）
            ez.Interfaces = ct.InterfaceNames;
            ez.InterfaceCount = ct.InterfaceCount;
        }
        return ez;
    }

    // GS3：methKey = 重载时 Name$arity，unique 时 bare Name（镜像 C# FuncToMethod mn=registry key）。
    // ExportedMethodZ 用 methKey 作名（TSIG byte-identical：C# TSIG 方法名含 $arity 后缀）。
    private static ExportedMethodZ _fromSymbol(MethodDecl md, MethodSymbol ms, bool isStatic, string methKey) {
        Z42FuncType sig = ms.Signature;
        // 用 sig（resolved Z42Type）而非 AST TypeExpr：镜像 C# FuncToMethod TypeToString(sig.Params[i]) /
        // TypeToString(sig.Ret)。Predicate<T>→Func<T,bool>、ISubscription<X>→裸名 ISubscription 等均由
        // Z42Type.Name() 正确处理。ctor 的 sig.Ret 是 Z42VoidType → _resolvedTypeName → "void"。
        int pc = md.ParamCount;
        ExportedParamZ[] ps = new ExportedParamZ[pc];
        int i = 0;
        while (i < pc) {
            ps[i] = new ExportedParamZ("p" + i.ToString(), ExportedTypeExtractor._hybridTypeName(md.Params[i].Type, sig.ParamTypes[i]));
            i = i + 1;
        }
        // G18：override → flags 0（镜像 C# FuncToMethod：仅 FunctionModifiers.Virtual 置 isVirtual；
        // override 方法的 Modifiers 不含 Virtual）。仅 `virtual` 关键字置位。
        bool isVirtual = ExportedTypeExtractor._hasWord(md.Mods, "virtual");
        bool isAbstract = ExportedTypeExtractor._hasWord(md.Mods, "abstract");
        string ret = "void";
        if (!md.IsCtor) { ret = ExportedTypeExtractor._hybridTypeName(md.RetType, sig.Ret); }
        int reqd = ExportedTypeExtractor._requiredCount(md.Params, pc);
        ExportedMethodZ em = new ExportedMethodZ(methKey, ret, ms.Visibility,
                                   isStatic, isVirtual, isAbstract, reqd, ps, pc);
        em.ParamsFrom = sig.ParamsFrom;
        return em;
    }

    // 必填参数个数 = 首个带默认值（`Param.Default != null`）参数的下标（其后皆可选）。
    // 镜像 C# SymbolCollector.BuildFuncSignature 的 RequiredCount 计算（默认值尾随）。
    // 无默认值 → 返回 pc（全必填）。TSIG 据此 emit minArgCount，否则跨包调用省略
    // 默认实参会被消费端误判 E0402（dogfood S3 暴露：MulticastAction.Invoke(T,bool=false) 等）。
    private static int _requiredCount(Param[] ps, int pc) {
        int required = pc;
        int i = 0;
        while (i < pc) {
            if (ps[i].Default != null) {
                if (i < required) { required = i; }
            }
            i = i + 1;
        }
        return required;
    }

    // G18-import：imported 祖先方法（无 MethodDecl）→ 从 MethodSymbol 构建 ExportedMethodZ。
    // 类比 _fromSymbol 但用 _resolvedTypeName（无 AST TypeExpr nullable 补 "?"）。
    private static ExportedMethodZ _fromImportedMethod(string methKey, MethodSymbol ms, bool isVirtual, bool isAbstract) {
        Z42FuncType sig = ms.Signature;
        int pc = sig.ParamCount;
        ExportedParamZ[] ps = new ExportedParamZ[pc];
        int i = 0;
        while (i < pc) {
            ps[i] = new ExportedParamZ("p" + i.ToString(), ExportedTypeExtractor._resolvedTypeName(sig.ParamTypes[i]));
            i = i + 1;
        }
        string ret = ExportedTypeExtractor._resolvedTypeName(sig.Ret);
        ExportedMethodZ em = new ExportedMethodZ(methKey, ret, ms.Visibility, false, isVirtual, isAbstract, pc, ps, pc);
        em.ParamsFrom = sig.ParamsFrom;
        return em;
    }

    private static ExportedFuncZ _extractFunc(MethodDecl md, SymbolTable symbols) {
        MethodSymbol ms = symbols.GetFunc(md.Name);
        ExportedParamZ[] ps = new ExportedParamZ[0];
        string ret = "void";
        int pc = 0;
        int paramsFrom = 0 - 1;
        if (ms != null) {
            Z42FuncType sig = ms.Signature;
            pc = sig.ParamCount;
            ps = new ExportedParamZ[pc];
            int i = 0;
            while (i < pc) {
                ps[i] = new ExportedParamZ("p" + i.ToString(), ExportedTypeExtractor._hybridTypeName(md.Params[i].Type, sig.ParamTypes[i]));
                i = i + 1;
            }
            ret = ExportedTypeExtractor._hybridTypeName(md.RetType, sig.Ret);
            paramsFrom = sig.ParamsFrom;
        }
        ExportedFuncZ ef = new ExportedFuncZ(md.Name, ret, ExportedTypeExtractor._requiredCount(md.Params, pc), ps, pc);
        ef.ParamsFrom = paramsFrom;
        return ef;
    }

    // 方法/函数**签名**类型名（ret + param）：规范化 prim 名（byte→u8 等）+ 保留数组/nullable 结构。
    // 镜像 C# FuncToMethod 用 `TypeToString(resolved)`——C# 自 G17c-2 后漂移：方法签名类型走规范名
    // （ByteWriter.ToBytes 返回 byte[] → TSIG=u8[]，与 SIGS 一致），区别于**字段**仍用源拼写（byte[]，
    // 见 _extractClass static-field 段用 fd.Type.Dump()）。泛型实参暂回落 Dump（z42c.ir 无泛型签名）。G18d。
    // 公开（SymbolCollector 回填 OwnField 规范拼写复用）：纯 TypeExpr 函数，无符号表依赖。
    public static string TsigTypeName(TypeExpr te) {
        if (te is ArrayType) { return ExportedTypeExtractor.TsigTypeName((te as ArrayType).Elem) + "[]"; }
        if (te is NullableType) { return ExportedTypeExtractor.TsigTypeName((te as NullableType).Inner) + "?"; }
        if (te is NamedType) {
            NamedType nt = te as NamedType;
            if (nt.ArgCount == 0) { return ExportedTypeExtractor._canonName(nt.Name); }
            // 泛型实参用 ", " 分隔（镜像 C# TypeToString: string.Join(", ", ...)），避免 Dump() 的无空格格式。
            string s = nt.Name + "<";
            int ai = 0;
            while (ai < nt.ArgCount) {
                if (ai > 0) { s = s + ", "; }
                s = s + ExportedTypeExtractor.TsigTypeName(nt.Args[ai]);
                ai = ai + 1;
            }
            return s + ">";
        }
        return te.Dump();
    }
    private static string _tsigTypeName(TypeExpr te) { return ExportedTypeExtractor.TsigTypeName(te); }
    // 解析后 Z42Type → TSIG 规范名（镜像 C# TypeToString：Unknown/Error → sentinel 字符串）。
    private static string _resolvedTypeName(Z42Type t) {
        if (t == null || t is Z42UnknownType) { return "unknown"; }
        if (t is Z42ErrorType) { return "error"; }
        string n = t.Name();
        if (n == "<unknown>") { return "unknown"; }
        if (n == "<error>") { return "error"; }
        return n;
    }
    // 混合模式：resolved 处理委托规范化（Predicate→Func）；AST nullable 包装补 "?"（z42c ResolveTypeP 擦除 nullable）。
    private static string _hybridTypeName(TypeExpr te, Z42Type resolved) {
        if (te is NullableType) { return ExportedTypeExtractor._resolvedTypeName(resolved) + "?"; }
        return ExportedTypeExtractor._resolvedTypeName(resolved);
    }
    // prim 源名 → IR 规范名（镜像 SymbolTable._canonPrim / C# TypeRegistry：仅次要别名归一）。
    private static string _canonName(string n) {
        if (n == "byte")   { return "u8"; }
        if (n == "sbyte")  { return "i8"; }
        if (n == "short")  { return "i16"; }
        if (n == "ushort") { return "u16"; }
        if (n == "uint")   { return "u32"; }
        if (n == "ulong")  { return "u64"; }
        return n;
    }

    // 名→位线性查找（方法合并：seenName/seenAt 平行表；方法数小，线性足够）。G18。
    private static int _indexOf(string[] arr, int count, string name) {
        int i = 0;
        while (i < count) {
            if (arr[i] == name) { return i; }
            i = i + 1;
        }
        return 0 - 1;
    }

    private static bool _hasWord(string mods, string word) {
        if (mods == "") { return false; }
        string[] parts = mods.Split(" ");
        int i = 0;
        while (i < parts.Length) {
            if (parts[i] == word) { return true; }
            i = i + 1;
        }
        return false;
    }

    // ── 内建面（固定 prelude；序与形态 = C# 同源 1199B 字节实测）─────────────────────

    private static ExportedMethodZ _m0(string name, string ret, bool virt) {
        return new ExportedMethodZ(name, ret, "public", false, virt, false, 0, new ExportedParamZ[0], 0);
    }
    private static ExportedMethodZ _m1(string name, string ret, string pn, string pt, bool virt) {
        ExportedParamZ[] ps = new ExportedParamZ[1];
        ps[0] = new ExportedParamZ(pn, pt);
        return new ExportedMethodZ(name, ret, "public", false, virt, false, 1, ps, 1);
    }
    // 接口方法：public + virtual + abstract（flags=6），minArg=参数数
    private static ExportedMethodZ _im(string name, string ret, string[] paramTypes, int pc) {
        ExportedParamZ[] ps = new ExportedParamZ[pc];
        int i = 0;
        while (i < pc) { ps[i] = new ExportedParamZ("p" + i.ToString(), paramTypes[i]); i = i + 1; }
        return new ExportedMethodZ(name, ret, "public", false, true, true, pc, ps, pc);
    }
    // static abstract 接口成员（INumber op_*）
    private static ExportedMethodZ _ims(string name, string ret, string[] paramTypes, int pc) {
        ExportedParamZ[] ps = new ExportedParamZ[pc];
        int i = 0;
        while (i < pc) { ps[i] = new ExportedParamZ("p" + i.ToString(), paramTypes[i]); i = i + 1; }
        return new ExportedMethodZ(name, ret, "public", true, false, true, pc, ps, pc);
    }

    private static string[] _t0() { return new string[0]; }
    private static string[] _t1(string a) { string[] r = new string[1]; r[0] = a; return r; }
    private static string[] _t2(string a, string b) { string[] r = new string[2]; r[0] = a; r[1] = b; return r; }

    private static ExportedInterfaceZ _iface(string name, string[] tps, int tpc, ExportedMethodZ[] ms, int mc) {
        return new ExportedInterfaceZ(name, ms, mc, tps, tpc);
    }

    private static ExportedInterfaceZ[] _builtinInterfaces() {
        ExportedInterfaceZ[] r = new ExportedInterfaceZ[11];
        ExportedMethodZ[] m;
        m = new ExportedMethodZ[3];
        m[0] = ExportedTypeExtractor._im("Get", "TD", ExportedTypeExtractor._t0(), 0);
        m[1] = ExportedTypeExtractor._im("IsAlive", "bool", ExportedTypeExtractor._t0(), 0);
        m[2] = ExportedTypeExtractor._im("OnInvoked", "void", ExportedTypeExtractor._t0(), 0);
        r[0] = ExportedTypeExtractor._iface("ISubscription", ExportedTypeExtractor._t1("TD"), 1, m, 3);
        m = new ExportedMethodZ[4];
        m[0] = ExportedTypeExtractor._im("Count", "int", ExportedTypeExtractor._t0(), 0);
        m[1] = ExportedTypeExtractor._im("IsEmpty", "bool", ExportedTypeExtractor._t0(), 0);
        m[2] = ExportedTypeExtractor._im("Clear", "void", ExportedTypeExtractor._t0(), 0);
        m[3] = ExportedTypeExtractor._im("AddOne", "void", ExportedTypeExtractor._t1("T"), 1);   // 2026-06-11 prelude 漂移（并行流）
        r[1] = ExportedTypeExtractor._iface("IBasicCollection", ExportedTypeExtractor._t1("T"), 1, m, 4);
        m = new ExportedMethodZ[1];
        m[0] = ExportedTypeExtractor._im("CompareTo", "int", ExportedTypeExtractor._t1("T"), 1);
        r[2] = ExportedTypeExtractor._iface("IComparable", ExportedTypeExtractor._t1("T"), 1, m, 1);
        m = new ExportedMethodZ[1];
        m[0] = ExportedTypeExtractor._im("Compare", "int", ExportedTypeExtractor._t2("T", "T"), 2);
        r[3] = ExportedTypeExtractor._iface("IComparer", ExportedTypeExtractor._t1("T"), 1, m, 1);
        m = new ExportedMethodZ[1];
        m[0] = ExportedTypeExtractor._im("Dispose", "void", ExportedTypeExtractor._t0(), 0);
        r[4] = ExportedTypeExtractor._iface("IDisposable", ExportedTypeExtractor._t0(), 0, m, 1);
        m = new ExportedMethodZ[1];
        m[0] = ExportedTypeExtractor._im("GetEnumerator", "IEnumerator", ExportedTypeExtractor._t0(), 0);
        r[5] = ExportedTypeExtractor._iface("IEnumerable", ExportedTypeExtractor._t1("T"), 1, m, 1);
        m = new ExportedMethodZ[2];
        m[0] = ExportedTypeExtractor._im("MoveNext", "bool", ExportedTypeExtractor._t0(), 0);
        m[1] = ExportedTypeExtractor._im("get_Current", "T", ExportedTypeExtractor._t0(), 0);
        r[6] = ExportedTypeExtractor._iface("IEnumerator", ExportedTypeExtractor._t1("T"), 1, m, 2);
        m = new ExportedMethodZ[2];
        m[0] = ExportedTypeExtractor._im("Equals", "bool", ExportedTypeExtractor._t2("T", "T"), 2);
        m[1] = ExportedTypeExtractor._im("GetHashCode", "int", ExportedTypeExtractor._t1("T"), 1);
        r[7] = ExportedTypeExtractor._iface("IEqualityComparer", ExportedTypeExtractor._t1("T"), 1, m, 2);
        m = new ExportedMethodZ[2];
        m[0] = ExportedTypeExtractor._im("Equals", "bool", ExportedTypeExtractor._t1("T"), 1);
        m[1] = ExportedTypeExtractor._im("GetHashCode", "int", ExportedTypeExtractor._t0(), 0);
        r[8] = ExportedTypeExtractor._iface("IEquatable", ExportedTypeExtractor._t1("T"), 1, m, 2);
        m = new ExportedMethodZ[1];
        m[0] = ExportedTypeExtractor._im("ToString", "string", ExportedTypeExtractor._t1("string"), 1);
        r[9] = ExportedTypeExtractor._iface("IFormattable", ExportedTypeExtractor._t0(), 0, m, 1);
        m = new ExportedMethodZ[5];
        // INumber 五方法是 static abstract 接口成员（C# 11 形态）：flags = static|abstract（=5，非 virtual）
        m[0] = ExportedTypeExtractor._ims("op_Add", "T", ExportedTypeExtractor._t2("T", "T"), 2);
