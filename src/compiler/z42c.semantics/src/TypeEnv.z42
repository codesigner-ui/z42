// 类型环境（port-z42c-semantics 1A-4a）。词法嵌套 scope 链 + 全局符号表。
// 受限写法：① public 字段（同 z42c.syntax AST 约定）；② 全字段经构造器（this.）设置——
//   避免对刚 new 的同型实例做跨实例字段写（z42 此处报 E0402）；PushScope/WithClass 走构造器。
// Vars: 本层 locals/params（string → Z42Type，StrMap）。LookupVar 走父链。
namespace Z42.Semantics;

using Z42.Syntax;

public sealed class TypeEnv {
    public bool        HasParent;
    public TypeEnv     Parent;
    public StrMap      Vars;
    public StrMap      LocalFns;   // impl-local-fn-l2：本层局部函数签名（name → Z42FuncType）；LookupLocalFn 走父链
    public SymbolTable Symbols;
    public bool        ClassFlag;
    public string      ClassName;
    public string[]    TypeParamNames;   // 活跃类型形参（泛型类/方法 scope，2A）
    public int         TypeParamCount;

    public TypeEnv(SymbolTable symbols, bool hasParent, TypeEnv parent, bool classFlag, string className,
                   string[] typeParamNames, int typeParamCount) {
        this.Symbols = symbols;
        this.HasParent = hasParent;
        this.Parent = parent;
        this.Vars = new StrMap();
        this.LocalFns = new StrMap();
        this.ClassFlag = classFlag;
        this.ClassName = className;
        this.TypeParamNames = typeParamNames;
        this.TypeParamCount = typeParamCount;
    }

    public static TypeEnv Root(SymbolTable symbols) {
        return new TypeEnv(symbols, false, null, false, "", new string[0], 0);
    }

    public TypeEnv PushScope() {
        return new TypeEnv(this.Symbols, true, this, this.ClassFlag, this.ClassName, this.TypeParamNames, this.TypeParamCount);
    }

    public TypeEnv WithClass(string className) {
        return new TypeEnv(this.Symbols, true, this, true, className, new string[0], 0);
    }

    // 泛型类 scope（携类型形参）。
    public TypeEnv WithClassGeneric(string className, string[] typeParamNames, int typeParamCount) {
        return new TypeEnv(this.Symbols, true, this, true, className, typeParamNames, typeParamCount);
    }

    // 类型解析（携本 scope 的活跃类型形参）。
    public Z42Type ResolveType(TypeExpr te) {
        return this.Symbols.ResolveTypeP(te, this.TypeParamNames, this.TypeParamCount);
    }

    public void Define(string name, Z42Type type) { this.Vars.Put(name, type); }

    // impl-local-fn-l2：局部函数签名注册 / 父链查找（null = 非局部函数）。
    public void DefineLocalFn(string name, Z42FuncType sig) { this.LocalFns.Put(name, sig); }
    public Z42FuncType LookupLocalFn(string name) {
        TypeEnv e = this;
        bool more = true;
        while (more) {
            if (e.LocalFns.ContainsKey(name)) { return e.LocalFns.Get(name) as Z42FuncType; }
            if (e.HasParent) { e = e.Parent; } else { more = false; }
        }
        return null;
    }

    // 本层 → 父链查找；未找到返回 null。
    // 迭代（非递归）：z42 无法在自身方法内对 self-type 字段调自身方法（编译中类型未就绪）→ 走字段读循环。
    public Z42Type LookupVar(string name) {
        TypeEnv e = this;
        bool more = true;
        while (more) {
            if (e.Vars.ContainsKey(name)) { return e.Vars.Get(name) as Z42Type; }
            if (e.HasParent) { e = e.Parent; }
            else { more = false; }
        }
        return null;
    }

    public bool        HasClass()     { return this.ClassFlag; }
    public string      CurrentClass() { return this.ClassName; }
    public SymbolTable GetSymbols()   { return this.Symbols; }
}
