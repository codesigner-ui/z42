// 语义类型（port-z42c-semantics 1A-1）。解析后类型（≠ syntax TypeExpr：那是语法层文本结构）。
// 受限写法：class 继承 + virtual（z42 无 abstract）。起步：Prim/Class/Void/Error/Unknown。
// 后续增量：Array/Func/Interface/GenericParam/Instantiated/Option/Enum。
// Z42ClassType 的 Fields/Methods（StrMap 符号）待 1A-2/1A-3（符号就绪后回填）。
namespace Z42.Semantics;

public class Z42Type {
    public virtual string Name() { return "?type"; }
    public virtual bool   IsAssignableTo(Z42Type other) { return false; }
    public virtual string Dump() { return this.Name(); }

    // 规范化基本类型名用于可赋性比较：剥 nullable `?`（z42 nullable 在类型模型擦除）+
    // 基本类型别名归一（`byte`≡`u8` 等；imported TSIG 用 keyword 拼写、本地用 canonical，须等价）。
    public static string Canon(string n) {
        string s = n;
        if (s.EndsWith("?")) { s = s.Substring(0, s.Length - 1); }
        if (s == "byte")   { return "u8"; }
        if (s == "sbyte")  { return "i8"; }
        if (s == "short")  { return "i16"; }
        if (s == "ushort") { return "u16"; }
        if (s == "int")    { return "i32"; }
        if (s == "uint")   { return "u32"; }
        if (s == "long")   { return "i64"; }
        if (s == "ulong")  { return "u64"; }
        if (s == "float")  { return "f32"; }
        if (s == "double") { return "f64"; }
        return s;
    }
}

public sealed class Z42PrimType : Z42Type {
    private string _name;
    public Z42PrimType(string name) { this._name = name; }
    public override string Name() { return this._name; }
    public override bool IsAssignableTo(Z42Type other) {
        if (other is Z42ErrorType) { return true; }
        if (Z42Type.Canon(this._name) == Z42Type.Canon(other.Name())) { return true; }   // 名等价（剥 ? + 别名）
        return this._canWiden(this._name, other.Name());
    }
    // 数值拓宽（无收窄）：int→long/float/double；long→float/double；float→double；byte·short→int 起。
    private bool _canWiden(string from, string to) {
        if (from == "byte" || from == "short") { return to == "int" || to == "long" || to == "float" || to == "double"; }
        if (from == "int")   { return to == "long" || to == "float" || to == "double"; }
        if (from == "long")  { return to == "float" || to == "double"; }
        if (from == "float") { return to == "double"; }
        return false;
    }
}

public sealed class Z42ClassType : Z42Type {
    private string _name;
    public bool   HasBase;
    public string BaseName;
    public StrMap Fields;    // name → FieldSymbol（1A-3 收集时回填）
    public StrMap Methods;   // name → MethodSymbol
    public StrMap EventFields;   // add-event-keyword-multicast：event 字段名集（`+=`/`-=` desugar 判别）
    public string[] InterfaceNames; public int InterfaceCount;   // 实现的接口（port-z42c-interface）
    // 本类**自有实例字段**（声明序 + AST 源拼写 + 可见性），供 TSIG 继承字段展开走 base 链按序读取
    // （Fields 是 hashed StrMap，迭代非确定；TSIG 需确定序 + 源拼写 → 单独有序元数据）。G18。
    public string[] OwnFieldNames; public string[] OwnFieldSpellings; public string[] OwnFieldVis; public int OwnFieldCount;
    // 本类**自有实例方法**（TSIG 序 + 各 flag），供 imported 祖先（无 ClassDecl AST）参与 TSIG 方法继承展开。
    // 仅实例方法（非 static）；含 ctor、override、virtual。static 走自有 ClassDecl 段，不需有序备份。G18-import。
    public string[] OwnMethodNames; public bool[] OwnMethodIsVirtual; public bool[] OwnMethodIsAbstract; public int OwnMethodCount;
    // class-arity-overloading（同名多 arity 同 CU；泛型版注册 Name$N 键，IrName() 返回 Name$N）。
    public bool HasArityMangle;    // true → 此 CT 以 Name$N 键注册
    public int  ArityMangleCount;  // TypeParams.Count when HasArityMangle
    public Z42ClassType(string name, bool hasBase, string baseName) {
        this._name = name; this.HasBase = hasBase; this.BaseName = baseName;
        this.Fields = new StrMap();
        this.Methods = new StrMap();
        this.EventFields = new StrMap();
        this.InterfaceNames = new string[0]; this.InterfaceCount = 0;
        this.OwnFieldNames = new string[0]; this.OwnFieldSpellings = new string[0]; this.OwnFieldVis = new string[0]; this.OwnFieldCount = 0;
        this.OwnMethodNames = new string[0]; this.OwnMethodIsVirtual = new bool[0]; this.OwnMethodIsAbstract = new bool[0]; this.OwnMethodCount = 0;
    }

    // 追加一个自有实例字段元数据（SymbolCollector._fillClass 按 AST 声明序调用；static 字段不入此表）。G18。
    public void AddOwnField(string name, string spelling, string vis) {
        if (this.OwnFieldCount == this.OwnFieldNames.Length) {
            int cap = this.OwnFieldNames.Length * 2;
            if (cap == 0) { cap = 4; }
            string[] nn = new string[cap]; string[] ns = new string[cap]; string[] nv = new string[cap];
            int i = 0;
            while (i < this.OwnFieldCount) { nn[i] = this.OwnFieldNames[i]; ns[i] = this.OwnFieldSpellings[i]; nv[i] = this.OwnFieldVis[i]; i = i + 1; }
            this.OwnFieldNames = nn; this.OwnFieldSpellings = ns; this.OwnFieldVis = nv;
        }
        this.OwnFieldNames[this.OwnFieldCount] = name;
        this.OwnFieldSpellings[this.OwnFieldCount] = spelling;
        this.OwnFieldVis[this.OwnFieldCount] = vis;
        this.OwnFieldCount = this.OwnFieldCount + 1;
    }
    // 追加一个自有实例方法元数据（TSIG 序调用；ImportedSymbolLoader 按 ExportedClassZ.Methods 顺序调用）。G18-import。
    public void AddOwnMethod(string key, bool isVirtual, bool isAbstract) {
        if (this.OwnMethodCount == this.OwnMethodNames.Length) {
            int cap = this.OwnMethodNames.Length * 2;
            if (cap == 0) { cap = 4; }
            string[] nn = new string[cap]; bool[] nv = new bool[cap]; bool[] na = new bool[cap];
            int i = 0;
            while (i < this.OwnMethodCount) { nn[i] = this.OwnMethodNames[i]; nv[i] = this.OwnMethodIsVirtual[i]; na[i] = this.OwnMethodIsAbstract[i]; i = i + 1; }
            this.OwnMethodNames = nn; this.OwnMethodIsVirtual = nv; this.OwnMethodIsAbstract = na;
        }
        this.OwnMethodNames[this.OwnMethodCount] = key;
        this.OwnMethodIsVirtual[this.OwnMethodCount] = isVirtual;
        this.OwnMethodIsAbstract[this.OwnMethodCount] = isAbstract;
        this.OwnMethodCount = this.OwnMethodCount + 1;
    }
    // 追加一个实现的接口名（port-z42c-impl-block：`impl Trait for Target` 把 Trait 并入 target 接口集）。
    public void AddInterfaceName(string name) {
        if (this.InterfaceCount == this.InterfaceNames.Length) {
            int cap = this.InterfaceNames.Length * 2;
            if (cap == 0) { cap = 4; }
            string[] nn = new string[cap];
            int i = 0;
            while (i < this.InterfaceCount) { nn[i] = this.InterfaceNames[i]; i = i + 1; }
            this.InterfaceNames = nn;
        }
        this.InterfaceNames[this.InterfaceCount] = name;
        this.InterfaceCount = this.InterfaceCount + 1;
    }
    // add-type-based-overloads：本类中所有源名为 name 的方法符号（重载候选枚举；不走 base 链——调用方按需 base walk）。
    public MethodSymbol[] OverloadsOf(string name) {
        string[] keys = this.Methods.Keys();
        MethodSymbol[] tmp = new MethodSymbol[keys.Length];
        int n = 0;
        int i = 0;
        while (i < keys.Length) {
            object v = this.Methods.Get(keys[i]);
            if (v is MethodSymbol) {
                MethodSymbol ms = v as MethodSymbol;
                if (ms.Name == name) { tmp[n] = ms; n = n + 1; }
            }
            i = i + 1;
        }
        MethodSymbol[] r = new MethodSymbol[n];
        int k = 0;
        while (k < n) { r[k] = tmp[k]; k = k + 1; }
        return r;
    }
    public override string Name() { return this._name; }
    // IR 名：arity-mangled 时返回 Name$N（镜像 C# Z42ClassType.IrName）。
    public string IrName() {
        if (this.HasArityMangle) { return this._name + "$" + this.ArityMangleCount.ToString(); }
        return this._name;
    }
    public override bool IsAssignableTo(Z42Type other) {
        if (other is Z42ErrorType) { return true; }
        // 同名（1A-1 不查继承链；subclass→base 赋值在 1C，需类表走 base 链）
        return (other is Z42ClassType) && this._name == other.Name();
    }
}

// 接口类型（port-z42c-interface）：方法签名表（MethodSymbol，同类方法形态——D1）。
public sealed class Z42InterfaceType : Z42Type {
    private string _name;
    public StrMap Methods;    // name → MethodSymbol
    public Z42InterfaceType(string name) { this._name = name; this.Methods = new StrMap(); }
    public override string Name() { return this._name; }
    public override bool IsAssignableTo(Z42Type other) {
        if (other is Z42ErrorType) { return true; }
        return (other is Z42InterfaceType) && this._name == other.Name();
    }
}

// 函数签名类型（形参类型 + 返回类型）。1A：结构相等（同 Dump）。
public sealed class Z42FuncType : Z42Type {
    public Z42Type[] ParamTypes;
    public int       ParamCount;
    public Z42Type   Ret;
    public int       ParamsFrom;   // add-params-varargs：变长形参 0-based 索引（= ParamCount-1）；-1 = 非变长。
                                   // 构造后由 SymbolCollector / ImportedSymbolLoader 设置；不入 Dump（默认 -1 → 现有签名 Dump 不变）。
    public Z42FuncType(Z42Type[] paramTypes, int paramCount, Z42Type ret) {
        this.ParamTypes = paramTypes; this.ParamCount = paramCount; this.Ret = ret; this.ParamsFrom = 0 - 1;
    }
    // C# TypeToString 镜像（TSIG/SIGS 串字节实证）：void 返回 → "Action[<p,…>]"；否则 "Func<p,…,ret>"（", " 分隔）。
    public override string Name() {
        bool isVoid = this.Ret is Z42VoidType;
        string s = "Func<";
        if (isVoid) {
            if (this.ParamCount == 0) { return "Action"; }
            s = "Action<";
        }
        int i = 0;
        while (i < this.ParamCount) {
            if (i > 0) { s = s + ", "; }
            s = s + this.ParamTypes[i].Name();
            i = i + 1;
        }
        if (!isVoid) {
            if (this.ParamCount > 0) { s = s + ", "; }
            s = s + this.Ret.Name();
        }
        return s + ">";
    }
    public override string Dump() {
        string s = "(";
        int i = 0;
        while (i < this.ParamCount) {
            if (i > 0) { s = s + ","; }
            s = s + this.ParamTypes[i].Dump();
            i = i + 1;
        }
        return s + ")->" + this.Ret.Dump();
    }
    public override bool IsAssignableTo(Z42Type other) {
        if (other is Z42ErrorType) { return true; }
        return (other is Z42FuncType) && this.Dump() == other.Dump();
    }
}

// 泛型类型形参（2A）：T / K / V 等。约束求解延后（2B）→ 仅同名互赋。
public sealed class Z42GenericParamType : Z42Type {
    private string _name;
    public Z42GenericParamType(string name) { this._name = name; }
    public override string Name() { return this._name; }
    public override bool IsAssignableTo(Z42Type other) {
        if (other is Z42ErrorType) { return true; }
        return (other is Z42GenericParamType) && this._name == other.Name();
    }
}

// 泛型实例化（2A-2）：Box<int>。Def = 泛型类定义，TypeArgs = 实参。不变（同 def 同实参才可赋）。
// 成员类型替换（T→int）延后（需 substitution pass）。
public sealed class Z42InstantiatedType : Z42Type {
    public Z42ClassType Def;
    public Z42Type[]    TypeArgs;
    public int          ArgCount;
    public Z42InstantiatedType(Z42ClassType def, Z42Type[] typeArgs, int argCount) {
        this.Def = def; this.TypeArgs = typeArgs; this.ArgCount = argCount;
    }
    public override string Name() {
        string s = this.Def.Name() + "<";
        int i = 0;
        while (i < this.ArgCount) {
            if (i > 0) { s = s + ", "; }
            s = s + this.TypeArgs[i].Name();
            i = i + 1;
        }
        return s + ">";
    }
    public override bool IsAssignableTo(Z42Type other) {
        if (other is Z42ErrorType) { return true; }
        if (other is Z42InstantiatedType) { return this.Name() == other.Name(); }
        return false;
    }
}

// 数组类型（1D）：T[]。不变（无协变）。
public sealed class Z42ArrayType : Z42Type {
    public Z42Type Elem;
    public Z42ArrayType(Z42Type elem) { this.Elem = elem; }
    public override string Name() { return this.Elem.Name() + "[]"; }
    public override bool IsAssignableTo(Z42Type other) {
        if (other is Z42ErrorType) { return true; }
        if (other is Z42ArrayType) {
            Z42ArrayType o = other as Z42ArrayType;
            // 元素 unknown/error 任一侧吸收（镜像标量；imported 元素类型在字段位未解析时退化为 unknown，
            // codegen 经 DepIndex 真实解析）。否则元素名规范等价（byte[]≡u8[] 等）。
            if ((this.Elem is Z42UnknownType) || (this.Elem is Z42ErrorType)) { return true; }
            if ((o.Elem is Z42UnknownType) || (o.Elem is Z42ErrorType)) { return true; }
            return Z42Type.Canon(this.Elem.Name()) == Z42Type.Canon(o.Elem.Name());
        }
        return false;
    }
}

public sealed class Z42VoidType : Z42Type {
    public override string Name() { return "void"; }
    public override bool IsAssignableTo(Z42Type other) {
        if (other is Z42ErrorType) { return true; }
        return other is Z42VoidType;
    }
}

// 错误吸收哨兵：任何 → error、error → 任何，均 true（防止级联报错）。
public sealed class Z42ErrorType : Z42Type {
    public override string Name() { return "<error>"; }
    public override bool IsAssignableTo(Z42Type other) { return true; }
}

public sealed class Z42UnknownType : Z42Type {
    public override string Name() { return "<unknown>"; }
    public override bool IsAssignableTo(Z42Type other) {
        if (other is Z42ErrorType) { return true; }
        return false;
    }
}
