// 方法重载决议 + 签名键派生（add-type-based-overloads）。
//
// z42c 方法身份 = 精确函数签名（name + 形参类型序列）。签名键统一派生、可序列化、跨包可复算：
//   key = Name$arity[$T1$T2...]，Ti = Z42Type.Canon(paramType.Name())（剥空白）。
//   用 Canon 归一基本类型别名 + 剥 nullable → imported（keyword 拼写）与本地（canonical）两侧一致。
//
// 决议：候选集（同名所有重载，沿 base 链聚合）→ 适用性（arity + 每位 IsAssignableTo）→
//   最具体（better-conversion 偏序：精确匹配优于加宽/装箱）→ 唯一极小 = 选中 / 空 = no-match /
//   多个不可比 = 歧义。v1 不做 int→long→double 隐式数值排序（并列即歧义，让用户显式 cast）。
namespace Z42.Semantics;

// 决议结果（z42 无元组 → holder）。Kind：0=Resolved，1=NoMatch，2=Ambiguous。
public sealed class OverloadResult {
    public int          Kind;
    public MethodSymbol Method;   // Kind==0 时有效
    public string       Key;      // 选中重载的签名键（Kind==0）
    public OverloadResult(int kind, MethodSymbol method, string key) {
        this.Kind = kind; this.Method = method; this.Key = key;
    }
    public bool IsResolved()  { return this.Kind == 0; }
    public bool IsNoMatch()   { return this.Kind == 1; }
    public bool IsAmbiguous() { return this.Kind == 2; }
}

public sealed class OverloadResolver {

    // ── 签名键派生 ──────────────────────────────────────────────────────────
    // 统一签名键：每个方法（含唯一方法）一律编码完整签名。定义点与跨包 import 两侧用本函数 +
    // 解析后类型 .Name() → round-trip 一致。
    public static string MangleKey(string name, Z42Type[] paramTypes, int paramCount) {
        string s = name + "$" + paramCount.ToString();
        int i = 0;
        while (i < paramCount) {
            s = s + "$" + OverloadResolver.TypeKey(paramTypes[i]);
            i = i + 1;
        }
        return s;
    }

    // 单个形参类型 → 键片段：Canon 归一（基本别名 + 剥 nullable）后剥空白（泛型名含 ", "）。
    public static string TypeKey(Z42Type t) {
        if (t == null) { return "unknown"; }
        return OverloadResolver._stripSpaces(Z42Type.Canon(t.Name()));
    }

    private static string _stripSpaces(string s) {
        string r = "";
        int i = 0;
        while (i < s.Length) {
            string ch = s.Substring(i, 1);
            if (ch != " ") { r = r + ch; }
            i = i + 1;
        }
        return r;
    }

    // ── 决议 ────────────────────────────────────────────────────────────────
    // candidates = 同名所有重载（调用方枚举）；argTypes = 实参解析类型。
    public static OverloadResult Resolve(MethodSymbol[] candidates, int candCount,
                                         Z42Type[] argTypes, int argCount) {
        // 1. 适用集
        MethodSymbol[] applic = new MethodSymbol[candCount];
        int ac = 0;
        int i = 0;
        while (i < candCount) {
            if (OverloadResolver._applicable(candidates[i], argTypes, argCount)) {
                applic[ac] = candidates[i]; ac = ac + 1;
            }
            i = i + 1;
        }
        if (ac == 0) { return new OverloadResult(1, null, ""); }
        if (ac == 1) {
            return new OverloadResult(0, applic[0], applic[0].RegKey);
        }
        // 2. 最具体：找一个 betterThan 所有其它的候选
        int bestIdx = 0 - 1;
        int j = 0;
        while (j < ac) {
            bool dominatesAll = true;
            int k = 0;
            while (k < ac) {
                if (k != j) {
                    if (!OverloadResolver._betterThan(applic[j], applic[k], argTypes, argCount)) {
                        dominatesAll = false;
                    }
                }
                k = k + 1;
            }
            if (dominatesAll) {
                if (bestIdx >= 0) {
                    // 两个都"支配所有" → 不可能除非相等签名；保守判歧义
                    return new OverloadResult(2, null, "");
                }
                bestIdx = j;
            }
            j = j + 1;
        }
        if (bestIdx < 0) { return new OverloadResult(2, null, ""); }   // 无唯一极小 → 歧义
        return new OverloadResult(0, applic[bestIdx], applic[bestIdx].RegKey);
    }

    // 候选适用 ⟺ arity 匹配 ∧ 每个实参可赋值到对应形参（含子类→基类 / prim→object 装箱 / 接口实现）。
    private static bool _applicable(MethodSymbol ms, Z42Type[] argTypes, int argCount) {
        Z42FuncType sig = ms.Signature;
        if (sig.ParamCount != argCount) { return false; }
        int i = 0;
        while (i < argCount) {
            if (!OverloadResolver._assignable(argTypes[i], sig.ParamTypes[i])) { return false; }
            i = i + 1;
        }
        return true;
    }

    // X 比 Y 更优 ⟺ 每个位置 X 不差于 Y（X 的形参更精确或同等）且至少一处严格更优。
    private static bool _betterThan(MethodSymbol x, MethodSymbol y, Z42Type[] argTypes, int argCount) {
        Z42FuncType sx = x.Signature;
        Z42FuncType sy = y.Signature;
        bool someStrict = false;
        int i = 0;
        while (i < argCount) {
            int c = OverloadResolver._betterAtPos(sx.ParamTypes[i], sy.ParamTypes[i], argTypes[i]);
            if (c < 0) { return false; }       // 某位 X 更差 → 非更优
            if (c > 0) { someStrict = true; }
            i = i + 1;
        }
        return someStrict;
    }

    // 位置比较：+1 = px 比 py 更适合 argType，-1 = 更差，0 = 同等。
    private static int _betterAtPos(Z42Type px, Z42Type py, Z42Type arg) {
        bool exX = OverloadResolver._sameType(arg, px);
        bool exY = OverloadResolver._sameType(arg, py);
        if (exX && !exY) { return 1; }
        if (exY && !exX) { return 0 - 1; }
        if (exX && exY)  { return 0; }
        // 都非精确：更"具体"的形参类型胜（px 可赋值到 py 而非反向 → px 更派生/更具体）。
        bool xToY = OverloadResolver._assignable2(px, py);
        bool yToX = OverloadResolver._assignable2(py, px);
        if (xToY && !yToX) { return 1; }
        if (yToX && !xToY) { return 0 - 1; }
        return 0;
    }

    // 类型相等（规范名比较，归一别名）。
    private static bool _sameType(Z42Type a, Z42Type b) {
        if (a == null || b == null) { return false; }
        return Z42Type.Canon(a.Name()) == Z42Type.Canon(b.Name());
    }

    // 实参类型可赋值到形参类型（复用 Z42Type.IsAssignableTo + 精确名等价兜底）。
    private static bool _assignable(Z42Type arg, Z42Type param) {
        if (OverloadResolver._sameType(arg, param)) { return true; }
        if (param != null && param.Name() == "object") { return true; }   // prim/任意 → object 装箱
        if (arg == null) { return false; }
        return arg.IsAssignableTo(param);
    }
    private static bool _assignable2(Z42Type a, Z42Type b) {
        if (OverloadResolver._sameType(a, b)) { return true; }
        if (b != null && b.Name() == "object") { return true; }
        if (a == null) { return false; }
        return a.IsAssignableTo(b);
    }
}
