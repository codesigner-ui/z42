// z42c.project ManifestLoader 单测（incr port-z42c-project 1）：.z42.toml → ProjectManifest 模型。
namespace Z42cProjectManifestTests;

using Std;
using Std.Test;
using Z42.Project;

[Test]
void test_parse_project_section() {
    string toml = "[project]\nname = \"myapp\"\nversion = \"0.2.0\"\nkind = \"exe\"\nentry = \"Main\"\npack = true\n";
    var m = ManifestLoader.ParseText(toml);
    Assert.Equal("myapp", m.Name);
    Assert.Equal("0.2.0", m.Version);
    Assert.Equal("exe", m.Kind);
    Assert.Equal(true, m.HasEntry);
    Assert.Equal("Main", m.Entry);
    Assert.Equal(true, m.HasPack);
    Assert.Equal(true, m.Pack);
}

[Test]
void test_parse_sources_and_deps() {
    string toml = "[project]\nname = \"lib1\"\nversion = \"1.0.0\"\nkind = \"lib\"\n\n[sources]\ninclude = [\"src/**/*.z42\"]\nexclude = [\"src/gen/**\"]\n\n[dependencies]\n\"z42.io\" = \"1.0\"\n";
    var m = ManifestLoader.ParseText(toml);
    Assert.Equal("lib1", m.Name);
    Assert.Equal("lib", m.Kind);
    Assert.Equal(false, m.HasEntry);              // 无 entry
    Assert.Equal(1, m.IncludeCount);
    Assert.Equal("src/**/*.z42", m.IncludeGlobs[0]);
    Assert.Equal(1, m.ExcludeCount);
    Assert.Equal("src/gen/**", m.ExcludeGlobs[0]);
    Assert.Equal(1, m.DepCount);
    Assert.Equal("z42.io@1.0", m.Deps[0].Dump());
}

[Test]
void test_dep_table_form() {
    // 依赖值为表 { version, path } —— 取 version
    string toml = "[project]\nname = \"a\"\nversion = \"0.1.0\"\nkind = \"lib\"\n\n[dependencies]\nmylib = { version = \"2.0\", path = \"../shared\" }\n";
    var m = ManifestLoader.ParseText(toml);
    Assert.Equal(1, m.DepCount);
    Assert.Equal("mylib@2.0", m.Deps[0].Dump());
}

[Test]
void test_parse_workspace() {
    string toml = "[workspace]\nmembers = [\"*\"]\nexclude = [\"scratch\"]\ndefault-members = [\"a\", \"b\"]\n\n[workspace.project]\nversion = \"0.1.0\"\nlicense = \"MIT\"\n\n[workspace.build]\noutput_dir = \"out/${member_name}\"\ncache_dir = \"${output_dir}/cache\"\n\n[workspace.dependencies]\n\"z42.io\" = \"1.0\"\n";
    var w = ManifestLoader.ParseWorkspaceText(toml);
    Assert.Equal(1, w.MembersCount);
    Assert.Equal("*", w.MembersPatterns[0]);
    Assert.Equal(1, w.ExcludeCount);
    Assert.Equal(2, w.DefaultCount);
    Assert.Equal("a", w.DefaultMembers[0]);
    Assert.Equal("b", w.DefaultMembers[1]);
    Assert.Equal(true, w.HasSharedVersion);
    Assert.Equal("0.1.0", w.SharedVersion);
    Assert.Equal(true, w.HasSharedLicense);
    Assert.Equal("MIT", w.SharedLicense);
    Assert.Equal("out/${member_name}", w.OutputDir);          // 路径模板原样保留
    Assert.Equal("${output_dir}/cache", w.CacheDir);
    Assert.Equal(1, w.WorkspaceDepCount);
    Assert.Equal("z42.io@1.0", w.WorkspaceDeps[0].Dump());
}

[Test]
void test_parse_real_z42c_workspace_shape() {
    // 镜像 src/compiler/z42.workspace.toml 形态：members=["*"] + default-members 列表 + 共享 version/license
    string toml = "[workspace]\nmembers = [\"*\"]\ndefault-members = [\"z42c.core\", \"z42c.ir\", \"z42c.syntax\"]\n\n[workspace.project]\nversion = \"0.1.0\"\nlicense = \"MIT\"\n\n[workspace.build]\noutput_dir = \"../../artifacts/build/z42c/${member_name}/${profile}\"\ncache_dir = \"${output_dir}/cache\"\n";
    var w = ManifestLoader.ParseWorkspaceText(toml);
    Assert.Equal(3, w.DefaultCount);
    Assert.Equal("z42c.core", w.DefaultMembers[0]);
    Assert.Equal("z42c.syntax", w.DefaultMembers[2]);
    Assert.Equal("0.1.0", w.SharedVersion);
    Assert.Equal(0, w.WorkspaceDepCount);                     // 无 [workspace.dependencies]
}

[Test]
void test_path_template_expand() {
    var ctx = new TemplateContext("/ws", "/ws/mem", "z42c.syntax", "release", "/out/z42c.syntax");
    // 镜像真实 z42c [workspace.build]：output_dir + cache_dir
    Assert.Equal("../../artifacts/build/z42c/z42c.syntax/release",
                 PathTemplate.Expand("../../artifacts/build/z42c/${member_name}/${profile}", ctx));
    Assert.Equal("/out/z42c.syntax/cache", PathTemplate.Expand("${output_dir}/cache", ctx));
    Assert.Equal("/ws/sub", PathTemplate.Expand("${workspace_dir}/sub", ctx));
    Assert.Equal("a$b", PathTemplate.Expand("a$$b", ctx));                    // $$ → $
    Assert.Equal("x${unknown}y", PathTemplate.Expand("x${unknown}y", ctx));   // 未知变量保留字面
    Assert.Equal("plain/path", PathTemplate.Expand("plain/path", ctx));       // 无模板原样
}
