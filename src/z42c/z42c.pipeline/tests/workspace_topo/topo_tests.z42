// z42c.pipeline WorkspaceBuild.TopoOrder 单测（z42c-build-workspace Milestone 2 task 1.5）。
// 覆盖 chain / fan-out / cycle 三形态。WsMembers 平行数组直接构造（无需真 toml）。
//   depFlat = 各成员 workspace 内依赖名（flat）；成员 i 的依赖 = depFlat[depOff[i] .. +depLen[i]]
// TopoOrder 返回**成员索引**的拓扑序（叶子在前；同层按 name Ordinal）。
namespace Z42cPipelineWorkspaceTopoTests;

using Std;
using Std.Test;
using Z42.Pipeline;

// chain: a→b→c（a 依赖 b，b 依赖 c）→ 拓扑序 c,b,a（叶子在前）。
[Test]
void test_topo_chain() {
    string[] names = new string[]{ "a", "b", "c" };
    string[] tomls = new string[]{ "a.toml", "b.toml", "c.toml" };
    string[] depFlat = new string[]{ "b", "c" };   // a→b, b→c
    int[] depOff = new int[]{ 0, 1, 2 };
    int[] depLen = new int[]{ 1, 1, 0 };
    var m = new WsMembers(tomls, names, depFlat, depOff, depLen, 3);
    int[] order = WorkspaceBuild.TopoOrder(m);
    Assert.Equal(3, order.Length);
    Assert.Equal("c", names[order[0]]);
    Assert.Equal("b", names[order[1]]);
    Assert.Equal("a", names[order[2]]);
}

// fan-out: root 依赖 x,y（两叶子互不依赖）→ 叶子按 name Ordinal 先发（x,y），root 最后。
[Test]
void test_topo_fanout() {
    string[] names = new string[]{ "root", "x", "y" };
    string[] tomls = new string[]{ "root.toml", "x.toml", "y.toml" };
    string[] depFlat = new string[]{ "x", "y" };   // root→x, root→y
    int[] depOff = new int[]{ 0, 2, 2 };
    int[] depLen = new int[]{ 2, 0, 0 };
    var m = new WsMembers(tomls, names, depFlat, depOff, depLen, 3);
    int[] order = WorkspaceBuild.TopoOrder(m);
    Assert.Equal(3, order.Length);
    Assert.Equal("x", names[order[0]]);
    Assert.Equal("y", names[order[1]]);
    Assert.Equal("root", names[order[2]]);
}

// cycle: a→b, b→a → 无进展 → 抛 Exception。
[Test]
void test_topo_cycle_throws() {
    string[] names = new string[]{ "a", "b" };
    string[] tomls = new string[]{ "a.toml", "b.toml" };
    string[] depFlat = new string[]{ "b", "a" };   // a→b, b→a
    int[] depOff = new int[]{ 0, 1 };
    int[] depLen = new int[]{ 1, 1 };
    var m = new WsMembers(tomls, names, depFlat, depOff, depLen, 2);
    bool threw = false;
    try {
        WorkspaceBuild.TopoOrder(m);
    } catch (Exception e) {
        threw = true;
    }
    Assert.True(threw);
}
