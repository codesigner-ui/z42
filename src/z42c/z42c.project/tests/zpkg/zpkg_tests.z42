// zpkg 组装/写入单测（port-z42c-zpkg-build BP-5）。
// 全文件 byte-identical 对真 C# CLI 由 xtask e2e 承担（TSIG/IMPL follow-up 后升级为全等）。
namespace Z42cProjectZpkgTests;

using Std;
using Std.Test;
using Z42.Project;
using Z42.IR;

ZbcFileZ _mod(string ns, string fname) {
    string[] exports = new string[1];
    exports[0] = fname;
    string[] pool = new string[1];
    IrClassDesc[] classes = new IrClassDesc[0];
    IrFunction[] fns = new IrFunction[0];
    var irm = new IrModule(ns, pool, 1, classes, 0, fns, 0);
    return new ZbcFileZ("a.z42", "HASH", ns, exports, 1, irm);
}

[Test]
void test_sha256_hex_form() {
    // SHA256("abc") 标准向量（"sha256:" 前缀 + 小写——真 C# CLI 字节实测形态，port-z42c-tsig 校准）
    Assert.Equal("sha256:ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad",
                 ZpkgBuilder.Sha256Hex("abc"));
}

[Test]
void test_entry_autodetect_priority() {
    // FQ .Main 优先于裸 main
    var e1 = new ZpkgExportZ[2];
    e1[0] = new ZpkgExportZ("main", "func");
    e1[1] = new ZpkgExportZ("Demo.Main", "func");
    Assert.Equal("Demo.Main", ZpkgBuilder.AutoDetectEntry(e1, 2));
    // 仅裸 main
    var e2 = new ZpkgExportZ[1];
    e2[0] = new ZpkgExportZ("main", "func");
    Assert.Equal("main", ZpkgBuilder.AutoDetectEntry(e2, 1));
    // 同级歧义
    var e3 = new ZpkgExportZ[2];
    e3[0] = new ZpkgExportZ("A.Main", "func");
    e3[1] = new ZpkgExportZ("B.Main", "func");
    Assert.Equal("<ambiguous>", ZpkgBuilder.AutoDetectEntry(e3, 2));
    // 无候选
    Assert.Equal("", ZpkgBuilder.AutoDetectEntry(new ZpkgExportZ[0], 0));
}

[Test]
void test_build_packed_namespaces_and_exports() {
    var mods = new ZbcFileZ[2];
    mods[0] = _mod("Demo", "Demo.F");    // 已 FQ → 幂等不再加前缀
    mods[1] = _mod("Demo", "G");         // 短名 → 限定为 Demo.G
    ZpkgFileZ z = ZpkgBuilder.BuildPacked("p", "0.1.0", false, false, "", mods, 2);
    Assert.Equal(1, z.NsCount);                       // 同 ns 去重
    Assert.Equal("Demo", z.Namespaces[0]);
    Assert.Equal("Demo.F", z.Exports[0].Symbol);
    Assert.Equal("Demo.G", z.Exports[1].Symbol);
    Assert.Equal("", z.Entry);                        // lib 无 entry
}

[Test]
void test_write_packed_header() {
    var mods = new ZbcFileZ[1];
    mods[0] = _mod("Demo", "Demo.Main");
    ZpkgFileZ z = ZpkgBuilder.BuildPacked("p", "0.1.0", true, false, "", mods, 1);
    Assert.Equal("Demo.Main", z.Entry);               // exe 自动检测
    string hex = ZpkgWriterZ.WritePacked(z).ToHex();
    // "ZPK\0" + major 0 + minor 21 + flags 0x03(Packed|Exe) + secCount 7
    Assert.Equal("5a504b0000001500030007000000", hex.Substring(0, 28));
}
