// zpkg 组装（port-z42c-zpkg-build BP-2）。镜像 C# ZpkgBuilder.BuildPacked +
// PackageCompiler.AutoDetectEntry + Sha256Hex。cache .zbc 落盘延后（增量编译物质基础，MVP 不需）。
namespace Z42.Project;

using Std;
using Std.Crypto;
using Std.Encoding;
using Z42.IR;

public static class ZpkgBuilder {
    // packed 组装：namespaces 去重（首现序）+ exports FQ 限定（幂等）+ entry（显式或自动检测）。
    // entryError 经返回值外带：entry=="<ambiguous>" 表歧义（调用方报错退出）。
    public static ZpkgFileZ BuildPacked(string name, string version, bool isExe, bool hasExplicitEntry,
                                        string explicitEntry, ZbcFileZ[] modules, int moduleCount) {
        return ZpkgBuilder.BuildPackedD(name, version, isExe, hasExplicitEntry, explicitEntry,
                                        modules, moduleCount, new ZpkgDepZ[0], 0);
    }

    // 带 DEPS 条目（CI-4）。
    public static ZpkgFileZ BuildPackedD(string name, string version, bool isExe, bool hasExplicitEntry,
                                         string explicitEntry, ZbcFileZ[] modules, int moduleCount,
                                         ZpkgDepZ[] deps, int depCount) {
        // namespaces：首现序去重（镜像 C# Distinct 保序）
        string[] nss = new string[4];
        int nsc = 0;
        int i = 0;
        while (i < moduleCount) {
            string ns = modules[i].Namespace;
            bool seen = false;
            int j = 0;
            while (j < nsc) { if (nss[j] == ns) { seen = true; } j = j + 1; }
            if (!seen) {
                if (nsc == nss.Length) {
                    string[] b = new string[nss.Length * 2];
                    int k = 0; while (k < nsc) { b[k] = nss[k]; k = k + 1; }
                    nss = b;
                }
                nss[nsc] = ns; nsc = nsc + 1;
            }
            i = i + 1;
        }
        // exports：平铺 + FQ 限定（幂等：已带 ns 前缀不再加，镜像 C# QualifyExport）
        ZpkgExportZ[] exps = new ZpkgExportZ[8];
        int ec = 0;
        i = 0;
        while (i < moduleCount) {
            ZbcFileZ m = modules[i];
            int x = 0;
            while (x < m.ExportCount) {
                string sym = ZpkgBuilder._qualifyExport(m.Namespace, m.Exports[x]);
                if (ec == exps.Length) {
                    ZpkgExportZ[] b = new ZpkgExportZ[exps.Length * 2];
                    int k = 0; while (k < ec) { b[k] = exps[k]; k = k + 1; }
                    exps = b;
                }
                exps[ec] = new ZpkgExportZ(sym, "func"); ec = ec + 1;
                x = x + 1;
            }
            i = i + 1;
        }
        // entry：用**原始函数名**检测（限定前——C# AutoDetectEntry 输入是 unit.Exports 原始名；
        // 字节实证：no-ns 单元 entry="Main" 短名而 EXPT="main.Main"）
        string entry = "";
        if (isExe) {
            if (hasExplicitEntry) { entry = explicitEntry; }
            else {
                ZpkgExportZ[] raw = new ZpkgExportZ[ec];
                int rc = 0;
                i = 0;
                while (i < moduleCount) {
                    int x = 0;
                    while (x < modules[i].ExportCount) {
                        raw[rc] = new ZpkgExportZ(modules[i].Exports[x], "func");
                        rc = rc + 1;
                        x = x + 1;
                    }
                    i = i + 1;
                }
                entry = ZpkgBuilder.AutoDetectEntry(raw, rc);
            }
        }
        return new ZpkgFileZ(name, version, isExe, entry, nss, nsc, exps, ec,
                             deps, depCount, modules, moduleCount);
    }

    // DEPS 条目（镜像 C# BuildDependencyMap）：每单元 usings → usedDepNs 顺序 AddDepNs；
    // ns→file 经 nsNames/nsFiles 平行表（DepScan 产物）。z42 无交错数组/out 参 →
    // 扁平 (file,ns) 对收集（去重保序）+ 二遍按 file 首现序聚合，holder 返回。
    public static ZpkgDepList BuildDependencyMap(ZbcFileZ[] modules, int moduleCount,
                                                 string[] nsNames, string[] nsFiles, int nsCount) {
        string[] pairFile = new string[8];
        string[] pairNs   = new string[8];
        int pairCount = 0;
        int mi = 0;
        while (mi < moduleCount) {
            ZbcFileZ m = modules[mi];
            int u = 0;
            while (u < m.UsingCount) {
                pairCount = ZpkgBuilder._addPair(pairFile, pairNs, pairCount, nsNames, nsFiles, nsCount, m.Usings[u]);
                if (pairCount > pairFile.Length - 1) {
                    string[] b1 = new string[pairFile.Length * 2];
                    string[] b2 = new string[pairFile.Length * 2];
                    int k = 0; while (k < pairCount) { b1[k] = pairFile[k]; b2[k] = pairNs[k]; k = k + 1; }
                    pairFile = b1; pairNs = b2;
                }
                u = u + 1;
            }
            u = 0;
            while (u < m.UsedDepNsCount) {
                pairCount = ZpkgBuilder._addPair(pairFile, pairNs, pairCount, nsNames, nsFiles, nsCount, m.UsedDepNs[u]);
                if (pairCount > pairFile.Length - 1) {
                    string[] b1 = new string[pairFile.Length * 2];
                    string[] b2 = new string[pairFile.Length * 2];
                    int k = 0; while (k < pairCount) { b1[k] = pairFile[k]; b2[k] = pairNs[k]; k = k + 1; }
                    pairFile = b1; pairNs = b2;
                }
                u = u + 1;
            }
            mi = mi + 1;
        }
        // 二遍：file 首现序聚合
        string[] files = new string[pairCount + 1];
        int fileCount = 0;
        int i = 0;
        while (i < pairCount) {
            bool seen = false;
            int j = 0;
            while (j < fileCount) { if (files[j] == pairFile[i]) { seen = true; } j = j + 1; }
            if (!seen) { files[fileCount] = pairFile[i]; fileCount = fileCount + 1; }
            i = i + 1;
        }
        ZpkgDepZ[] deps = new ZpkgDepZ[fileCount];
        i = 0;
        while (i < fileCount) {
            int n = 0;
            int j = 0;
            while (j < pairCount) { if (pairFile[j] == files[i]) { n = n + 1; } j = j + 1; }
            string[] nsList = new string[n];
            int k = 0;
            j = 0;
            while (j < pairCount) {
                if (pairFile[j] == files[i]) { nsList[k] = pairNs[j]; k = k + 1; }
                j = j + 1;
            }
            deps[i] = new ZpkgDepZ(files[i], nsList, n);
            i = i + 1;
        }
        return new ZpkgDepList(deps, fileCount);
    }

    // (file,ns) 对去重追加；ns 不在 nsMap → 跳过（镜像 AddDepNs 未解析即略）。返回新 count。
    private static int _addPair(string[] pairFile, string[] pairNs, int pairCount,
                                string[] nsNames, string[] nsFiles, int nsCount, string ns) {
        string file = "";
        int i = 0;
        while (i < nsCount) {
            if (nsNames[i] == ns) { file = nsFiles[i]; }
            i = i + 1;
        }
        if (file == "") { return pairCount; }
        i = 0;
        while (i < pairCount) {
            if (pairFile[i] == file && pairNs[i] == ns) { return pairCount; }
            i = i + 1;
        }
        pairFile[pairCount] = file;
        pairNs[pairCount] = ns;
        return pairCount + 1;
    }

    // entry 自动检测（镜像 C# AutoDetectEntry / vm.rs resolve_entry 四级优先）：
    // 1. FQ `.Main` 结尾  2. 裸 `Main`  3. FQ `.main`  4. 裸 `main`。同级多候选 → "<ambiguous>"。
    public static string AutoDetectEntry(ZpkgExportZ[] exports, int count) {
        string r = ZpkgBuilder._pick(exports, count, ".Main", "Main");
        if (r != "") { return r; }
        return ZpkgBuilder._pick(exports, count, ".main", "main");
    }

    private static string _pick(ZpkgExportZ[] exports, int count, string fqSuffix, string bare) {
        string fqHit = "";
        int fqN = 0;
        string bareHit = "";
        int bareN = 0;
        int i = 0;
        while (i < count) {
            string s = exports[i].Symbol;
            if (s.EndsWith(fqSuffix)) { fqHit = s; fqN = fqN + 1; }
            else if (s == bare) { bareHit = s; bareN = bareN + 1; }
            i = i + 1;
        }
        if (fqN == 1) { return fqHit; }
        if (fqN > 1) { return "<ambiguous>"; }
        if (bareN == 1) { return bareHit; }
        if (bareN > 1) { return "<ambiguous>"; }
        return "";
    }

    private static string _qualifyExport(string ns, string export) {
        if (ns == "" || export.StartsWith(ns + ".")) { return export; }
        return ns + "." + export;
    }

    // 源文本哈希（真 C# CLI 字节实测："sha256:" 前缀 + 小写 hex；fixture 的大写无前缀是测试合成形态）。
    public static string Sha256Hex(string text) {
        byte[] hash = Sha256.Hash(Utf8.GetBytes(text));
        string digits = "0123456789abcdef";
        string s = "sha256:";
        int i = 0;
        while (i < hash.Length) {
            int b = (int)hash[i];
            s = s + digits.Substring((b >> 4) & 0xF, 1) + digits.Substring(b & 0xF, 1);
            i = i + 1;
        }
        return s;
    }
}
