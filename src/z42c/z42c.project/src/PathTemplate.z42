// 路径模板展开（port-z42c-project increment 3）。镜像 C# PathTemplateExpander 核心。
// 内置变量：${workspace_dir} / ${member_dir} / ${member_name} / ${profile} / ${output_dir}（合成，cache_dir 用）。
// `$$` → 字面 `$`；未闭合 `${` → 原样保留；未知变量 → 保留字面 `${name}`。
// 延后：WS037/WS038/WS039 校验 + scalar/path 字段白名单区分（C# Expand 的 FieldKind）。
namespace Z42.Project;

public sealed class TemplateContext {
    public string WorkspaceDir;
    public string MemberDir;
    public string MemberName;
    public string Profile;
    public string OutputDir;
    public TemplateContext(string workspaceDir, string memberDir, string memberName, string profile, string outputDir) {
        this.WorkspaceDir = workspaceDir; this.MemberDir = memberDir;
        this.MemberName = memberName; this.Profile = profile; this.OutputDir = outputDir;
    }
}

public static class PathTemplate {
    public static string Expand(string template, TemplateContext ctx) {
        string s = "";
        int i = 0;
        int n = template.Length;
        while (i < n) {
            char c = template.CharAt(i);
            if (c == '$' && i + 1 < n && template.CharAt(i + 1) == '$') {
                s = s + "$"; i = i + 2; continue;
            }
            if (c == '$' && i + 1 < n && template.CharAt(i + 1) == '{') {
                int close = PathTemplate._findClose(template, i + 2);
                if (close < 0) { s = s + template.Substring(i, n - i); break; }   // 未闭合：原样
                string name = template.Substring(i + 2, close - (i + 2));
                s = s + PathTemplate._resolve(name, ctx, template, i, close);
                i = close + 1;
                continue;
            }
            s = s + template.Substring(i, 1);
            i = i + 1;
        }
        return s;
    }

    private static int _findClose(string t, int from) {
        int i = from;
        int n = t.Length;
        while (i < n) { if (t.CharAt(i) == '}') { return i; } i = i + 1; }
        return -1;
    }

    private static string _resolve(string name, TemplateContext ctx, string orig, int start, int close) {
        if (name == "workspace_dir") { return ctx.WorkspaceDir; }
        if (name == "member_dir")    { return ctx.MemberDir; }
        if (name == "member_name")   { return ctx.MemberName; }
        if (name == "project_name")  { return ctx.MemberName; }   // 别名（镜像 C# PathTemplateExpander）
        if (name == "profile")       { return ctx.Profile; }
        if (name == "output_dir")    { return ctx.OutputDir; }
        return orig.Substring(start, close + 1 - start);   // 未知变量：保留字面
    }
}
