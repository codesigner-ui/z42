// z42c.semantics SymbolCollector 单测（1A-3）：源 → parse → 符号表（类字段/方法签名 + 顶层 func）。
namespace Z42cSemanticsCollectTests;

using Std;
using Std.Test;
using Z42.Syntax;
using Z42.Semantics;

SymbolTable collect(string src) {
    var p = new Parser(src, "t.z42");
    var cu = p.ParseCompilationUnit();
    return new SymbolCollector().Collect(cu);
}

[Test]
void test_collect_class_members() {
    var table = collect("class Box { private int value; public int Get() { return value; } }");
    Assert.Equal(true, table.HasClass("Box"));
    var box = table.GetClass("Box");
    Assert.Equal(true, box.Fields.ContainsKey("value"));
    var f = box.Fields.Get("value") as FieldSymbol;
    Assert.Equal("int", f.FieldType.Name());
    Assert.Equal("private", f.Visibility);
    Assert.Equal(true, box.Methods.ContainsKey("Get"));
    var m = box.Methods.Get("Get") as MethodSymbol;
    Assert.Equal("()->int", m.Signature.Dump());
    Assert.Equal("public", m.Visibility);
}

[Test]
void test_collect_method_signature_and_static() {
    var table = collect("class Calc { public static int Add(int a, int b) { return a + b; } }");
    var calc = table.GetClass("Calc");
    var m = calc.Methods.Get("Add") as MethodSymbol;
    Assert.Equal("(int,int)->int", m.Signature.Dump());
    Assert.Equal(true, m.IsStatic);
    Assert.Equal("Calc", m.ContainingTypeName);
}

[Test]
void test_collect_top_level_func() {
    var table = collect("int Add(int a, int b) { return a + b; }");
    Assert.Equal(true, table.HasFunc("Add"));
    var m = table.GetFunc("Add");
    Assert.Equal("(int,int)->int", m.Signature.Dump());
}

[Test]
void test_resolve_class_field_type() {
    // 字段类型为兄弟类（两阶段 stub 保证可解析）
    var table = collect("class Node { } class List { private Node head; }");
    var list = table.GetClass("List");
    var f = list.Fields.Get("head") as FieldSymbol;
    Assert.Equal("Node", f.FieldType.Name());        // 解析到 Z42ClassType
}

// G18 回归：TSIG 继承成员展开（镜像 C# ct.Fields/ct.Methods merge=base∪own）。
// 此前 z42c 只导出自有成员 → 跨包对账 TSIG −598 + 方法序/flags 偏离；gate fixture 无
// base-virtual-override 故未暴露。守护字段继承（祖先在前）+ 方法合并（override 保留祖先位、
// 新方法追加）+ override→flags 0（去 virtual）。
[Test]
void test_tsig_inherited_fields_and_method_merge() {
    string src = "class Base { public int Tag; public virtual string Dump() { return \"b\"; } } "
               + "class Derived : Base { public int Extra; public Derived(int e) { Extra = e; } public override string Dump() { return \"d\"; } }";
    // Base：自有 Tag；方法 Object 四 + 自有 virtual Dump（v）。
    // Derived：继承 Tag 在前、自有 Extra 在后；方法 Object 四 + 继承位 Dump（override→无 v）+ 追加 ctor Derived。
    Assert.Equal(
        "Base(Object) F:[Tag:int] M:[ToString/v,Equals/v,GetHashCode/v,GetType,Dump/v]\n"
      + "Derived(Base) F:[Tag:int,Extra:int] M:[ToString/v,Equals/v,GetHashCode/v,GetType,Dump,Derived]",
        SemanticDump.DumpExports(src));
}

// G18d 回归：方法签名类型规范化（byte→u8 等），镜像 C# FuncToMethod TypeToString(resolved)；
// 字段仍用源拼写（byte[]）。`u8[]` 来自 byte[] 数组规范名，验证结构保留（数组）+ prim 规范。
[Test]
void test_tsig_method_signature_canonical_field_source() {
    string src = "class W { public byte[] data; public byte[] ToBytes(short n) { return data; } }";
    // 方法返回/参数 → 规范名（byte[]→u8[]，short→i16）；字段 → 源拼写（byte[]）。
    Assert.Equal("u8[]", SemanticDump.ExportMethodRet(src, "W", "ToBytes"));
    Assert.Equal("byte[]", SemanticDump.ExportFieldType(src, "W", "data"));
}

// G18d 回归：nullable 在方法签名规范名下结构保留（string? 不被 sig.Name() 擦除为 string）。
[Test]
void test_tsig_method_nullable_return_preserved() {
    string src = "class N { public string? Find(int k) { return null; } }";
    Assert.Equal("string?", SemanticDump.ExportMethodRet(src, "N", "Find"));
}

// G18g 回归：TYPE 段（IrClassDesc）字段类型源拼写（byte[]，非规范 u8[]）——同顶层 SIGS，
// 区别于 TSIG 方法签名规范名（G18d）。int[]（非次要别名）不变。
[Test]
void test_type_section_field_source_spelling() {
    string src = "class W { public byte[] data; public int[] nums; }";
    Assert.Equal("byte[]", SemanticDump.TypeFieldName(src, "W", "data"));
    Assert.Equal("int[]", SemanticDump.TypeFieldName(src, "W", "nums"));
}

// G18 回归：多级继承字段链（topmost 祖先字段最前）+ static 字段不参与继承合并。
[Test]
void test_tsig_multilevel_inheritance_and_static_field() {
    string src = "class A { public int a; } "
               + "class B : A { public int b; public static int counter; } "
               + "class C : B { public int c; }";
    // C 实例字段链：a(A) → b(B) → c(C)；B.counter 是 static 仅在 B 自身（不继承到 C）。
    Assert.Equal(
        "A(Object) F:[a:int] M:[ToString/v,Equals/v,GetHashCode/v,GetType]\n"
      + "B(A) F:[a:int,b:int,counter:int(s)] M:[ToString/v,Equals/v,GetHashCode/v,GetType]\n"
      + "C(B) F:[a:int,b:int,c:int] M:[ToString/v,Equals/v,GetHashCode/v,GetType]",
        SemanticDump.DumpExports(src));
}
