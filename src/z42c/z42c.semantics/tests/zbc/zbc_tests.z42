// z42c byte-identical .zbc writer 单测（port-z42c-zbc-writer ZW-1A..1D）。
// golden = src/tests/zbc-format/empty/source.zbc（C# z42c 对 `void Main(){}` 产出，zbc 1.14，247 字节）的小写 hex。
// 验证 z42c 自举 ZbcWriter 逐字节复刻 C# ZbcWriter（header/directory/全 8 section/intern 序/ret 终结符）。
// 指令级编码 = spec-derived hex（DBUG 阻塞使 C# 全文件 golden 限于 empty；端到端正确性由 xtask e2e 验证）。
namespace Z42cSemanticsZbcTests;

using Std;
using Std.Test;
using Z42.Semantics;
using Z42.IR;
using Z42.IR.BinaryFormat;

// 空 allocator（无本模块函数/类 → 全 import token）。
TokenAllocator _emptyAlloc() {
    return new TokenAllocator(new string[0], 0, new string[0], 0);
}

[Test]
void test_zbc_empty_byte_identical() {
    // void Main(){} → 8 section 最小完整文件（NSPC/STRS/TYPE/SIGS/IMPT/EXPT/FUNC/REGT）。
    // 池序 main/?/Main/void/entry；SIGS 含 zbc 1.11 attrCount=0（1.12 TYPE flags 字节仅含类时出现，empty 无类）；FUNC entry 块仅 ret(42 00 ffff)。
    string src = "void Main() { }";
    string golden = "";
    Assert.Equal(golden, IrDump.DumpZbcHex(src));
}

// ── ZW-1B：比较/位/一元/throw ─────────────────────────────────────────────────────

[Test]
void test_zbc_instr_compare_and_binary() {
    var pool = new ZbcStringPool();
    // eq %2(bool), %0, %1 → op 0x30 + dst-tag bool(01) + dst 0200 + a 0000 + b 0100
    var w1 = new ByteWriter();
    ZbcInstr.WriteInstr(w1, new EqInstr(new TypedReg(2, IrType.Bool), new TypedReg(0, IrType.I32), new TypedReg(1, IrType.I32)),
                        pool, new int[1], _emptyAlloc());
    Assert.Equal("3001020000000100", w1.ToHex());
    // bit_and %2(i32), %0, %1 → op 0x19 + tag i32(04)
    var w2 = new ByteWriter();
    ZbcInstr.WriteInstr(w2, new BitAndInstr(new TypedReg(2, IrType.I32), new TypedReg(0, IrType.I32), new TypedReg(1, IrType.I32)),
                        pool, new int[1], _emptyAlloc());
    Assert.Equal("1904020000000100", w2.ToHex());
}

[Test]
void test_zbc_instr_unary_and_throw() {
    var pool = new ZbcStringPool();
    // neg %1(i32), %0 → op 0x15 + tag 04 + dst 0100 + src 0000
    var w1 = new ByteWriter();
    ZbcInstr.WriteInstr(w1, new NegInstr(new TypedReg(1, IrType.I32), new TypedReg(0, IrType.I32)),
                        pool, new int[1], _emptyAlloc());
    Assert.Equal("150401000000", w1.ToHex());
    // throw %3(ref) → op 0x44 + tag object(20) + reg 0300
    var w2 = new ByteWriter();
    ZbcInstr.WriteTerm(w2, new ThrowTerm(new TypedReg(3, IrType.Ref)), new string[0], 0);
    Assert.Equal("44200300", w2.ToHex());
}

// ── ZW-1C/1D：调用/字段/对象 ─────────────────────────────────────────────────────

[Test]
void test_zbc_call_token_encoding() {
    // call @Helper() → op 0x50 + tag + dst + u32 token（本模块函数 → 插入序 index）+ argc
    var pool = new ZbcStringPool();
    string[] fns = new string[2];
    fns[0] = "Main"; fns[1] = "Helper";
    var alloc = new TokenAllocator(fns, 2, new string[0], 0);
    var w = new ByteWriter();
    ZbcInstr.WriteInstr(w, new CallInstr(new TypedReg(0, IrType.I32), "Helper", new TypedReg[0], 0),
                        pool, new int[1], alloc);
    Assert.Equal("500400000100000000", w.ToHex());   // 50 04 0000 | token=1 LE | argc=0
}

[Test]
void test_zbc_field_get_encoding() {
    // field_get %1 = %0.v → op 0x60 + tag + dst + obj + u32 pool idx（VCall/Field 不 token 化）
    var pool = new ZbcStringPool();
    pool.Intern("v");
    var w = new ByteWriter();
    ZbcInstr.WriteInstr(w, new FieldGetInstr(new TypedReg(1, IrType.I32), new TypedReg(0, IrType.Ref), "v"),
                        pool, new int[1], _emptyAlloc());
    Assert.Equal("60040100000000000000", w.ToHex());   // 60 04 0100 | obj=0000 | idx=0
}

[Test]
void test_zbc_objnew_ctorless_import_token() {
    // new Counter()（无显式 ctor）→ class token = 本模块 index 0；ctor "Counter.Counter" 非本模块函数
    // → IMPORT_BASE|STRS idx（VM 查无此函数即跳过 ctor = 默认无参语义）
    var pool = new ZbcStringPool();
    pool.Intern("Counter");            // idx 0
    pool.Intern("Counter.Counter");    // idx 1
    string[] cls = new string[1];
    cls[0] = "Counter";
    var alloc = new TokenAllocator(new string[0], 0, cls, 1);
    var w = new ByteWriter();
    ZbcInstr.WriteInstr(w, new ObjNewInstr(new TypedReg(0, IrType.Ref), "Counter",
                        new string[0], 0, new TypedReg[0], 0), pool, new int[1], alloc);
    // 70 20 0000 | class=00000000 | ctor=0x80000001 LE=01000080 | argc=00 | tpCount=00
    Assert.Equal("7020000000000000010000800000", w.ToHex());
}

[Test]
void test_zbc_const_f64_encoding() {
    // const.f64 1.5 → op 0x01 + tag f64(0b) + dst + IEEE754 bits LE（1.5 = 0x3FF8000000000000）
    var pool = new ZbcStringPool();
    var w = new ByteWriter();
    ZbcInstr.WriteInstr(w, new ConstF64Instr(new TypedReg(0, IrType.F64), "1.5"),
                        pool, new int[1], _emptyAlloc());
    Assert.Equal("010b0000000000000000f83f", w.ToHex());
    // 后缀剥离：1.5f → float tag(0a)，bits 仍按 double 写（镜像 C# ConstF64Instr.Val 恒 8 字节）
    var w2 = new ByteWriter();
    ZbcInstr.WriteInstr(w2, new ConstF64Instr(new TypedReg(1, IrType.F32), "1.5f"),
                        pool, new int[1], _emptyAlloc());
    Assert.Equal("010a0100000000000000f83f", w2.ToHex());
}

[Test]
void test_zbc_selfcheck_program_header() {
    // e2e 自检程序（mul/add/le/eq/while/if/div）写出不应损坏：header = magic+1.14+flags0
    string src = "int Main() { int x = 6 * 7; int ok = 0; if (x == 42) { ok = 1; } return 100 / ok; }";
    string hex = IrDump.DumpZbcHex(src);
    Assert.Equal("5a42430001000e000000", hex.Substring(0, 20));
}
