// z42c.semantics TypeChecker 单测（1A-4b）：源 → bound s-expr（含类型注解）+ 错误用例诊断计数。
namespace Z42cSemanticsTypeCheckTests;

using Std;
using Std.Test;
using Z42.Semantics;

[Test]
void test_bind_var_infer_and_return() {
    // var 推断 + 标识符解析 + return 类型检查
    string src = "class C { int Get() { var x = 5; return x; } }";
    Assert.Equal("(block (decl x :int (lit-int 5 :int)) (return (ident x :int)))",
                 SemanticDump.DumpBody(src, "C.Get"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_explicit_type_and_assign() {
    string src = "class C { void M() { int n = 3; n = 7; } }";
    Assert.Equal("(block (decl n :int (lit-int 3 :int)) (expr (assign (ident n :int) (lit-int 7 :int) :int)))",
                 SemanticDump.DumpBody(src, "C.M"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_field_in_scope() {
    // 实例方法可见字段（this 上下文）
    string src = "class Box { int value; int Get() { return value; } }";
    Assert.Equal("(block (return (ident value :int)))", SemanticDump.DumpBody(src, "Box.Get"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_free_func_call() {
    string src = "int Helper() { return 1; } int Main() { return Helper(); }";
    Assert.Equal("(block (return (call Helper :int)))", SemanticDump.DumpBody(src, "Main"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_error_return_type_mismatch() {
    string src = "class C { int Bad() { return \"hi\"; } }";   // string 不可赋给 int
    Assert.Equal(1, SemanticDump.ErrorCount(src));
}

[Test]
void test_error_undefined_ident() {
    string src = "class C { int M() { return missing; } }";   // 未定义标识符（error 吸收，仅 1 条）
    Assert.Equal(1, SemanticDump.ErrorCount(src));
}

[Test]
void test_error_undefined_func() {
    string src = "class C { int M() { return Nope(); } }";    // 未声明函数
    Assert.Equal(1, SemanticDump.ErrorCount(src));
}

// ── 1B：运算 + 控制流端到端 ──────────────────────────────────────────────────────

[Test]
void test_arithmetic() {
    string src = "class C { int Add(int a, int b) { return a + b; } }";
    Assert.Equal("(block (return (bin + (ident a :int) (ident b :int) :int)))",
                 SemanticDump.DumpBody(src, "C.Add"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_numeric_widening() {
    // double / int → double（拓宽表）；double 可赋给 double 返回
    string src = "class C { double Half(double d) { return d / 2; } }";
    Assert.Equal("(block (return (bin / (ident d :double) (lit-int 2 :int) :double)))",
                 SemanticDump.DumpBody(src, "C.Half"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_comparison_yields_bool() {
    string src = "class C { bool Lt(int a, int b) { return a < b; } }";
    Assert.Equal("(block (return (bin < (ident a :int) (ident b :int) :bool)))",
                 SemanticDump.DumpBody(src, "C.Lt"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_logical_and_bitwise() {
    string and = "class C { bool A(bool x, bool y) { return x && y; } }";
    Assert.Equal("(block (return (bin && (ident x :bool) (ident y :bool) :bool)))",
                 SemanticDump.DumpBody(and, "C.A"));
    Assert.Equal(0, SemanticDump.ErrorCount(and));
    string bits = "class C { int O(int a, int b) { return a | b; } }";
    Assert.Equal("(block (return (bin | (ident a :int) (ident b :int) :int)))",
                 SemanticDump.DumpBody(bits, "C.O"));
    Assert.Equal(0, SemanticDump.ErrorCount(bits));
}

[Test]
void test_unary() {
    string neg = "class C { int N(int x) { return -x; } }";
    Assert.Equal("(block (return (unary - (ident x :int) :int)))",
                 SemanticDump.DumpBody(neg, "C.N"));
    Assert.Equal(0, SemanticDump.ErrorCount(neg));
    string not = "class C { bool F(bool b) { return !b; } }";
    Assert.Equal("(block (return (unary ! (ident b :bool) :bool)))",
                 SemanticDump.DumpBody(not, "C.F"));
    Assert.Equal(0, SemanticDump.ErrorCount(not));
}

[Test]
void test_if_while_break_continue() {
    string src = "class C { void Run(int n) { while (n < 3) { if (n == 0) { break; } continue; } } }";
    Assert.Equal(
        "(block (while (bin < (ident n :int) (lit-int 3 :int) :bool) (block (if (bin == (ident n :int) (lit-int 0 :int) :bool) (block (break))) (continue))))",
        SemanticDump.DumpBody(src, "C.Run"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_error_operator_type_mismatch() {
    // string - int：`-` 要求 numeric 操作数，左 string 不符
    string src = "class C { int Bad(string s) { return s - 1; } }";
    Assert.Equal(1, SemanticDump.ErrorCount(src));
}

[Test]
void test_error_non_bool_condition() {
    // if 条件须 bool，int 不符
    string src = "class C { void M(int n) { if (n) { } } }";
    Assert.Equal(1, SemanticDump.ErrorCount(src));
}

[Test]
void test_error_break_outside_loop() {
    string src = "class C { void M() { break; } }";
    Assert.Equal(1, SemanticDump.ErrorCount(src));
}

// ── 1C-1：成员字段访问 + 继承 ──────────────────────────────────────────────
[Test]
void test_member_field_access() {
    string src = "class Box { int value; int Get() { return this.value; } }";
    Assert.Equal("(block (return (member (ident this :Box) value :int)))",
                 SemanticDump.DumpBody(src, "Box.Get"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_inherited_field_access() {
    // this.x 来自 Base（继承字段，走 base 链查找）
    string src = "class Base { int x; } class Derived : Base { int y; int Sum() { return this.x + this.y; } }";
    Assert.Equal("(block (return (bin + (member (ident this :Derived) x :int) (member (ident this :Derived) y :int) :int)))",
                 SemanticDump.DumpBody(src, "Derived.Sum"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_subclass_assignable_to_base() {
    // return Derived 给 Base 形参 → subclass→base 可赋（IsSubclassOf）
    string src = "class Base { } class Derived : Base { } class C { Base Pick(Derived d) { return d; } }";
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_unrelated_class_not_assignable() {
    string src = "class A { } class B { } class C { A Bad(B b) { return b; } }";
    Assert.Equal(1, SemanticDump.ErrorCount(src));   // B 不是 A 的子类
}

[Test]
void test_field_not_found_error() {
    string src = "class Box { int value; int M() { return this.missing; } }";
    Assert.Equal(1, SemanticDump.ErrorCount(src));   // no field missing
}

// ── 1C-2：实例 + 静态方法调用 ──────────────────────────────────────────────
[Test]
void test_instance_method_call() {
    // this.Helper() 实例调用（同类方法，base 链查找）
    string src = "class C { int Helper() { return 1; } int Use() { return this.Helper(); } }";
    Assert.Equal("(block (return (call-inst (ident this :C) Helper :int)))",
                 SemanticDump.DumpBody(src, "C.Use"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_instance_call_on_param() {
    string src = "class Box { int Get() { return 7; } } class C { int Read(Box b) { return b.Get(); } }";
    Assert.Equal("(block (return (call-inst (ident b :Box) Get :int)))",
                 SemanticDump.DumpBody(src, "C.Read"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_static_method_call() {
    // Math.Square(...) 静态调用（裸类名 target）
    string src = "class Math { static int Square(int n) { return n; } } class C { int Use() { return Math.Square(4); } }";
    Assert.Equal("(block (return (call-static Math Square (lit-int 4 :int) :int)))",
                 SemanticDump.DumpBody(src, "C.Use"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_inherited_method_call() {
    // 继承方法调用（this.BaseM() 在 Base 定义）
    string src = "class Base { int BaseM() { return 0; } } class Derived : Base { int Use() { return this.BaseM(); } }";
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_error_no_such_method() {
    string src = "class Box { } class C { int M(Box b) { return b.Nope(); } }";
    Assert.Equal(1, SemanticDump.ErrorCount(src));   // no method Nope on Box
}

// ── 1D-1：is / as / new ────────────────────────────────────────────────────
[Test]
void test_is_expr() {
    string src = "class C { bool Check(object o) { return o is C; } }";
    Assert.Equal("(block (return (is (ident o :object) C :bool)))", SemanticDump.DumpBody(src, "C.Check"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_as_cast() {
    string src = "class Base { } class Derived : Base { } class C { Derived Down(Base b) { return b as Derived; } }";
    Assert.Equal("(block (return (cast (ident b :Base) :Derived)))", SemanticDump.DumpBody(src, "C.Down"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_new_no_args() {
    string src = "class Box { } class C { Box Make() { return new Box(); } }";
    Assert.Equal("(block (return (new Box :Box)))", SemanticDump.DumpBody(src, "C.Make"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_new_with_args() {
    string src = "class Point { } class C { Point Make() { return new Point(1, 2); } }";
    Assert.Equal("(block (return (new Point (lit-int 1 :int) (lit-int 2 :int) :Point)))", SemanticDump.DumpBody(src, "C.Make"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_new_unknown_type_error() {
    string src = "class C { object Make() { return new Nonexistent(); } }";
    Assert.Equal(1, SemanticDump.ErrorCount(src));   // 未知类型
}

// ── 1D-2：数组类型 + 索引 ──────────────────────────────────────────────────
[Test]
void test_array_index() {
    string src = "class C { int First(int[] xs) { return xs[0]; } }";
    Assert.Equal("(block (return (index (ident xs :int[]) (lit-int 0 :int) :int)))",
                 SemanticDump.DumpBody(src, "C.First"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_array_type_assign() {
    // int[] 字段 + 同型赋值（数组类型不变性）
    string src = "class C { void M(int[] a) { int[] b = a; } }";
    Assert.Equal("(block (decl b :int[] (ident a :int[])))", SemanticDump.DumpBody(src, "C.M"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_index_on_non_array_error() {
    string src = "class C { int M(int x) { return x[0]; } }";
    Assert.Equal(1, SemanticDump.ErrorCount(src));   // int 不是数组
}

// ── 1E：三目 + ?? ──────────────────────────────────────────────────────────
[Test]
void test_ternary() {
    string src = "class C { int Max(int a, int b) { return a > b ? a : b; } }";
    Assert.Equal("(block (return (cond (bin > (ident a :int) (ident b :int) :bool) (ident a :int) (ident b :int) :int)))",
                 SemanticDump.DumpBody(src, "C.Max"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_ternary_widen_branches() {
    // 分支 int / double → double（公共类型取较宽）
    string src = "class C { double Pick(bool f, int a, double b) { return f ? a : b; } }";
    Assert.Equal("(block (return (cond (ident f :bool) (ident a :int) (ident b :double) :double)))",
                 SemanticDump.DumpBody(src, "C.Pick"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_null_coalesce() {
    string src = "class C { string Pick(string a, string b) { return a ?? b; } }";
    Assert.Equal("(block (return (bin ?? (ident a :string) (ident b :string) :string)))",
                 SemanticDump.DumpBody(src, "C.Pick"));
    Assert.Equal(0, SemanticDump.ErrorCount(src));
}

[Test]
void test_ternary_non_bool_cond_error() {
    string src = "class C { int M(int x) { return x ? 1 : 2; } }";   // x 非 bool 条件
    Assert.Equal(1, SemanticDump.ErrorCount(src));
}
