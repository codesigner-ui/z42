// z42c.semantics Z42Type 单测（1A-1）：赋值兼容（数值拓宽 / error 吸收 / class·void）。
namespace Z42cSemanticsTypeTests;

using Std;
using Std.Test;
using Z42.Semantics;

[Test]
void test_prim_widening() {
    var i = new Z42PrimType("int");
    var l = new Z42PrimType("long");
    var d = new Z42PrimType("double");
    var s = new Z42PrimType("string");
    Assert.Equal("int", i.Name());
    Assert.Equal(true,  i.IsAssignableTo(i));    // 同型
    Assert.Equal(true,  i.IsAssignableTo(l));    // int→long 拓宽
    Assert.Equal(true,  i.IsAssignableTo(d));    // int→double
    Assert.Equal(false, l.IsAssignableTo(i));    // long→int 收窄 ✗
    Assert.Equal(false, i.IsAssignableTo(s));    // int→string ✗
}

[Test]
void test_error_absorbs() {
    var i = new Z42PrimType("int");
    var err = new Z42ErrorType();
    Assert.Equal(true, i.IsAssignableTo(err));   // 任何 → error（不级联报错）
    Assert.Equal(true, err.IsAssignableTo(i));   // error → 任何
}

[Test]
void test_class_and_void() {
    var foo = new Z42ClassType("Foo", false, "");
    var bar = new Z42ClassType("Bar", true, "Foo");
    Assert.Equal("Foo", foo.Name());
    Assert.Equal(true,  foo.IsAssignableTo(foo));  // 同名
    Assert.Equal(false, bar.IsAssignableTo(foo));  // 继承赋值留 1C（1A-1 仅同名）
    var v = new Z42VoidType();
    Assert.Equal("void", v.Name());
    Assert.Equal(false, v.IsAssignableTo(foo));
    Assert.Equal(true,  v.IsAssignableTo(v));
}

[Test]
void test_func_type_and_symbols() {
    var i = new Z42PrimType("int");
    var ps = new Z42Type[2]; ps[0] = i; ps[1] = i;
    var sig = new Z42FuncType(ps, 2, i);           // (int,int)->int
    Assert.Equal("(int,int)->int", sig.Dump());
    var m = new MethodSymbol("Add", "public", sig, false, "Calc", false, null);
    Assert.Equal("Add", m.Name);
    Assert.Equal("(method Add (int,int)->int)", m.Dump());
    var f = new FieldSymbol("count", "private", i, false, "Calc");
    Assert.Equal("int", f.FieldType.Name());
    Assert.Equal("(field count int)", f.Dump());
}

[Test]
void test_class_members() {
    var i = new Z42PrimType("int");
    var c = new Z42ClassType("Box", false, "");
    c.Fields.Put("value", new FieldSymbol("value", "public", i, false, "Box"));
    Assert.Equal(true, c.Fields.ContainsKey("value"));
    var f = c.Fields.Get("value") as FieldSymbol;   // object → 下行
    Assert.Equal("int", f.FieldType.Name());
}
