// z42c.semantics codegen 单测（port-z42c-codegen CG-1A）：源 → typecheck → IrGen → .zasm-like IR 文本断言。
namespace Z42cSemanticsCodegenTests;

using Std;
using Std.Test;
using Z42.Semantics;

[Test]
void test_return_int_literal() {
    string src = "int F() { return 5; }";
    Assert.Equal("fn @F(0) -> int {\nentry:\n  %0 = const.i64 5\n  ret %0\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_binary_add_instance_method() {
    // 实例方法：this=%0，a=%1，b=%2；ParamCount 含 this = 3
    string src = "class C { int Add(int a, int b) { return a + b; } }";
    Assert.Equal("fn @C.Add(3) -> int {\nentry:\n  %3 = add i32 %1, %2\n  ret %3\n}",
                 IrDump.DumpFunc(src, "C.Add"));
}

[Test]
void test_var_decl_and_assign() {
    // var x = 1; x = x + 2; return x; —— 赋值回写 copy 进 x 的寄存器（SSA-lite）
    string src = "int F() { var x = 1; x = x + 2; return x; }";
    Assert.Equal("fn @F(0) -> int {\nentry:\n  %0 = const.i64 1\n  %1 = copy %0\n  %2 = const.i64 2\n  %3 = add i32 %1, %2\n  %1 = copy %3\n  ret %1\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_double_literal() {
    string src = "double F() { return 1.5; }";
    Assert.Equal("fn @F(0) -> double {\nentry:\n  %0 = const.f64 1.5\n  ret %0\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_bool_literal() {
    string src = "bool F() { return true; }";
    Assert.Equal("fn @F(0) -> bool {\nentry:\n  %0 = const.bool true\n  ret %0\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_string_literal() {
    // 字符串入池（1-based）；const.str 引用池索引
    string src = "string F() { return \"hi\"; }";
    Assert.Equal("fn @F(0) -> string {\nentry:\n  %0 = const.str #1\n  ret %0\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_void_implicit_ret() {
    // void 方法无显式 return → entry 块以隐式 ret 终结
    string src = "void F() { }";
    Assert.Equal("fn @F(0) -> void {\nentry:\n  ret\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_module_dump() {
    // 模块名 = 根命名空间（无 → "main"，对齐 C# `cu.Namespace ?? "main"`）
    string src = "int F() { return 5; }";
    Assert.Equal("module \"main\"\n\nfn @F(0) -> int {\nentry:\n  %0 = const.i64 5\n  ret %0\n}",
                 IrDump.DumpModule(src));
}

// ── CG-1B：控制流 if/while/break/continue → 多基本块 ──────────────────────────────

[Test]
void test_if_then_return() {
    // if 无 else：cond 块 br.cond → then / 汇合 end（end 可达，承接后续 return）
    string src = "int F(bool c) { if (c) { return 1; } return 2; }";
    Assert.Equal("fn @F(1) -> int {\nentry:\n  br.cond %0, then_0, end_1\nthen_0:\n  %1 = const.i64 1\n  ret %1\nend_1:\n  %2 = const.i64 2\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_if_else_merge() {
    // if/else 两分支写 x，汇合 end 块读 x
    string src = "int F(bool c) { int x = 0; if (c) { x = 1; } else { x = 2; } return x; }";
    Assert.Equal("fn @F(1) -> int {\nentry:\n  %1 = const.i64 0\n  %2 = copy %1\n  br.cond %0, then_0, else_1\nthen_0:\n  %3 = const.i64 1\n  %2 = copy %3\n  br end_2\nelse_1:\n  %4 = const.i64 2\n  %2 = copy %4\n  br end_2\nend_2:\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_while_break() {
    // while：entry→cond，cond br.cond→body/end；break→end
    string src = "void F(bool c) { while (c) { break; } }";
    Assert.Equal("fn @F(1) -> void {\nentry:\n  br cond_0\ncond_0:\n  br.cond %0, body_1, end_2\nbody_1:\n  br end_2\nend_2:\n  ret\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_while_continue() {
    // continue→cond（回边）
    string src = "void F(bool c) { while (c) { continue; } }";
    Assert.Equal("fn @F(1) -> void {\nentry:\n  br cond_0\ncond_0:\n  br.cond %0, body_1, end_2\nbody_1:\n  br cond_0\nend_2:\n  ret\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_body_assign() {
    // body 非空，末尾回边 br cond
    string src = "int F(bool c) { int x = 0; while (c) { x = 1; } return x; }";
    Assert.Equal("fn @F(1) -> int {\nentry:\n  %1 = const.i64 0\n  %2 = copy %1\n  br cond_0\ncond_0:\n  br.cond %0, body_1, end_2\nbody_1:\n  %3 = const.i64 1\n  %2 = copy %3\n  br cond_0\nend_2:\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

// ── CG-1C：方法调用 + 字段 get/set + this + 继承分派 ──────────────────────────────

[Test]
void test_field_read_this() {
    // this.v → field_get on reg0
    string src = "class C { int v; int Get() { return this.v; } }";
    Assert.Equal("fn @C.Get(1) -> int {\nentry:\n  %1 = field_get %0.v\n  ret %1\n}",
                 IrDump.DumpFunc(src, "C.Get"));
}

[Test]
void test_field_read_bare() {
    // 裸字段 ident（typechecker 把自身字段入 scope）→ 同 field_get on reg0
    string src = "class C { int v; int Get() { return v; } }";
    Assert.Equal("fn @C.Get(1) -> int {\nentry:\n  %1 = field_get %0.v\n  ret %1\n}",
                 IrDump.DumpFunc(src, "C.Get"));
}

[Test]
void test_field_write() {
    // 裸字段赋值 → field_set on reg0
    string src = "class C { int v; void Set(int x) { v = x; } }";
    Assert.Equal("fn @C.Set(2) -> void {\nentry:\n  field_set %0.v, %1\n  ret\n}",
                 IrDump.DumpFunc(src, "C.Set"));
}

[Test]
void test_free_call() {
    string src = "int Helper() { return 7; } int Main() { return Helper(); }";
    Assert.Equal("fn @Main(0) -> int {\nentry:\n  %0 = call @Helper()\n  ret %0\n}",
                 IrDump.DumpFunc(src, "Main"));
}

[Test]
void test_free_call_args() {
    string src = "int Add(int a, int b) { return a + b; } int Main() { return Add(1, 2); }";
    Assert.Equal("fn @Main(0) -> int {\nentry:\n  %0 = const.i64 1\n  %1 = const.i64 2\n  %2 = call @Add(%0, %1)\n  ret %2\n}",
                 IrDump.DumpFunc(src, "Main"));
}

[Test]
void test_instance_call() {
    // this.Compute() → vcall（虚分派）
    string src = "class C { int Compute() { return 1; } int Get() { return this.Compute(); } }";
    Assert.Equal("fn @C.Get(1) -> int {\nentry:\n  %1 = vcall %0.Compute()\n  ret %1\n}",
                 IrDump.DumpFunc(src, "C.Get"));
}

[Test]
void test_static_call() {
    // C.Make() 静态 → 直接 call @C.Make
    string src = "class C { static int Make() { return 5; } int Use() { return C.Make(); } }";
    Assert.Equal("fn @C.Use(1) -> int {\nentry:\n  %1 = call @C.Make()\n  ret %1\n}",
                 IrDump.DumpFunc(src, "C.Use"));
}

// ── CG-1D：new / 数组索引 / is / as ──────────────────────────────────────────────

[Test]
void test_new() {
    string src = "class C { } class D { C Make() { return new C(); } }";
    Assert.Equal("fn @D.Make(1) -> C {\nentry:\n  %1 = obj_new C()\n  ret %1\n}",
                 IrDump.DumpFunc(src, "D.Make"));
}

[Test]
void test_new_args() {
    string src = "class P { } class D { P Make() { return new P(1, 2); } }";
    Assert.Equal("fn @D.Make(1) -> P {\nentry:\n  %1 = const.i64 1\n  %2 = const.i64 2\n  %3 = obj_new P(%1, %2)\n  ret %3\n}",
                 IrDump.DumpFunc(src, "D.Make"));
}

[Test]
void test_array_get() {
    string src = "class C { int First(int[] xs) { return xs[0]; } }";
    Assert.Equal("fn @C.First(2) -> int {\nentry:\n  %2 = const.i64 0\n  %3 = array_get %1[%2]\n  ret %3\n}",
                 IrDump.DumpFunc(src, "C.First"));
}

[Test]
void test_array_set() {
    string src = "class C { void Set(int[] xs, int v) { xs[0] = v; } }";
    Assert.Equal("fn @C.Set(3) -> void {\nentry:\n  %3 = const.i64 0\n  array_set %1[%3], %2\n  ret\n}",
                 IrDump.DumpFunc(src, "C.Set"));
}

[Test]
void test_is_instance() {
    string src = "class A { } class C { bool Check(A a) { return a is A; } }";
    Assert.Equal("fn @C.Check(2) -> bool {\nentry:\n  %2 = is_instance %1, A\n  ret %2\n}",
                 IrDump.DumpFunc(src, "C.Check"));
}

[Test]
void test_as_cast() {
    string src = "class A { } class B : A { } class C { B Down(A a) { return a as B; } }";
    Assert.Equal("fn @C.Down(2) -> B {\nentry:\n  %2 = as_cast %1, B\n  ret %2\n}",
                 IrDump.DumpFunc(src, "C.Down"));
}

// ── CG-1E：比较 / 位 / 一元 / 字符串拼接（逻辑短路 && || 三目 ?? → CG-1E-2）─────────────

[Test]
void test_comparison() {
    // a < b → lt（结果 bool；操作数类型 i32）
    string src = "bool F(int a, int b) { return a < b; }";
    Assert.Equal("fn @F(2) -> bool {\nentry:\n  %2 = lt i32 %0, %1\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_bitwise_and() {
    string src = "int F(int a, int b) { return a & b; }";
    Assert.Equal("fn @F(2) -> int {\nentry:\n  %2 = bit_and i32 %0, %1\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_unary_neg() {
    string src = "int F(int a) { return -a; }";
    Assert.Equal("fn @F(1) -> int {\nentry:\n  %1 = neg i32 %0\n  ret %1\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_unary_not() {
    string src = "bool F(bool b) { return !b; }";
    Assert.Equal("fn @F(1) -> bool {\nentry:\n  %1 = not %0\n  ret %1\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_string_concat() {
    // a + b（string）→ add tag=str（C# 字节实证）
    string src = "string F(string a, string b) { return a + b; }";
    Assert.Equal("fn @F(2) -> string {\nentry:\n  %2 = add str %0, %1\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_loop_with_comparison() {
    // 真实循环：while (i < n) { i = i + 1; } —— 比较条件 + 回边
    string src = "int F(int n) { int i = 0; while (i < n) { i = i + 1; } return i; }";
    Assert.Equal("fn @F(1) -> int {\nentry:\n  %1 = const.i64 0\n  %2 = copy %1\n  br cond_0\ncond_0:\n  %3 = lt i32 %2, %0\n  br.cond %3, body_1, end_2\nbody_1:\n  %4 = const.i64 1\n  %5 = add i32 %2, %4\n  %2 = copy %5\n  br cond_0\nend_2:\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

// ── CG-1E-2：块化表达式（短路 && || / 三目 ?: / ??）──────────────────────────────

[Test]
void test_ternary() {
    // c ? a : b → 结果寄存器两分支各 copy
    string src = "int F(bool c, int a, int b) { return c ? a : b; }";
    Assert.Equal("fn @F(3) -> int {\nentry:\n  br.cond %0, tern_then_0, tern_else_1\ntern_then_0:\n  %3 = copy %1\n  br tern_end_2\ntern_else_1:\n  %3 = copy %2\n  br tern_end_2\ntern_end_2:\n  ret %3\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_logical_and() {
    // a && b：a 假 → false（不求 b）
    string src = "bool F(bool a, bool b) { return a && b; }";
    Assert.Equal("fn @F(2) -> bool {\nentry:\n  br.cond %0, and_rhs_0, and_short_1\nand_rhs_0:\n  %2 = copy %1\n  br and_end_2\nand_short_1:\n  %3 = const.bool false\n  %2 = copy %3\n  br and_end_2\nand_end_2:\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_logical_or() {
    // a || b：a 真 → true（不求 b）
    string src = "bool F(bool a, bool b) { return a || b; }";
    Assert.Equal("fn @F(2) -> bool {\nentry:\n  br.cond %0, or_short_1, or_rhs_0\nor_rhs_0:\n  %2 = copy %1\n  br or_end_2\nor_short_1:\n  %3 = const.bool true\n  %2 = copy %3\n  br or_end_2\nor_end_2:\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

[Test]
void test_null_coalesce() {
    // a ?? b：a==null → b，否则 a
    string src = "string F(string a, string b) { return a ?? b; }";
    Assert.Equal("fn @F(2) -> string {\nentry:\n  %2 = const.null\n  %3 = eq str %0, %2\n  br.cond %3, nc_null_0, nc_end_1\nnc_end_1:\n  %4 = copy %0\n  br nc_after_2\nnc_null_0:\n  %4 = copy %1\n  br nc_after_2\nnc_after_2:\n  ret %4\n}",
                 IrDump.DumpFunc(src, "F"));
}

// ── CG-2：泛型（obj_new 携 resolved type-args + 泛型方法签名类型解析）─────────────────

[Test]
void test_new_generic() {
    // new Box<int>() → obj_new Box<int>（class "Box" + type-args ["int"]）
    string src = "class Box<T> { } class C { Box<int> Make() { return new Box<int>(); } }";
    Assert.Equal("fn @C.Make(1) -> Box<int> {\nentry:\n  %1 = obj_new Box<int>()\n  ret %1\n}",
                 IrDump.DumpFunc(src, "C.Make"));
}

[Test]
void test_new_generic_multi() {
    string src = "class Pair<K, V> { } class C { Pair<int, string> Make() { return new Pair<int, string>(); } }";
    Assert.Equal("fn @C.Make(1) -> Pair<int,string> {\nentry:\n  %1 = obj_new Pair<int,string>()\n  ret %1\n}",
                 IrDump.DumpFunc(src, "C.Make"));
}

[Test]
void test_generic_method_return() {
    // 泛型类方法返回 T：签名 -> T（ResolveTypeP 带类型参 scope），体 field_get（T → ref）
    string src = "class Box<T> { T v; T Get() { return this.v; } }";
    Assert.Equal("fn @Box.Get(1) -> T {\nentry:\n  %1 = field_get %0.v\n  ret %1\n}",
                 IrDump.DumpFunc(src, "Box.Get"));
}

[Test]
void test_generic_method_param() {
    // T 形参 + T 返回 → 签名两处皆 T；T 形参寄存器为 ref
    string src = "class Box<T> { T Echo(T x) { return x; } }";
    Assert.Equal("fn @Box.Echo(2) -> T {\nentry:\n  ret %1\n}",
                 IrDump.DumpFunc(src, "Box.Echo"));
}

// ── char（port-z42c-char）────────────────────────────────────────────────────
[Test]
void test_char_const() {
    string src = "char F() { return 'x'; }";
    Assert.Equal("fn @F(0) -> char {\nentry:\n  %0 = const.char x\n  ret %0\n}",
                 IrDump.DumpFunc(src, "F"));
}

// ── try/throw（port-z42c-try）────────────────────────────────────────────────
[Test]
void test_throw_lowering() {
    string src = "class E { } class C { void M() { throw new E(); } }";
    Assert.Equal("fn @C.M(1) -> void {\nentry:\n  %1 = obj_new E()\n  throw %1\n}",
                 IrDump.DumpFunc(src, "C.M"));
}

// ── lambda（port-z42c-closures）─────────────────────────────────────────────
[Test]
void test_lambda_lift_loadfn() {
    // 无捕获 → lift + load_fn；lift 函数追加在模块尾
    string src = "int Use() { Func<int, int> f = x => x + 1; return f(1); }";
    Assert.Equal("fn @Use(0) -> int {\nentry:\n  %0 = load_fn @Use__lambda_0\n  %1 = copy %0\n  %2 = const.i64 1\n  %3 = call_ind %1(%2)\n  ret %3\n}",
                 IrDump.DumpFunc(src, "Use"));
}

// ── arr.Length（port-z42c-package-symbols PS-2）──────────────────────────────
[Test]
void test_array_len_lowering() {
    string src = "class C { int M(int[] xs) { return xs.Length; } }";
    Assert.Equal("fn @C.M(2) -> int {\nentry:\n  %2 = field_get %1.Length\n  ret %2\n}",
                 IrDump.DumpFunc(src, "C.M"));
}

// ── C 风格强制转换 (T)x → ConvertInstr（port-z42c-self-compile G3）──────────────
[Test]
void test_cstyle_cast_convert() {
    // (int)v：long→int 跨类型 → convert i32（identity/Unknown/Ref no-op，镜像 C# VisitCast）
    string src = "int F() { long v = 255; return (int)v; }";
    Assert.Equal("fn @F(0) -> int {\nentry:\n  %0 = const.i64 255\n  %1 = copy %0\n  %2 = convert i32 %1\n  ret %2\n}",
                 IrDump.DumpFunc(src, "F"));
}

// ── 无初始化器局部声明（port-z42c-self-compile G8）─────────────────────────────
[Test]
void test_var_decl_no_init() {
    // `int x;` 不发 IR；`x = 5` 首次赋值**分配专用寄存器 + copy**（镜像 C# WriteBackName：
    // 首赋值 `new TypedReg(_nextReg++, valReg.Type)` + copy，非直接绑 rhs 寄存器——
    // z42c.semantics `ExportedMethodZ[] m; m = new[3]` dual-build 实证 C# 发 copy）。
    string src = "int F() { int x; x = 5; return x; }";
    Assert.Equal("fn @F(0) -> int {\nentry:\n  %0 = const.i64 5\n  %1 = copy %0\n  ret %1\n}",
                 IrDump.DumpFunc(src, "F"));
}

// ── 构造器 lowering（port-z42c-self-compile G11）→ `<qualClass>.<Class>` 实例函数 ret void ──
[Test]
void test_ctor_lowering() {
    // ctor 发为实例方法（this=%0, 参数 %1+），ret void，体=字段赋值（镜像 C# EmitMethod ctor）
    string src = "public sealed class C { public int X; public C(int x) { this.X = x; } }";
    Assert.Equal("fn @C.C(2) -> void {\nentry:\n  field_set %0.X, %1\n  ret\n}",
                 IrDump.DumpFunc(src, "C.C"));
}

// ── new T[n] 元素类型名 FQ 化（port-z42c-self-compile G16）─────────────────────────
// 用户类元素名须经 QualifyClass → FQ（镜像 C# Z42TypeName）；prim 元素名保留短名。
// 默认 gate 语料只含 prim 数组（new int[n]），故此处显式覆盖用户类数组回归。
[Test]
void test_array_new_user_class_fq() {
    string src = "namespace Foo; class C { } class D { C[] Make(int n) { return new C[n]; } }";
    Assert.Equal("fn @Foo.D.Make(2) -> C[] {\nentry:\n  %2 = array_new Foo.C[%1]\n  ret %2\n}",
                 IrDump.DumpFunc(src, "Foo.D.Make"));
}

[Test]
void test_array_new_prim_short() {
    string src = "class C { int[] Make(int n) { return new int[n]; } }";
    Assert.Equal("fn @C.Make(2) -> int[] {\nentry:\n  %2 = array_new int[%1]\n  ret %2\n}",
                 IrDump.DumpFunc(src, "C.Make"));
}

// ── 数组字面量初始化 new T[]{v,...}（SA-2）──────────────────────────────────────────
// 镜像 C# BoundArrayLit → ArrayNewLitInstr（opcode 0x81）；Dump = arr.new.lit  %e0, %e1, ...。
[Test]
void test_array_init_prim() {
    string src = "int[] Make() { return new int[]{1, 2, 3}; }";
    Assert.Equal("fn @Make(0) -> int[] {\nentry:\n  %0 = const.i64 1\n  %1 = const.i64 2\n  %2 = const.i64 3\n  %3 = arr.new.lit  %0, %1, %2\n  ret %3\n}",
                 IrDump.DumpFunc(src, "Make"));
}

[Test]
void test_array_init_empty() {
    string src = "int[] Make() { return new int[]{}; }";
    Assert.Equal("fn @Make(0) -> int[] {\nentry:\n  %0 = arr.new.lit\n  ret %0\n}",
                 IrDump.DumpFunc(src, "Make"));
}

// ── ref 参数 load_local_addr（SA-3 ref）────────────────────────────────────────────
// 调用方 ref arg → load_local_addr slot → 传 call 实参（镜像 C# AddressOf.cs Alloc(Unknown)）。
[Test]
void test_ref_arg_emits_load_local_addr() {
    string src = "void Inc(ref int x) { } void Main() { int c = 0; Inc(ref c); }";
    string ir = IrDump.DumpFunc(src, "Main");
    Assert.Equal("fn @Main(0) -> void {\nentry:\n  %0 = const.i64 0\n  %1 = copy %0\n  %2 = load_local_addr %1\n  %3 = call @Inc(%2)\n  ret\n}",
                 ir);
}

// ── var-decl 寄存器复用（port-z42c-self-compile G17c-4）────────────────────────────
// 同名局部在兄弟作用域重声明（if/else 各分支 `int x = ...`）复用首次分配的寄存器
// （镜像 C# WriteBackName 平表 locals）；否则寄存器数随分支膨胀（z42c.ir WriteInstr +73B REGT）。
[Test]
void test_var_decl_reuses_register_across_branches() {
    string src = "class C { int Pick(bool b) { if (b) { int x = 10; return x; } else { int x = 20; return x; } } }";
    Assert.Equal("fn @C.Pick(2) -> int {\nentry:\n  br.cond %1, then_0, else_1\nthen_0:\n  %2 = const.i64 10\n  %3 = copy %2\n  ret %3\nelse_1:\n  %4 = const.i64 20\n  %3 = copy %4\n  ret %3\nend_2:\n  ret\n}",
                 IrDump.DumpFunc(src, "C.Pick"));
}
