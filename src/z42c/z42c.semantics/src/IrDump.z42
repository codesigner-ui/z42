// IR dump 工具（port-z42c-codegen CG-1A）。源 → typecheck → codegen → .zasm-like IR 文本。
// 供 [Test] 断言 + driver `--dump-ir`（后续）。纯函数（内部建临时 DiagnosticBag）。
namespace Z42.Semantics;

using Z42.Syntax;
using Z42.Core;
using Z42.IR;
using Z42.IR.BinaryFormat;

public static class IrDump {
    // 指定函数（key="Class.Method" / 顶层函数名）的 IR 文本。
    public static string DumpFunc(string src, string funcKey) {
        IrModule m = IrDump._build(src);
        int i = 0;
        while (i < m.FuncCount) {
            if (m.Functions[i].Name == funcKey) { return m.Functions[i].Dump(); }
            i = i + 1;
        }
        return "(no-func " + funcKey + ")";
    }

    // 整模块 IR 文本（所有函数）。
    public static string DumpModule(string src) {
        return IrDump._build(src).Dump();
    }

    // 整模块 → byte-identical .zbc 的小写 hex（golden-hex 断言；port-z42c-zbc-writer）。
    public static string DumpZbcHex(string src) {
        return ZbcWriter.WriteHex(IrDump._build(src));
    }

    // 整模块 → .zbc 字节（driver --emit-zbc 写盘；纯函数，IO 在 driver）。file 进 span→DBUG（basename 化在 TrackLine）。
    public static byte[] ZbcBytes(string src, string file) {
        return ZbcWriter.Write(IrDump._buildF(src, file)).ToBytes();
    }

    // deps-aware 单文件 emit（replace-csharp Phase C：golden regen 脱 dotnet 需跨包 dep 解析，
    // 否则调 stdlib（Assert/Console）的源 emit 出 `<error>` 函数名）。镜像 build 路径用 BuildModuleD。
    public static byte[] ZbcBytesD(string src, string file, DependencyIndex deps, ImportedSymbols imported) {
        CompiledModuleZ cm = IrDump.BuildModuleD(src, file, deps, imported);
        return ZbcWriter.Write(cm.Module).ToBytes();
    }

    // golden-hex 断言用：指定文件名（DBUG file 串须与 C# 同源 capture 一致）。
    public static string DumpZbcHexF(string src, string file) {
        return ZbcWriter.WriteHex(IrDump._buildF(src, file));
    }

    private static IrModule _build(string src) {
        return IrDump._buildF(src, "<input>");
    }

    // 公开：源→IrModule（pipeline/driver build 用）。
    public static IrModule BuildModule(string src, string file) {
        return IrDump._buildF(src, file);
    }

    // 包级编译（PS-1）：全文件 parse → 全包合并收集 → 逐文件 typecheck/codegen（per-file IrModule）。
    public static CompiledModuleZ[] BuildPackage(string[] srcs, string[] files, int count,
                                                 DependencyIndex deps, ImportedSymbols imported,
                                                 bool isRelease) {
        CompilationUnit[] cus = new CompilationUnit[count];
        int i = 0;
        while (i < count) {
            var pp = new Parser(srcs[i], files[i]);
            cus[i] = pp.ParseCompilationUnit();
            i = i + 1;
        }
        SymbolTable symbols = new SymbolCollector().CollectAll(cus, count, imported);
        // G17b：同包跨-ns 类名解析图（跨-zpkg imported + 包内每个有 ns 的类 短名→声明 ns）。
        // is/as/static-get/ObjNew 引用兄弟 ns 的本地类时限定到声明 ns（镜像 C# ImportedClassNamespaces 含 using 引入的同包类）。
        StrMap classNs = IrDump._pkgClassNs(cus, count, imported);
        StrMap localClasses = IrDump._pkgLocalClasses(cus, count);   // G18：反劫持守卫仅认本地类
        // 全包自由函数聚合（文件序+声明序）——每模块 TSIG functions 全包（C# sem.Funcs 兄弟泄漏镜像）
        ExportedFuncZ[] allFuncs = new ExportedFuncZ[4];
        int afc = 0;
        i = 0;
        while (i < count) {
            ExportedModuleZ own = ExportedTypeExtractor.Extract(cus[i], symbols, "");
            int f = 0;
            while (f < own.FunctionCount) {
                if (afc == allFuncs.Length) {
                    ExportedFuncZ[] b = new ExportedFuncZ[allFuncs.Length * 2];
                    int k = 0; while (k < afc) { b[k] = allFuncs[k]; k = k + 1; }
                    allFuncs = b;
                }
                allFuncs[afc] = own.Functions[f];
                afc = afc + 1;
                f = f + 1;
            }
            i = i + 1;
        }
        // G18 部分修���：全包 classMap（shortName/Name$N → ClassDecl），用于跨文件 base 类方法继承���
        // 镜像 C# SymbolCollector 第二趟 mergedMethods 对同包跨文件基类的处理。
        StrMap pkgClassMap = new StrMap();
        int pci = 0;
        while (pci < count) {
            int pcj = 0;
            while (pcj < cus[pci].DeclCount) {
                Decl pcd = cus[pci].Decls[pcj];
                if (pcd is AttributedDecl) { pcd = (pcd as AttributedDecl).Inner; }
                if (pcd is ClassDecl) {
                    ClassDecl pccd = pcd as ClassDecl;
                    if (pccd.Kind == "class" || pccd.Kind == "struct") {
                        if (!pkgClassMap.ContainsKey(pccd.Name)) { pkgClassMap.Put(pccd.Name, pccd); }
                        if (pccd.TypeParams.Count > 0) {
                            string pcmk = pccd.Name + "$" + pccd.TypeParams.Count.ToString();
                            if (!pkgClassMap.ContainsKey(pcmk)) { pkgClassMap.Put(pcmk, pccd); }
                        }
                    }
                }
                pcj = pcj + 1;
            }
            pci = pci + 1;
        }
        CompiledModuleZ[] r = new CompiledModuleZ[count];
        i = 0;
        while (i < count) {
            r[i] = IrDump._compileCu(cus[i], symbols, deps, imported, classNs, localClasses, isRelease);
            string ns2 = "main";                                 // no-ns build 路径缺省（C# 字节实证）
            if (cus[i].HasNamespace) { ns2 = cus[i].Namespace; }
            r[i].Exported = ExportedTypeExtractor.ExtractP(cus[i], symbols, ns2, allFuncs, afc, pkgClassMap, classNs);
            i = i + 1;
        }
        return r;
    }

    // G17b：构建「短类名 → 声明 ns」图（跨-zpkg imported + 包内每个有 ns 的类/接口）。
    // 镜像 C# QualifyClassName 经 ImportedClassNamespaces 把 using 引入的同包跨-ns 类限定到
    // 其声明 ns；同 ns 类 declNs==currentNs，QualifyClass 结果与 Qualify(currentNs) 一致（无回归）。
    // 全包共用一张图（类 FQ 名恒为 declNs.name，与引用方 CU 无关，无需按 CU using 过滤）。
    private static StrMap _pkgClassNs(CompilationUnit[] cus, int count, ImportedSymbols imported) {
        StrMap m = new StrMap();
        if (imported != null && imported.ClassNamespaces != null) {
            string[] ks = imported.ClassNamespaces.Keys();
            int j = 0;
            while (j < ks.Length) { m.Put(ks[j], imported.ClassNamespaces.Get(ks[j])); j = j + 1; }
        }
        int i = 0;
        while (i < count) {
            CompilationUnit cu = cus[i];
            if (cu.HasNamespace && cu.Namespace != "") {
                int d = 0;
                while (d < cu.DeclCount) {
                    Decl dd = cu.Decls[d];
                    if (dd is AttributedDecl) { dd = (dd as AttributedDecl).Inner; }
                    if (dd is ClassDecl) { m.Put((dd as ClassDecl).Name, new StrBox(cu.Namespace)); }
                    d = d + 1;
                }
            }
            i = i + 1;
        }
        return m;
    }

    // 本包**自有声明**类名集（G18：ChainHasMethod 反劫持守卫仅认本地类，镜像 C# ClassRegistry 仅本地）。
    // 含所有 ns / 无 ns 的本包 class·struct（不含 imported）。值=占位 StrBox（仅用 ContainsKey）。
    private static StrMap _pkgLocalClasses(CompilationUnit[] cus, int count) {
        StrMap m = new StrMap();
        int i = 0;
        while (i < count) {
            CompilationUnit cu = cus[i];
            int d = 0;
            while (d < cu.DeclCount) {
                Decl dd = cu.Decls[d];
                if (dd is AttributedDecl) { dd = (dd as AttributedDecl).Inner; }
                if (dd is ClassDecl) {
                    ClassDecl cd = dd as ClassDecl;
                    if (cd.Kind == "class" || cd.Kind == "struct") { m.Put(cd.Name, new StrBox(cd.Name)); }
                }
                d = d + 1;
            }
            i = i + 1;
        }
        return m;
    }

    // 文件 stem（SA-3 镜像 C# GetFileNameWithoutExtension）：cu 源文件 basename 去 .z42。
    private static string _stem(CompilationUnit cu) {
        string path = cu.Span.File;
        int slash = 0 - 1;
        int i = path.Length - 1;
        bool more = i >= 0;
        while (more) {
            char ch = path.CharAt(i);
            if (ch == '/' || ch == '\\') { slash = i; more = false; } else { i = i - 1; more = i >= 0; }
        }
        string base2 = path;
        if (slash >= 0) { base2 = path.Substring(slash + 1, path.Length - slash - 1); }
        if (base2.EndsWith(".z42")) { base2 = base2.Substring(0, base2.Length - 4); }
        return base2;
    }

    private static CompiledModuleZ _compileCu(CompilationUnit cu, SymbolTable symbols, DependencyIndex deps, ImportedSymbols imported, StrMap classNs, StrMap localClasses, bool isRelease) {
        var diags = new DiagnosticBag();
        var model = new TypeChecker(diags).Infer(cu, symbols);
        var gen = new IrGen();
        gen.Deps = deps;
        gen.IsRelease = isRelease;   // 传入 release 标志（strip debug info）
        gen.SourceStem = IrDump._stem(cu);
        gen.ImportedClassNs = classNs;   // 跨-zpkg imported + 同包跨-ns 类（G17b）；QualifyClass 用
        gen.LocalClasses = localClasses; // G18：ChainHasMethod 反劫持守卫仅认本地类
        IrModule irm = gen.Generate(cu, model);
        string[] usings = new string[8];
        int uc = 0;
        int i = 0;
        while (i < cu.DeclCount) {
            if (cu.Decls[i] is UsingDecl) { usings[uc] = (cu.Decls[i] as UsingDecl).Name; uc = uc + 1; }
            i = i + 1;
        }
        string ns = "";
        if (cu.HasNamespace) { ns = cu.Namespace; }
        var cm2 = new CompiledModuleZ(irm, ns, usings, uc, gen.UsedDepNs, gen.UsedDepNsCount, diags.ErrorCount());
        string[] dm = new string[diags.Count()];
        int di = 0;
        while (di < diags.Count()) {
            Diagnostic dg = diags.Get(di);
            dm[di] = dg.Span.File + "(" + dg.Span.Line.ToString() + "," + dg.Span.Column.ToString() + "): " + dg.Code + ": " + dg.Message;
            di = di + 1;
        }
        cm2.DiagMsgs = dm; cm2.DiagCount = diags.Count();
        return cm2;
    }

    // 公开：带跨包依赖的编译（CI-4）。imported 合并符号表；deps 驱动静态调用 FQ 命中。
    public static CompiledModuleZ BuildModuleD(string src, string file, DependencyIndex deps, ImportedSymbols imported) {
        var p = new Parser(src, file);
        var cu = p.ParseCompilationUnit();
        var symbols = new SymbolCollector().CollectWithImports(cu, imported);
        var diags = new DiagnosticBag();
        var model = new TypeChecker(diags).Infer(cu, symbols);
        var gen = new IrGen();
        gen.Deps = deps;
        gen.SourceStem = IrDump._stem(cu);
        if (imported != null) { gen.ImportedClassNs = imported.ClassNamespaces; }
        CompilationUnit[] one = new CompilationUnit[1]; one[0] = cu;
        gen.LocalClasses = IrDump._pkgLocalClasses(one, 1);   // G18：反劫持守卫仅认本地类
        IrModule irm = gen.Generate(cu, model);
        // usings 抽取（DEPS 用）
        string[] usings = new string[4];
        int uc = 0;
        int i = 0;
        while (i < cu.DeclCount) {
            if (cu.Decls[i] is UsingDecl) {
                if (uc == usings.Length) {
                    string[] b = new string[usings.Length * 2];
                    int k = 0; while (k < uc) { b[k] = usings[k]; k = k + 1; }
                    usings = b;
                }
                usings[uc] = (cu.Decls[i] as UsingDecl).Name;
                uc = uc + 1;
            }
            i = i + 1;
        }
        string ns = "";
        if (cu.HasNamespace) { ns = cu.Namespace; }
        var cm2 = new CompiledModuleZ(irm, ns, usings, uc, gen.UsedDepNs, gen.UsedDepNsCount, diags.ErrorCount());
        string[] dm = new string[diags.Count()];
        int di = 0;
        while (di < diags.Count()) {
            Diagnostic dg = diags.Get(di);
            dm[di] = dg.Span.File + "(" + dg.Span.Line.ToString() + "," + dg.Span.Column.ToString() + "): " + dg.Code + ": " + dg.Message;
            di = di + 1;
        }
        cm2.DiagMsgs = dm; cm2.DiagCount = diags.Count();
        return cm2;
    }

    // 公开：仅 usings + 导出（driver 组装期先收 usings 决定激活集时用）。
    public static string[] ExtractUsings(string src, string file) {
        var p = new Parser(src, file);
        var cu = p.ParseCompilationUnit();
        string[] usings = new string[8];
        int uc = 0;
        int i = 0;
        while (i < cu.DeclCount) {
            if (cu.Decls[i] is UsingDecl) {
                usings[uc] = (cu.Decls[i] as UsingDecl).Name;
                uc = uc + 1;
            }
            i = i + 1;
        }
        string[] r = new string[uc];
        i = 0;
        while (i < uc) { r[i] = usings[i]; i = i + 1; }
        return r;
    }

    // 公开：源→导出类型签名（TSIG；port-z42c-tsig）。独立 parse+collect（与 BuildModule 分离，
    // 形态简单；增量编译期再合并为单趟）。
    public static ExportedModuleZ ExtractExports(string src, string file, string ns) {
        var p = new Parser(src, file);
        var cu = p.ParseCompilationUnit();
        var symbols = new SymbolCollector().Collect(cu);
        return ExportedTypeExtractor.Extract(cu, symbols, ns);
    }

    private static IrModule _buildF(string src, string file) {
        var p = new Parser(src, file);
        var cu = p.ParseCompilationUnit();
        var symbols = new SymbolCollector().Collect(cu);
        var diags = new DiagnosticBag();
        var model = new TypeChecker(diags).Infer(cu, symbols);
        var gen = new IrGen();
        gen.SourceStem = IrDump._stem(cu);   // SA-3：__static_init__ 名前缀须用文件 stem（镜像 _compileCu / C# _cuStem），否则回落 "main" → 与 C# `<stem>.__static_init__` 字节不一致
        CompilationUnit[] one = new CompilationUnit[1]; one[0] = cu;
        gen.LocalClasses = IrDump._pkgLocalClasses(one, 1);   // G18：反劫持守卫仅认本地类
        return gen.Generate(cu, model);
    }
}

// 带依赖编译的产物束（CI-4）。
public sealed class CompiledModuleZ {
    public IrModule Module;
    public ExportedModuleZ Exported;   // PS-1：包级提取（全包函数泄漏镜像）
    public string[] DiagMsgs; public int DiagCount;   // 诊断详情（driver 打印）
    public string   Namespace;  // cu 真实 ns（""=无——C# ZbcFile.Namespace 语义；≠ IrModule.Name 的 "main" 缺省）
    public string[] Usings;     public int UsingCount;
    public string[] UsedDepNs;  public int UsedDepNsCount;
    public int      ErrorCount;
    public CompiledModuleZ(IrModule irm, string ns, string[] usings, int usingCount,
                           string[] usedDepNs, int usedDepNsCount, int errorCount) {
        this.Module = irm; this.Namespace = ns; this.Usings = usings; this.UsingCount = usingCount;
        this.UsedDepNs = usedDepNs; this.UsedDepNsCount = usedDepNsCount; this.ErrorCount = errorCount;
    }
}
