// Codegen 由 0.3.5–0.3.6 spec 落地。引用 core/syntax/ir 验证多依赖跨包编译。
namespace Z42.Semantics;

using Z42.Core;
using Z42.Syntax;
using Z42.IR;

public sealed class SemanticsSkeleton {
    public string Name() {
        var core = new CoreSkeleton();
        var syn = new SyntaxSkeleton();
        var ir = new IrSkeleton();
        return "z42c.semantics(" + core.Name() + "," + syn.Name() + "," + ir.Name() + ")";
    }
}
