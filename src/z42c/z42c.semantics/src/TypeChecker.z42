// 类型检查 Pass 1（port-z42c-semantics 1A-4b）。CompilationUnit + SymbolTable → SemanticModel。
// 调度：集中式 if-is 链（D1，镜像 C# 集中 switch）。1A 范围：lit/ident/assign/free-call + decl/return/expr/block。
// 检查：var-decl 初值可赋 / return 类型可赋 / 标识符已定义 / 函数已声明。其余表达式·语句 → 1B+。
namespace Z42.Semantics;

using Z42.Syntax;
using Z42.Core;
using Z42.IR.BinaryFormat;

public sealed class TypeChecker {
    private DiagnosticBag     _diags;
    private int               _loopDepth;    // break/continue 越界检查（1B）
    // lambda 捕获 frame（port-z42c-closures）：active 时 Ident 钩子检测外层命中。
    private bool _lambdaActive;
    private StrMap _lambdaLocals;
    private BoundCapture[] _lambdaCaps; private int _lambdaCapCount;
    private ConstraintChecker _constraints;  // 泛型 where 约束解析 + call-site 校验（2B）
    private string _currentNs;               // 当前 CU 命名空间（namespace-qualified free call 用）
    public TypeChecker(DiagnosticBag diags) {
        this._diags = diags;
        this._loopDepth = 0;
        this._lambdaActive = false;
        this._constraints = new ConstraintChecker(diags);
        this._currentNs = "";
    }

    public SemanticModel Infer(CompilationUnit cu, SymbolTable symbols) {
        var model = new SemanticModel(symbols);
        this._currentNs = cu.HasNamespace ? cu.Namespace : "";
        this._constraints.Resolve(cu, symbols);   // Pass 0.5：泛型 where 约束解析（2B，镜像 C# ResolveAllWhereConstraints）
        int i = 0;
        while (i < cu.DeclCount) {
            Decl d = this._unwrap(cu.Decls[i]);
            if (d is ClassDecl) {
                ClassDecl c = d as ClassDecl;
                if (c.Kind == "class" || c.Kind == "struct" || c.Kind == "record") { this._bindClass(model, symbols, c); }
            } else if (d is MethodDecl) {
                MethodDecl m = d as MethodDecl;
                this._bindFreeFunc(model, symbols, m);
            } else if (d is ImplDecl) {
                this._bindImpl(model, symbols, d as ImplDecl);   // port-z42c-impl-block 2b
            }
            i = i + 1;
        }
        this._synthCtors(model, symbols, cu);
        return model;
    }

    // 合成隐式 ctor 体（镜像 C# EmitImplicitCtor + CollectChainFieldInits）：
    // 类无显式实例 ctor 但本类或本地祖先有实例字段 init 时，发 `<ctKey>.<Name>` 体——
    // 沿基类链（root→self）的 `this.field = init` 赋值（无 base 调用，整链内联）。IrGen 据此发函数。
    private void _synthCtors(SemanticModel model, SymbolTable symbols, CompilationUnit cu) {
        StrMap clsMap = new StrMap();   // 简单名 → ClassDecl（本地 class/struct/record）
        int i0 = 0;
        while (i0 < cu.DeclCount) {
            Decl d0 = this._unwrap(cu.Decls[i0]);
            if (d0 is ClassDecl) {
                ClassDecl cc = d0 as ClassDecl;
                if (cc.Kind == "class" || cc.Kind == "struct" || cc.Kind == "record") { clsMap.Put(cc.Name, cc); }
            }
            i0 = i0 + 1;
        }
        int i = 0;
        while (i < cu.DeclCount) {
            Decl d = this._unwrap(cu.Decls[i]);
            if (d is ClassDecl) {
                ClassDecl c = d as ClassDecl;
                if ((c.Kind == "class" || c.Kind == "struct" || c.Kind == "record") && !this._hasExplicitInstanceCtor(c)) {
                    string ctKey = c.Name;
                    if (c.TypeParams.Count > 0) { string mk = c.Name + "$" + c.TypeParams.Count.ToString(); if (symbols.HasClass(mk)) { ctKey = mk; } }
                    Z42ClassType ct = symbols.GetClass(ctKey);
                    if (ct != null) {
                        // 收集祖先链（self→root）
                        ClassDecl[] chain = new ClassDecl[8]; int chainN = 0;
                        StrMap seen = new StrMap();
                        ClassDecl cur = c;
                        Z42ClassType curCt = ct;
                        while (cur != null && !seen.ContainsKey(cur.Name)) {
                            seen.Put(cur.Name, "1");
                            if (chainN == chain.Length) { ClassDecl[] b = new ClassDecl[chain.Length * 2]; int z = 0; while (z < chainN) { b[z] = chain[z]; z = z + 1; } chain = b; }
                            chain[chainN] = cur; chainN = chainN + 1;
                            if (curCt == null || !curCt.HasBase || curCt.BaseName == "" || !clsMap.ContainsKey(curCt.BaseName)) { cur = null; }
                            else { cur = clsMap.Get(curCt.BaseName) as ClassDecl; curCt = symbols.GetClass(curCt.BaseName); }
                        }
                        // 绑定环境：this + 全部字段（含继承，_passInheritFields 已并入）
                        var env = TypeEnv.Root(symbols).WithClassGeneric(ct.Name(), c.TypeParams.Names, c.TypeParams.Count);
                        env.Define("this", ct);
                        string[] fnames = ct.Fields.Keys();
                        int fk = 0;
                        while (fk < fnames.Length) { FieldSymbol fs = ct.Fields.Get(fnames[fk]) as FieldSymbol; env.Define(fnames[fk], fs.FieldType); fk = fk + 1; }
                        // root→self 顺序绑定字段 init 赋值
                        BoundStmt[] inits = new BoundStmt[16]; int ic = 0;
                        int chx = chainN - 1;
                        while (chx >= 0) {
                            ClassDecl cd = chain[chx];
                            Z42ClassType cdCt = symbols.GetClass(cd.Name);
                            int mj = 0;
                            while (mj < cd.MemberCount) {
                                Decl mem = this._unwrap(cd.Members[mj]);
                                if (mem is FieldDecl) {
                                    FieldDecl fd = mem as FieldDecl;
                                    FieldSymbol fsym = (cdCt != null) ? (cdCt.Fields.Get(fd.Name) as FieldSymbol) : null;
                                    if (fd.HasInit && fsym != null && !fsym.IsStatic) {
                                        Expr tgt = new MemberExpr(new IdentExpr("this", fd.Span), fd.Name, fd.Span);
                                        Expr asn = new AssignExpr("=", tgt, fd.Init, fd.Span);
                                        if (ic == inits.Length) { BoundStmt[] b2 = new BoundStmt[inits.Length * 2]; int z = 0; while (z < ic) { b2[z] = inits[z]; z = z + 1; } inits = b2; }
                                        inits[ic] = new BoundExprStmt(this._bindExpr(asn, env), fd.Span); ic = ic + 1;
                                    }
                                }
                                mj = mj + 1;
                            }
                            chx = chx - 1;
                        }
                        if (ic > 0) { model.AddBody(ctKey + "." + c.Name, new BoundBlock(inits, ic, c.Span)); }
                    }
                }
            }
            i = i + 1;
        }
    }

    private bool _hasExplicitInstanceCtor(ClassDecl c) {
        int j = 0;
        while (j < c.MemberCount) {
            Decl m = this._unwrap(c.Members[j]);
            if (m is MethodDecl) {
                MethodDecl md = m as MethodDecl;
                if (md.IsCtor && !this._hasWordTc(md.Mods, "static")) { return true; }
            }
            j = j + 1;
        }
        return false;
    }

    // 运算符符号 → 重载方法名（与 Parser._operatorMethodName 一致；"" 表不可重载）。
    private string _operatorMethodNameTc(string op) {
        if (op == "+") { return "op_Add"; }
        if (op == "-") { return "op_Subtract"; }
        if (op == "*") { return "op_Multiply"; }
        if (op == "/") { return "op_Divide"; }
        if (op == "%") { return "op_Modulo"; }
        return "";
    }

    private bool _hasWordTc(string mods, string w) {
        if (mods == "") { return false; }
        return (" " + mods + " ").IndexOf(" " + w + " ") >= 0;
    }

    // impl-block 方法体绑定（port-z42c-impl-block 2b，镜像 _bindClass 的 MethodDecl 分支）：
    // 方法 this=target、target 字段入 scope；body 键 `<target>.<mkey>`（IrGen 2c 同键发函数）。
    private void _bindImpl(SemanticModel model, SymbolTable symbols, ImplDecl im) {
        string targetName = "";
        if (im.TargetType is NamedType) { targetName = (im.TargetType as NamedType).Name; }
        if (targetName == "" || !symbols.HasClass(targetName)) { return; }
        Z42ClassType ct = symbols.GetClass(targetName);
        int j = 0;
        while (j < im.MethodCount) {
            if (im.Methods[j] is MethodDecl) {
                MethodDecl md = im.Methods[j] as MethodDecl;
                if (md.HasBody) {
                    string mkey = md.Name + "$" + md.ParamCount.ToString();
                    if (!ct.Methods.ContainsKey(mkey)) { mkey = md.Name; }
                    MethodSymbol ms = ct.Methods.Get(mkey) as MethodSymbol;
                    int mtpc = md.TypeParams.Count;
                    string[] allParams = this._mergeParams(new string[0], 0, md.TypeParams.Names, mtpc);
                    var env = TypeEnv.Root(symbols).WithClassGeneric(ct.Name(), allParams, mtpc);
                    if (ms != null && !ms.IsStatic) {
                        env.Define("this", ct);
                        string[] fnames = ct.Fields.Keys();
                        int k = 0;
                        while (k < fnames.Length) {
                            FieldSymbol fs = ct.Fields.Get(fnames[k]) as FieldSymbol;
                            env.Define(fnames[k], fs.FieldType);
                            k = k + 1;
                        }
                    }
                    BoundStmt body = this._bindMethodBody(symbols, env, md);
                    model.AddBody(targetName + "." + mkey, body);
                }
            }
            j = j + 1;
        }
    }

    private Decl _unwrap(Decl d) {
        if (d is AttributedDecl) { AttributedDecl ad = d as AttributedDecl; return ad.Inner; }
        return d;
    }

    private void _bindClass(SemanticModel model, SymbolTable symbols, ClassDecl c) {
        // Arity-mangle：泛型类若以 Name$N 键注册，优先取该 CT。
        string ctKey = c.Name;
        if (c.TypeParams.Count > 0) { string mk = c.Name + "$" + c.TypeParams.Count.ToString(); if (symbols.HasClass(mk)) { ctKey = mk; } }
        Z42ClassType ct = symbols.GetClass(ctKey);
        int j = 0;
        while (j < c.MemberCount) {
            Decl mem = this._unwrap(c.Members[j]);
            if (mem is FieldDecl) {                                  // 静态字段 init（SA-3）
                FieldDecl fd = mem as FieldDecl;
                FieldSymbol fsym = ct.Fields.Get(fd.Name) as FieldSymbol;
                if (fd.HasInit && fsym != null && fsym.IsStatic) {
                    var fenv = TypeEnv.Root(symbols);
                    model.AddStaticInit(c.Name, fd.Name, this._bindExpr(fd.Init, fenv));
                }
            } else if (mem is MethodDecl) {
                MethodDecl md = mem as MethodDecl;
                if (md.HasBody) {                       // G11：ctor（IsCtor）也绑体——ms 已收集（名=类名，ret void），this+字段入 scope
                    // GS3：重载方法以 Name$arity 键存于 ct.Methods；先试 Name$arity，再 bare name（镜像 C# regName 逻辑）。
                    string mkey = md.Name + "$" + md.ParamCount.ToString();
                    if (!ct.Methods.ContainsKey(mkey)) { mkey = md.Name; }
                    MethodSymbol ms = ct.Methods.Get(mkey) as MethodSymbol;
                    // 活跃类型形参 = 类的 + 方法自身的（2A-2）。
                    int mtpc = md.TypeParams.Count;
                    string[] allParams = this._mergeParams(c.TypeParams.Names, c.TypeParams.Count, md.TypeParams.Names, mtpc);
                    var env = TypeEnv.Root(symbols).WithClassGeneric(ct.Name(), allParams, c.TypeParams.Count + mtpc);
                    if (!ms.IsStatic) {
                        env.Define("this", ct);
                        string[] fnames = ct.Fields.Keys();
                        int k = 0;
                        while (k < fnames.Length) {
                            FieldSymbol fs = ct.Fields.Get(fnames[k]) as FieldSymbol;
                            env.Define(fnames[k], fs.FieldType);
                            k = k + 1;
                        }
                    }
                    BoundStmt body = this._bindMethodBody(symbols, env, md);
                    // 实例 ctor：注入实例字段初始化器（`int x=1`）到体首（base 调用后、用户体前）。
                    // 此前完全未注入 → 字段停留类型默认值（got 0/null）。仅 ctor-exists 路径；
                    // ctor-less 类的合成 ctor 待 follow-up。
                    if (md.IsCtor && !ms.IsStatic && !md.IsThisInit) { body = this._injectFieldInits(c, ct, env, body); }
                    model.AddBody(ctKey + "." + mkey, body);   // GS3：body 键用 mkey（重载时=Name$arity）；arity-mangle 时用 ctKey（Name$N）
                }
            } else if (mem is IndexerDecl) {
                // get_Item / set_Item 体绑定（IndexerDecl lowering；镜像 C# IndexerDecl 处理）。
                IndexerDecl id = mem as IndexerDecl;
                if (id.HasGet) {
                    var getEnv = TypeEnv.Root(symbols).WithClassGeneric(ct.Name(), c.TypeParams.Names, c.TypeParams.Count);
                    getEnv.Define("this", ct);
                    string[] gfns = ct.Fields.Keys();
                    int gfk = 0;
                    while (gfk < gfns.Length) { FieldSymbol gfs = ct.Fields.Get(gfns[gfk]) as FieldSymbol; getEnv.Define(gfns[gfk], gfs.FieldType); gfk = gfk + 1; }
                    int gp = 0;
                    while (gp < id.ParamCount) { getEnv.Define(id.Params[gp].Name, getEnv.ResolveType(id.Params[gp].Type)); gp = gp + 1; }
                    Z42Type gret = getEnv.ResolveType(id.RetType);
                    model.AddBody(ctKey + ".get_Item", this._bindStmt(id.GetBody, getEnv, gret));
                }
                if (id.HasSet) {
                    var setEnv = TypeEnv.Root(symbols).WithClassGeneric(ct.Name(), c.TypeParams.Names, c.TypeParams.Count);
                    setEnv.Define("this", ct);
                    string[] sfns = ct.Fields.Keys();
                    int sfk = 0;
                    while (sfk < sfns.Length) { FieldSymbol sfs = ct.Fields.Get(sfns[sfk]) as FieldSymbol; setEnv.Define(sfns[sfk], sfs.FieldType); sfk = sfk + 1; }
                    int sp = 0;
                    while (sp < id.ParamCount) { setEnv.Define(id.Params[sp].Name, setEnv.ResolveType(id.Params[sp].Type)); sp = sp + 1; }
                    setEnv.Define("value", setEnv.ResolveType(id.RetType));
                    model.AddBody(ctKey + ".set_Item", this._bindStmt(id.SetBody, setEnv, new Z42VoidType()));
                }
            }
            j = j + 1;
        }
    }

    private void _bindFreeFunc(SemanticModel model, SymbolTable symbols, MethodDecl md) {
        if (md.HasBody) {
            // 顶层泛型函数携自身型参（classFlag=false）。
            var env = new TypeEnv(symbols, false, null, false, "", md.TypeParams.Names, md.TypeParams.Count);
            BoundStmt body = this._bindMethodBody(symbols, env, md);
            model.AddBody(md.Name, body);
        }
    }

    private string[] _mergeParams(string[] a, int ac, string[] b, int bc) {
        string[] r = new string[ac + bc];
        int i = 0;
        while (i < ac) { r[i] = a[i]; i = i + 1; }
        int j = 0;
        while (j < bc) { r[ac + j] = b[j]; j = j + 1; }
        return r;
    }

    // 实例字段初始化器注入：把 `this.field = init`（声明序）绑定后前置到 ctor 体首。
    // env 已含 this + 字段（调用方 ctor 绑定时建立）。空则返回原体。
    private BoundStmt _injectFieldInits(ClassDecl c, Z42ClassType ct, TypeEnv env, BoundStmt body) {
        BoundStmt[] inits = new BoundStmt[c.MemberCount];
        int ic = 0;
        int j = 0;
        while (j < c.MemberCount) {
            Decl mem = this._unwrap(c.Members[j]);
            if (mem is FieldDecl) {
                FieldDecl fd = mem as FieldDecl;
                FieldSymbol fsym = ct.Fields.Get(fd.Name) as FieldSymbol;
                if (fd.HasInit && fsym != null && !fsym.IsStatic) {
                    Expr tgt = new MemberExpr(new IdentExpr("this", fd.Span), fd.Name, fd.Span);
                    Expr asn = new AssignExpr("=", tgt, fd.Init, fd.Span);
                    inits[ic] = new BoundExprStmt(this._bindExpr(asn, env), fd.Span);
                    ic = ic + 1;
                }
            }
            j = j + 1;
        }
        if (ic == 0) { return body; }
        BoundStmt[] orig = new BoundStmt[1]; orig[0] = body; int origN = 1;
        if (body is BoundBlock) { BoundBlock bb = body as BoundBlock; orig = bb.Stmts; origN = bb.Count; }
        BoundStmt[] merged = new BoundStmt[ic + origN];
        int m = 0;
        while (m < ic) { merged[m] = inits[m]; m = m + 1; }
        int k = 0;
        while (k < origN) { merged[ic + k] = orig[k]; k = k + 1; }
        return new BoundBlock(merged, ic + origN, body.Span);
    }

    private BoundStmt _bindMethodBody(SymbolTable symbols, TypeEnv env, MethodDecl md) {
        int p = 0;
        while (p < md.ParamCount) {
            env.Define(md.Params[p].Name, env.ResolveType(md.Params[p].Type));
            p = p + 1;
        }
        Z42Type ret = env.ResolveType(md.RetType);
        BoundStmt body = this._bindStmt(md.Body, env, ret);
        // ctor 初始化调用：ctor + BaseArgCount > 0 → 在体首插入 call @TargetCls.CtorKey %0, ...args。
        // IsThisInit → `: this(args)` 委托同类 ctor（TargetCls = curCls）；
        // 否则 → `: base(args)` 调用基类 ctor（TargetCls = baseCls）。镜像 C# FunctionEmitter
        // BoundThisCtorArgs / BoundBaseCtorArgs 两分支。
        if (md.IsCtor && md.BaseArgCount > 0) {
            Z42Type thisType = env.LookupVar("this");
            if (thisType is Z42ClassType) {
                Z42ClassType curCls = thisType as Z42ClassType;
                Z42ClassType targetCls = null;
                string targetName = "";
                if (md.IsThisInit) {
                    targetCls = curCls;
                    targetName = curCls.Name();
                } else if (curCls.HasBase && curCls.BaseName != "") {
                    targetCls = symbols.GetClass(curCls.BaseName);
                    targetName = curCls.BaseName;
                }
                if (targetCls != null) {
                    string bKey = this._ctorKey(targetCls, md.BaseArgCount);
                    BoundExpr[] callArgs = new BoundExpr[md.BaseArgCount + 1];
                    callArgs[0] = new BoundIdent("this", thisType, md.Span);
                    int ba = 0;
                    while (ba < md.BaseArgCount) { callArgs[ba + 1] = this._bindExpr(md.BaseArgs[ba], env); ba = ba + 1; }
                    BoundCall baseCall = new BoundCall("base_ctor", false, null, targetName, bKey,
                                                        callArgs, md.BaseArgCount + 1, new Z42VoidType(), md.Span);
                    BoundExprStmt baseStmt = new BoundExprStmt(baseCall, md.Span);
                    BoundStmt[] stmts = null;
                    int sc = 0;
                    if (body is BoundBlock) {
                        BoundBlock bb = body as BoundBlock;
                        stmts = new BoundStmt[bb.Count + 1];
                        stmts[0] = baseStmt;
                        int si = 0;
                        while (si < bb.Count) { stmts[si + 1] = bb.Stmts[si]; si = si + 1; }
                        sc = bb.Count + 1;
                    } else {
                        stmts = new BoundStmt[2];
                        stmts[0] = baseStmt; stmts[1] = body; sc = 2;
                    }
                    return new BoundBlock(stmts, sc, md.Span);
                }
            }
        }
        return body;
    }

    // ════ 语句（集中 if-is）═══════════════════════════════════════════════════
    private BoundStmt _bindStmt(Stmt s, TypeEnv env, Z42Type ret) {
        if (s is BlockStmt) {
            BlockStmt b = s as BlockStmt;
            TypeEnv scope = env.PushScope();
            // impl-local-fn-l2 pre-pass：先注册块内全部局部函数签名（前向引用 + 递归）。
            int pp = 0;
            while (pp < b.Count) {
                if (b.Stmts[pp] is LocalFunctionStmt) {
                    MethodDecl lmd = (b.Stmts[pp] as LocalFunctionStmt).Decl;
                    Z42Type[] pts = new Z42Type[lmd.ParamCount];
                    int z = 0; while (z < lmd.ParamCount) { pts[z] = scope.ResolveType(lmd.Params[z].Type); z = z + 1; }
                    scope.DefineLocalFn(lmd.Name, new Z42FuncType(pts, lmd.ParamCount, scope.ResolveType(lmd.RetType)));
                }
                pp = pp + 1;
            }
            BoundStmt[] outs = new BoundStmt[b.Count];
            int i = 0;
            while (i < b.Count) { outs[i] = this._bindStmt(b.Stmts[i], scope, ret); i = i + 1; }
            return new BoundBlock(outs, b.Count, b.Span);
        }
        if (s is LocalFunctionStmt) {
            LocalFunctionStmt lf = s as LocalFunctionStmt;
            TypeEnv lscope = env.PushScope();   // 体内可见同级/外层局部函数（递归/前向引用）；L2 无值捕获
            BoundStmt lbody = this._bindMethodBody(env.Symbols, lscope, lf.Decl);
            return new BoundLocalFunction(lf.Decl.Name, lf.Decl, lbody, lf.Span);
        }
        if (s is VarDeclStmt) {
            VarDeclStmt v = s as VarDeclStmt;
            BoundExpr init = null;
            if (v.Init is LambdaExpr) {                              // lambda + 显式 Func 类型 → expected 推导
                Z42Type declared = env.ResolveType(v.Type);          // `var` → Unknown，自然跳过
                if (declared is Z42FuncType) {
                    init = this._bindLambda(v.Init as LambdaExpr, declared as Z42FuncType, env);
                }
            }
            if (init == null && v.Init != null) { init = this._bindExpr(v.Init, env); }   // G8：无 init 则 init 留 null
            Z42Type vt = this._varType(env, v, init);
            env.Define(v.Name, vt);
            if (this._lambdaActive) { this._lambdaLocals.Put(v.Name, vt); }
            return new BoundVarDeclStmt(v.Name, vt, init, v.Span);
        }
        if (s is ReturnStmt) {
            ReturnStmt r = s as ReturnStmt;
            if (r.HasValue) {
                BoundExpr val = this._bindExpr(r.Value, env);
                if (!this._isAssignable(val.Type(), ret, env.Symbols)) {
                    this._diags.Error(DiagnosticCodes.TypeMismatch,
                        "return type " + val.Type().Name() + " not assignable to " + ret.Name(), r.Value.Span);
                }
                return new BoundReturn(true, val, r.Span);
            }
            return new BoundReturn(false, new BoundLitNull(new Z42VoidType(), r.Span), r.Span);
        }
        if (s is ExprStmt) {
            ExprStmt e = s as ExprStmt;
            return new BoundExprStmt(this._bindExpr(e.E, env), e.Span);
        }
        if (s is IfStmt) {
            IfStmt f = s as IfStmt;
            BoundExpr cond = this._bindExpr(f.Cond, env);
            this._requireBool(cond.Type(), "if", f.Cond.Span);
            BoundStmt then = this._bindStmt(f.Then, env, ret);
            if (f.HasElse) {
                return new BoundIf(cond, then, true, this._bindStmt(f.Else, env, ret), f.Span);
            }
            return new BoundIf(cond, then, false, new BoundBlock(new BoundStmt[0], 0, f.Span), f.Span);
        }
        if (s is ThrowStmt) {
            ThrowStmt th = s as ThrowStmt;
            return new BoundThrow(this._bindExpr(th.E, env), th.Span);
        }
        if (s is TryCatchStmt) {
            TryCatchStmt ts = s as TryCatchStmt;
            BoundStmt tryBody = this._bindStmt(ts.TryBody, env, ret);
            BoundCatchClause[] catches = new BoundCatchClause[ts.CatchCount];
            int ci = 0;
            while (ci < ts.CatchCount) {
                CatchClause cc = ts.Catches[ci];
                string exName = "";
                Z42Type exType = new Z42UnknownType();
                if (cc.HasType) {
                    Z42Type t = env.ResolveType(cc.ExType);
                    exName = cc.ExType.Dump();           // 解析失败也保留源类型名（imported 异常类经 Unknown 吸收）
                    if (t is Z42ClassType) { exName = t.Name(); exType = t; }
                }
                TypeEnv cenv = env;
                if (cc.HasVar) {
                    cenv = env.PushScope();
                    cenv.Define(cc.VarName, exType);
                    if (this._lambdaActive) { this._lambdaLocals.Put(cc.VarName, exType); }
                }
                BoundStmt body = this._bindStmt(cc.Body, cenv, ret);
                catches[ci] = new BoundCatchClause(cc.HasType, exName, cc.HasVar, cc.VarName, body, cc.Span);
                ci = ci + 1;
            }
            BoundStmt fin = null;
            if (ts.HasFinally) { fin = this._bindStmt(ts.Finally, env, ret); }
            return new BoundTry(tryBody, catches, ts.CatchCount, ts.HasFinally, fin, ts.Span);
        }
        if (s is WhileStmt) {
            WhileStmt w = s as WhileStmt;
            BoundExpr cond = this._bindExpr(w.Cond, env);
            this._requireBool(cond.Type(), "while", w.Cond.Span);
            this._loopDepth = this._loopDepth + 1;
            BoundStmt body = this._bindStmt(w.Body, env, ret);
            this._loopDepth = this._loopDepth - 1;
            return new BoundWhile(cond, body, w.Span);
        }
        if (s is DoWhileStmt) {
            DoWhileStmt dw = s as DoWhileStmt;
            this._loopDepth = this._loopDepth + 1;
            BoundStmt dwBody = this._bindStmt(dw.Body, env, ret);
            this._loopDepth = this._loopDepth - 1;
            BoundExpr dwCond = this._bindExpr(dw.Cond, env);
            this._requireBool(dwCond.Type(), "do-while", dw.Cond.Span);
            return new BoundDoWhile(dwBody, dwCond, dw.Span);
        }
        if (s is SwitchStmt) {
            SwitchStmt sw = s as SwitchStmt;
            BoundExpr subj = this._bindExpr(sw.Subject, env);
            BoundSwitchCase[] cases = new BoundSwitchCase[sw.CaseCount];
            int ci = 0;
            while (ci < sw.CaseCount) {
                SwitchCase sc = sw.Cases[ci];
                BoundExpr pat = null;
                if (sc.HasPattern) { pat = this._bindExpr(sc.Pattern, env); }
                TypeEnv caseScope = env.PushScope();
                BoundStmt[] cbody = new BoundStmt[sc.BodyCount];
                int bi = 0;
                while (bi < sc.BodyCount) { cbody[bi] = this._bindStmt(sc.Body[bi], caseScope, ret); bi = bi + 1; }
                cases[ci] = new BoundSwitchCase(sc.HasPattern, pat, cbody, sc.BodyCount, sc.Span);
                ci = ci + 1;
            }
            return new BoundSwitch(subj, cases, sw.CaseCount, sw.Span);
        }
        if (s is BreakStmt) {
            if (this._loopDepth == 0) {
                this._diags.Error(DiagnosticCodes.InvalidBreakContinue, "`break` outside of loop", s.Span);
            }
            return new BoundBreak(s.Span);
        }
        if (s is ContinueStmt) {
            if (this._loopDepth == 0) {
                this._diags.Error(DiagnosticCodes.InvalidBreakContinue, "`continue` outside of loop", s.Span);
            }
            return new BoundContinue(s.Span);
        }
        // for 循环 → BoundFor（独立节点，FunctionEmitter 生成 cond/body/incr/end 四块，
        // continue 跳 incrL 而非 condL，镜像 C# EmitBoundFor，block 结构 byte-identical）。
        if (s is ForStmt) {
            ForStmt f = s as ForStmt;
            TypeEnv forScope = env.PushScope();
            BoundStmt finit = null;
            if (f.HasInit) { finit = this._bindStmt(f.Init, forScope, ret); }
            BoundExpr fcond = null;
            if (f.HasCond) {
                fcond = this._bindExpr(f.Cond, forScope);
                this._requireBool(fcond.Type(), "for", f.Cond.Span);
            }
            this._loopDepth = this._loopDepth + 1;
            BoundStmt fbody = this._bindStmt(f.Body, forScope, ret);
            this._loopDepth = this._loopDepth - 1;
            BoundExpr fincr = null;
            if (f.HasIncr) { fincr = this._bindExpr(f.Incr, forScope); }
            return new BoundFor(f.HasInit, finit, f.HasCond, fcond, f.HasIncr, fincr, fbody, s.Span);
        }
        // GS6: foreach → BoundForeach（镜像 C# TypeChecker：保留语义节点，FunctionEmitter 专用 _emitForeach
        // 产出 ArrayLen+ConstI32 计数器 byte-identical IR；替代旧脱糖到 while+BoundMember.Length 路径）。
        if (s is ForeachStmt) {
            ForeachStmt fe = s as ForeachStmt;
            TypeEnv feScope = env.PushScope();
            BoundExpr feIter = this._bindExpr(fe.Iter, feScope);
            Z42Type feElem = new Z42UnknownType();
            bool feIsVar = (fe.Type is NamedType) && ((fe.Type as NamedType).Name == "var");
            if (feIsVar) {
                if (feIter.Type() is Z42ArrayType) { feElem = (feIter.Type() as Z42ArrayType).Elem; }
                else if (feIter.Type() is Z42ClassType) {
                    // class-iter：elem type from get_Item return type（镜像 C# ElemTypeOf）
                    Z42ClassType feCt = feIter.Type() as Z42ClassType;
                    if (feCt.Methods.ContainsKey("get_Item")) {
                        MethodSymbol feMs = feCt.Methods.Get("get_Item") as MethodSymbol;
                        if (feMs != null && feMs.Signature != null) { feElem = feMs.Signature.Ret; }
                    }
                }
            } else { feElem = feScope.ResolveType(fe.Type); }
            TypeEnv elemScope = feScope.PushScope();
            elemScope.Define(fe.Name, feElem);
            this._loopDepth = this._loopDepth + 1;
            BoundStmt febody = this._bindStmt(fe.Body, elemScope, ret);
            this._loopDepth = this._loopDepth - 1;
            // ClassIterTarget：class with get_Item + Count field or method（镜像 C# ClassIterTarget）
            bool feIsClassIter = false; bool feCountIsField = false;
            Z42Type feCollType = feIter.Type();
            Z42ClassType feClassDef = null;
            if (feCollType is Z42ClassType) { feClassDef = feCollType as Z42ClassType; }
            else if (feCollType is Z42InstantiatedType) { feClassDef = (feCollType as Z42InstantiatedType).Def; }
            if (feClassDef != null && feClassDef.Methods.ContainsKey("get_Item")) {
                if (feClassDef.Fields.ContainsKey("Count")) { feIsClassIter = true; feCountIsField = true; }
                else if (feClassDef.Methods.ContainsKey("Count")) { feIsClassIter = true; feCountIsField = false; }
            }
            return new BoundForeach(fe.Name, feElem, feIter, febody, feIsClassIter, feCountIsField, s.Span);
        }
        this._diags.Error(DiagnosticCodes.TypeMismatch, "unsupported statement (1A)", s.Span);
        return new BoundExprStmt(new BoundError("unsupported stmt", new Z42ErrorType(), s.Span), s.Span);
    }

    // `var x` → 推断 init 类型；显式类型 → 解析 + 检查 init 可赋。
    private Z42Type _varType(TypeEnv env, VarDeclStmt v, BoundExpr init) {
        if (v.Type is NamedType) {
            NamedType nt = v.Type as NamedType;
            if (nt.Name == "var") {
                if (init != null) { return init.Type(); }
                return new Z42UnknownType();              // G8：`var` 无 init 不可推断（实践不出现，防崩）
            }
        }
        Z42Type vt = env.ResolveType(v.Type);
        if (init != null && !this._isAssignable(init.Type(), vt, env.Symbols)) {   // G8：无 init 跳赋值检查
            this._diags.Error(DiagnosticCodes.TypeMismatch,
                "cannot assign " + init.Type().Name() + " to " + vt.Name(), v.Init.Span);
        }
        return vt;
    }

    // ════ 表达式（集中 if-is）═════════════════════════════════════════════════
    private BoundExpr _bindExpr(Expr e, TypeEnv env) {
        if (e is IntLitExpr) {
            IntLitExpr lit = e as IntLitExpr;
            // 镜像 C# TypeChecker.Exprs：字面量数值越 int 界（> int.MaxValue 或 < int.MinValue）
            // → 类型 long，否则 int。值解析复用 ZbcInstr._parseIntLit（hex/bin/十进制 + 后缀剥离）。
            long v = ZbcInstr._parseIntLit(lit.Value);
            long imax = 2147483647;
            long imin = 0 - 2147483647 - 1;
            Z42Type lt = new Z42PrimType("int");
            if (v > imax || v < imin) { lt = new Z42PrimType("long"); }
            return new BoundLitInt(lit.Value, lt, lit.Span);
        }
        if (e is CharLitExpr) {
            CharLitExpr ch = e as CharLitExpr;
            return new BoundLitChar(ch.Value, new Z42PrimType("char"), ch.Span);
        }
        if (e is FloatLitExpr) {
            FloatLitExpr lit = e as FloatLitExpr;
            return new BoundLitFloat(lit.Value, this._floatLitType(lit.Value), lit.Span);
        }
        if (e is StringLitExpr) {
            StringLitExpr lit = e as StringLitExpr;
            return new BoundLitStr(lit.Raw, new Z42PrimType("string"), lit.Span);
        }
        if (e is BoolLitExpr) {
            BoolLitExpr lit = e as BoolLitExpr;
            return new BoundLitBool(lit.Value, new Z42PrimType("bool"), lit.Span);
        }
        if (e is NullLitExpr) {
            return new BoundLitNull(new Z42UnknownType(), e.Span);
        }
        if (e is IdentExpr) {
            IdentExpr id = e as IdentExpr;
            Z42Type t = env.LookupVar(id.Name);
            if (t == null) {
                // 枚举类型名（如 GCHandleType）裸出现时不报 undefined——MemberExpr 路径会处理常量访问。
                if (env.Symbols.EnumTypes.ContainsKey(id.Name)) {
                    return new BoundIdent(id.Name, new Z42UnknownType(), id.Span);
                }
                // 方法组转换：自由函数名作值（`IntFn0 a = Helper`）→ func 引用（LoadFn）。
                if (env.Symbols.HasFunc(id.Name)) {
                    MethodSymbol mfs = env.Symbols.GetFunc(id.Name);
                    return new BoundFuncRef(id.Name, mfs.Signature, id.Span);
                }
                this._diags.Error(DiagnosticCodes.UndefinedSymbol, "undefined: " + id.Name, id.Span);
                return new BoundError("undefined " + id.Name, new Z42ErrorType(), id.Span);
            }
            // lambda 捕获钩子（port-z42c-closures）：域内未声明而外层命中 → 记捕获 + BoundCapturedIdent
            if (this._lambdaActive && !this._lambdaLocals.ContainsKey(id.Name)) {
                int ci = 0;
                int hit = 0 - 1;
                while (ci < this._lambdaCapCount) {
                    if (this._lambdaCaps[ci].Name == id.Name) { hit = ci; }
                    ci = ci + 1;
                }
                if (hit < 0) {
                    if (this._lambdaCapCount == this._lambdaCaps.Length) {
                        BoundCapture[] b = new BoundCapture[this._lambdaCaps.Length * 2];
                        int k = 0; while (k < this._lambdaCapCount) { b[k] = this._lambdaCaps[k]; k = k + 1; }
                        this._lambdaCaps = b;
                    }
                    hit = this._lambdaCapCount;
                    this._lambdaCaps[hit] = new BoundCapture(id.Name, t);
                    this._lambdaCapCount = this._lambdaCapCount + 1;
                }
                return new BoundCapturedIdent(id.Name, hit, t, id.Span);
            }
            return new BoundIdent(id.Name, t, id.Span);
        }
        if (e is AssignExpr) {
            AssignExpr a = e as AssignExpr;
            // 类索引器写 obj[i] = v → set_Item(i, v) 虚调用（仅简单 `=`；否则落普通路径）。
            if (a.Op == "=" && a.Target is IndexExpr) {
                IndexExpr aix = a.Target as IndexExpr;
                BoundExpr arecv = this._bindExpr(aix.Target, env);
                Z42Type att = arecv.Type();
                Z42ClassType aCls = null;
                if (att is Z42ClassType) { aCls = att as Z42ClassType; }
                else if (att is Z42InstantiatedType) { aCls = (att as Z42InstantiatedType).Def; }
                if (aCls != null && aCls.Methods.ContainsKey("set_Item")) {
                    BoundExpr aidx = this._bindExpr(aix.Index, env);
                    BoundExpr aval = this._bindExpr(a.Value, env);
                    BoundExpr[] sa = new BoundExpr[2]; sa[0] = aidx; sa[1] = aval;
                    return new BoundCall("instance", true, arecv, aCls.Name(), "set_Item", sa, 2, new Z42VoidType(), a.Span);
                }
            }
            // add-event-keyword-multicast：event 字段 `recv.E += h` / `-= h` → `recv.E.Subscribe(h)` /
            // `.Unsubscribe(h)`（recv 类的 EventFields 含该成员名时）。须在 compound desugar 前拦截。
            if ((a.Op == "+=" || a.Op == "-=") && a.Target is MemberExpr) {
                MemberExpr emtgt = a.Target as MemberExpr;
                BoundExpr erecv = this._bindExpr(emtgt.Target, env);
                Z42Type ertype = erecv.Type();
                Z42ClassType ecls = null;
                if (ertype is Z42ClassType) { ecls = ertype as Z42ClassType; }
                else if (ertype is Z42InstantiatedType) { ecls = (ertype as Z42InstantiatedType).Def; }
                if (ecls != null && ecls.EventFields.ContainsKey(emtgt.Name)) {
                    BoundExpr efield = this._bindMember(emtgt, env);   // field.get recv.E
                    BoundExpr erhs = this._bindExpr(a.Value, env);
                    string subMethod = (a.Op == "+=") ? "Subscribe" : "Unsubscribe";
                    string efcls = efield.Type().Name();
                    if (efield.Type() is Z42InstantiatedType) { efcls = (efield.Type() as Z42InstantiatedType).Def.Name(); }
                    BoundExpr[] sargs = new BoundExpr[1]; sargs[0] = erhs;
                    return new BoundCall("instance", true, efield, efcls, subMethod, sargs, 1, new Z42UnknownType(), a.Span);
                }
            }
            BoundExpr target = this._bindExpr(a.Target, env);
            BoundExpr value = this._bindExpr(a.Value, env);
            // 复合赋值 `x op= v` desugar → `x = x op v`（原 binder 忽略 a.Op 直存 value →
            // `+=` 退化成 `=`，丢旧值；arr[0]+=5 得 5 非 15）。binop = 去掉末尾 '='。
            if (a.Op != "=") {
                string binop = a.Op.Substring(0, a.Op.Length - 1);
                value = new BoundBinary(binop, target, value, target.Type(), a.Span);
            }
            if (!this._isAssignable(value.Type(), target.Type(), env.Symbols)) {
                this._diags.Error(DiagnosticCodes.TypeMismatch,
                    "cannot assign " + value.Type().Name() + " to " + target.Type().Name(), a.Value.Span);
            }
            return new BoundAssign(target, value, target.Type(), a.Span);
        }
        if (e is BinaryExpr) {
            return this._bindBinary(e as BinaryExpr, env);
        }
        if (e is UnaryExpr) {
            return this._bindUnary(e as UnaryExpr, env);
        }
        if (e is MemberExpr) {
            return this._bindMember(e as MemberExpr, env);
        }
        if (e is NullCondMemberExpr) {
            // obj?.member 脱糖：(recv != null) ? recv.member : null（复用 BoundConditional）。
            // 简单接收者双求值无副作用；goldens 均为局部接收者。
            NullCondMemberExpr nc = e as NullCondMemberExpr;
            BoundExpr access = this._bindMember(new MemberExpr(nc.Target, nc.Name, nc.Span), env);
            Z42Type mt = access.Type();
            BoundExpr recv = this._bindExpr(nc.Target, env);
            BoundExpr cond = new BoundBinary("!=", recv, new BoundLitNull(mt, nc.Span), new Z42PrimType("bool"), nc.Span);
            BoundExpr elseE = new BoundLitNull(mt, nc.Span);
            return new BoundConditional(cond, access, elseE, mt, nc.Span);
        }
        if (e is IsExpr) {
            IsExpr ix = e as IsExpr;
            BoundExpr operand = this._bindExpr(ix.E, env);
            // 用 AST 原始类型名（镜像 C# bin.Right ident → QualifyClassName），不用 resolved 类型：
            // Array/Object 等内建类 ResolveType 得 Unknown → "<unknown>"，致 is_instance 失配。
            string tn;
            if (ix.Type is NamedType) { tn = (ix.Type as NamedType).Name; }
            else { tn = env.ResolveType(ix.Type).Name(); }
            return new BoundIsExpr(operand, tn, ix.Span);
        }
        if (e is TypeofExpr) {
            TypeofExpr tox = e as TypeofExpr;
            Z42Type toTarget = env.ResolveType(tox.Type);
            // 结果类型 = Std.Type（反射 Type 类；Name/GetFields/FullName 等成员据此解析）。
            Z42Type toType = env.ResolveType(new NamedType("Type", new TypeExpr[0], 0, tox.Span));
            return new BoundTypeof(toTarget, toType, tox.Span);
        }
        if (e is AsExpr) {
            AsExpr ax = e as AsExpr;
            BoundExpr operand = this._bindExpr(ax.E, env);
            return new BoundCast(operand, env.ResolveType(ax.Type), ax.Span);
        }
        if (e is CastExpr) {                                    // C 风格 (T)x（G3）→ BoundConvert（结果类型 = T）
            CastExpr cx = e as CastExpr;
            BoundExpr operand = this._bindExpr(cx.E, env);
            return new BoundConvert(operand, env.ResolveType(cx.Type), cx.Span);
        }
        if (e is ArrayNewExpr) {
            ArrayNewExpr an = e as ArrayNewExpr;
            BoundExpr size = this._bindExpr(an.Size, env);
            Z42Type elem = env.ResolveType(an.Elem);
            return new BoundArrayNew(size, elem.Name(), new Z42ArrayType(elem), an.Span);
        }
        if (e is ArrayInitExpr) {
            ArrayInitExpr ai = e as ArrayInitExpr;
            Z42Type elem = env.ResolveType(ai.Elem);
            BoundExpr[] elems = new BoundExpr[ai.ElemCount];
            int bi = 0;
            while (bi < ai.ElemCount) { elems[bi] = this._bindExpr(ai.Elems[bi], env); bi = bi + 1; }
            return new BoundArrayLit(elems, ai.ElemCount, elem.Name(), new Z42ArrayType(elem), ai.Span);
        }
        if (e is RefArgExpr) {
            RefArgExpr ra = e as RefArgExpr;
            BoundExpr inner = this._bindExpr(ra.Inner, env);
            return new BoundRefArg(inner, new Z42UnknownType(), ra.Span);
        }
        if (e is ObjNewExpr) {
            return this._bindNew(e as ObjNewExpr, env);
        }
        if (e is DefaultExpr) {
            return this._bindDefault(e as DefaultExpr, env);
        }
        if (e is TernaryExpr) {
            TernaryExpr t = e as TernaryExpr;
            BoundExpr cond = this._bindExpr(t.Cond, env);
            this._requireBool(cond.Type(), "ternary", t.Cond.Span);
            BoundExpr thenE = this._bindExpr(t.Then, env);
            BoundExpr elseE = this._bindExpr(t.Else, env);
            return new BoundConditional(cond, thenE, elseE, this._commonType(thenE.Type(), elseE.Type(), env.Symbols), t.Span);
        }
        if (e is SwitchExpr) {
            SwitchExpr se = e as SwitchExpr;
            BoundExpr subj = this._bindExpr(se.Subject, env);
            BoundSwitchArm[] arms = new BoundSwitchArm[se.ArmCount];
            Z42Type resTy = new Z42UnknownType();
            int ai = 0;
            while (ai < se.ArmCount) {
                SwitchArm a = se.Arms[ai];
                BoundExpr pat = null;
                if (a.HasPattern) { pat = this._bindExpr(a.Pattern, env); }
                BoundExpr armBody = this._bindExpr(a.Body, env);
                if (ai == 0) { resTy = armBody.Type(); }
                arms[ai] = new BoundSwitchArm(a.HasPattern, pat, armBody, a.Span);
                ai = ai + 1;
            }
            return new BoundSwitchExpr(subj, arms, se.ArmCount, resTy, se.Span);
        }
        if (e is IndexExpr) {
            IndexExpr ix = e as IndexExpr;
            BoundExpr target = this._bindExpr(ix.Target, env);
            BoundExpr index = this._bindExpr(ix.Index, env);
            Z42Type tt = target.Type();
            if (tt is Z42ArrayType) {
                Z42ArrayType at = tt as Z42ArrayType;
                return new BoundIndex(target, index, at.Elem, ix.Span);
            }
            // 类索引器读 obj[i] → get_Item(i) 虚调用（泛型返回类型擦除为 Unknown）。
            Z42ClassType ixCls = null;
            if (tt is Z42ClassType) { ixCls = tt as Z42ClassType; }
            else if (tt is Z42InstantiatedType) { ixCls = (tt as Z42InstantiatedType).Def; }
            if (ixCls != null && ixCls.Methods.ContainsKey("get_Item")) {
                MethodSymbol gm = ixCls.Methods.Get("get_Item") as MethodSymbol;
                Z42Type gret = gm.Signature.Ret;
                if (gret is Z42GenericParamType) { gret = new Z42UnknownType(); }
                BoundExpr[] ia = new BoundExpr[1]; ia[0] = index;
                return new BoundCall("instance", true, target, ixCls.Name(), "get_Item", ia, 1, gret, ix.Span);
            }
            if ((tt is Z42ErrorType) || (tt is Z42UnknownType)) {
                return new BoundIndex(target, index, new Z42ErrorType(), ix.Span);
            }
            this._diags.Error(DiagnosticCodes.TypeMismatch, "index on non-array `" + tt.Name() + "`", ix.Span);
            return new BoundIndex(target, index, new Z42ErrorType(), ix.Span);
        }
        if (e is CallExpr) {
            return this._bindCall(e as CallExpr, env);
        }
        if (e is InterpolatedStringExpr) {
            return this._bindInterpolatedStr(e as InterpolatedStringExpr, env);
        }
        // GS6: lambda 作为调用参数（无 expected type 上下文）→ 按参数显式类型或 Unknown 合成 expected。
        if (e is LambdaExpr) {
            LambdaExpr lam2 = e as LambdaExpr;
            Z42Type[] lpts = new Z42Type[lam2.ParamCount];
            int li = 0;
            while (li < lam2.ParamCount) {
                if (lam2.Params[li].HasType) { lpts[li] = env.ResolveType(lam2.Params[li].Type); }
                else { lpts[li] = new Z42UnknownType(); }
                li = li + 1;
            }
            return this._bindLambda(lam2, new Z42FuncType(lpts, lam2.ParamCount, new Z42UnknownType()), env);
        }
        this._diags.Error(DiagnosticCodes.TypeMismatch, "unsupported expression (1A)", e.Span);
        return new BoundError("unsupported expr", new Z42ErrorType(), e.Span);
    }

    // GS4：插值字符串绑定。每 text → BoundInterpText；每 hole → 递归 _bindExpr → BoundInterpHole。
    // 结果类型恒为 string（镜像 C# TypeChecker.Exprs case InterpolatedStrExpr）。
    private BoundExpr _bindInterpolatedStr(InterpolatedStringExpr e, TypeEnv env) {
        BoundInterpPart[] bparts = new BoundInterpPart[e.PartCount];
        int i = 0;
        while (i < e.PartCount) {
            InterpPart p = e.Parts[i];
            if (p is InterpText) {
                InterpText tp = p as InterpText;
                bparts[i] = new BoundInterpText(tp.Text, tp.Span);
            } else {
                InterpHole hp = p as InterpHole;
                BoundExpr inner = this._bindExpr(hp.Inner, env);
                bparts[i] = new BoundInterpHole(inner, hp.Span);
            }
            i = i + 1;
        }
        return new BoundInterpolatedStr(bparts, e.PartCount, new Z42PrimType("string"), e.Span);
    }

    // ════ 运算（集中 if-is + BinaryTypeTable，1B）═══════════════════════════════
    private BoundExpr _bindBinary(BinaryExpr bin, TypeEnv env) {
        BoundExpr left  = this._bindExpr(bin.Left, env);
        BoundExpr right = this._bindExpr(bin.Right, env);
        Z42Type lt = left.Type();
        Z42Type rt = right.Type();
        if ((lt is Z42ErrorType) || (rt is Z42ErrorType)) {
            return new BoundBinary(bin.Op, left, right, new Z42ErrorType(), bin.Span);
        }
        // null 合并 a ?? b → 公共类型（不在拓宽表内）。
        if (bin.Op == "??") {
            return new BoundBinary("??", left, right, this._commonType(lt, rt, env.Symbols), bin.Span);
        }
        // 字符串拼接特例（任一侧 string）：先于查表，镜像 C# CheckBinary 前置。
        if (bin.Op == "+") {
            if (lt.Name() == "string" || rt.Name() == "string") {
                return new BoundBinary(bin.Op, left, right, new Z42PrimType("string"), bin.Span);
            }
        }
        // L3 运算符重载：左操作数为 class/struct（Z42ClassType）且有静态 op_X(2 参) →
        // 派发为 Class.op_X(a, b) 静态调用（镜像 C# TryBindOperatorCall）。原始数值对走下方表。
        string opMethod = this._operatorMethodNameTc(bin.Op);
        if (opMethod != "" && lt is Z42ClassType) {
            Z42ClassType lct = lt as Z42ClassType;
            string opKey = this._overloadKey(env.Symbols, lct, opMethod, 2);
            MethodSymbol opMs = this._findMethod(env.Symbols, lct, opKey);
            if (opMs != null) {
                BoundExpr[] opArgs = new BoundExpr[2];
                opArgs[0] = left; opArgs[1] = right;
                return new BoundCall("static", false, null, lct.Name(), opKey, opArgs, 2, opMs.Signature.Ret, bin.Span);
            }
        }
        BinaryRule rule = BinaryTypeTable.Lookup(bin.Op);
        if (!rule.Known) {
            return new BoundBinary(bin.Op, left, right, new Z42UnknownType(), bin.Span);
        }
        this._checkOperand(rule.Left,  rule.Requirement, lt, bin.Op, bin.Left.Span);
        this._checkOperand(rule.Right, rule.Requirement, rt, bin.Op, bin.Right.Span);
        return new BoundBinary(bin.Op, left, right, BinaryTypeTable.ResultType(rule.Out, lt, rt), bin.Span);
    }

    private BoundExpr _bindUnary(UnaryExpr u, TypeEnv env) {
        BoundExpr operand = this._bindExpr(u.Operand, env);
        Z42Type ot = operand.Type();
        if (ot is Z42ErrorType) {
            return new BoundUnary(u.Op, operand, new Z42ErrorType(), u.Span);
        }
        BinaryRule rule = BinaryTypeTable.LookupUnary(u.Op);
        if (!rule.Known) {
            return new BoundUnary(u.Op, operand, ot, u.Span);
        }
        this._checkOperand(rule.Left, rule.Requirement, ot, u.Op, u.Operand.Span);
        return new BoundUnary(u.Op, operand, BinaryTypeTable.ResultType(rule.Out, ot, ot), u.Span);
    }

    // 操作数约束检查（None / unknown / error → 跳过，防级联）。镜像 C# CheckBinaryOperand。
    private void _checkOperand(int kind, string req, Z42Type t, string op, Span sp) {
        if (kind == OperandKind.None) { return; }
        if ((t is Z42UnknownType) || (t is Z42ErrorType)) { return; }
        if (!TypeFacts.SatisfiesKind(kind, t)) {
            this._diags.Error(DiagnosticCodes.TypeMismatch,
                "operator `" + op + "` requires " + req + " operand, got `" + t.Name() + "`", sp);
        }
    }

    // 条件必须 bool（if/while）。error/unknown 吸收。镜像 C# RequireBool。
    private void _requireBool(Z42Type t, string context, Span sp) {
        if ((t is Z42ErrorType) || (t is Z42UnknownType)) { return; }
        if (!TypeFacts.IsBool(t)) {
            this._diags.Error(DiagnosticCodes.TypeMismatch,
                "`" + context + "` condition must be `bool`, got `" + t.Name() + "`", sp);
        }
    }

    // 浮点字面量类型：f/F 后缀 → float，否则 double（d/D/m/M 归 double）。
    private Z42Type _floatLitType(string text) {
        int n = text.Length;
        if (n > 0) {
            char last = text.CharAt(n - 1);
            if (last == 'f' || last == 'F') { return new Z42PrimType("float"); }
        }
        return new Z42PrimType("double");
    }

    // ════ 成员字段访问（1C）═══════════════════════════════════════════════════
    private BoundExpr _bindMember(MemberExpr m, TypeEnv env) {
        // 裸类名静态字段读（SA-2）：Sev.Error——target 是类名（非变量）→ StaticGet
        if (m.Target is IdentExpr) {
            IdentExpr tid = m.Target as IdentExpr;
            if (env.LookupVar(tid.Name) == null && env.Symbols.HasClass(tid.Name)) {
                Z42ClassType sct = env.Symbols.GetClass(tid.Name);
                FieldSymbol sfs = sct.Fields.Get(m.Name) as FieldSymbol;
                if (sfs != null && sfs.IsStatic) {
                    return new BoundStaticGet(tid.Name, m.Name, sfs.FieldType, m.Span);
                }
            }
            // 枚举常量访问 `EnumType.Member` → BoundLitInt（long）。
            if (env.LookupVar(tid.Name) == null && env.Symbols.EnumTypes.ContainsKey(tid.Name)) {
                string ekey = tid.Name + "." + m.Name;
                if (env.Symbols.EnumConsts.ContainsKey(ekey)) {
                    StrBox evalBox = env.Symbols.EnumConsts.Get(ekey) as StrBox;
                    return new BoundLitInt(evalBox.Value, new Z42PrimType("long"), m.Span);
                }
            }
        }
        BoundExpr target = this._bindExpr(m.Target, env);
        Z42Type tt = target.Type();
        if (tt is Z42ClassType) {
            Z42ClassType ct = tt as Z42ClassType;
            FieldSymbol fs = this._findField(env.Symbols, ct, m.Name);
            if (fs != null) { return new BoundMember(target, m.Name, fs.FieldType, m.Span); }
            // 属性 getter 派发：无字段但有 get_<Name>(0 参) → 虚调用 getter（镜像 C#）。
            MethodSymbol getter = this._findMethod(env.Symbols, ct, "get_" + m.Name);
            if (getter != null && getter.Signature != null) {
                return new BoundCall("instance", true, target, ct.Name(), "get_" + m.Name, new BoundExpr[0], 0, getter.Signature.Ret, m.Span);
            }
            this._diags.Error(DiagnosticCodes.UndefinedSymbol,
                "no field `" + m.Name + "` on `" + ct.Name() + "`", m.Span);
            return new BoundMember(target, m.Name, new Z42ErrorType(), m.Span);
        }
        // 接口收者属性访问：get_<Name>() 虚调用（接口 getter 已注册为 get_X 方法符号）。
        if (tt is Z42InterfaceType) {
            Z42InterfaceType it = tt as Z42InterfaceType;
            MethodSymbol ig = it.Methods.Get("get_" + m.Name) as MethodSymbol;
            if (ig != null && ig.Signature != null) {
                return new BoundCall("instance", true, target, it.Name(), "get_" + m.Name, new BoundExpr[0], 0, ig.Signature.Ret, m.Span);
            }
            return new BoundMember(target, m.Name, new Z42ErrorType(), m.Span);
        }
        // Length on array OR string → int；Count → int（镜像 C# TypeChecker.Exprs.Members 行 161-164：
        // `m.Member is "Length" && (target.Type is Z42ArrayType || target.Type == Z42Type.String)`）。
        if (m.Name == "Length" && ((tt is Z42ArrayType) || (tt is Z42PrimType && tt.Name() == "string"))) {
            return new BoundMember(target, m.Name, new Z42PrimType("int"), m.Span);
        }
        if (m.Name == "Count") {
            return new BoundMember(target, m.Name, new Z42PrimType("int"), m.Span);
        }
        if ((tt is Z42ErrorType) || (tt is Z42UnknownType)) {
            return new BoundMember(target, m.Name, new Z42ErrorType(), m.Span);
        }
        // GS5：泛型类型形参（TKey/TValue 等）上的成员访问松绑到 Unknown（调用方再按 DepIndex 真实解析）。
        if (tt is Z42GenericParamType) {
            return new BoundMember(target, m.Name, new Z42UnknownType(), m.Span);
        }
        // GS6: 泛型实例化类型（LinkedListNode<T> 等）成员访问 → 查 Def 类字段，泛型字段类型松绑 Unknown。
        if (tt is Z42InstantiatedType) {
            Z42ClassType itDef = (tt as Z42InstantiatedType).Def;
            FieldSymbol itFs = this._findField(env.Symbols, itDef, m.Name);
            if (itFs != null) {
                Z42Type fType = itFs.FieldType;
                if (fType is Z42GenericParamType) { fType = new Z42UnknownType(); }
                return new BoundMember(target, m.Name, fType, m.Span);
            }
            return new BoundMember(target, m.Name, new Z42UnknownType(), m.Span);
        }
        // prim receiver 属性访问（镜像 _bindMemberCall 的 prim 处理）：prim 名首字母大写 →
        // stdlib 包装类（"string"→"String"，imported 自 z42.core TSIG）→ 取字段/属性真类型；
        // 查无则松绑 Unknown（codegen 经 DepIndex/VM builtin 真实解析，如 string.Length）。
        string wrapper = TypeChecker._primWrapper(tt.Name());
        if (env.Symbols.HasClass(wrapper)) {
            Z42ClassType wct = env.Symbols.GetClass(wrapper);
            FieldSymbol wfs = this._findField(env.Symbols, wct, m.Name);
            if (wfs != null) { return new BoundMember(target, m.Name, wfs.FieldType, m.Span); }
            return new BoundMember(target, m.Name, new Z42UnknownType(), m.Span);
        }
        this._diags.Error(DiagnosticCodes.TypeMismatch,
            "member access on non-class `" + tt.Name() + "`", m.Span);
        return new BoundMember(target, m.Name, new Z42ErrorType(), m.Span);
    }

    // 字段查找：本类 → base 链（迭代）。
    private FieldSymbol _findField(SymbolTable symbols, Z42ClassType ct, string name) {
        Z42ClassType cur = ct;
        bool more = true;
        while (more) {
            if (cur.Fields.ContainsKey(name)) { return cur.Fields.Get(name) as FieldSymbol; }
            if (!cur.HasBase) {
                // 无显式 base 的 class 隐式继承 Object（struct 不继承，但字段不含在 Object）。
                if (cur.Name() != "Object" && symbols.HasClass("Object")) { cur = symbols.GetClass("Object"); }
                else { more = false; }
            } else {
                Z42ClassType b = symbols.GetClass(cur.BaseName);
                if (b == null) { more = false; } else { cur = b; }
            }
        }
        return null;
    }

    // 赋值兼容（含类继承 subclass→base）。error/unknown 任一侧吸收（防级联）。非 class 走 Z42Type.IsAssignableTo。
    private bool _isAssignable(Z42Type from, Z42Type to, SymbolTable symbols) {
        if ((from is Z42ErrorType) || (from is Z42UnknownType)) { return true; }
        if ((to is Z42ErrorType) || (to is Z42UnknownType)) { return true; }
        // GS6: 泛型类型参数（T）类型擦除——仅当恰好一侧是 GenericParamType 时放行（T→concrete 或 concrete→T）。
        // 两侧均为 GenericParamType（K→V）走 IsAssignableTo 判同名；两侧均为 concrete 走普通路径。
        if ((from is Z42GenericParamType) != (to is Z42GenericParamType)) { return true; }
        // GS6: 任何类型均可赋给 object（通用基类）
        if ((to is Z42PrimType) && (to.Name() == "object")) { return true; }
        if (from.IsAssignableTo(to)) { return true; }
        if ((from is Z42ClassType) && (to is Z42ClassType)) {
            return symbols.IsSubclassOf(from.Name(), to.Name());
        }
        if ((from is Z42ClassType) && (to is Z42InterfaceType)) {   // class→iface（port-z42c-interface；单向）
            return symbols.Implements(from.Name(), to.Name());
        }
        if ((from is Z42InstantiatedType) && (to is Z42InterfaceType)) {   // generic class instance → iface
            return symbols.Implements((from as Z42InstantiatedType).Def.Name(), to.Name());
        }
        if ((from is Z42InstantiatedType) && (to is Z42ClassType)) {   // generic class instance → base class
            return symbols.IsSubclassOf((from as Z42InstantiatedType).Def.Name(), to.Name());
        }
        if ((from is Z42ClassType) && (to is Z42InstantiatedType)) {   // `this` (bare class) → instantiated return type
            return from.Name() == (to as Z42InstantiatedType).Def.Name();
        }
        // GS6: 数值 prim 互相窄化（int→u8 等，stdlib 二进制格式大量使用）—— 信任程序员，运行期截断
        if ((from is Z42PrimType) && (to is Z42PrimType)) {
            if (TypeChecker._isNumericPrim(from.Name()) && TypeChecker._isNumericPrim(to.Name())) { return true; }
        }
        return false;
    }

    private BoundExpr _bindCall(CallExpr call, TypeEnv env) {
        BoundExpr[] args = new BoundExpr[call.ArgCount];
        int i = 0;
        while (i < call.ArgCount) { args[i] = this._bindExpr(call.Args[i], env); i = i + 1; }
        // 顶层自由函数：f(args)
        if (call.Callee is IdentExpr) {
            IdentExpr id = call.Callee as IdentExpr;
            Z42Type vfn = env.LookupVar(id.Name);
            if (vfn != null && (vfn is Z42FuncType)) {              // Func 值间接调用（port-z42c-closures）
                BoundExpr callee = this._bindExpr(call.Callee, env);
                return new BoundIndirectCall(callee, args, call.ArgCount, (vfn as Z42FuncType).Ret, call.Span);
            }
            // impl-local-fn-l2：局部函数调用 → BoundCall "free"（local 名；emit 期改写为 lifted 名）。
            Z42FuncType lfsig = env.LookupLocalFn(id.Name);
            if (lfsig != null) {
                return new BoundCall("free", false, null, "", id.Name, args, call.ArgCount, lfsig.Ret, call.Span);
            }
            if (env.Symbols.HasFunc(id.Name)) {
                MethodSymbol ms = env.Symbols.GetFunc(id.Name);
                return new BoundCall("free", false, null, "", id.Name, args, call.ArgCount, ms.Signature.Ret, call.Span);
            }
            // 同类无限定静态调用（unqualified static call within class body：OSKindValue() inside Platform）。
            if (env.HasClass()) {
                string cls = env.CurrentClass();
                if (env.Symbols.HasClass(cls)) {
                    Z42ClassType sct = env.Symbols.GetClass(cls);
                    string smkey = this._overloadKey(env.Symbols, sct, id.Name, call.ArgCount);
                    MethodSymbol sms = this._findMethod(env.Symbols, sct, smkey);
                    if (sms != null && sms.IsStatic) {
                        return new BoundCall("static", false, null, cls, smkey, args, call.ArgCount, sms.Signature.Ret, call.Span);
                    }
                }
            }
            this._diags.Error(DiagnosticCodes.UndefinedSymbol, "undefined function: " + id.Name, call.Span);
            return new BoundCall("free", false, null, "", id.Name, args, call.ArgCount, new Z42ErrorType(), call.Span);
        }
        // 成员调用：obj.m(args) / Class.m(args)
        if (call.Callee is MemberExpr) {
            return this._bindMemberCall(call.Callee as MemberExpr, args, call.ArgCount, env, call.Span);
        }
        // 通用间接调用：array[i](args) / method()(args) 等 callee 是任意表达式且类型为 Z42FuncType。
        // Z42GenericParamType：泛型接口方法返回类型参数（如 ISubscription<TD>.Get()→TD）；type-erased，运行期解析。
        {
            BoundExpr callee = this._bindExpr(call.Callee, env);
            Z42Type ct = callee.Type();
            if (ct is Z42FuncType) {
                return new BoundIndirectCall(callee, args, call.ArgCount, (ct as Z42FuncType).Ret, call.Span);
            }
            if (ct is Z42GenericParamType) {
                return new BoundIndirectCall(callee, args, call.ArgCount, new Z42UnknownType(), call.Span);
            }
        }
        this._diags.Error(DiagnosticCodes.TypeMismatch, "unsupported call form", call.Span);
        return new BoundError("unsupported call", new Z42ErrorType(), call.Span);
    }

    private BoundExpr _bindMemberCall(MemberExpr mem, BoundExpr[] args, int argCount, TypeEnv env, Span sp) {
        // fix-namespace-qualified-free-call：`ns.func()` 当 ns=当前命名空间且 func 是自由函数
        // → 自由调用（否则被误当类 ns 的静态调用 → 双限定 ns.ns.func → 运行期 undefined）。
        if (mem.Target is IdentExpr) {
            IdentExpr nsId = mem.Target as IdentExpr;
            if (this._currentNs != "" && nsId.Name == this._currentNs
                && env.LookupVar(nsId.Name) == null && env.Symbols.HasFunc(mem.Name)) {
                MethodSymbol nfs = env.Symbols.GetFunc(mem.Name);
                return new BoundCall("free", false, null, "", mem.Name, args, argCount, nfs.Signature.Ret, sp);
            }
        }
        // 静态：target 是裸类名（非局部变量）→ Class.m(args)
        if (mem.Target is IdentExpr) {
            IdentExpr tid = mem.Target as IdentExpr;
            if (env.LookupVar(tid.Name) == null && env.Symbols.HasClass(tid.Name)) {
                Z42ClassType ct = env.Symbols.GetClass(tid.Name);
                string mkey = this._overloadKey(env.Symbols, ct, mem.Name, argCount);
                MethodSymbol ms = this._findMethod(env.Symbols, ct, mkey);
                if (ms != null) {
                    return new BoundCall("static", false, null, ct.Name(), mkey, args, argCount, ms.Signature.Ret, sp);
                }
                this._diags.Error(DiagnosticCodes.UndefinedSymbol,
                    "no static method `" + mem.Name + "` on `" + ct.Name() + "`", sp);
                return new BoundCall("static", false, null, tid.Name, mem.Name, args, argCount, new Z42ErrorType(), sp);
            }
        }
        // GS6: prim 关键字静态调用（int.Parse / string.FromChars 等）→ wrapper class 静态方法
        if (mem.Target is IdentExpr) {
            IdentExpr tid2 = mem.Target as IdentExpr;
            if (env.LookupVar(tid2.Name) == null && TypeChecker._isPrimKeyword(tid2.Name)) {
                string pwrap2 = TypeChecker._primWrapper(tid2.Name);
                if (env.Symbols.HasClass(pwrap2)) {
                    Z42ClassType wct2 = env.Symbols.GetClass(pwrap2);
                    string wmkey2 = this._overloadKey(env.Symbols, wct2, mem.Name, argCount);
                    MethodSymbol wms2 = this._findMethod(env.Symbols, wct2, wmkey2);
                    if (wms2 != null) {
                        return new BoundCall("static", false, null, pwrap2, wmkey2, args, argCount, wms2.Signature.Ret, sp);
                    }
                    this._diags.Error(DiagnosticCodes.UndefinedSymbol,
                        "no static method `" + mem.Name + "` on `" + pwrap2 + "`", sp);
                    return new BoundCall("static", false, null, pwrap2, mem.Name, args, argCount, new Z42ErrorType(), sp);
                }
            }
        }
        // 实例：bind target 为值
        BoundExpr recv = this._bindExpr(mem.Target, env);
        Z42Type rt = recv.Type();
        if (rt is Z42ClassType) {
            Z42ClassType ct = rt as Z42ClassType;
            string mkey = this._overloadKey(env.Symbols, ct, mem.Name, argCount);
            MethodSymbol ms = this._findMethod(env.Symbols, ct, mkey);
            if (ms != null) {
                return new BoundCall("instance", true, recv, ct.Name(), mkey, args, argCount, ms.Signature.Ret, sp);
            }
            this._diags.Error(DiagnosticCodes.UndefinedSymbol,
                "no method `" + mem.Name + "` on `" + ct.Name() + "`", sp);
            return new BoundCall("instance", true, recv, ct.Name(), mem.Name, args, argCount, new Z42ErrorType(), sp);
        }
        if (rt is Z42InterfaceType) {                                // 接口收者（port-z42c-interface）
            Z42InterfaceType it = rt as Z42InterfaceType;
            MethodSymbol ims = it.Methods.Get(mem.Name) as MethodSymbol;
            if (ims != null) {
                return new BoundCall("instance", true, recv, it.Name(), mem.Name, args, argCount, ims.Signature.Ret, sp);
            }
            this._diags.Error(DiagnosticCodes.UndefinedSymbol,
                "no method `" + mem.Name + "` on interface `" + it.Name() + "`", sp);
            return new BoundCall("instance", true, recv, it.Name(), mem.Name, args, argCount, new Z42ErrorType(), sp);
        }
        if ((rt is Z42ErrorType) || (rt is Z42UnknownType)) {
            return new BoundCall("instance", true, recv, "<?>", mem.Name, args, argCount, new Z42ErrorType(), sp);
        }
        // GS6: 泛型实例化类型（LinkedList<T>.Next() 等）→ 查 Def 类方法，返回类型泛型参数松绑 Unknown。
        if (rt is Z42InstantiatedType) {
            Z42ClassType itDef2 = (rt as Z42InstantiatedType).Def;
            string itmkey = this._overloadKey(env.Symbols, itDef2, mem.Name, argCount);
            MethodSymbol itms = this._findMethod(env.Symbols, itDef2, itmkey);
            if (itms != null) {
                Z42Type itRet = itms.Signature.Ret;
                if (itRet is Z42GenericParamType) { itRet = new Z42UnknownType(); }
                return new BoundCall("instance", true, recv, itDef2.Name(), itmkey, args, argCount, itRet, sp);
            }
            return new BoundCall("instance", true, recv, itDef2.Name(), mem.Name, args, argCount, new Z42UnknownType(), sp);
        }
        // Z42GenericParamType：T.GetHashCode() 等继承自 Object 的方法 → 查 Object 类取真实返回类型。
        if (rt is Z42GenericParamType) {
            if (env.Symbols.HasClass("Object")) {
                Z42ClassType objCt = env.Symbols.GetClass("Object");
                string gpMkey = this._overloadKey(env.Symbols, objCt, mem.Name, argCount);
                MethodSymbol gpMs = this._findMethod(env.Symbols, objCt, gpMkey);
                if (gpMs != null) {
                    return new BoundCall("instance", true, recv, rt.Name(), gpMkey, args, argCount, gpMs.Signature.Ret, sp);
                }
            }
            return new BoundCall("instance", true, recv, rt.Name(), mem.Name, args, argCount, new Z42UnknownType(), sp);
        }
        // prim receiver（IC-3，镜像 C#）：prim 名首字母大写 → stdlib 包装类（"string"→"String"，
        // imported 自 z42.core TSIG）→ 取方法 ret 真类型（dst tag 字节实证 Str 非 Unknown）；
        // 查无则松绑定 Unknown（codegen 经 DepIndex 真实解析）。
        string wrapper = TypeChecker._primWrapper(rt.Name());
        if (env.Symbols.HasClass(wrapper)) {
            Z42ClassType wct = env.Symbols.GetClass(wrapper);
            string mkey = this._overloadKey(env.Symbols, wct, mem.Name, argCount);
            MethodSymbol wms = this._findMethod(env.Symbols, wct, mkey);
            if (wms != null) {
                return new BoundCall("instance", true, recv, rt.Name(), mkey, args, argCount, wms.Signature.Ret, sp);
            }
        }
        return new BoundCall("instance", true, recv, rt.Name(), mem.Name, args, argCount, new Z42UnknownType(), sp);
    }

    // lambda 绑定（port-z42c-closures；expected 自声明类型）：参数类型 = 显式或 expected 对位；
    // 体在 frame 下绑定（捕获钩子激活；嵌套 lambda 延后——frame 不重入）。
    private BoundExpr _bindLambda(LambdaExpr lam, Z42FuncType expected, TypeEnv env) {
        if (lam.ParamCount != expected.ParamCount) {
            this._diags.Error(DiagnosticCodes.TypeMismatch,
                "lambda arity " + lam.ParamCount.ToString() + " != expected " + expected.ParamCount.ToString(), lam.Span);
        }
        string[] pnames = new string[lam.ParamCount];
        Z42Type[] ptypes = new Z42Type[lam.ParamCount];
        TypeEnv lenv = env.PushScope();
        int i = 0;
        while (i < lam.ParamCount) {
            pnames[i] = lam.Params[i].Name;
            Z42Type pt = new Z42UnknownType();
            if (lam.Params[i].HasType) { pt = env.ResolveType(lam.Params[i].Type); }
            else if (i < expected.ParamCount) { pt = expected.ParamTypes[i]; }
            ptypes[i] = pt;
            lenv.Define(pnames[i], pt);
            i = i + 1;
        }
        // frame 激活（不重入：嵌套 lambda 延后）
        this._lambdaActive = true;
        this._lambdaLocals = new StrMap();
        i = 0;
        while (i < lam.ParamCount) { this._lambdaLocals.Put(pnames[i], ptypes[i]); i = i + 1; }
        this._lambdaCaps = new BoundCapture[2];
        this._lambdaCapCount = 0;
        BoundExpr exprBody = null;
        BoundStmt blockBody = null;
        if (lam.HasBlock) { blockBody = this._bindStmt(lam.BlockBody, lenv, expected.Ret); }
        else { exprBody = this._bindExpr(lam.ExprBody, lenv); }
        this._lambdaActive = false;
        BoundCapture[] caps = new BoundCapture[this._lambdaCapCount];
        i = 0;
        while (i < this._lambdaCapCount) { caps[i] = this._lambdaCaps[i]; i = i + 1; }
        return new BoundLambda(pnames, ptypes, lam.ParamCount,
                               lam.HasBlock, exprBody, blockBody,
                               caps, this._lambdaCapCount, expected, lam.Span);
    }

    // prim 名 → stdlib 包装类 BCL 简名（镜像 C# WellKnownTypes/TypeRegistry：int→Int32 等，
    // 取代旧 CapitalizeFirst 启发式——`int→Int` 错，真名是 `Int32`；string→String 巧合相同）。
    private static string _primWrapper(string n) {
        if (n == "int"    || n == "i32") { return "Int32"; }
        if (n == "long"   || n == "i64") { return "Int64"; }
        if (n == "short"  || n == "i16") { return "Int16"; }
        if (n == "sbyte"  || n == "i8")  { return "SByte"; }
        if (n == "byte"   || n == "u8")  { return "Byte"; }
        if (n == "ushort" || n == "u16") { return "UInt16"; }
        if (n == "uint"   || n == "u32") { return "UInt32"; }
        if (n == "ulong"  || n == "u64") { return "UInt64"; }
        if (n == "float"  || n == "f32") { return "Single"; }
        if (n == "double" || n == "f64") { return "Double"; }
        if (n == "bool") { return "Boolean"; }
        if (n == "char") { return "Char"; }
        if (n == "string") { return "String"; }
        return TypeChecker._capFirst(n);   // 其它（已是 PascalCase 或未知）→ 首字母大写回退
    }

    // GS6: 判断是否为 prim 关键字（_bindMemberCall 静态路由用）。
    private static bool _isPrimKeyword(string n) {
        if (n == "int"    || n == "i32")  { return true; }
        if (n == "long"   || n == "i64")  { return true; }
        if (n == "short"  || n == "i16")  { return true; }
        if (n == "sbyte"  || n == "i8")   { return true; }
        if (n == "byte"   || n == "u8")   { return true; }
        if (n == "ushort" || n == "u16")  { return true; }
        if (n == "uint"   || n == "u32")  { return true; }
        if (n == "ulong"  || n == "u64")  { return true; }
        if (n == "float"  || n == "f32")  { return true; }
        if (n == "double" || n == "f64")  { return true; }
        if (n == "bool"   || n == "char") { return true; }
        if (n == "string") { return true; }
        return false;
    }

    // GS6: 判断是否为数值 prim（_isAssignable 窄化用）。
    private static bool _isNumericPrim(string n) {
        if (n == "int"    || n == "i32")  { return true; }
        if (n == "long"   || n == "i64")  { return true; }
        if (n == "short"  || n == "i16")  { return true; }
        if (n == "sbyte"  || n == "i8")   { return true; }
        if (n == "byte"   || n == "u8")   { return true; }
        if (n == "ushort" || n == "u16")  { return true; }
        if (n == "uint"   || n == "u32")  { return true; }
        if (n == "ulong"  || n == "u64")  { return true; }
        if (n == "float"  || n == "f32")  { return true; }
        if (n == "double" || n == "f64")  { return true; }
        if (n == "char") { return true; }
        return false;
    }

    // prim 名 → 首字母大写（_primWrapper 的回退）。
    private static string _capFirst(string name) {
        if (name.Length == 0) { return name; }
        string head = name.Substring(0, 1).ToUpper();
        return head + name.Substring(1, name.Length - 1);
    }

    // 两分支公共类型（三目 / ??）：互为可赋取较宽，否则取左（C# 报错；1E 简化）。
    private Z42Type _commonType(Z42Type a, Z42Type b, SymbolTable symbols) {
        if (this._isAssignable(a, b, symbols)) { return b; }
        if (this._isAssignable(b, a, symbols)) { return a; }
        return a;
    }

    // default(T)（GS7 / D-8b-3 Phase 2）：泛型类型参数 → BoundDefault(paramIndex)；其他 → BoundDefault(-1)。
    private BoundExpr _bindDefault(DefaultExpr d, TypeEnv env) {
        Z42Type t = env.ResolveType(d.Target);
        if (t is Z42GenericParamType) {
            string pname = t.Name();
            int idx = 0;
            int pi = 0;
            while (pi < env.TypeParamCount) {
                if (env.TypeParamNames[pi] == pname) { idx = pi; pi = env.TypeParamCount + 1; }
                else { pi = pi + 1; }
            }
            return new BoundDefault(t, idx, d.Span);
        }
        return new BoundDefault(t, -1, d.Span);
    }

    // new T(args)（1D）：解析 T（须为已知类型）+ 绑定实参 + ctor 重载解析。
    private BoundExpr _bindNew(ObjNewExpr n, TypeEnv env) {
        Z42Type t = env.ResolveType(n.Type);
        if (t is Z42UnknownType) {
            this._diags.Error(DiagnosticCodes.UndefinedSymbol, "unknown type in `new`: " + n.Type.Dump(), n.Span);
        }
        if (t is Z42InstantiatedType) {   // 2B：泛型实例化 → 校验型参约束（委托 ConstraintChecker）
            this._constraints.Check(env.GetSymbols(), t as Z42InstantiatedType);
        }
        // ctor 重载键（镜像 C# ResolveCtorName：单 ctor bare、重载 Name$argCount）
        Z42ClassType cls = null;
        if (t is Z42ClassType) { cls = t as Z42ClassType; }
        if (t is Z42InstantiatedType) { cls = (t as Z42InstantiatedType).Def; }
        string ctorName = cls != null ? this._ctorKey(cls, n.ArgCount) : "";
        // GS1/named-arg：命名实参重排 + 可选参数默认值填充（镜像 C#——工厂体 `new Route("/u", method:"POST")`
        // 及省略可选实参 `new Route("/h")` 须在调用点解析为完整位置实参序）。仅本地有 Decl 的 ctor 适配。
        MethodSymbol cms = null;
        if (cls != null) { cms = this._findMethod(env.Symbols, cls, ctorName); }
        if (cms != null && cms.HasDecl && cms.Decl != null) {
            BoundExpr[] adapted = this._adaptArgs(cms.Decl, n.Args, n.ArgCount, env);
            if (adapted != null) { return new BoundNew(t.Name(), ctorName, adapted, cms.Decl.ParamCount, t, n.Span); }
        }
        BoundExpr[] args = new BoundExpr[n.ArgCount];
        int i = 0;
        while (i < n.ArgCount) { args[i] = this._bindExpr(n.Args[i], env); i = i + 1; }
        return new BoundNew(t.Name(), ctorName, args, n.ArgCount, t, n.Span);
    }

    // 命名实参重排 + 默认值填充（镜像 C# 调用绑定）：
    //   位置实参按序填；命名实参 `name: val`（AssignExpr，Target=ident）按形参名定位；
    //   未填形参用其 Default 表达式（无默认 → 绑定失败返回 null，回落旧 1:1 路径报常规错误）。
    // 返回长度 = md.ParamCount 的已绑定实参数组；不可适配（实参多于形参/缺默认/命名未匹配）→ null。
    private BoundExpr[] _adaptArgs(MethodDecl md, Expr[] callArgs, int callArgCount, TypeEnv env) {
        int pc = md.ParamCount;
        if (callArgCount > pc) { return null; }
        BoundExpr[] slots = new BoundExpr[pc];
        bool[] filled = new bool[pc];
        int pos = 0;
        int i = 0;
        while (i < callArgCount) {
            Expr a = callArgs[i];
            if (a is AssignExpr && (a as AssignExpr).Target is IdentExpr) {
                AssignExpr ae = a as AssignExpr;
                string nm = (ae.Target as IdentExpr).Name;
                int idx = 0 - 1;
                int p = 0;
                while (p < pc) { if (md.Params[p].Name == nm) { idx = p; } p = p + 1; }
                if (idx < 0) { return null; }                 // 命名实参无匹配形参 → 不可适配
                if (filled[idx]) { return null; }
                slots[idx] = this._bindExpr(ae.Value, env); filled[idx] = true;
            } else {
                if (pos >= pc) { return null; }
                slots[pos] = this._bindExpr(a, env); filled[pos] = true; pos = pos + 1;
            }
            i = i + 1;
        }
        int k = 0;
        while (k < pc) {
            if (!filled[k]) {
                if (md.Params[k].Default == null) { return null; }   // 缺实参且无默认 → 不可适配
                slots[k] = this._bindExpr(md.Params[k].Default, env);
            }
            k = k + 1;
        }
        return slots;
    }

    // ctor 方法键：重载存 Name$argCount，唯一 ctor 存 bare Name，无显式 ctor → bare Name。
    private string _ctorKey(Z42ClassType ct, int argCount) {
        string name = ct.Name();
        string ak = name + "$" + argCount.ToString();
        if (ct.Methods.ContainsKey(ak)) { return ak; }
        return name;
    }

    // 方法查找：本类 → base 链（迭代）。
    // 重载 arity 解析键（镜像 C# instArityKey / BindMemberCallOnPrimitive 的 primArityKey）：
    // 重载方法在 TSIG 以 `Name$arity` 存（如 String.Split→`Split$1`/`Split$2`），unique 方法存 bare。
    // 故 `Name$argCount` 键存在 → 该 overload，发 mangled 名；否则 bare。emit 名须用此键
    // （byte-identical：C# v_call 发 `Split$1` 非 `Split`）。对 unique 方法 arity 键不存在 → 退回 bare，
    // 6 个已 byte-identical 包不受影响（其调用皆 unique 方法）。
    private string _overloadKey(SymbolTable symbols, Z42ClassType ct, string name, int argCount) {
        string ak = name + "$" + argCount.ToString();
        if (this._findMethod(symbols, ct, ak) != null) { return ak; }
        return name;
    }

    private MethodSymbol _findMethod(SymbolTable symbols, Z42ClassType ct, string name) {
        Z42ClassType cur = ct;
        bool more = true;
        while (more) {
            if (cur.Methods.ContainsKey(name)) { return cur.Methods.Get(name) as MethodSymbol; }
            if (!cur.HasBase) {
                // 无显式 base 的 class 隐式继承 Object（mirror C# object root；struct 无 Object 方法）。
                if (cur.Name() != "Object" && symbols.HasClass("Object")) { cur = symbols.GetClass("Object"); }
                else { more = false; }
            } else {
                Z42ClassType b = symbols.GetClass(cur.BaseName);
                if (b == null) { more = false; } else { cur = b; }
            }
        }
        return null;
    }

}
