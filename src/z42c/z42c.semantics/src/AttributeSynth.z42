// add-attribute-reflection（镜像 C# AttributeFactorySynthesizer）：parse 后、typecheck 前的 AST 级
// 下降——把每个用户 attribute 应用 `[Foo(args)]` lower 成一个无参工厂自由函数：
//
//   [Route("/u", method: "POST")] class C { ... }
//     →  public Attribute __attr$cls$C$0() { return new Route("/u", method: "POST"); }
//
// 并把工厂名记到 Attr.FactoryFunc。反射（GetCustomAttributes）调工厂一次并缓存——产出 live
// attribute 实例，无需运行期 Activator/Invoke（构造全静态可知）。工厂体是普通 `new Foo(args)`，
// 故 TypeChecker（含命名实参重排 + 默认值，见 _adaptArgs）免费解析 ctor。
//
// 工厂 key 前缀（镜像 C#）：cls$<C> / mth$<C>$<M> / fld$<C>$<F> / fn$<F> / <prefix>$prm$<j>。
// 编译器/测试框架内建 attribute（Native/Test/Benchmark/Skip/ShouldThrow/Timeout）由别的 pass
// 处理，**不**合成工厂（否则 `new Test()` 等失败 + 破坏 self-build byte-identical）。
namespace Z42.Semantics;

using Z42.Syntax;

public sealed class AttributeSynth {
    private MethodDecl[] _fac;
    private int _facCount;

    public AttributeSynth() { this._fac = new MethodDecl[4]; this._facCount = 0; }

    // CU 下降：为每个用户 attribute 合成工厂；返回（可能新建的）CU。无用户 attribute → 原样返回。
    public static CompilationUnit Run(CompilationUnit cu) {
        return new AttributeSynth()._run(cu);
    }

    private CompilationUnit _run(CompilationUnit cu) {
        int i = 0;
        while (i < cu.DeclCount) {
            Decl d = cu.Decls[i];
            if (d is AttributedDecl) {
                AttributedDecl ad = d as AttributedDecl;
                if (ad.Inner is ClassDecl) {
                    this._processClass(ad, ad.Inner as ClassDecl);
                } else if (ad.Inner is MethodDecl) {
                    this._process(ad.Attrs, ad.AttrCount, "fn$" + (ad.Inner as MethodDecl).Name);
                    this._processParams((ad.Inner as MethodDecl), "fn$" + (ad.Inner as MethodDecl).Name);
                }
            } else if (d is ClassDecl) {
                this._processMembers(d as ClassDecl);
            } else if (d is MethodDecl) {
                this._processParams(d as MethodDecl, "fn$" + (d as MethodDecl).Name);
            }
            i = i + 1;
        }
        if (this._facCount == 0) { return cu; }
        Decl[] nd = new Decl[cu.DeclCount + this._facCount];
        int j = 0;
        while (j < cu.DeclCount) { nd[j] = cu.Decls[j]; j = j + 1; }
        j = 0;
        while (j < this._facCount) { nd[cu.DeclCount + j] = this._fac[j]; j = j + 1; }
        return new CompilationUnit(cu.HasNamespace, cu.Namespace, nd, cu.DeclCount + this._facCount, cu.Span);
    }

    private void _processClass(AttributedDecl ad, ClassDecl c) {
        this._process(ad.Attrs, ad.AttrCount, "cls$" + c.Name);
        this._processMembers(c);
    }

    private void _processMembers(ClassDecl c) {
        int m = 0;
        while (m < c.MemberCount) {
            Decl mem = c.Members[m];
            if (mem is AttributedDecl) {
                AttributedDecl mad = mem as AttributedDecl;
                if (mad.Inner is MethodDecl) {
                    MethodDecl md = mad.Inner as MethodDecl;
                    this._process(mad.Attrs, mad.AttrCount, "mth$" + c.Name + "$" + md.Name);
                    this._processParams(md, "mth$" + c.Name + "$" + md.Name);
                } else if (mad.Inner is FieldDecl) {
                    this._process(mad.Attrs, mad.AttrCount, "fld$" + c.Name + "$" + (mad.Inner as FieldDecl).Name);
                }
            } else if (mem is MethodDecl) {
                this._processParams(mem as MethodDecl, "mth$" + c.Name + "$" + (mem as MethodDecl).Name);
            }
            m = m + 1;
        }
    }

    // 参数 attr（`[Attr] int x`）：参数 j 的工厂 key = <prefix>$prm$<j>。
    private void _processParams(MethodDecl md, string keyPrefix) {
        int j = 0;
        while (j < md.ParamCount) {
            Param p = md.Params[j];
            if (p.AttrCount > 0) {
                this._process(p.Attrs, p.AttrCount, keyPrefix + "$prm$" + j.ToString());
            }
            j = j + 1;
        }
    }

    // 一组 attr：逐个非内建 attr 合成工厂 + 记 FactoryFunc。
    private void _process(Attr[] attrs, int count, string keyPrefix) {
        int a = 0;
        while (a < count) {
            Attr at = attrs[a];
            if (AttributeSynth._isUserAttr(at.Name)) {
                string fname = "__attr$" + keyPrefix + "$" + a.ToString();
                at.FactoryFunc = fname;
                this._addFactory(AttributeSynth._synthFactory(at, fname));
            }
            a = a + 1;
        }
    }

    private void _addFactory(MethodDecl fnd) {
        if (this._facCount == this._fac.Length) {
            MethodDecl[] b = new MethodDecl[this._fac.Length * 2];
            int k = 0; while (k < this._facCount) { b[k] = this._fac[k]; k = k + 1; }
            this._fac = b;
        }
        this._fac[this._facCount] = fnd; this._facCount = this._facCount + 1;
    }

    // 编译器/测试框架内建 attribute → 不合成工厂。
    private static bool _isUserAttr(string name) {
        if (name == "Native" || name == "Test" || name == "Benchmark") { return false; }
        if (name == "Skip" || name == "ShouldThrow" || name == "Timeout") { return false; }
        return true;
    }

    // `public Attribute <fname>() { return new <attr.Name>(attr.Args); }`
    // 返回类型用 Attribute 基类（非具体 attr 类）→ 普通类型检查免费强制 attribute 契约。
    private static MethodDecl _synthFactory(Attr at, string fname) {
        Span s = at.Span;
        TypeExpr attrType = new NamedType(at.Name, new TypeExpr[0], 0, s);
        Expr ctorCall = new ObjNewExpr(attrType, at.Args, at.ArgCount, s);
        Stmt[] stmts = new Stmt[1];
        stmts[0] = new ReturnStmt(true, ctorCall, s);
        Stmt body = new BlockStmt(stmts, 1, s);
        TypeExpr retType = new NamedType("Attribute", new TypeExpr[0], 0, s);
        TypeParamList tp = new TypeParamList(new string[0], 0, s);
        return new MethodDecl("public", true, false, retType, fname, tp,
                              new WhereClause[0], 0, new Param[0], 0, true, body,
                              new Expr[0], 0, false, s);
    }
}
