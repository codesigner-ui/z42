// 非泛型 string→object 哈希表（port-z42c-semantics 1A-2，D2 决策）。
// 因 z42 类字段不能带泛型参数 → 用专用非泛型 map；value 为 object，调用方 `as` 下行。
// 开放寻址 + 线性探测；key 哈希用 String 原生 GetHashCode；负载 >0.5 时 2x 重散列。
// 用作 SymbolTable（类/函数名→符号）/ Z42ClassType（成员名→符号）/ TypeEnv（变量名→Z42Type）。
namespace Z42.Semantics;

public sealed class StrMap {
    private string[] _keys;
    private object[] _vals;
    private bool[]   _used;
    private int      _count;
    private int      _cap;

    public StrMap() {
        this._cap = 16;
        this._keys = new string[16];
        this._vals = new object[16];
        this._used = new bool[16];
        this._count = 0;
    }

    public int Count() { return this._count; }

    public bool ContainsKey(string key) { return this._find(key) >= 0; }

    // 不存在返回 null（调用方 `as`-下行前 ContainsKey 或判 null）。
    public object Get(string key) {
        int i = this._find(key);
        if (i >= 0) { return this._vals[i]; }
        return null;
    }

    public void Put(string key, object val) {
        if (this._count * 2 >= this._cap) { this._grow(); }
        int slot = this._slotFor(key);
        if (!this._used[slot]) { this._count = this._count + 1; }
        this._keys[slot] = key;
        this._vals[slot] = val;
        this._used[slot] = true;
    }

    public string[] Keys() {
        string[] r = new string[this._count];
        int n = 0;
        int i = 0;
        while (i < this._cap) {
            if (this._used[i]) { r[n] = this._keys[i]; n = n + 1; }
            i = i + 1;
        }
        return r;
    }

    private int _hash(string key) {
        int h = key.GetHashCode();
        return h & 0x7FFFFFFF;   // 清符号位 → 非负
    }

    // 查找已有 key 的槽（命中返回槽号，未命中 -1）。
    private int _find(string key) {
        int slot = this._hash(key) % this._cap;
        int probes = 0;
        while (probes < this._cap) {
            if (!this._used[slot]) { return -1; }
            if (this._keys[slot] == key) { return slot; }
            slot = slot + 1;
            if (slot >= this._cap) { slot = 0; }
            probes = probes + 1;
        }
        return -1;
    }

    // 为 Put 找槽：命中 key 的槽（更新）或第一个空槽（负载 <0.5 必有空）。
    private int _slotFor(string key) {
        int slot = this._hash(key) % this._cap;
        while (this._used[slot] && this._keys[slot] != key) {
            slot = slot + 1;
            if (slot >= this._cap) { slot = 0; }
        }
        return slot;
    }

    private void _grow() {
        int oldCap = this._cap;
        string[] oldKeys = this._keys;
        object[] oldVals = this._vals;
        bool[]   oldUsed = this._used;
        this._cap = oldCap * 2;
        this._keys = new string[this._cap];
        this._vals = new object[this._cap];
        this._used = new bool[this._cap];
        this._count = 0;
        int i = 0;
        while (i < oldCap) {
            if (oldUsed[i]) { this.Put(oldKeys[i], oldVals[i]); }
            i = i + 1;
        }
    }
}
