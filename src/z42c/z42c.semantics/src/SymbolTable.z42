// 符号表（port-z42c-semantics 1A-3，Pass 0 产物）。类名→Z42ClassType / 顶层函数名→MethodSymbol。
// 含 TypeExpr（语法）→ Z42Type（语义）的桥 ResolveType。1A：NamedType（prim/void/class）；
// Array/Nullable/泛型实参 → Unknown（延后 1D/2A）。
namespace Z42.Semantics;

using Z42.Syntax;

public sealed class SymbolTable {
    public StrMap Classes;          // name → Z42ClassType
    public StrMap Interfaces;       // name → Z42InterfaceType（port-z42c-interface）
    public StrMap Functions;        // name → MethodSymbol（顶层 func）
    public StrMap ClassConstraints; // name → ConstraintSet（2B；仅有 where 子句的泛型类登记）
    public StrMap EnumTypes;        // name → "enum" 标记（枚举类型名注册）
    public StrMap EnumConsts;       // "EnumName.MemberName" → 整数值字符串
    public StrMap Delegates;        // name → Z42FuncType（用户 delegate，非泛型；委托类型即函数类型）
    public SymbolTable() {
        this.Classes = new StrMap();
        this.Interfaces = new StrMap();
        this.Functions = new StrMap();
        this.ClassConstraints = new StrMap();
        this.EnumTypes = new StrMap();
        this.EnumConsts = new StrMap();
        this.Delegates = new StrMap();
    }

    public bool          HasClass(string name) { return this.Classes.ContainsKey(name); }
    public bool             HasInterface(string name) { return this.Interfaces.ContainsKey(name); }
    public Z42InterfaceType GetInterface(string name) { return this.Interfaces.Get(name) as Z42InterfaceType; }

    // class（含 base 链）是否实现接口（可赋性 class→iface）。
    public bool Implements(string clsName, string ifaceName) {
        string cur = clsName;
        int hops = 0;
        while (hops < 32) {
            if (!this.Classes.ContainsKey(cur)) { return false; }
            Z42ClassType ct = this.Classes.Get(cur) as Z42ClassType;
            int i = 0;
            while (i < ct.InterfaceCount) {
                if (ct.InterfaceNames[i] == ifaceName) { return true; }
                i = i + 1;
            }
            if (!ct.HasBase || ct.BaseName == "") { return false; }
            cur = ct.BaseName;
            hops = hops + 1;
        }
        return false;
    }
    public Z42ClassType  GetClass(string name) { return this.Classes.Get(name) as Z42ClassType; }
    public bool          HasFunc(string name)  { return this.Functions.ContainsKey(name); }
    public MethodSymbol  GetFunc(string name)  { return this.Functions.Get(name) as MethodSymbol; }
    public bool          HasConstraints(string name) { return this.ClassConstraints.ContainsKey(name); }
    public ConstraintSet GetConstraints(string name) { return this.ClassConstraints.Get(name) as ConstraintSet; }

    // sub 是否为 baseName 的子类（含自身）。走 base 链（迭代——self-type 字段不可递归调本类方法）。
    public bool IsSubclassOf(string sub, string baseName) {
        if (sub == baseName) { return true; }
        string cur = sub;
        bool more = true;
        while (more) {
            Z42ClassType ct = this.GetClass(cur);
            if (ct == null) { more = false; }
            else if (!ct.HasBase) { more = false; }
            else if (ct.BaseName == baseName) { return true; }
            else { cur = ct.BaseName; }
        }
        return false;
    }

    public Z42Type ResolveType(TypeExpr te) {
        return this.ResolveTypeP(te, new string[0], 0);
    }

    // 带活跃类型形参（泛型类/方法 scope）：名字命中 paramNames → Z42GenericParamType。
    public Z42Type ResolveTypeP(TypeExpr te, string[] paramNames, int paramCount) {
        if (te is NamedType) {
            NamedType nt = te as NamedType;
            string n = nt.Name;
            int i = 0;
            while (i < paramCount) {
                if (paramNames[i] == n) { return new Z42GenericParamType(n); }
                i = i + 1;
            }
            if (n == "void") { return new Z42VoidType(); }
            if (this._isPrim(n)) { return new Z42PrimType(this._canonPrim(n)); }
            // Func/Action/Predicate → 结构 Z42FuncType（port-z42c-closures D1；C# 经委托注册表但产物同构）
            if (n == "Func" && nt.ArgCount > 0) {
                Z42Type[] fps = new Z42Type[nt.ArgCount - 1];
                int fa = 0;
                while (fa < nt.ArgCount - 1) { fps[fa] = this.ResolveTypeP(nt.Args[fa], paramNames, paramCount); fa = fa + 1; }
                return new Z42FuncType(fps, nt.ArgCount - 1, this.ResolveTypeP(nt.Args[nt.ArgCount - 1], paramNames, paramCount));
            }
            if (n == "Action") {
                Z42Type[] aps = new Z42Type[nt.ArgCount];
                int aa = 0;
                while (aa < nt.ArgCount) { aps[aa] = this.ResolveTypeP(nt.Args[aa], paramNames, paramCount); aa = aa + 1; }
                return new Z42FuncType(aps, nt.ArgCount, new Z42VoidType());
            }
            if (n == "Predicate" && nt.ArgCount == 1) {
                Z42Type[] pps = new Z42Type[1];
                pps[0] = this.ResolveTypeP(nt.Args[0], paramNames, paramCount);
                return new Z42FuncType(pps, 1, new Z42PrimType("bool"));
            }
            if (this.EnumTypes.ContainsKey(n)) { return new Z42ClassType(n, false, ""); }
            if (this.Delegates.ContainsKey(n)) { return this.Delegates.Get(n) as Z42FuncType; }   // 用户 delegate → 函数类型
            if (this.Interfaces.ContainsKey(n)) { return this.Interfaces.Get(n) as Z42InterfaceType; }
            // arity-mangle：泛型实例化 `C<T...>` 对 arity-overloaded 同名类（arity-0 base
            // shadow 着 arity-N 泛型，泛型版注册键 `Name$N`，如 MulticastException$1）须取 `Name$N`，
            // 否则误取 arity-0 base → new/throw 出非泛型 base，catch `C<int>` 失配。镜像
            // TypeChecker arity-mangle 取 CT。非 overloaded 泛型（如 Box<T>，仅注册 bare）未命中
            // `Name$N` → 回退 bare，不受影响。
            if (nt.ArgCount > 0) {
                string mangled = n + "$" + nt.ArgCount.ToString();
                if (this.Classes.ContainsKey(mangled)) {
                    Z42ClassType gdef = this.Classes.Get(mangled) as Z42ClassType;
                    Z42Type[] gtargs = new Z42Type[nt.ArgCount];
                    int ga = 0;
                    while (ga < nt.ArgCount) { gtargs[ga] = this.ResolveTypeP(nt.Args[ga], paramNames, paramCount); ga = ga + 1; }
                    return new Z42InstantiatedType(gdef, gtargs, nt.ArgCount);
                }
            }
            if (this.Classes.ContainsKey(n)) {
                Z42ClassType def = this.Classes.Get(n) as Z42ClassType;
                if (nt.ArgCount > 0) {       // 泛型实例化 Box<int>（2A-2；非 overloaded 泛型）
                    Z42Type[] targs = new Z42Type[nt.ArgCount];
                    int a = 0;
                    while (a < nt.ArgCount) { targs[a] = this.ResolveTypeP(nt.Args[a], paramNames, paramCount); a = a + 1; }
                    return new Z42InstantiatedType(def, targs, nt.ArgCount);
                }
                return def;
            }
            // 限定名回退（G19b）：源码写 "Std.Attribute" 时 NamedType.Name 保含点串；
            // 类注册用裸名（SymbolCollector line 139），点串查不到 → 取最后段重查。
            // 镜像 C# MemberType→类型系统能按最后段找到类；SIGS 仍输出 "unknown"（TypeName 不处理 MemberType）。
            // z42.core String has no LastIndexOf; find last '.' manually.
            int lastDot = -1;
            int di = 0;
            while (di < n.Length) {
                if (n.CharAt(di) == '.') { lastDot = di; }
                di = di + 1;
            }
            if (lastDot >= 0) {
                string bare = n.Substring(lastDot + 1);
                if (this.Interfaces.ContainsKey(bare)) { return this.Interfaces.Get(bare) as Z42InterfaceType; }
                if (nt.ArgCount > 0) {   // arity-mangle（同上，限定名路径）
                    string bmangled = bare + "$" + nt.ArgCount.ToString();
                    if (this.Classes.ContainsKey(bmangled)) {
                        Z42ClassType bgdef = this.Classes.Get(bmangled) as Z42ClassType;
                        Z42Type[] bgtargs = new Z42Type[nt.ArgCount];
                        int bga = 0;
                        while (bga < nt.ArgCount) { bgtargs[bga] = this.ResolveTypeP(nt.Args[bga], paramNames, paramCount); bga = bga + 1; }
                        return new Z42InstantiatedType(bgdef, bgtargs, nt.ArgCount);
                    }
                }
                if (this.Classes.ContainsKey(bare)) {
                    Z42ClassType bdef = this.Classes.Get(bare) as Z42ClassType;
                    if (nt.ArgCount > 0) {
                        Z42Type[] btargs = new Z42Type[nt.ArgCount];
                        int ba = 0;
                        while (ba < nt.ArgCount) { btargs[ba] = this.ResolveTypeP(nt.Args[ba], paramNames, paramCount); ba = ba + 1; }
                        return new Z42InstantiatedType(bdef, btargs, nt.ArgCount);
                    }
                    return bdef;
                }
            }
            return new Z42UnknownType();   // imported / 未声明 → Unknown
        }
        if (te is ArrayType) {
            ArrayType at = te as ArrayType;
            return new Z42ArrayType(this.ResolveTypeP(at.Elem, paramNames, paramCount));
        }
        if (te is NullableType) {
            NullableType nt = te as NullableType;
            return this.ResolveTypeP(nt.Inner, paramNames, paramCount);   // nullable → inner（Option 延后）
        }
        if (te is FuncTypeExpr) {                                          // `(T,...) -> R` → Z42FuncType
            FuncTypeExpr ft = te as FuncTypeExpr;
            Z42Type[] fps = new Z42Type[ft.ParamCount];
            int fi = 0;
            while (fi < ft.ParamCount) { fps[fi] = this.ResolveTypeP(ft.Params[fi], paramNames, paramCount); fi = fi + 1; }
            return new Z42FuncType(fps, ft.ParamCount, this.ResolveTypeP(ft.Ret, paramNames, paramCount));
        }
        return new Z42UnknownType();
    }

    // prim 源名 → C# TypeRegistry 规范名（IR 侧用：byte→u8 等次要名归一；int/long/float/
    // double/bool/char/string/object 保留源名——见 TypeRegistry.cs 各 TypeEntry 首字段）。
    // G17c-2：编译 IR（SIGS/TYPE/FUNC）用规范名；TSIG 仍用原始 AST 拼写（见 ExportedTypeExtractor）。
    private string _canonPrim(string n) {
        if (n == "byte")   { return "u8"; }
        if (n == "sbyte")  { return "i8"; }
        if (n == "short")  { return "i16"; }
        if (n == "ushort") { return "u16"; }
        if (n == "uint")   { return "u32"; }
        if (n == "ulong")  { return "u64"; }
        return n;
    }

    private bool _isPrim(string n) {
        if (n == "int" || n == "long" || n == "short" || n == "byte" || n == "sbyte") { return true; }
        if (n == "uint" || n == "ulong" || n == "ushort") { return true; }
        if (n == "double" || n == "float" || n == "bool" || n == "char" || n == "string" || n == "object") { return true; }
        if (n == "i8" || n == "i16" || n == "i32" || n == "i64") { return true; }
        if (n == "u8" || n == "u16" || n == "u32" || n == "u64" || n == "f32" || n == "f64") { return true; }
        return false;
    }
}
