// ── 调用（CG-1C）──────────────────────────────────────────────────────────────────
// 直接调用（自由函数 / 静态方法，按限定名）。void 结果 dst 未读（镜像 C#，恒带 dst）。
public sealed class CallInstr : IrInstr {
    public TypedReg   Dst;
    public string     Func;
    public TypedReg[] Args;
    public int        ArgCount;
    public CallInstr(TypedReg dst, string func, TypedReg[] args, int argCount) {
        this.Dst = dst; this.Func = func; this.Args = args; this.ArgCount = argCount;
    }
    public override string Dump() {
        string s = this.Dst.Dump() + " = call @" + this.Func + "(";
        int i = 0;
        while (i < this.ArgCount) { if (i > 0) { s = s + ", "; } s = s + this.Args[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

// 虚分派（实例方法，经 receiver 的 vtable）。
public sealed class VCallInstr : IrInstr {
    public TypedReg   Dst;
    public TypedReg   Obj;
    public string     Method;
    public TypedReg[] Args;
    public int        ArgCount;
    public VCallInstr(TypedReg dst, TypedReg obj, string method, TypedReg[] args, int argCount) {
        this.Dst = dst; this.Obj = obj; this.Method = method; this.Args = args; this.ArgCount = argCount;
    }
    public override string Dump() {
        string s = this.Dst.Dump() + " = vcall " + this.Obj.Dump() + "." + this.Method + "(";
        int i = 0;
        while (i < this.ArgCount) { if (i > 0) { s = s + ", "; } s = s + this.Args[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

// ── 字段访问（CG-1C）──────────────────────────────────────────────────────────────
public sealed class FieldGetInstr : IrInstr {
    public TypedReg Dst;
    public TypedReg Obj;
    public string   Field;
    public FieldGetInstr(TypedReg dst, TypedReg obj, string field) {
        this.Dst = dst; this.Obj = obj; this.Field = field;
    }
    public override string Dump() { return this.Dst.Dump() + " = field_get " + this.Obj.Dump() + "." + this.Field; }
}

public sealed class FieldSetInstr : IrInstr {
    public TypedReg Obj;
    public string   Field;
    public TypedReg Val;
    public FieldSetInstr(TypedReg obj, string field, TypedReg val) {
        this.Obj = obj; this.Field = field; this.Val = val;
    }
    public override string Dump() { return "field_set " + this.Obj.Dump() + "." + this.Field + ", " + this.Val.Dump(); }
}

// ── 对象 / 数组 / 类型测试（CG-1D；CG-2 加泛型 type-args）─────────────────────────
// new ClassName<TypeArgs>(args)。ctor 名（重载解析）延后——z42c BoundNew 暂无 ctor 信息。
// TypeArgs = resolved 类型实参名（new Box<int>() → ["int"]，VM 写入 ScriptObject.type_args）；非泛型空。
public sealed class ObjNewInstr : IrInstr {
    public TypedReg   Dst;
    public string     ClassName;
    public string[]   TypeArgs;
    public int        TypeArgCount;
    public TypedReg[] Args;
    public int        ArgCount;
    public ObjNewInstr(TypedReg dst, string className, string[] typeArgs, int typeArgCount,
                       TypedReg[] args, int argCount) {
        this.Dst = dst; this.ClassName = className;
        this.TypeArgs = typeArgs; this.TypeArgCount = typeArgCount;
        this.Args = args; this.ArgCount = argCount;
    }
    public override string Dump() {
        string s = this.Dst.Dump() + " = obj_new " + this.ClassName;
        if (this.TypeArgCount > 0) {
            s = s + "<";
            int t = 0;
            while (t < this.TypeArgCount) { if (t > 0) { s = s + ","; } s = s + this.TypeArgs[t]; t = t + 1; }
            s = s + ">";
        }
        s = s + "(";
        int i = 0;
        while (i < this.ArgCount) { if (i > 0) { s = s + ", "; } s = s + this.Args[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

public sealed class ArrayGetInstr : IrInstr {
    public TypedReg Dst;
    public TypedReg Arr;
    public TypedReg Idx;
    public ArrayGetInstr(TypedReg dst, TypedReg arr, TypedReg idx) { this.Dst = dst; this.Arr = arr; this.Idx = idx; }
    public override string Dump() { return this.Dst.Dump() + " = array_get " + this.Arr.Dump() + "[" + this.Idx.Dump() + "]"; }
}

public sealed class ArraySetInstr : IrInstr {
    public TypedReg Arr;
    public TypedReg Idx;
    public TypedReg Val;
    public ArraySetInstr(TypedReg arr, TypedReg idx, TypedReg val) { this.Arr = arr; this.Idx = idx; this.Val = val; }
    public override string Dump() { return "array_set " + this.Arr.Dump() + "[" + this.Idx.Dump() + "], " + this.Val.Dump(); }
}

// x is T → bool。
public sealed class IsInstanceInstr : IrInstr {
    public TypedReg Dst;
    public TypedReg Obj;
    public string   ClassName;
    public IsInstanceInstr(TypedReg dst, TypedReg obj, string className) {
        this.Dst = dst; this.Obj = obj; this.ClassName = className;
    }
    public override string Dump() { return this.Dst.Dump() + " = is_instance " + this.Obj.Dump() + ", " + this.ClassName; }
}

// x as T → T（不匹配返回 null）。
public sealed class AsCastInstr : IrInstr {
    public TypedReg Dst;
    public TypedReg Obj;
    public string   ClassName;
    public AsCastInstr(TypedReg dst, TypedReg obj, string className) {
        this.Dst = dst; this.Obj = obj; this.ClassName = className;
    }
    public override string Dump() { return this.Dst.Dump() + " = as_cast " + this.Obj.Dump() + ", " + this.ClassName; }
}

// ── 比较（CG-1E）：→ bool。类型名取操作数（A）的标签（结果恒 bool）。──────────────────
public sealed class EqInstr : IrInstr {
    public TypedReg Dst; public TypedReg A; public TypedReg B;
    public EqInstr(TypedReg dst, TypedReg a, TypedReg b) { this.Dst = dst; this.A = a; this.B = b; }
    public override string Dump() { return this.Dst.Dump() + " = eq " + IrType.Name(this.A.Type) + " " + this.A.Dump() + ", " + this.B.Dump(); }
}
