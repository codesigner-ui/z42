// 指令 + 终结符字节编码（port-z42c-zbc-writer ZW-1A-4）。镜像 C# ZbcWriter.Instructions.cs。
// 调度：集中 if-is（D2，沿用 codegen）。指令头恒 = op u8 + type_tag u8 + dst u16（0xFFFF=无 dst）。
// ZW-1A 子集：const(i32/i64/bool/null) / copy / 算术(add..rem) + 终结符(ret/retval/br/brcond)。
// 其余 opcode（比较/位/一元/调用/字段/对象/数组/is·as）随 ZW-1B..1D 增量补。
namespace Z42.IR.BinaryFormat;

using Z42.IR;
using Std;

public static class ZbcInstr {
    public static int NoReg = 0xFFFF;

    // f64 → IEEE754 bits（runtime 既有 builtin，z42.io.binary BinaryWriter 同款；z42c 自声明免 stdlib 改动）。
    [Native("__double_to_bits")]
    public static extern long DoubleToBits(double v);

    // 一条指令 → 字节。strRemap：z42c 1-based 池 idx → 最终 STRS idx（ConstStr）；
    // alloc：Call/ObjNew/IsInstance/AsCast 的 token（VCall/Field 不 token 化，直 pool idx）。
    public static void WriteInstr(ByteWriter w, IrInstr ins, ZbcStringPool pool, int[] strRemap, TokenAllocator alloc) {
        if (ins is ConstStrInstr) {
            ConstStrInstr i = ins as ConstStrInstr;
            w.WriteU8(Op.ConstStr); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU32(strRemap[i.Idx]);
            return;
        }
        if (ins is ConstF64Instr) {
            ConstF64Instr i = ins as ConstF64Instr;
            w.WriteU8(Op.ConstF); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteI64(ZbcInstr.DoubleToBits(Convert.ToDouble(ZbcInstr._cleanFloat(i.Text))));
            return;
        }
        if (ins is CallInstr) {
            CallInstr i = ins as CallInstr;
            w.WriteU8(Op.Call); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU32(alloc.ResolveMethod(i.Func, pool));
            ZbcInstr._args(w, i.Args, i.ArgCount);
            return;
        }
        if (ins is BuiltinInstr) {
            BuiltinInstr i = ins as BuiltinInstr;
            w.WriteU8(Op.Builtin); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU32(pool.Idx(i.Name));   // builtin 名直接 pool idx（非 method token）
            ZbcInstr._args(w, i.Args, i.ArgCount);
            return;
        }
        if (ins is VCallInstr) {
            VCallInstr i = ins as VCallInstr;
            w.WriteU8(Op.VCall); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU32(pool.Idx(i.Method)); w.WriteU16(i.Obj.Id);
            ZbcInstr._args(w, i.Args, i.ArgCount);
            return;
        }
        if (ins is FieldGetInstr) {
            FieldGetInstr i = ins as FieldGetInstr;
            w.WriteU8(Op.FieldGet); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU16(i.Obj.Id); w.WriteU32(pool.Idx(i.Field));
            return;
        }
        if (ins is FieldSetInstr) {
            FieldSetInstr i = ins as FieldSetInstr;
            w.WriteU8(Op.FieldSet); w.WriteU8(Tag.FromIrType(i.Val.Type)); w.WriteU16(ZbcInstr.NoReg);
            w.WriteU16(i.Obj.Id); w.WriteU32(pool.Idx(i.Field)); w.WriteU16(i.Val.Id);
            return;
        }
        if (ins is ObjNewInstr) {
            ObjNewInstr i = ins as ObjNewInstr;
            w.WriteU8(Op.ObjNew); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU32(alloc.ResolveType(i.ClassName, pool));
            w.WriteU32(alloc.ResolveMethod(ZbcInstr.CtorName(i.ClassName), pool));
            ZbcInstr._args(w, i.Args, i.ArgCount);
            w.WriteU8(i.TypeArgCount);
            int t = 0;
            while (t < i.TypeArgCount) { w.WriteU32(pool.Idx(i.TypeArgs[t])); t = t + 1; }
            return;
        }
        if (ins is ArrayNewInstr) {
            ArrayNewInstr an = ins as ArrayNewInstr;
            w.WriteU8(Op.ArrayNew); w.WriteU8(Tag.FromIrType(an.Dst.Type)); w.WriteU16(an.Dst.Id);
            w.WriteU16(an.Size.Id);
            w.WriteU8(Tag.FromIrType(an.ElemTag));
            w.WriteU32(pool.Idx(an.ElemName));   // zbc 1.16：elem FQ 名
            return;
        }
        if (ins is StaticGetInstr) {
            StaticGetInstr sg = ins as StaticGetInstr;
            w.WriteU8(Op.StaticGet); w.WriteU8(Tag.FromIrType(sg.Dst.Type)); w.WriteU16(sg.Dst.Id);
            w.WriteU32(pool.Idx(sg.Field));
            return;
        }
        if (ins is StaticSetInstr) {
            StaticSetInstr ss = ins as StaticSetInstr;
            w.WriteU8(Op.StaticSet); w.WriteU8(Tag.FromIrType(ss.Val.Type)); w.WriteU16(ZbcInstr.NoReg);
            w.WriteU32(pool.Idx(ss.Field)); w.WriteU16(ss.Val.Id);
            return;
        }
        if (ins is ArrayLenInstr) {
            ArrayLenInstr al = ins as ArrayLenInstr;
            w.WriteU8(Op.ArrayLen); w.WriteU8(Tag.FromIrType(al.Dst.Type)); w.WriteU16(al.Dst.Id);
            w.WriteU16(al.Arr.Id);
            return;
        }
        if (ins is LoadFnInstr) {
            LoadFnInstr lf = ins as LoadFnInstr;
            w.WriteU8(Op.LoadFn); w.WriteU8(Tag.FromIrType(lf.Dst.Type)); w.WriteU16(lf.Dst.Id);
            w.WriteU32(alloc.ResolveMethod(lf.Func, pool));
            return;
        }
        if (ins is MkClosInstr) {
            MkClosInstr mk = ins as MkClosInstr;
            w.WriteU8(Op.MkClos); w.WriteU8(Tag.FromIrType(mk.Dst.Type)); w.WriteU16(mk.Dst.Id);
            w.WriteU32(alloc.ResolveMethod(mk.Func, pool));
            if (mk.StackAlloc) { w.WriteU8(1); } else { w.WriteU8(0); }
            ZbcInstr._args(w, mk.Captures, mk.CaptureCount);
            return;
        }
        if (ins is CallIndirectInstr) {
            CallIndirectInstr cind = ins as CallIndirectInstr;
            w.WriteU8(Op.CallIndirect); w.WriteU8(Tag.FromIrType(cind.Dst.Type)); w.WriteU16(cind.Dst.Id);
            w.WriteU16(cind.Callee.Id);
            ZbcInstr._args(w, cind.Args, cind.ArgCount);
            return;
        }
        if (ins is IsInstanceInstr) {
            IsInstanceInstr i = ins as IsInstanceInstr;
            w.WriteU8(Op.IsInstance); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU16(i.Obj.Id); w.WriteU32(alloc.ResolveType(i.ClassName, pool));
            return;
        }
        if (ins is AsCastInstr) {
            AsCastInstr i = ins as AsCastInstr;
            w.WriteU8(Op.AsCast); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU16(i.Obj.Id); w.WriteU32(alloc.ResolveType(i.ClassName, pool));
            return;
        }
        if (ins is ArrayGetInstr) {
            ArrayGetInstr i = ins as ArrayGetInstr;
            w.WriteU8(Op.ArrayGet); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU16(i.Arr.Id); w.WriteU16(i.Idx.Id);
            return;
        }
        if (ins is ArraySetInstr) {
            ArraySetInstr i = ins as ArraySetInstr;
            w.WriteU8(Op.ArraySet); w.WriteU8(Tag.FromIrType(i.Val.Type)); w.WriteU16(ZbcInstr.NoReg);
            w.WriteU16(i.Arr.Id); w.WriteU16(i.Idx.Id); w.WriteU16(i.Val.Id);
            return;
        }
        ZbcInstr._writeCore(w, ins);
    }

    // z42c 无 ctor 解析（BoundNew.CtorName 延后）→ 合成 FQ ctor 名 "{fqCls}.{短类名}"（镜像 C# ctor-less：
    // CtorName=短类名 → fqCtor="{qualCls}.{短}"，如 "Demo.Greeter.Greeter"；VM 查无此函数即跳过 ctor）。
    public static string CtorName(string className) {
        int cut = 0 - 1;
        int i = className.Length - 1;
        bool more = i >= 0;
        while (more) {
            if (className.CharAt(i) == '.') { cut = i; more = false; }
            else { i = i - 1; more = i >= 0; }
        }
        string shortName = className;
        if (cut >= 0) { shortName = className.Substring(cut + 1, className.Length - cut - 1); }
        return className + "." + shortName;
    }

    // 浮点字面量文本 → Convert.ToDouble 可解析形（剥后缀 f/F/d/D/m/M + 去 `_` 分隔符）。
    private static string _cleanFloat(string text) {
        string s = "";
        int i = 0;
        while (i < text.Length) {
            char c = text.CharAt(i);
            if (c != '_') {
                bool isSuffix = (i == text.Length - 1)
                    && (c == 'f' || c == 'F' || c == 'd' || c == 'D' || c == 'm' || c == 'M');
                if (!isSuffix) { s = s + text.Substring(i, 1); }
            }
            i = i + 1;
        }
        return s;
    }

    // 整型字面量文本 → long 值（G4；镜像 C# ParseIntLit）：`0x`→16 / `0b`→2 / 否则 10；
    // 逐位累加，遇非该进制字符即停（天然剥尾后缀 L/l/u/U），`_` 分隔跳过。
    public static long _parseIntLit(string text) {
        if (ZbcInstr._isRadix(text, 'x')) { return ZbcInstr._parseRadix(text, 2, 16); }
        if (ZbcInstr._isRadix(text, 'b')) { return ZbcInstr._parseRadix(text, 2, 2); }
        return ZbcInstr._parseRadix(text, 0, 10);
    }
    private static bool _isRadix(string t, char lo) {
        if (t.Length < 2) { return false; }
        if (t.CharAt(0) != '0') { return false; }
        char c1 = t.CharAt(1);
        char up = lo;
        if (lo == 'x') { up = 'X'; }
        if (lo == 'b') { up = 'B'; }
        return c1 == lo || c1 == up;
    }
    private static long _parseRadix(string s, int start, int baseN) {
        long v = 0;
        int i = start;
        bool more = i < s.Length;
        while (more) {
            char c = s.CharAt(i);
            if (c == '_') { i = i + 1; more = i < s.Length; }
            else {
                int d = ZbcInstr._digitVal(c, baseN);
                if (d < 0) { more = false; }
                else { v = v * (long)baseN + (long)d; i = i + 1; more = i < s.Length; }
            }
        }
        return v;
    }
    private static int _digitVal(char c, int baseN) {
        int d = 0 - 1;
        if (c >= '0' && c <= '9') { d = (int)c - 48; }
        else if (c >= 'a' && c <= 'f') { d = (int)c - 87; }
        else if (c >= 'A' && c <= 'F') { d = (int)c - 55; }
        if (d >= baseN) { d = 0 - 1; }
        return d;
    }

    private static void _args(ByteWriter w, TypedReg[] args, int argCount) {
        w.WriteU8(argCount);
        int i = 0;
        while (i < argCount) { w.WriteU16(args[i].Id); i = i + 1; }
    }

    // 无字符串/token 操作数的核心指令（const/copy/算术/比较/位/一元）。
    private static void _writeCore(ByteWriter w, IrInstr ins) {
        if (ins is ConstI32Instr) {
            ConstI32Instr i = ins as ConstI32Instr;
            w.WriteU8(Op.ConstI); w.WriteU8(Tag.I32); w.WriteU16(i.Dst.Id);
            w.WriteU32((int)ZbcInstr._parseIntLit(i.Text));
            return;
        }
        if (ins is ConstI64Instr) {
            ConstI64Instr i = ins as ConstI64Instr;
            w.WriteU8(Op.ConstI); w.WriteU8(Tag.I64); w.WriteU16(i.Dst.Id);
            w.WriteI64(ZbcInstr._parseIntLit(i.Text));
            return;
        }
        if (ins is ConstCharInstr) {
            ConstCharInstr i = ins as ConstCharInstr;
            w.WriteU8(Op.ConstChar); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU32((int)i.Val);
            return;
        }
        if (ins is ConstBoolInstr) {
            ConstBoolInstr i = ins as ConstBoolInstr;
            w.WriteU8(Op.ConstBool); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            if (i.Value) { w.WriteU8(1); } else { w.WriteU8(0); }
            return;
        }
        if (ins is ConstNullInstr) {
            ConstNullInstr i = ins as ConstNullInstr;
            w.WriteU8(Op.ConstNull); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            return;
        }
        if (ins is CopyInstr) {
            CopyInstr i = ins as CopyInstr;
            w.WriteU8(Op.Copy); w.WriteU8(Tag.FromIrType(i.Dst.Type)); w.WriteU16(i.Dst.Id);
            w.WriteU16(i.Src.Id);
            return;
        }
        if (ins is AddInstr) { AddInstr i = ins as AddInstr; ZbcInstr._bin(w, Op.Add, i.Dst, i.A, i.B); return; }
        if (ins is SubInstr) { SubInstr i = ins as SubInstr; ZbcInstr._bin(w, Op.Sub, i.Dst, i.A, i.B); return; }
        if (ins is MulInstr) { MulInstr i = ins as MulInstr; ZbcInstr._bin(w, Op.Mul, i.Dst, i.A, i.B); return; }
        if (ins is DivInstr) { DivInstr i = ins as DivInstr; ZbcInstr._bin(w, Op.Div, i.Dst, i.A, i.B); return; }
        if (ins is RemInstr) { RemInstr i = ins as RemInstr; ZbcInstr._bin(w, Op.Rem, i.Dst, i.A, i.B); return; }
        // 比较（ZW-1B）：tag 取 Dst（恒 bool），镜像 C# WriteBin。
        if (ins is EqInstr) { EqInstr i = ins as EqInstr; ZbcInstr._bin(w, Op.Eq, i.Dst, i.A, i.B); return; }
        if (ins is NeInstr) { NeInstr i = ins as NeInstr; ZbcInstr._bin(w, Op.Ne, i.Dst, i.A, i.B); return; }
        if (ins is LtInstr) { LtInstr i = ins as LtInstr; ZbcInstr._bin(w, Op.Lt, i.Dst, i.A, i.B); return; }
        if (ins is LeInstr) { LeInstr i = ins as LeInstr; ZbcInstr._bin(w, Op.Le, i.Dst, i.A, i.B); return; }
        if (ins is GtInstr) { GtInstr i = ins as GtInstr; ZbcInstr._bin(w, Op.Gt, i.Dst, i.A, i.B); return; }
        if (ins is GeInstr) { GeInstr i = ins as GeInstr; ZbcInstr._bin(w, Op.Ge, i.Dst, i.A, i.B); return; }
        // 位运算（ZW-1B）。
        if (ins is BitAndInstr) { BitAndInstr i = ins as BitAndInstr; ZbcInstr._bin(w, Op.BitAnd, i.Dst, i.A, i.B); return; }
        if (ins is BitOrInstr)  { BitOrInstr i = ins as BitOrInstr;   ZbcInstr._bin(w, Op.BitOr,  i.Dst, i.A, i.B); return; }
        if (ins is BitXorInstr) { BitXorInstr i = ins as BitXorInstr; ZbcInstr._bin(w, Op.BitXor, i.Dst, i.A, i.B); return; }
        if (ins is ShlInstr) { ShlInstr i = ins as ShlInstr; ZbcInstr._bin(w, Op.Shl, i.Dst, i.A, i.B); return; }
        if (ins is ShrInstr) { ShrInstr i = ins as ShrInstr; ZbcInstr._bin(w, Op.Shr, i.Dst, i.A, i.B); return; }
        if (ins is StrConcatInstr) { StrConcatInstr i = ins as StrConcatInstr; ZbcInstr._bin(w, Op.StrConcat, i.Dst, i.A, i.B); return; }
        // 一元（ZW-1B）：op + dst-tag + dst + src，镜像 C# WriteUn。
        if (ins is NegInstr) { NegInstr i = ins as NegInstr; ZbcInstr._un(w, Op.Neg, i.Dst, i.Src); return; }
        if (ins is NotInstr) { NotInstr i = ins as NotInstr; ZbcInstr._un(w, Op.Not, i.Dst, i.Src); return; }
        if (ins is BitNotInstr) { BitNotInstr i = ins as BitNotInstr; ZbcInstr._un(w, Op.BitNot, i.Dst, i.Src); return; }
        if (ins is ConvertInstr) { ConvertInstr i = ins as ConvertInstr; ZbcInstr._un(w, Op.Convert, i.Dst, i.Src); return; }
        // 未覆盖 opcode（call/field/obj/array/is·as/const-str·f64·char → ZW-1C/1D/1E）：
        // 静默跳过会产出语义错流（e2e div-zero oracle 可截获）；e2e 源须避开未覆盖指令。
    }

    // 终结符 → 字节。labels/blockCount：本函数块 label 序（Br/BrCond 目标 → 块索引 u16）。
    public static void WriteTerm(ByteWriter w, IrTerminator t, string[] labels, int blockCount) {
        if (t is RetTerm) {
            RetTerm r = t as RetTerm;
            if (r.HasReg) {
                w.WriteU8(Op.RetVal); w.WriteU8(Tag.FromIrType(r.Reg.Type)); w.WriteU16(r.Reg.Id);
            } else {
                w.WriteU8(Op.Ret); w.WriteU8(Tag.Unknown); w.WriteU16(ZbcInstr.NoReg);
            }
            return;
        }
        if (t is BrTerm) {
            BrTerm b = t as BrTerm;
            w.WriteU8(Op.Br); w.WriteU8(Tag.Unknown); w.WriteU16(ZbcInstr.NoReg);
            w.WriteU16(ZbcInstr._idx(b.Label, labels, blockCount));
            return;
        }
        if (t is BrCondTerm) {
            BrCondTerm b = t as BrCondTerm;
            w.WriteU8(Op.BrCond); w.WriteU8(Tag.FromIrType(b.Cond.Type)); w.WriteU16(b.Cond.Id);
            w.WriteU16(ZbcInstr._idx(b.TrueLabel, labels, blockCount));
            w.WriteU16(ZbcInstr._idx(b.FalseLabel, labels, blockCount));
            return;
        }
        if (t is ThrowTerm) {
            ThrowTerm th = t as ThrowTerm;
            w.WriteU8(Op.Throw); w.WriteU8(Tag.FromIrType(th.Reg.Type)); w.WriteU16(th.Reg.Id);
            return;
        }
    }

    private static void _bin(ByteWriter w, int op, TypedReg dst, TypedReg a, TypedReg b) {
        w.WriteU8(op); w.WriteU8(Tag.FromIrType(dst.Type)); w.WriteU16(dst.Id);
        w.WriteU16(a.Id); w.WriteU16(b.Id);
    }

    private static void _un(ByteWriter w, int op, TypedReg dst, TypedReg src) {
        w.WriteU8(op); w.WriteU8(Tag.FromIrType(dst.Type)); w.WriteU16(dst.Id);
        w.WriteU16(src.Id);
    }

    private static int _idx(string label, string[] labels, int blockCount) {
        int i = 0;
        while (i < blockCount) {
            if (labels[i] == label) { return i; }
            i = i + 1;
        }
        return 0;
    }

    // 指令引用串预扫 intern（镜像 C# InternInstrStrings；调用序 = STRS 字节序的一部分，须 1:1）。
    public static void InternStrings(ZbcStringPool pool, IrInstr ins) {
        if (ins is CallInstr) { CallInstr i = ins as CallInstr; pool.Intern(i.Func); return; }
        if (ins is LoadFnInstr) { pool.Intern((ins as LoadFnInstr).Func); return; }       // C# 池序实证：lift 名入池
        if (ins is ArrayNewInstr) { pool.Intern((ins as ArrayNewInstr).ElemName); return; }
        if (ins is StaticGetInstr) { pool.Intern((ins as StaticGetInstr).Field); return; }
        if (ins is StaticSetInstr) { pool.Intern((ins as StaticSetInstr).Field); return; }
        if (ins is MkClosInstr) { pool.Intern((ins as MkClosInstr).Func); return; }
        if (ins is BuiltinInstr) { pool.Intern((ins as BuiltinInstr).Name); return; }   // 镜像 C# InternInstrStrings
        if (ins is VCallInstr) { VCallInstr i = ins as VCallInstr; pool.Intern(i.Method); return; }
        if (ins is FieldGetInstr) { FieldGetInstr i = ins as FieldGetInstr; pool.Intern(i.Field); return; }
        if (ins is FieldSetInstr) { FieldSetInstr i = ins as FieldSetInstr; pool.Intern(i.Field); return; }
        if (ins is ObjNewInstr) {
            ObjNewInstr i = ins as ObjNewInstr;
            pool.Intern(i.ClassName); pool.Intern(ZbcInstr.CtorName(i.ClassName));
            int t = 0;
            while (t < i.TypeArgCount) { pool.Intern(i.TypeArgs[t]); t = t + 1; }
            return;
        }
        if (ins is IsInstanceInstr) { IsInstanceInstr i = ins as IsInstanceInstr; pool.Intern(i.ClassName); return; }
        if (ins is AsCastInstr) { AsCastInstr i = ins as AsCastInstr; pool.Intern(i.ClassName); return; }
    }
}
