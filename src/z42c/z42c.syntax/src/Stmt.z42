// AST 语句节点（z42c.syntax）。受限写法：class 继承 + virtual Dump()。
// 无 nullable 字段：用 bool 标志（HasValue / HasElse 等）+ 占位（gated by 标志）。
// expr/var-decl/return/if/while/block/break/continue/throw/foreach（incr 1-5）
//   + for/do-while/switch/try-catch-finally（incr 6a）。
namespace Z42.Syntax;

using Z42.Core;

public class Stmt {
    public Span Span;
    public virtual string Dump() { return "?stmt"; }
}

public sealed class ExprStmt : Stmt {
    public Expr E;
    public ExprStmt(Expr e, Span span) { this.Span = span; this.E = e; }
    public override string Dump() { return "(expr " + this.E.Dump() + ")"; }
}

public sealed class VarDeclStmt : Stmt {
    public TypeExpr Type;     // `var` 推断 → NamedType("var")
    public string   Name;
    public Expr     Init;
    public VarDeclStmt(TypeExpr type, string name, Expr init, Span span) { this.Span = span;
        this.Type = type; this.Name = name; this.Init = init;
    }
    public override string Dump() {
        string i = "_"; if (this.Init != null) { i = this.Init.Dump(); }   // G8：无 init → "_"
        return "(decl " + this.Type.Dump() + " " + this.Name + " " + i + ")";
    }
}

public sealed class ReturnStmt : Stmt {
    public bool HasValue;
    public Expr Value;   // 仅 HasValue 时有效
    public ReturnStmt(bool hasValue, Expr value, Span span) { this.Span = span; this.HasValue = hasValue; this.Value = value; }
    public override string Dump() {
        if (this.HasValue) { return "(return " + this.Value.Dump() + ")"; }
        return "(return)";
    }
}

public sealed class IfStmt : Stmt {
    public Expr Cond;
    public Stmt Then;
    public bool HasElse;
    public Stmt Else;    // 仅 HasElse 时有效
    public IfStmt(Expr cond, Stmt then, bool hasElse, Stmt els, Span span) { this.Span = span;
        this.Cond = cond; this.Then = then; this.HasElse = hasElse; this.Else = els;
    }
    public override string Dump() {
        if (this.HasElse) {
            return "(if " + this.Cond.Dump() + " " + this.Then.Dump() + " " + this.Else.Dump() + ")";
        }
        return "(if " + this.Cond.Dump() + " " + this.Then.Dump() + ")";
    }
}

public sealed class WhileStmt : Stmt {
    public Expr Cond;
    public Stmt Body;
    public WhileStmt(Expr cond, Stmt body, Span span) { this.Span = span; this.Cond = cond; this.Body = body; }
    public override string Dump() {
        return "(while " + this.Cond.Dump() + " " + this.Body.Dump() + ")";
    }
}

public sealed class BlockStmt : Stmt {
    public Stmt[] Stmts;
    public int    Count;
    public BlockStmt(Stmt[] stmts, int count, Span span) { this.Span = span; this.Stmts = stmts; this.Count = count; }
    public override string Dump() {
        string s = "(block";
        int i = 0;
        while (i < this.Count) { s = s + " " + this.Stmts[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

public sealed class BreakStmt : Stmt {
    public BreakStmt(Span span) { this.Span = span;}
    public override string Dump() { return "(break)"; }
}

public sealed class ContinueStmt : Stmt {
    public ContinueStmt(Span span) { this.Span = span;}
    public override string Dump() { return "(continue)"; }
}

public sealed class ThrowStmt : Stmt {
    public Expr E;
    public ThrowStmt(Expr e, Span span) { this.Span = span; this.E = e; }
    public override string Dump() { return "(throw " + this.E.Dump() + ")"; }
}

public sealed class ForeachStmt : Stmt {
    public TypeExpr Type;
    public string   Name;
    public Expr     Iter;
    public Stmt     Body;
    public ForeachStmt(TypeExpr type, string name, Expr iter, Stmt body, Span span) { this.Span = span;
        this.Type = type; this.Name = name; this.Iter = iter; this.Body = body;
    }
    public override string Dump() {
        return "(foreach " + this.Type.Dump() + " " + this.Name + " " + this.Iter.Dump() + " " + this.Body.Dump() + ")";
    }
}

// C 式 for：三段任意可省（gated by HasInit/HasCond/HasIncr，省略处 Dump 为 "_"）。
public sealed class ForStmt : Stmt {
    public bool HasInit;
    public Stmt Init;     // 含自身 ';'（解析时由 ParseStatement 消费）
    public bool HasCond;
    public Expr Cond;
    public bool HasIncr;
    public Expr Incr;
    public Stmt Body;
    public ForStmt(bool hasInit, Stmt init, bool hasCond, Expr cond, bool hasIncr, Expr incr, Stmt body, Span span) { this.Span = span;
        this.HasInit = hasInit; this.Init = init;
        this.HasCond = hasCond; this.Cond = cond;
        this.HasIncr = hasIncr; this.Incr = incr;
        this.Body = body;
    }
    public override string Dump() {
        string i = "_"; if (this.HasInit) { i = this.Init.Dump(); }
        string c = "_"; if (this.HasCond) { c = this.Cond.Dump(); }
        string n = "_"; if (this.HasIncr) { n = this.Incr.Dump(); }
        return "(for " + i + " " + c + " " + n + " " + this.Body.Dump() + ")";
    }
}

public sealed class DoWhileStmt : Stmt {
    public Stmt Body;
    public Expr Cond;
    public DoWhileStmt(Stmt body, Expr cond, Span span) { this.Span = span; this.Body = body; this.Cond = cond; }
    public override string Dump() {
        return "(do " + this.Body.Dump() + " " + this.Cond.Dump() + ")";
    }
}

// switch 的单个分支。非 Stmt（无独立 Dump 多态需求）：plain class + Dump()。
// HasPattern=false ⇒ default 分支。Body 为该分支下的语句序列（typed array + count，受限写法）。
public sealed class SwitchCase {
    public Span Span;
    public bool   HasPattern;
    public Expr   Pattern;   // 仅 HasPattern 时有效
    public Stmt[] Body;
    public int    BodyCount;
    public SwitchCase(bool hasPattern, Expr pattern, Stmt[] body, int bodyCount, Span span) { this.Span = span;
        this.HasPattern = hasPattern; this.Pattern = pattern;
        this.Body = body; this.BodyCount = bodyCount;
    }
    public string Dump() {
        string s = "(default";
        if (this.HasPattern) { s = "(case " + this.Pattern.Dump(); }
        int i = 0;
        while (i < this.BodyCount) { s = s + " " + this.Body[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

public sealed class SwitchStmt : Stmt {
    public Expr         Subject;
    public SwitchCase[] Cases;
    public int          CaseCount;
    public SwitchStmt(Expr subject, SwitchCase[] cases, int caseCount, Span span) { this.Span = span;
        this.Subject = subject; this.Cases = cases; this.CaseCount = caseCount;
    }
    public override string Dump() {
        string s = "(switch " + this.Subject.Dump();
        int i = 0;
        while (i < this.CaseCount) { s = s + " " + this.Cases[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

// try 的单个 catch。类型/变量名均可省（裸 catch / catch(Type) / catch(Type v)）。
public sealed class CatchClause {
    public Span Span;
    public bool     HasType;
    public TypeExpr ExType;   // 仅 HasType 时有效
    public bool     HasVar;
    public string   VarName;  // 仅 HasVar 时有效
    public Stmt     Body;
    public CatchClause(bool hasType, TypeExpr exType, bool hasVar, string varName, Stmt body, Span span) { this.Span = span;
        this.HasType = hasType; this.ExType = exType;
        this.HasVar = hasVar; this.VarName = varName; this.Body = body;
    }
    public string Dump() {
        string t = "_"; if (this.HasType) { t = this.ExType.Dump(); }
        string v = "_"; if (this.HasVar) { v = this.VarName; }
        return "(catch " + t + " " + v + " " + this.Body.Dump() + ")";
    }
}

public sealed class TryCatchStmt : Stmt {
    public Stmt          TryBody;
    public CatchClause[] Catches;
    public int           CatchCount;
    public bool          HasFinally;
    public Stmt          Finally;   // 仅 HasFinally 时有效
    public TryCatchStmt(Stmt tryBody, CatchClause[] catches, int catchCount, bool hasFinally, Stmt finallyBody, Span span) { this.Span = span;
        this.TryBody = tryBody; this.Catches = catches; this.CatchCount = catchCount;
        this.HasFinally = hasFinally; this.Finally = finallyBody;
    }
    public override string Dump() {
        string s = "(try " + this.TryBody.Dump();
        int i = 0;
        while (i < this.CatchCount) { s = s + " " + this.Catches[i].Dump(); i = i + 1; }
        if (this.HasFinally) { s = s + " (finally " + this.Finally.Dump() + ")"; }
        return s + ")";
    }
}
