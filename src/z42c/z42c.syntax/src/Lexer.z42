// 手写词法器（z42c.syntax，自举 increment：syntax #1）。
// 镜像 C# z42.Syntax 的 token KINDS + 词法规则；内部用直写式扫描（非组合子框架）——
// byte-identical 目标针对 z42c 产物，不要求 lexer 内部结构与 C# 同，只要 token 流一致。
//
// 覆盖：空白/换行/行注释(//)/块注释(/* */) 作 trivia 跳过；标识符+关键字（全表）；
// 数字字面量（十进制/hex `0x`/bin `0b` + `_` 分隔 + 小数 + 指数 [eE][+-]? + 后缀 L/u/f/d/m，incr 6c-1）；
// 字符串 "..."（含转义跳过，raw lexeme 保留引号）；字符 '...'；raw 串 """..."""；插值串 $"...{e}..."（单 token）；
// 全套符号/运算符（最长匹配）；EOF。`DecodeString` 静态助手剥引号 + 还原常见转义（incr 6c-2）。
// 延后：转义 \0 / \uXXXX / \xXX 解码（DecodeString 仅常见集）；插值洞的结构化解析（lexer 整体单 token）。
namespace Z42.Syntax;

using Z42.Core;

public sealed class Lexer {
    private string _src;
    private string _file;
    private int    _pos;
    private int    _line;
    private int    _col;
    private DiagnosticBag _diags;

    // 关键字表（并行数组；无泛型字段）
    private string[] _kwNames;
    private int[]    _kwKinds;
    private int      _kwCount;

    // 输出 token（typed array + count）
    private Token[]  _toks;
    private int      _tokCount;

    // 当前 token 起点（_emit 用）
    private int _sPos;
    private int _sLine;
    private int _sCol;

    public Lexer(string src, string file) {
        this._src = src;
        this._file = file;
        this._pos = 0;
        this._line = 1;
        this._col = 1;
        this._diags = new DiagnosticBag();
        this._toks = new Token[64];
        this._tokCount = 0;
        this._kwNames = new string[128];
        this._kwKinds = new int[128];
        this._kwCount = 0;
        this._initKeywords();
    }

    public DiagnosticBag Diagnostics() { return this._diags; }
    public int   TokenCount()    { return this._tokCount; }
    public Token TokenAt(int i)  { return this._toks[i]; }

    // ── 公开入口 ────────────────────────────────────────────────────────────
    public void Tokenize() {
        while (this._pos < this._src.Length) {
            this._skipTrivia();
            if (this._pos >= this._src.Length) { break; }
            this._sPos = this._pos; this._sLine = this._line; this._sCol = this._col;
            this._lexOne();
        }
        this._sPos = this._pos; this._sLine = this._line; this._sCol = this._col;
        this._emit(TokenKind.Eof, "");
    }

    // ── 字符工具 ────────────────────────────────────────────────────────────
    private string _src2() { return this._src; }
    // 越界返回空格哨兵（调用方主循环已用 _pos<Length 守卫，哨兵仅供前瞻安全）
    private char _ch(int i) {
        if (i < this._src.Length) { return this._src.CharAt(i); }
        return ' ';
    }
    private bool _isDigit(char c) { return c >= '0' && c <= '9'; }
    private bool _isAlpha(char c) {
        return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_';
    }
    private bool _isAlnum(char c) { return this._isAlpha(c) || this._isDigit(c); }

    private char _advance() {
        char c = this._src.CharAt(this._pos);
        this._pos = this._pos + 1;
        if (c == '\n') { this._line = this._line + 1; this._col = 1; }
        else { this._col = this._col + 1; }
        return c;
    }

    // ── trivia（空白 + 注释）────────────────────────────────────────────────
    private void _skipTrivia() {
        while (this._pos < this._src.Length) {
            char c = this._ch(this._pos);
            if (c == ' ' || c == '\t' || c == '\r' || c == '\n') {
                this._advance();
            } else if (c == '/' && this._ch(this._pos + 1) == '/') {
                while (this._pos < this._src.Length && this._ch(this._pos) != '\n') { this._advance(); }
            } else if (c == '/' && this._ch(this._pos + 1) == '*') {
                this._advance(); this._advance();   // consume /*
                while (this._pos < this._src.Length) {
                    if (this._ch(this._pos) == '*' && this._ch(this._pos + 1) == '/') {
                        this._advance(); this._advance(); break;
                    }
                    this._advance();
                }
            } else {
                break;
            }
        }
    }

    // ── 单 token 分派 ───────────────────────────────────────────────────────
    private void _lexOne() {
        char c = this._ch(this._pos);
        if (this._isAlpha(c))      { this._lexIdent(); }
        else if (this._isDigit(c)) { this._lexNumber(); }
        else if (c == '$' && this._ch(this._pos + 1) == '"') { this._lexInterpolated(); }
        else if (c == '"' && this._ch(this._pos + 1) == '"' && this._ch(this._pos + 2) == '"') { this._lexRawString(); }
        else if (c == '"')         { this._lexString(); }
        else if (c == '\'')        { this._lexChar(); }
        else                       { this._lexSymbol(); }
    }

    private void _lexIdent() {
        int start = this._pos;
        while (this._pos < this._src.Length && this._isAlnum(this._ch(this._pos))) { this._advance(); }
        string text = this._src.Substring(start, this._pos - start);
        if (text == "_") { this._emit(TokenKind.Underscore, text); return; }
        int kind = this._kwLookup(text);
        if (kind >= 0) { this._emit(kind, text); }
        else { this._emit(TokenKind.Identifier, text); }
    }

    // 数字字面量：hex `0x..` / bin `0b..` / 十进制（含 `_` 分隔、小数、指数 [eE][+-]?）+ 后缀（L u f d m）。
    private void _lexNumber() {
        int start = this._pos;
        char c0 = this._ch(this._pos);
        char c1 = this._ch(this._pos + 1);
        if (c0 == '0' && (c1 == 'x' || c1 == 'X')) {
            this._adv2();
            while (this._pos < this._src.Length
                && (this._isHexDigit(this._ch(this._pos)) || this._ch(this._pos) == '_')) { this._advance(); }
            this._consumeNumSuffix();
            this._emitNum(start, false);
            return;
        }
        if (c0 == '0' && (c1 == 'b' || c1 == 'B')) {
            this._adv2();
            while (this._pos < this._src.Length
                && (this._ch(this._pos) == '0' || this._ch(this._pos) == '1' || this._ch(this._pos) == '_')) { this._advance(); }
            this._consumeNumSuffix();
            this._emitNum(start, false);
            return;
        }
        bool isFloat = false;
        this._consumeDigits();
        // 小数部分（`.` 后须跟数字，否则是成员访问的 Dot）
        if (this._ch(this._pos) == '.' && this._isDigit(this._ch(this._pos + 1))) {
            isFloat = true;
            this._advance();   // .
            this._consumeDigits();
        }
        // 指数 [eE] [+-]? digits（须有数字才算指数）
        char e = this._ch(this._pos);
        if (e == 'e' || e == 'E') {
            int j = this._pos + 1;
            if (this._ch(j) == '+' || this._ch(j) == '-') { j = j + 1; }
            if (this._isDigit(this._ch(j))) {
                isFloat = true;
                this._advance();   // e/E
                if (this._ch(this._pos) == '+' || this._ch(this._pos) == '-') { this._advance(); }
                this._consumeDigits();
            }
        }
        if (this._consumeNumSuffix()) { isFloat = true; }   // f/d/m 后缀 → 浮点
        this._emitNum(start, isFloat);
    }

    private void _consumeDigits() {
        while (this._pos < this._src.Length
            && (this._isDigit(this._ch(this._pos)) || this._ch(this._pos) == '_')) { this._advance(); }
    }

    private bool _isHexDigit(char c) {
        return this._isDigit(c) || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F');
    }

    // 数字后缀（L l u U f F d D m M）。返回是否含浮点型后缀（f/d/m）。
    private bool _consumeNumSuffix() {
        bool fl = false;
        while (this._pos < this._src.Length && this._isNumSuffix(this._ch(this._pos))) {
            char s = this._ch(this._pos);
            if (s == 'f' || s == 'F' || s == 'd' || s == 'D' || s == 'm' || s == 'M') { fl = true; }
            this._advance();
        }
        return fl;
    }

    private bool _isNumSuffix(char c) {
        if (c == 'L' || c == 'l' || c == 'u' || c == 'U') { return true; }
        if (c == 'f' || c == 'F' || c == 'd' || c == 'D' || c == 'm' || c == 'M') { return true; }
        return false;
    }

    private void _emitNum(int start, bool isFloat) {
        string text = this._src.Substring(start, this._pos - start);
        if (isFloat) { this._emit(TokenKind.FloatLiteral, text); }
        else { this._emit(TokenKind.IntLiteral, text); }
    }

    private void _lexString() {
        int start = this._pos;
        this._advance();   // opening "
        while (this._pos < this._src.Length && this._ch(this._pos) != '"') {
            if (this._ch(this._pos) == '\\') { this._advance(); }   // skip escaped char
            if (this._pos < this._src.Length) { this._advance(); }
        }
        if (this._pos >= this._src.Length) {
            this._diags.Error(DiagnosticCodes.UnterminatedString, "unterminated string literal", this._curSpan(start));
        } else {
            this._advance();   // closing "
        }
        this._emit(TokenKind.StringLiteral, this._src.Substring(start, this._pos - start));
    }

    private void _lexChar() {
        int start = this._pos;
        this._advance();   // opening '
        while (this._pos < this._src.Length && this._ch(this._pos) != '\'') {
            if (this._ch(this._pos) == '\\') { this._advance(); }
            if (this._pos < this._src.Length) { this._advance(); }
        }
        if (this._pos < this._src.Length) { this._advance(); }   // closing '
        this._emit(TokenKind.CharLiteral, this._src.Substring(start, this._pos - start));
    }

    // raw 串 """..."""：不处理转义；扫描到下一个 `"""`。整体 raw lexeme 入 token。
    private void _lexRawString() {
        int start = this._pos;
        this._advance(); this._advance(); this._advance();   // opening """
        bool closed = false;
        while (this._pos < this._src.Length) {
            if (this._ch(this._pos) == '"' && this._ch(this._pos + 1) == '"' && this._ch(this._pos + 2) == '"') {
                this._advance(); this._advance(); this._advance();
                closed = true;
                break;
            }
            this._advance();
        }
        if (!closed) {
            this._diags.Error(DiagnosticCodes.UnterminatedString, "unterminated raw string literal", this._curSpan(start));
        }
        this._emit(TokenKind.RawStringLiteral, this._src.Substring(start, this._pos - start));
    }

    // 插值串 $"...{expr}...": 整体 lex 为单 token（raw lexeme）。
    // 文本段处理转义跳过 + `{{`/`}}` 字面；`{...}` 洞按 brace 深度跟踪，洞内嵌套串单独跳过。
    private void _lexInterpolated() {
        int start = this._pos;
        this._advance(); this._advance();   // opening $"
        int depth = 0;
        bool closed = false;
        while (this._pos < this._src.Length) {
            char c = this._ch(this._pos);
            if (depth == 0) {
                if (c == '\\') { this._advance(); if (this._pos < this._src.Length) { this._advance(); } continue; }
                if (c == '"') { this._advance(); closed = true; break; }
                if (c == '{') {
                    if (this._ch(this._pos + 1) == '{') { this._advance(); this._advance(); continue; }   // {{ 字面
                    depth = depth + 1; this._advance(); continue;
                }
                if (c == '}') {
                    if (this._ch(this._pos + 1) == '}') { this._advance(); this._advance(); continue; }   // }} 字面
                    this._advance(); continue;
                }
                this._advance();
            } else {
                if (c == '{') { depth = depth + 1; this._advance(); continue; }
                if (c == '}') { depth = depth - 1; this._advance(); continue; }
                if (c == '"') { this._skipNestedString(); continue; }   // 洞内嵌套字符串
                this._advance();
            }
        }
        if (!closed) {
            this._diags.Error(DiagnosticCodes.UnterminatedString, "unterminated interpolated string literal", this._curSpan(start));
        }
        this._emit(TokenKind.InterpolatedStringLiteral, this._src.Substring(start, this._pos - start));
    }

    private void _skipNestedString() {
        this._advance();   // opening "
        while (this._pos < this._src.Length && this._ch(this._pos) != '"') {
            if (this._ch(this._pos) == '\\') { this._advance(); }
            if (this._pos < this._src.Length) { this._advance(); }
        }
        if (this._pos < this._src.Length) { this._advance(); }   // closing "
    }

    // 把字符串字面量的 raw lexeme（含两端引号）解码为实际值：剥引号 + 转义还原。
    // 支持 \n \t \r \\ \" \'（常见集）；\0 / \uXXXX / \xXX 延后（见 deferred）。
    public static string DecodeString(string raw) {
        if (raw.Length < 2) { return raw; }
        string inner = raw.Substring(1, raw.Length - 2);
        string result = "";
        int i = 0;
        int runStart = 0;
        while (i < inner.Length) {
            if (inner.CharAt(i) == '\\' && i + 1 < inner.Length) {
                result = result + inner.Substring(runStart, i - runStart);   // flush 字面段
                char e = inner.CharAt(i + 1);
                if (e == 'n')       { result = result + "\n"; }
                else if (e == 't')  { result = result + "\t"; }
                else if (e == 'r')  { result = result + "\r"; }
                else if (e == '\\') { result = result + "\\"; }
                else if (e == '"')  { result = result + "\""; }
                else if (e == '\'') { result = result + "'"; }
                else                { result = result + inner.Substring(i + 1, 1); }   // 未知转义：保留原字符
                i = i + 2;
                runStart = i;
            } else {
                i = i + 1;
            }
        }
        result = result + inner.Substring(runStart, inner.Length - runStart);   // flush 末段
        return result;
    }

    // ── 符号（最长匹配）─────────────────────────────────────────────────────
    private void _lexSymbol() {
        char c = this._ch(this._pos);
        char d = this._ch(this._pos + 1);
        // 两字符
        if (c == '-' && d == '>') { this._adv2(); this._emit(TokenKind.Arrow, "->"); return; }
        if (c == '=' && d == '>') { this._adv2(); this._emit(TokenKind.FatArrow, "=>"); return; }
        if (c == '=' && d == '=') { this._adv2(); this._emit(TokenKind.EqEq, "=="); return; }
        if (c == '!' && d == '=') { this._adv2(); this._emit(TokenKind.BangEq, "!="); return; }
        if (c == '<' && d == '=') { this._adv2(); this._emit(TokenKind.LtEq, "<="); return; }
        if (c == '>' && d == '=') { this._adv2(); this._emit(TokenKind.GtEq, ">="); return; }
        if (c == '<' && d == '<') { this._adv2(); this._emit(TokenKind.LtLt, "<<"); return; }
        if (c == '>' && d == '>') { this._adv2(); this._emit(TokenKind.GtGt, ">>"); return; }
        if (c == '&' && d == '&') { this._adv2(); this._emit(TokenKind.AmpAmp, "&&"); return; }
        if (c == '|' && d == '|') { this._adv2(); this._emit(TokenKind.PipePipe, "||"); return; }
        if (c == '?' && d == '?') { this._adv2(); this._emit(TokenKind.QuestionQuestion, "??"); return; }
        if (c == ':' && d == ':') { this._adv2(); this._emit(TokenKind.ColonColon, "::"); return; }
        if (c == '.' && d == '.') { this._adv2(); this._emit(TokenKind.DotDot, ".."); return; }
        if (c == '+' && d == '+') { this._adv2(); this._emit(TokenKind.PlusPlus, "++"); return; }
        if (c == '-' && d == '-') { this._adv2(); this._emit(TokenKind.MinusMinus, "--"); return; }
        if (c == '+' && d == '=') { this._adv2(); this._emit(TokenKind.PlusEq, "+="); return; }
        if (c == '-' && d == '=') { this._adv2(); this._emit(TokenKind.MinusEq, "-="); return; }
        if (c == '*' && d == '=') { this._adv2(); this._emit(TokenKind.StarEq, "*="); return; }
        if (c == '/' && d == '=') { this._adv2(); this._emit(TokenKind.SlashEq, "/="); return; }
        if (c == '%' && d == '=') { this._adv2(); this._emit(TokenKind.PercentEq, "%="); return; }
        if (c == '&' && d == '=') { this._adv2(); this._emit(TokenKind.AmpEq, "&="); return; }
        if (c == '|' && d == '=') { this._adv2(); this._emit(TokenKind.PipeEq, "|="); return; }
        if (c == '^' && d == '=') { this._adv2(); this._emit(TokenKind.CaretEq, "^="); return; }
        // 单字符
        this._advance();
        if (c == '(') { this._emit(TokenKind.LParen, "("); return; }
        if (c == ')') { this._emit(TokenKind.RParen, ")"); return; }
        if (c == '{') { this._emit(TokenKind.LBrace, "{"); return; }
        if (c == '}') { this._emit(TokenKind.RBrace, "}"); return; }
        if (c == '[') { this._emit(TokenKind.LBracket, "["); return; }
        if (c == ']') { this._emit(TokenKind.RBracket, "]"); return; }
        if (c == ',') { this._emit(TokenKind.Comma, ","); return; }
        if (c == '.') { this._emit(TokenKind.Dot, "."); return; }
        if (c == ':') { this._emit(TokenKind.Colon, ":"); return; }
        if (c == ';') { this._emit(TokenKind.Semicolon, ";"); return; }
        if (c == '?') { this._emit(TokenKind.Question, "?"); return; }
        if (c == '!') { this._emit(TokenKind.Bang, "!"); return; }
        if (c == '&') { this._emit(TokenKind.Ampersand, "&"); return; }
        if (c == '|') { this._emit(TokenKind.Pipe, "|"); return; }
        if (c == '^') { this._emit(TokenKind.Caret, "^"); return; }
        if (c == '~') { this._emit(TokenKind.Tilde, "~"); return; }
        if (c == '+') { this._emit(TokenKind.Plus, "+"); return; }
        if (c == '-') { this._emit(TokenKind.Minus, "-"); return; }
        if (c == '*') { this._emit(TokenKind.Star, "*"); return; }
        if (c == '/') { this._emit(TokenKind.Slash, "/"); return; }
        if (c == '%') { this._emit(TokenKind.Percent, "%"); return; }
        if (c == '=') { this._emit(TokenKind.Eq, "="); return; }
        if (c == '<') { this._emit(TokenKind.Lt, "<"); return; }
        if (c == '>') { this._emit(TokenKind.Gt, ">"); return; }
        if (c == '#') { this._emit(TokenKind.Hash, "#"); return; }
        // 未知字符
        string bad = this._src.Substring(this._sPos, this._pos - this._sPos);
        this._diags.Error(DiagnosticCodes.InvalidNumericLit, "unexpected character", this._curSpan(this._sPos));
        this._emit(TokenKind.Error_Unknown, bad);
    }

    private void _adv2() { this._advance(); this._advance(); }

    private Span _curSpan(int start) {
        return new Span(start, this._pos, this._sLine, this._sCol, this._file);
    }

    // ── 输出 ────────────────────────────────────────────────────────────────
    private void _emit(int kind, string text) {
        if (this._tokCount == this._toks.Length) { this._growToks(); }
        this._toks[this._tokCount] = new Token(kind, text,
            new Span(this._sPos, this._pos, this._sLine, this._sCol, this._file));
        this._tokCount = this._tokCount + 1;
    }

    private void _growToks() {
        int n = this._toks.Length * 2;
        Token[] bigger = new Token[n];
        int i = 0;
        while (i < this._tokCount) { bigger[i] = this._toks[i]; i = i + 1; }
        this._toks = bigger;
    }

    // ── 关键字表 ────────────────────────────────────────────────────────────
    private int _kwLookup(string text) {
        int i = 0;
        while (i < this._kwCount) {
            if (this._kwNames[i] == text) { return this._kwKinds[i]; }
            i = i + 1;
        }
        return -1;
    }

    private void _kw(string name, int kind) {
        this._kwNames[this._kwCount] = name;
        this._kwKinds[this._kwCount] = kind;
        this._kwCount = this._kwCount + 1;
    }

    private void _initKeywords() {
        this._kw("return", TokenKind.Return); this._kw("if", TokenKind.If); this._kw("else", TokenKind.Else);
        this._kw("while", TokenKind.While); this._kw("for", TokenKind.For); this._kw("foreach", TokenKind.Foreach);
        this._kw("in", TokenKind.In); this._kw("do", TokenKind.Do); this._kw("break", TokenKind.Break);
        this._kw("continue", TokenKind.Continue); this._kw("switch", TokenKind.Switch); this._kw("case", TokenKind.Case);
        this._kw("default", TokenKind.Default); this._kw("try", TokenKind.Try); this._kw("catch", TokenKind.Catch);
        this._kw("finally", TokenKind.Finally); this._kw("throw", TokenKind.Throw); this._kw("pinned", TokenKind.Pinned);
        this._kw("import", TokenKind.Import); this._kw("namespace", TokenKind.Namespace); this._kw("using", TokenKind.Using);
        this._kw("var", TokenKind.Var); this._kw("static", TokenKind.Static); this._kw("public", TokenKind.Public);
        this._kw("private", TokenKind.Private); this._kw("protected", TokenKind.Protected); this._kw("internal", TokenKind.Internal);
        this._kw("ref", TokenKind.Ref); this._kw("out", TokenKind.Out); this._kw("class", TokenKind.Class);
        this._kw("struct", TokenKind.Struct); this._kw("enum", TokenKind.Enum); this._kw("interface", TokenKind.Interface);
        this._kw("record", TokenKind.Record); this._kw("delegate", TokenKind.Delegate); this._kw("event", TokenKind.Event);
        this._kw("abstract", TokenKind.Abstract); this._kw("extern", TokenKind.Extern); this._kw("sealed", TokenKind.Sealed);
        this._kw("override", TokenKind.Override); this._kw("virtual", TokenKind.Virtual); this._kw("new", TokenKind.New);
        this._kw("async", TokenKind.Async); this._kw("await", TokenKind.Await); this._kw("typeof", TokenKind.Typeof);
        this._kw("is", TokenKind.Is); this._kw("as", TokenKind.As); this._kw("where", TokenKind.Where);
        this._kw("operator", TokenKind.Operator); this._kw("null", TokenKind.Null); this._kw("true", TokenKind.True);
        this._kw("false", TokenKind.False); this._kw("string", TokenKind.String); this._kw("int", TokenKind.Int);
        this._kw("long", TokenKind.Long); this._kw("short", TokenKind.Short); this._kw("double", TokenKind.Double);
        this._kw("float", TokenKind.Float); this._kw("byte", TokenKind.Byte); this._kw("uint", TokenKind.Uint);
        this._kw("ulong", TokenKind.Ulong); this._kw("ushort", TokenKind.Ushort); this._kw("sbyte", TokenKind.Sbyte);
        this._kw("object", TokenKind.Object); this._kw("bool", TokenKind.Bool); this._kw("char", TokenKind.Char);
