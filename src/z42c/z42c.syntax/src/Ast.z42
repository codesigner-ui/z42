// AST 表达式节点（z42c.syntax）。受限写法：class 继承 + virtual Dump()（s-expression）。
// 表达式：字面量/标识符/一元/二元/后缀（成员·调用·索引）/赋值。语句见 Stmt.z42。
namespace Z42.Syntax;

using Z42.Core;

public class Expr {
    public Span Span;
    public virtual string Dump() { return "?"; }
}

public sealed class IntLitExpr : Expr {
    public string Value;
    public IntLitExpr(string value, Span span) { this.Span = span; this.Value = value; }
    public override string Dump() { return this.Value; }
}

public sealed class ArrayNewExpr : Expr {
    public TypeExpr Elem;
    public Expr     Size;
    public ArrayNewExpr(TypeExpr elem, Expr size, Span span) { this.Span = span; this.Elem = elem; this.Size = size; }
    public override string Dump() { return "(array-new " + this.Elem.Dump() + " " + this.Size.Dump() + ")"; }
}

// ref 实参（ref var）→ 传变量地址（load_local_addr）。Inner 必须是 lvalue 局部变量。
public sealed class RefArgExpr : Expr {
    public Expr Inner;
    public RefArgExpr(Expr inner, Span span) { this.Span = span; this.Inner = inner; }
    public override string Dump() { return "(ref " + this.Inner.Dump() + ")"; }
}

public sealed class ArrayInitExpr : Expr {
    public TypeExpr Elem;
    public Expr[]   Elems;
    public int      ElemCount;
    public ArrayInitExpr(TypeExpr elem, Expr[] elems, int elemCount, Span span) {
        this.Span = span; this.Elem = elem; this.Elems = elems; this.ElemCount = elemCount;
    }
    public override string Dump() {
        string s = "(array-init " + this.Elem.Dump() + " [";
        int i = 0;
        while (i < this.ElemCount) { if (i > 0) { s = s + " "; } s = s + this.Elems[i].Dump(); i = i + 1; }
        return s + "])";
    }
}

public sealed class LambdaParam {
    public Span     Span;
    public bool     HasType;
    public TypeExpr Type;      // 仅 HasType
    public string   Name;
    public LambdaParam(bool hasType, TypeExpr type, string name, Span span) {
        this.Span = span; this.HasType = hasType; this.Type = type; this.Name = name;
    }
}

public sealed class LambdaExpr : Expr {
    public LambdaParam[] Params;
    public int           ParamCount;
    public bool          HasBlock;
    public Expr          ExprBody;   // !HasBlock
    public Stmt          BlockBody;  // HasBlock
    public LambdaExpr(LambdaParam[] params_, int paramCount, bool hasBlock, Expr exprBody, Stmt blockBody, Span span) {
        this.Span = span; this.Params = params_; this.ParamCount = paramCount;
        this.HasBlock = hasBlock; this.ExprBody = exprBody; this.BlockBody = blockBody;
    }
    public override string Dump() {
        string s = "(lambda (";
        int i = 0;
        while (i < this.ParamCount) {
            if (i > 0) { s = s + " "; }
            s = s + this.Params[i].Name;
            i = i + 1;
        }
        s = s + ")";
        if (this.HasBlock) { s = s + " " + this.BlockBody.Dump(); }
        else { s = s + " " + this.ExprBody.Dump(); }
        return s + ")";
    }
}

public sealed class CharLitExpr : Expr {
    public char Value;     // 解码后（剥引号+转义；镜像 C# LitCharExpr——区别于 Int/Str 存 raw）
    public CharLitExpr(char value, Span span) { this.Span = span; this.Value = value; }
    public override string Dump() { return "(char " + this.Value.ToString() + ")"; }
}

public sealed class FloatLitExpr : Expr {
    public string Value;
    public FloatLitExpr(string value, Span span) { this.Span = span; this.Value = value; }
    public override string Dump() { return this.Value; }
}

public sealed class StringLitExpr : Expr {
    public string Raw;
    public StringLitExpr(string raw, Span span) { this.Span = span; this.Raw = raw; }
    public override string Dump() { return this.Raw; }
}

public sealed class BoolLitExpr : Expr {
    public bool Value;
    public BoolLitExpr(bool value, Span span) { this.Span = span; this.Value = value; }
    public override string Dump() { if (this.Value) { return "true"; } return "false"; }
}

public sealed class NullLitExpr : Expr {
    public NullLitExpr(Span span) { this.Span = span;}
    public override string Dump() { return "null"; }
}

public sealed class IdentExpr : Expr {
    public string Name;
    public IdentExpr(string name, Span span) { this.Span = span; this.Name = name; }
    public override string Dump() { return this.Name; }
}

public sealed class UnaryExpr : Expr {
    public string Op;
    public Expr   Operand;
    public UnaryExpr(string op, Expr operand, Span span) { this.Span = span; this.Op = op; this.Operand = operand; }
    public override string Dump() { return "(" + this.Op + " " + this.Operand.Dump() + ")"; }
}

public sealed class BinaryExpr : Expr {
    public string Op;
    public Expr   Left;
    public Expr   Right;
    public BinaryExpr(string op, Expr left, Expr right, Span span) { this.Span = span;
        this.Op = op; this.Left = left; this.Right = right;
    }
    public override string Dump() {
        return "(" + this.Op + " " + this.Left.Dump() + " " + this.Right.Dump() + ")";
    }
}

// ── 后缀 / 赋值 ──────────────────────────────────────────────────────────────

public sealed class MemberExpr : Expr {
    public Expr   Target;
    public string Name;
    public MemberExpr(Expr target, string name, Span span) { this.Span = span; this.Target = target; this.Name = name; }
    public override string Dump() { return "(. " + this.Target.Dump() + " " + this.Name + ")"; }
}

public sealed class IndexExpr : Expr {
    public Expr Target;
    public Expr Index;
    public IndexExpr(Expr target, Expr index, Span span) { this.Span = span; this.Target = target; this.Index = index; }
    public override string Dump() { return "(index " + this.Target.Dump() + " " + this.Index.Dump() + ")"; }
}

public sealed class AssignExpr : Expr {
    public string Op;    // "=" / "+=" / "-=" / ...
    public Expr   Target;
    public Expr   Value;
    public AssignExpr(string op, Expr target, Expr value, Span span) { this.Span = span; this.Op = op; this.Target = target; this.Value = value; }
    public override string Dump() { return "(" + this.Op + " " + this.Target.Dump() + " " + this.Value.Dump() + ")"; }
}

public sealed class CallExpr : Expr {
    public Expr   Callee;
    public Expr[] Args;
    public int    ArgCount;
    public CallExpr(Expr callee, Expr[] args, int argCount, Span span) { this.Span = span;
        this.Callee = callee; this.Args = args; this.ArgCount = argCount;
    }
    public override string Dump() {
        string s = "(call " + this.Callee.Dump();
        int i = 0;
        while (i < this.ArgCount) { s = s + " " + this.Args[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

public sealed class TernaryExpr : Expr {
    public Expr Cond;
    public Expr Then;
    public Expr Else;
    public TernaryExpr(Expr cond, Expr then, Expr els, Span span) { this.Span = span; this.Cond = cond; this.Then = then; this.Else = els; }
    public override string Dump() {
        return "(?: " + this.Cond.Dump() + " " + this.Then.Dump() + " " + this.Else.Dump() + ")";
    }
}

public sealed class IsExpr : Expr {
    public Expr     E;
    public TypeExpr Type;
    public IsExpr(Expr e, TypeExpr type, Span span) { this.Span = span; this.E = e; this.Type = type; }
    public override string Dump() { return "(is " + this.E.Dump() + " " + this.Type.Dump() + ")"; }
}

// switch 表达式的单个 arm：`pattern => body` 或 `_ => body`（HasPattern=false）。
public sealed class SwitchArm {
    public Span Span;
    public bool HasPattern;
    public Expr Pattern;   // 仅 HasPattern 时有效
    public Expr Body;
    public SwitchArm(bool hasPattern, Expr pattern, Expr body, Span span) { this.Span = span;
        this.HasPattern = hasPattern; this.Pattern = pattern; this.Body = body;
    }
}

// `subject switch { p => b, ..., _ => d }`（postfix，bp 85）。
public sealed class SwitchExpr : Expr {
    public Expr        Subject;
    public SwitchArm[] Arms;
    public int         ArmCount;
    public SwitchExpr(Expr subject, SwitchArm[] arms, int armCount, Span span) { this.Span = span;
        this.Subject = subject; this.Arms = arms; this.ArmCount = armCount;
    }
    public override string Dump() {
        string s = "(switch-expr " + this.Subject.Dump();
        int i = 0;
        while (i < this.ArmCount) {
            if (this.Arms[i].HasPattern) { s = s + " (" + this.Arms[i].Pattern.Dump() + " => " + this.Arms[i].Body.Dump() + ")"; }
            else { s = s + " (_ => " + this.Arms[i].Body.Dump() + ")"; }
            i = i + 1;
        }
        return s + ")";
    }
}

public sealed class AsExpr : Expr {
    public Expr     E;
    public TypeExpr Type;
    public AsExpr(Expr e, TypeExpr type, Span span) { this.Span = span; this.E = e; this.Type = type; }
    public override string Dump() { return "(as " + this.E.Dump() + " " + this.Type.Dump() + ")"; }
}

// typeof(T) → reflection Std.Type（make-typeof-return-type）。
public sealed class TypeofExpr : Expr {
    public TypeExpr Type;
    public TypeofExpr(TypeExpr type, Span span) { this.Span = span; this.Type = type; }
    public override string Dump() { return "(typeof " + this.Type.Dump() + ")"; }
}

// C 风格强制转换 (Type)expr（G3；数值转换，区别于 as 的引用 cast）。
public sealed class CastExpr : Expr {
    public TypeExpr Type;
    public Expr     E;
    public CastExpr(TypeExpr type, Expr e, Span span) { this.Span = span; this.Type = type; this.E = e; }
    public override string Dump() { return "(cast " + this.Type.Dump() + " " + this.E.Dump() + ")"; }
}

public sealed class ObjNewExpr : Expr {
    public TypeExpr Type;
    public Expr[]   Args;
    public int      ArgCount;
    public ObjNewExpr(TypeExpr type, Expr[] args, int argCount, Span span) { this.Span = span;
        this.Type = type; this.Args = args; this.ArgCount = argCount;
    }
    public override string Dump() {
        string s = "(new " + this.Type.Dump();
        int i = 0;
        while (i < this.ArgCount) { s = s + " " + this.Args[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

// GS7：default(T) 表达式（D-8b-3 Phase 2）。Target = 类型表达式（含泛型类型参数）。
public sealed class DefaultExpr : Expr {
    public TypeExpr Target;
    public DefaultExpr(TypeExpr target, Span span) { this.Span = span; this.Target = target; }
    public override string Dump() { return "(default " + this.Target.Dump() + ")"; }
}

// GS4：插值字符串节点。InterpPart 基类 → InterpText（纯文本段）/ InterpHole（{expr} 洞）。
public class InterpPart {
    public Span Span;
    public InterpPart(Span span) { this.Span = span; }
}
public sealed class InterpText : InterpPart {
    public string Text;
    public InterpText(string text, Span span) : base(span) { this.Text = text; }
}
public sealed class InterpHole : InterpPart {
    public Expr Inner;
    public InterpHole(Expr inner, Span span) : base(span) { this.Inner = inner; }
}
public sealed class InterpolatedStringExpr : Expr {
    public InterpPart[] Parts;
    public int          PartCount;
    public InterpolatedStringExpr(InterpPart[] parts, int partCount, Span span) {
        this.Span = span; this.Parts = parts; this.PartCount = partCount;
    }
    public override string Dump() { return "(interp " + this.PartCount.ToString() + ")"; }
}
