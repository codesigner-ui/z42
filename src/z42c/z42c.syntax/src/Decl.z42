// AST 声明节点（z42c.syntax）。CompilationUnit / using / class·struct·interface / enum / record / delegate
//   / 顶层 func（MethodDecl.IsFree）/ field / method / property / param / attribute（AttributedDecl 包裹）。
// 受限写法：class 继承 + virtual Dump()。类型/修饰符捕获为字符串文本（增量；TypeExpr 后续）。
namespace Z42.Syntax;

using Z42.Core;

public sealed class Param {
    public Span Span;
    public TypeExpr Type;
    public string   Name;
    public bool     IsRef;     // ref/out 修饰（调用方传地址，VM 处理间接；callee 寄存器类型不变）
    public Expr     Default;   // GS1：可选参数默认值（`int x = 5`）；无默认值 = null。镜像 C# Param.Default。
    public Param(TypeExpr type, string name, Span span) { this.Span = span; this.Type = type; this.Name = name; this.IsRef = false; this.Default = null; }
    // Dump 不含 Default（镜像 C# AstDumper.VisitParam：仅 `Param {mod}{name} {span}`，不输出默认值）→ 无默认值参数 Dump 不变。
    public string Dump() { return this.Type.Dump() + " " + this.Name; }
}

// 解析期临时持有者：参数列表（Items + Count）。z42 无元组返回 → 用 holder。
public sealed class ParamList {
    public Span Span;
    public Param[] Items;
    public int     Count;
    public ParamList(Param[] items, int count, Span span) { this.Span = span; this.Items = items; this.Count = count; }
}

// 解析期临时持有者：类型列表（基类/接口列表）。
public sealed class TypeList {
    public Span Span;
    public TypeExpr[] Items;
    public int        Count;
    public TypeList(TypeExpr[] items, int count, Span span) { this.Span = span; this.Items = items; this.Count = count; }
}

// 单个 attribute：Name [( arg, ... )]。参数捕获为表达式（命名参数 `k=v` 即 AssignExpr）。
public sealed class Attr {
    public Span Span;
    public string Name;
    public Expr[] Args;
    public int    ArgCount;
    public Attr(string name, Expr[] args, int argCount, Span span) { this.Span = span;
        this.Name = name; this.Args = args; this.ArgCount = argCount;
    }
    public string Dump() {
        string s = "[" + this.Name;
        int i = 0;
        while (i < this.ArgCount) { s = s + " " + this.Args[i].Dump(); i = i + 1; }
        return s + "]";
    }
}

// 解析期临时持有者：前置 attribute 集合。
public sealed class AttrList {
    public Span Span;
    public Attr[] Items;
    public int    Count;
    public AttrList(Attr[] items, int count, Span span) { this.Span = span; this.Items = items; this.Count = count; }
}

public class Decl {
    public Span Span;
    public virtual string Dump() { return "?decl"; }
}

// attribute 包裹：`[A][B] <decl>` → 把前置 attribute 附着到内层 decl，不污染各 decl 构造器。
public sealed class AttributedDecl : Decl {
    public Attr[] Attrs;
    public int    AttrCount;
    public Decl   Inner;
    public AttributedDecl(Attr[] attrs, int attrCount, Decl inner, Span span) { this.Span = span;
        this.Attrs = attrs; this.AttrCount = attrCount; this.Inner = inner;
    }
    public override string Dump() {
        string s = "(attr";
        int i = 0;
        while (i < this.AttrCount) { s = s + " " + this.Attrs[i].Dump(); i = i + 1; }
        return s + " " + this.Inner.Dump() + ")";
    }
}

public sealed class UsingDecl : Decl {
    public string Name;
    public UsingDecl(string name, Span span) { this.Span = span; this.Name = name; }
    public override string Dump() { return "(using " + this.Name + ")"; }
}

public sealed class FieldDecl : Decl {
    public string   Mods;
    public TypeExpr Type;
    public string   Name;
    public bool     HasInit;
    public Expr     Init;
    public FieldDecl(string mods, TypeExpr type, string name, bool hasInit, Expr init, Span span) { this.Span = span;
        this.Mods = mods; this.Type = type; this.Name = name;
        this.HasInit = hasInit; this.Init = init;
    }
    public override string Dump() {
        string m = this._modPart();
        if (this.HasInit) { return "(field " + m + this.Type.Dump() + " " + this.Name + " " + this.Init.Dump() + ")"; }
        return "(field " + m + this.Type.Dump() + " " + this.Name + ")";
    }
    private string _modPart() { if (this.Mods == "") { return ""; } return this.Mods + " "; }
}

// 类成员方法 / ctor / 顶层自由函数（IsFree）共用。Dump head：ctor / func / method。
// TypeParams（如 "<T>"，含尖括号，"" 表无）+ WhereText（如 "where T : new()"，"" 表无）。
public sealed class MethodDecl : Decl {
    public string        Mods;
    public bool          IsFree;     // 顶层自由函数（命名空间级，无 this）
    public bool          IsCtor;
    public TypeExpr      RetType;    // ctor 时为占位 NamedType("")（不 Dump）
    public string        Name;
    public TypeParamList TypeParams;
    public WhereClause[] Wheres;
    public int           WhereCount;
    public Param[]       Params;
    public int           ParamCount;
    public bool          HasBody;
    public Stmt          Body;        // 仅 HasBody 时有效
    public Expr[]        BaseArgs;    // `: base(args)` 调用实参（isCtor 时有意义；无 base call 时 null/Count=0）
    public int           BaseArgCount;
    public MethodDecl(string mods, bool isFree, bool isCtor, TypeExpr retType, string name,
                      TypeParamList typeParams, WhereClause[] wheres, int whereCount,
                      Param[] ps, int pc, bool hasBody, Stmt body, Expr[] baseArgs, int baseArgCount,
                Span span) { this.Span = span;
        this.Mods = mods; this.IsFree = isFree; this.IsCtor = isCtor; this.RetType = retType; this.Name = name;
        this.TypeParams = typeParams; this.Wheres = wheres; this.WhereCount = whereCount;
        this.Params = ps; this.ParamCount = pc; this.HasBody = hasBody; this.Body = body;
        this.BaseArgs = baseArgs; this.BaseArgCount = baseArgCount;
    }
    public override string Dump() {
        string head = this.IsCtor ? "ctor" : (this.IsFree ? "func" : "method");
        string m = (this.Mods == "") ? "" : (this.Mods + " ");
        string sig = "(" + head + " " + m;
        if (!this.IsCtor) { sig = sig + this.RetType.Dump() + " "; }
        sig = sig + this.Name + this.TypeParams.Dump() + " (";
        int i = 0;
        while (i < this.ParamCount) {
            if (i > 0) { sig = sig + ", "; }
            sig = sig + this.Params[i].Dump();
            i = i + 1;
        }
        sig = sig + ")";
        sig = sig + DeclHelpers.DumpWheres(this.Wheres, this.WhereCount);
        if (this.HasBody) { sig = sig + " " + this.Body.Dump(); }
        return sig + ")";
    }
}

// auto-property `T Name { get; [set;] }`（可带访问器修饰 + 初值）。自定义 body / 表达式体 / init-only 延后。
// desugar（合成 backing field + get_X/set_X）留给后端；parser 仅捕获结构。
public sealed class PropertyDecl : Decl {
    public string   Mods;
    public TypeExpr Type;
    public string   Name;
    public bool     HasGet;
    public string   GetMods;   // 访问器修饰（如 "private"），"" 表示无
    public bool     HasSet;
    public string   SetMods;
    public bool     HasInit;
    public Expr     Init;      // 仅 HasInit 时有效
    public PropertyDecl(string mods, TypeExpr type, string name,
                        bool hasGet, string getMods, bool hasSet, string setMods,
                        bool hasInit, Expr init,
                Span span) { this.Span = span;
        this.Mods = mods; this.Type = type; this.Name = name;
        this.HasGet = hasGet; this.GetMods = getMods; this.HasSet = hasSet; this.SetMods = setMods;
        this.HasInit = hasInit; this.Init = init;
    }
    public override string Dump() {
        string m = (this.Mods == "") ? "" : (this.Mods + " ");
        string s = "(prop " + m + this.Type.Dump() + " " + this.Name;
        if (this.HasGet) { s = s + " " + this._acc(this.GetMods, "get"); }
        if (this.HasSet) { s = s + " " + this._acc(this.SetMods, "set"); }
        if (this.HasInit) { s = s + " " + this.Init.Dump(); }
        return s + ")";
    }
    private string _acc(string mods, string kw) {
        if (mods == "") { return kw; }
        return mods + " " + kw;
    }
}

// class / struct / interface 同构（Kind 区分；语义差异留给后端）。Dump head = Kind。
public sealed class ClassDecl : Decl {
    public string        Kind;    // "class" / "struct" / "interface"
    public string        Mods;
    public string        Name;
    public TypeParamList TypeParams;
    public TypeExpr[]    Bases;
    public int           BaseCount;
    public WhereClause[] Wheres;
    public int           WhereCount;
    public Decl[]        Members;
    public int           MemberCount;
    public ClassDecl(string kind, string mods, string name, TypeParamList typeParams,
                     TypeExpr[] bases, int baseCount, WhereClause[] wheres, int whereCount, Decl[] members, int mc,
                Span span) { this.Span = span;
        this.Kind = kind; this.Mods = mods; this.Name = name; this.TypeParams = typeParams;
        this.Bases = bases; this.BaseCount = baseCount; this.Wheres = wheres; this.WhereCount = whereCount;
        this.Members = members; this.MemberCount = mc;
    }
    public override string Dump() {
        string m = (this.Mods == "") ? "" : (this.Mods + " ");
        string s = "(" + this.Kind + " " + m + this.Name + this.TypeParams.Dump();
        s = s + DeclHelpers.DumpBaseList(this.Bases, this.BaseCount);
        s = s + DeclHelpers.DumpWheres(this.Wheres, this.WhereCount);
        int i = 0;
        while (i < this.MemberCount) { s = s + " " + this.Members[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

// 索引器 `T this[P p] { get { ... } set { ... } }`（GS5 stdlib Dictionary）。
// 下游 SymbolCollector/TypeChecker/IrGen/ExportedTypeExtractor 暂跳过（只读消费）；
// 未来 byte-identical 需展开为 get_Item/set_Item（镜像 C# IndexerDecl lowering）。
public sealed class IndexerDecl : Decl {
    public string  Mods;
    public TypeExpr RetType;       // 元素类型（TValue）
    public Param[] Params;         // 索引器参数（TKey key）
    public int     ParamCount;
    public bool    HasGet;
    public Stmt    GetBody;        // 仅 HasGet 时有效
    public bool    HasSet;
    public Stmt    SetBody;        // 仅 HasSet 时有效
    public IndexerDecl(string mods, TypeExpr retType, Param[] params_, int paramCount,
                       bool hasGet, Stmt getBody, bool hasSet, Stmt setBody, Span span) { this.Span = span;
        this.Mods = mods; this.RetType = retType; this.Params = params_; this.ParamCount = paramCount;
        this.HasGet = hasGet; this.GetBody = getBody; this.HasSet = hasSet; this.SetBody = setBody;
    }
    public override string Dump() { return "(indexer " + this.RetType.Dump() + ")"; }
}

// 声明 Dump 辅助：基类列表 + where 子句列表渲染（与旧字符串拼接逐字符一致）。
public class DeclHelpers {
    // `` 或 ` : A, B, C`
    public static string DumpBaseList(TypeExpr[] bases, int count) {
        if (count == 0) { return ""; }
        string s = " : ";
        int i = 0;
        while (i < count) { if (i > 0) { s = s + ", "; } s = s + bases[i].Dump(); i = i + 1; }
        return s;
    }
    // `` 或 ` where T : C1, C2 where U : ...`（前导空格 + 各子句以空格连）
    public static string DumpWheres(WhereClause[] wheres, int count) {
        if (count == 0) { return ""; }
        string s = "";
        int i = 0;
        while (i < count) { s = s + " " + wheres[i].Dump(); i = i + 1; }
        return s;
    }
}

public sealed class EnumMember {
    public Span Span;
    public string Name;
    public bool   HasValue;
    public string Value;   // int 字面量文本（可含前导 '-'）；仅 HasValue 时有效
    public EnumMember(string name, bool hasValue, string value, Span span) { this.Span = span;
        this.Name = name; this.HasValue = hasValue; this.Value = value;
    }
    public string Dump() {
        if (this.HasValue) { return "(" + this.Name + " " + this.Value + ")"; }
        return this.Name;
    }
}

public sealed class EnumDecl : Decl {
    public string       Mods;
    public string       Name;
    public bool         HasBase;     // 底层类型 `: int` 等
    public TypeExpr     Base;        // 仅 HasBase 时有效
    public EnumMember[] Members;
    public int          MemberCount;
    public EnumDecl(string mods, string name, bool hasBase, TypeExpr baseType, EnumMember[] members, int mc, Span span) { this.Span = span;
        this.Mods = mods; this.Name = name; this.HasBase = hasBase; this.Base = baseType;
        this.Members = members; this.MemberCount = mc;
    }
    public override string Dump() {
        string m = (this.Mods == "") ? "" : (this.Mods + " ");
        string s = "(enum " + m + this.Name;
        if (this.HasBase) { s = s + " : " + this.Base.Dump(); }
        int i = 0;
        while (i < this.MemberCount) { s = s + " " + this.Members[i].Dump(); i = i + 1; }
        return s + ")";
    }
}

// delegate R Name<T>(params) where ...; —— 类型声明（无体）。
public sealed class DelegateDecl : Decl {
    public string        Mods;
    public TypeExpr      RetType;
    public string        Name;
    public TypeParamList TypeParams;
    public WhereClause[] Wheres;
    public int           WhereCount;
    public Param[]       Params;
    public int           ParamCount;
    public DelegateDecl(string mods, TypeExpr retType, string name, TypeParamList typeParams,
                        Param[] ps, int pc, WhereClause[] wheres, int whereCount,
                Span span) { this.Span = span;
        this.Mods = mods; this.RetType = retType; this.Name = name; this.TypeParams = typeParams;
        this.Params = ps; this.ParamCount = pc; this.Wheres = wheres; this.WhereCount = whereCount;
    }
    public override string Dump() {
        string m = (this.Mods == "") ? "" : (this.Mods + " ");
        string s = "(delegate " + m + this.RetType.Dump() + " " + this.Name + this.TypeParams.Dump() + " (";
        int i = 0;
        while (i < this.ParamCount) {
            if (i > 0) { s = s + ", "; }
            s = s + this.Params[i].Dump();
            i = i + 1;
        }
        s = s + ")";
        s = s + DeclHelpers.DumpWheres(this.Wheres, this.WhereCount);
        return s + ")";
    }
}

// record：位置式 `record P(T a, ...)`（PosParams）+ 可选基类 + 可选块体成员。
// 位置式 desugar（合成字段/ctor）留给后端；parser 仅捕获结构。
public sealed class RecordDecl : Decl {
    public string        Mods;
    public string        Name;
    public TypeParamList TypeParams;
    public Param[]       PosParams;
    public int           PosCount;
    public TypeExpr[]    Bases;
    public int           BaseCount;
    public WhereClause[] Wheres;
    public int           WhereCount;
    public Decl[]        Members;
    public int           MemberCount;
    public RecordDecl(string mods, string name, TypeParamList typeParams, Param[] pos, int pc,
                      TypeExpr[] bases, int baseCount, WhereClause[] wheres, int whereCount, Decl[] members, int mc,
                Span span) { this.Span = span;
        this.Mods = mods; this.Name = name; this.TypeParams = typeParams; this.PosParams = pos; this.PosCount = pc;
        this.Bases = bases; this.BaseCount = baseCount; this.Wheres = wheres; this.WhereCount = whereCount;
        this.Members = members; this.MemberCount = mc;
    }
    public override string Dump() {
        string m = (this.Mods == "") ? "" : (this.Mods + " ");
        string s = "(record " + m + this.Name + this.TypeParams.Dump();
        int i = 0;
        while (i < this.PosCount) { s = s + " (pos " + this.PosParams[i].Dump() + ")"; i = i + 1; }
        s = s + DeclHelpers.DumpBaseList(this.Bases, this.BaseCount);
        s = s + DeclHelpers.DumpWheres(this.Wheres, this.WhereCount);
        int j = 0;
        while (j < this.MemberCount) { s = s + " " + this.Members[j].Dump(); j = j + 1; }
        return s + ")";
    }
}

public sealed class CompilationUnit {
    public Span Span;
    public bool   HasNamespace;
    public string Namespace;
    public Decl[] Decls;
    public int    DeclCount;
    public CompilationUnit(bool hasNs, string ns, Decl[] decls, int dc, Span span) { this.Span = span;
        this.HasNamespace = hasNs; this.Namespace = ns; this.Decls = decls; this.DeclCount = dc;
    }
    public string Dump() {
        string s = "(unit";
        if (this.HasNamespace) { s = s + " (ns " + this.Namespace + ")"; }
        int i = 0;
        while (i < this.DeclCount) { s = s + " " + this.Decls[i].Dump(); i = i + 1; }
        return s + ")";
    }
}
