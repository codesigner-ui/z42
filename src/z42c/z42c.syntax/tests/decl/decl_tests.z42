// z42c.syntax 顶层声明解析单测：namespace/using/class/field/method/ctor/类型文本（incr 4）
//   + struct/interface/enum（incr 6b-1）+ record/delegate/顶层func（incr 6b-2）+ property（incr 6b-3）。
namespace Z42cSyntaxDeclTests;

using Std;
using Std.Test;
using Z42.Syntax;

string parseUnit(string src) {
    var p = new Parser(src, "t.z42");
    var u = p.ParseCompilationUnit();
    return u.Dump();
}

[Test]
void test_namespace_and_usings() {
    Assert.Equal("(unit (ns Foo.Bar) (using Std) (using Std.IO))",
                 parseUnit("namespace Foo.Bar; using Std; using Std.IO;"));
}

[Test]
void test_empty_class() {
    Assert.Equal("(unit (class C))", parseUnit("class C {}"));
}

[Test]
void test_class_modifiers_and_base() {
    Assert.Equal("(unit (class public sealed Foo : Bar, IBaz))",
                 parseUnit("public sealed class Foo : Bar, IBaz {}"));
}

[Test]
void test_fields() {
    Assert.Equal("(unit (class C (field private int x) (field public string Name \"a\")))",
                 parseUnit("class C { private int x; public string Name = \"a\"; }"));
}

[Test]
void test_method() {
    Assert.Equal("(unit (class C (method public int Add (int a, int b) (block (return (+ a b))))))",
                 parseUnit("class C { public int Add(int a, int b) { return a + b; } }"));
}

[Test]
void test_constructor() {
    Assert.Equal("(unit (class Point (ctor public Point (int x) (block (expr (= (. this x) x))))))",
                 parseUnit("class Point { public Point(int x) { this.x = x; } }"));
}

[Test]
void test_abstract_method_no_body() {
    Assert.Equal("(unit (class C (method public abstract int Foo ())))",
                 parseUnit("class C { public abstract int Foo(); }"));
}

[Test]
void test_generic_and_array_types() {
    Assert.Equal("(unit (class C (field private List<int> xs) (field private string[] names) (field private Dict<string,int> m)))",
                 parseUnit("class C { private List<int> xs; private string[] names; private Dict<string, int> m; }"));
}

[Test]
void test_nested_generic_type() {
    Assert.Equal("(unit (class C (field private List<List<int>> m)))",
                 parseUnit("class C { private List<List<int>> m; }"));
}

[Test]
void test_full_class() {
    Assert.Equal("(unit (ns App) (using Std) (class public Counter (field private int n) (ctor public Counter (int start) (block (expr (= (. this n) start)))) (method public int Next () (block (expr (= n (+ n 1))) (return n)))))",
        parseUnit("namespace App; using Std; public class Counter { private int n; public Counter(int start) { this.n = start; } public int Next() { n = n + 1; return n; } }"));
}

[Test]
void test_struct() {
    // struct 复用 class 成员机制（含 ctor 消歧）
    Assert.Equal("(unit (struct Point (field public int X) (field public int Y)))",
                 parseUnit("struct Point { public int X; public int Y; }"));
    Assert.Equal("(unit (struct public Pair (field public int A) (ctor public Pair (int a) (block (expr (= (. this A) a))))))",
                 parseUnit("public struct Pair { public int A; public Pair(int a) { this.A = a; } }"));
}

[Test]
void test_interface() {
    // interface 体为方法签名（无体 → `;`）
    Assert.Equal("(unit (interface IFoo (method int Bar ()) (method void Baz (int x))))",
                 parseUnit("interface IFoo { int Bar(); void Baz(int x); }"));
    Assert.Equal("(unit (interface public IShape : IDrawable (method double Area ())))",
                 parseUnit("public interface IShape : IDrawable { double Area(); }"));
}

[Test]
void test_enum() {
    Assert.Equal("(unit (enum Color Red Green Blue))",
                 parseUnit("enum Color { Red, Green, Blue }"));
    // 底层类型 + 显式值（含未显式的裸成员） + 尾随逗号
    Assert.Equal("(unit (enum public Flags : int (A 1) B (C 5)))",
                 parseUnit("public enum Flags : int { A = 1, B, C = 5, }"));
}

[Test]
void test_top_level_func() {
    // 顶层自由函数（head=func，区别于类成员 method）
    Assert.Equal("(unit (func int Add (int a, int b) (block (return (+ a b)))))",
                 parseUnit("int Add(int a, int b) { return a + b; }"));
    Assert.Equal("(unit (ns T) (func string greet (string n) (block (return n))))",
                 parseUnit("namespace T; string greet(string n) { return n; }"));
}

[Test]
void test_delegate() {
    Assert.Equal("(unit (delegate int BinOp (int a, int b)))",
                 parseUnit("delegate int BinOp(int a, int b);"));
    Assert.Equal("(unit (delegate public void Handler (string msg)))",
                 parseUnit("public delegate void Handler(string msg);"));
}

[Test]
void test_record() {
    // 位置式（仅参数，`;` 结尾）
    Assert.Equal("(unit (record Point (pos int X) (pos int Y)))",
                 parseUnit("record Point(int X, int Y);"));
    // 位置式 + 基类 + 块体成员
    Assert.Equal("(unit (record public Person (pos string Name) : Base (method int Age () (block (return 0)))))",
                 parseUnit("public record Person(string Name) : Base { int Age() { return 0; } }"));
    // 块式（无位置参数）
    Assert.Equal("(unit (record Empty))", parseUnit("record Empty { }"));
}

[Test]
void test_property() {
    Assert.Equal("(unit (class C (prop public int Age get set)))",
                 parseUnit("class C { public int Age { get; set; } }"));
    Assert.Equal("(unit (class C (prop public string Name get)))",   // get-only
                 parseUnit("class C { public string Name { get; } }"));
    Assert.Equal("(unit (class C (prop public int X get set 0)))",   // 初值
                 parseUnit("class C { public int X { get; set; } = 0; }"));
    Assert.Equal("(unit (class C (prop public int Y get private set)))",  // 访问器修饰
                 parseUnit("class C { public int Y { get; private set; } }"));
}

[Test]
void test_property_in_interface() {
    Assert.Equal("(unit (interface IShape (prop double Area get) (method void Draw ())))",
                 parseUnit("interface IShape { double Area { get; } void Draw(); }"));
}
