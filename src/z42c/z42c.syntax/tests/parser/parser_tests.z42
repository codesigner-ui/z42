// z42c.syntax Parser（Pratt 表达式）单测：用 Dump() 的 s-expression 断言结构 + 优先级。
namespace Z42cSyntaxParserTests;

using Std;
using Std.Test;
using Z42.Syntax;

// 辅助：解析表达式并返回其 s-expression dump。
string parse(string src) {
    var p = new Parser(src, "t.z42");
    var e = p.ParseExpression();
    return e.Dump();
}

[Test]
void test_literal_and_ident() {
    Assert.Equal("42", parse("42"));
    Assert.Equal("3.14", parse("3.14"));
    Assert.Equal("true", parse("true"));
    Assert.Equal("false", parse("false"));
    Assert.Equal("null", parse("null"));
    Assert.Equal("foo", parse("foo"));
    Assert.Equal("\"hi\"", parse("\"hi\""));
}

[Test]
void test_simple_binary() {
    Assert.Equal("(+ 1 2)", parse("1 + 2"));
    Assert.Equal("(* a b)", parse("a * b"));
}

[Test]
void test_precedence_mul_over_add() {
    Assert.Equal("(+ 1 (* 2 3))", parse("1 + 2 * 3"));
    Assert.Equal("(+ (* 1 2) 3)", parse("1 * 2 + 3"));
}

[Test]
void test_parens_override_precedence() {
    Assert.Equal("(* (+ 1 2) 3)", parse("(1 + 2) * 3"));
}

[Test]
void test_left_associativity() {
    Assert.Equal("(- (- a b) c)", parse("a - b - c"));
    Assert.Equal("(/ (/ a b) c)", parse("a / b / c"));
}

[Test]
void test_logical_precedence() {
    // && 绑定紧于 ||
    Assert.Equal("(|| (&& a b) c)", parse("a && b || c"));
    Assert.Equal("(|| a (&& b c))", parse("a || b && c"));
}

[Test]
void test_comparison_and_arithmetic() {
    // + 紧于 ==
    Assert.Equal("(== 1 (+ 2 3))", parse("1 == 2 + 3"));
    Assert.Equal("(< (+ a b) c)", parse("a + b < c"));
}

[Test]
void test_unary() {
    Assert.Equal("(- x)", parse("-x"));
    Assert.Equal("(! a)", parse("!a"));
    // 一元紧于二元：!a && b → (&& (! a) b)
    Assert.Equal("(&& (! a) b)", parse("!a && b"));
    // -a * b → (* (- a) b)
    Assert.Equal("(* (- a) b)", parse("-a * b"));
}

[Test]
void test_mixed_complex() {
    Assert.Equal("(|| (== (+ 1 (* 2 3)) 7) done)", parse("1 + 2 * 3 == 7 || done"));
}
