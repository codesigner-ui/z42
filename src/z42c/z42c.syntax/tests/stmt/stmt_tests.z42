// z42c.syntax 语句解析单测：var-decl / return / expr-stmt / block / if / while
//   / foreach / break / continue / throw / ternary（incr 1-5）
//   + for / do-while / switch / try-catch-finally（incr 6a）。
namespace Z42cSyntaxStmtTests;

using Std;
using Std.Test;
using Z42.Syntax;

string parseStmt(string src) {
    var p = new Parser(src, "t.z42");
    var s = p.ParseStatement();
    return s.Dump();
}

[Test]
void test_var_decl() {
    Assert.Equal("(decl var x 1)", parseStmt("var x = 1;"));
    Assert.Equal("(decl int y (+ 2 3))", parseStmt("int y = 2 + 3;"));
    Assert.Equal("(decl Foo f bar)", parseStmt("Foo f = bar;"));   // 自定义类型
}

[Test]
void test_return() {
    Assert.Equal("(return)", parseStmt("return;"));
    Assert.Equal("(return (+ x 1))", parseStmt("return x + 1;"));
}

[Test]
void test_expr_stmt() {
    Assert.Equal("(expr (call f 1))", parseStmt("f(1);"));
    Assert.Equal("(expr (= x 5))", parseStmt("x = 5;"));
    Assert.Equal("(expr (call (. obj method) a b))", parseStmt("obj.method(a, b);"));
}

[Test]
void test_block() {
    Assert.Equal("(block (decl var x 1) (return x))", parseStmt("{ var x = 1; return x; }"));
    Assert.Equal("(block)", parseStmt("{ }"));
}

[Test]
void test_if() {
    Assert.Equal("(if a (return 1))", parseStmt("if (a) return 1;"));
    Assert.Equal("(if a (expr (= x 1)) (expr (= x 2)))", parseStmt("if (a) x = 1; else x = 2;"));
}

[Test]
void test_while() {
    Assert.Equal("(while (< i 10) (expr (= i (+ i 1))))", parseStmt("while (i < 10) i = i + 1;"));
}

[Test]
void test_nested() {
    Assert.Equal("(if a (block (while b (expr (call c)))))",
                 parseStmt("if (a) { while (b) c(); }"));
}

[Test]
void test_foreach() {
    Assert.Equal("(foreach var x items (expr (call f x)))",
                 parseStmt("foreach (var x in items) f(x);"));
    Assert.Equal("(foreach int n (. obj nums) (block (expr (= sum (+ sum n)))))",
                 parseStmt("foreach (int n in obj.nums) { sum = sum + n; }"));
}

[Test]
void test_break_continue() {
    Assert.Equal("(block (break) (continue))", parseStmt("{ break; continue; }"));
    Assert.Equal("(while a (block (if b (break))))", parseStmt("while (a) { if (b) break; }"));
}

[Test]
void test_throw() {
    Assert.Equal("(throw err)", parseStmt("throw err;"));
    Assert.Equal("(throw (call (. ex Make) msg))", parseStmt("throw ex.Make(msg);"));
}

[Test]
void test_ternary_in_stmt() {
    Assert.Equal("(return (?: (> a b) a b))", parseStmt("return a > b ? a : b;"));
}

[Test]
void test_for() {
    Assert.Equal("(for (decl int i 0) (< i 10) (= i (+ i 1)) (expr (call f i)))",
                 parseStmt("for (int i = 0; i < 10; i = i + 1) f(i);"));
    Assert.Equal("(for _ _ _ (break))", parseStmt("for (;;) break;"));   // 三段全省
    Assert.Equal("(for (expr (= i 0)) (< i n) (= i (+ i 1)) (block (expr (= sum (+ sum i)))))",
                 parseStmt("for (i = 0; i < n; i = i + 1) { sum = sum + i; }"));   // init 为 expr-stmt
}

[Test]
void test_do_while() {
    Assert.Equal("(do (expr (call x)) (< i 10))", parseStmt("do x(); while (i < 10);"));
    Assert.Equal("(do (block (expr (= i (+ i 1)))) (< i n))",
                 parseStmt("do { i = i + 1; } while (i < n);"));
}

[Test]
void test_switch() {
    Assert.Equal("(switch x (case 1 (return a)) (case 2 (return b)) (default (return c)))",
                 parseStmt("switch (x) { case 1: return a; case 2: return b; default: return c; }"));
    // 空分支贯穿（case 1 无语句直落 case 2）
    Assert.Equal("(switch x (case 1) (case 2 (expr (call f)) (break)))",
                 parseStmt("switch (x) { case 1: case 2: f(); break; }"));
}

[Test]
void test_try() {
    Assert.Equal("(try (block (expr (call f))) (catch Exception e (block (expr (call g)))))",
                 parseStmt("try { f(); } catch (Exception e) { g(); }"));
    // 仅类型无变量 + finally
    Assert.Equal("(try (block (expr (call a))) (catch Error _ (block (expr (call b)))) (finally (block (expr (call c)))))",
                 parseStmt("try { a(); } catch (Error) { b(); } finally { c(); }"));
    // 裸 catch（无类型无变量）
    Assert.Equal("(try (block (expr (call a))) (catch _ _ (block (expr (call b)))))",
                 parseStmt("try { a(); } catch { b(); }"));
}
