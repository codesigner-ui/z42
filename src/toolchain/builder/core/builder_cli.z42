// z42b CLI 路由 —— Std.Cli 嵌套 router（对照 launcher_cli.z42）。
//
// SCOPE（retire-test-runner）：本编译单元只接 **test / bench** 反射式运行器
// （取代 Rust z42-test-runner）。new / build / publish / export / run 的编排实现
// 依赖 Z42.Build / Z42.Project（其 `Z42.Project` 命名空间与编译器内部 z42c.project
// 在共享 Z42_LIBS 下冲突），属 wire-z42b-host-build —— 这里先登记命令面并给出
// "pending" 提示，待该变更接入 PARKED 的 builder.z42 / builder_commands.z42 /
// builder_new.z42。test/bench 处理见 builder_test.z42。
namespace Z42Builder;

using Std;
using Std.IO;
using Std.Cli;

// exe 入口。standalone（`z42vm z42.builder.zbc -- <verb> ...`）与 launcher 透传
// （`z42 <verb> ...`）都经 Environment.GetCommandLineArgs() 拿到动词起的 argv。
void Main() {
    Environment.Exit(_runBuilder(Environment.GetCommandLineArgs()));
}

// 入口：launcher 透传的 argv（已去掉 `z42` 前缀的动词起）。
int _runBuilder(string[] argv) {
    if (argv.Length == 0) { Console.WriteLine(_builderRoot().HelpText()); return 0; }

    SubcommandRouter root = _builderRoot();
    CommandResolution res;
    try { res = root.Resolve(argv); }
    catch (CliException e) {
        ConsoleError.WriteLine("z42b: " + e.Message);
        return 2;
    }
    if (res.IsHelp())    { Console.WriteLine(res.HelpText()); return 0; }
    if (res.IsUnknown()) { ConsoleError.WriteLine(res.ErrorMessage()); return 2; }
    return _dispatchBuilder(res);
}

SubcommandRouter _builderRoot() {
    SubcommandRouter root = new SubcommandRouter("z42b", "z42 build orchestrator");

    // new / build / publish / export / run — 命令面登记，编排待 wire-z42b-host-build。
    ArgParser newP = new ArgParser("z42b new", "scaffold a new project (pending wire-z42b-host-build)");
    newP.AddOptionalPositional("name", "project name (kebab-case)");
    root.Add("new", "scaffold a new project", newP);

    ArgParser build = new ArgParser("z42b build", "compile to app.zpkg (pending wire-z42b-host-build)");
    build.AddOptionalPositional("project", "<project.z42.toml>");
    root.Add("build", "compile to a platform-agnostic app.zpkg", build);

    ArgParser pub = new ArgParser("z42b publish", "produce a release deployable (pending wire-z42b-host-build)");
    pub.AddOptionalPositional("project", "<project.z42.toml>");
    root.Add("publish", "produce a release deployable", pub);

    ArgParser exp = new ArgParser("z42b export", "generate a native IDE project (pending wire-z42b-host-build)");
    exp.AddOptionalPositional("project", "<project.z42.toml>");
    root.Add("export", "generate a native IDE project", exp);

    ArgParser runP = new ArgParser("z42b run", "run app.zpkg on host (served by the launcher)");
    runP.AllowExtras();
    runP.AddOptionalPositional("target", "<app.zpkg> | <project.z42.toml> [-- args]");
    root.Add("run", "run app.zpkg or platform deploy form", runP);

    // test / bench — 反射式运行器（functional；取代 Rust z42-test-runner）。
    ArgParser test = new ArgParser("z42b test", "run a compiled module's [Test] methods");
    test.AddOptionalPositional("target", "<file.zbc|file.zpkg>");
    test.AddOption("filter", "", "test name substring filter (reserved)", "");
    root.Add("test", "run [Test] in a compiled module", test);

    ArgParser bench = new ArgParser("z42b bench", "run a compiled module's [Benchmark] methods");
    bench.AddOptionalPositional("target", "<file.zbc|file.zpkg>");
    bench.AddOption("filter", "", "benchmark name substring filter (reserved)", "");
    root.Add("bench", "run [Benchmark] in a compiled module", bench);

    return root;
}

// ── dispatch ──────────────────────────────────────────────────────────────

int _dispatchBuilder(CommandResolution res) {
    string[] p = res.Path();
    if (p.Length == 0) { return 0; }
    ParseResult r = res.Result();
    string top = p[0];
    if (top == "test")  { return _cmdTest(r); }
    if (top == "bench") { return _cmdBench(r); }
    if (top == "run") {
        ConsoleError.WriteLine("z42b run: host bytecode run is served by the launcher (z42 run <app.zpkg>)");
        return 2;
    }
    // new / build / publish / export — pending wire-z42b-host-build.
    ConsoleError.WriteLine("z42b " + top + ": pending wire-z42b-host-build "
        + "(needs the in-process compiler API; not yet wired)");
    return 1;
}
