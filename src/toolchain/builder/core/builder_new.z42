// `z42b new <name>` —— 项目脚手架。生成最小可构建工程：z42.toml + src 模板 +
// .gitignore + README。模板族：exe（默认）/ lib / test。纯 Std.IO，无编译器依赖。
//
// ⚠️ PARKED：与 builder 其余部分一同未接编译（无 z42.builder.z42.toml）。
namespace Z42Builder;

using Std;
using Std.IO;
using Std.Cli;

// new 入口：解析 name + 模板 + 落点 → 写模板文件。
int _cmdNew(ParseResult r) {
    string name = r.GetPositional(0);
    if (name.Length == 0) {
        ConsoleError.WriteLine("z42b new: missing <name>");
        return 2;
    }
    string kind = "exe";
    if (r.GetFlag("lib"))  { kind = "lib"; }
    if (r.GetFlag("test")) { kind = "test"; }

    string dir = r.GetOption("path");
    if (dir.Length == 0) { dir = name; }

    if (Directory.Exists(dir) && _dirNonEmpty(dir)) {
        ConsoleError.WriteLine("z42b new: target '" + dir + "' exists and is not empty");
        return 1;
    }

    Directory.Create(dir);
    Directory.Create(Path.Join(dir, "src"));

    File.WriteAllText(Path.Join(dir, "z42.toml"), _tomlTemplate(name, kind));
    File.WriteAllText(Path.Join(dir, ".gitignore"), _gitignoreTemplate());
    File.WriteAllText(Path.Join(dir, "README.md"), _readmeTemplate(name, kind));
    _writeSource(dir, name, kind);

    Console.WriteLine("created " + kind + " project '" + name + "' in " + dir + "/");
    Console.WriteLine("  next:  cd " + dir + " && z42 build && z42 run");
    return 0;
}

// ── 模板 ─────────────────────────────────────────────────────────────────────

string _tomlTemplate(string name, string kind) {
    string projKind = (kind == "lib") ? "lib" : "exe";
    string s = "";
    s = s + "[project]\n";
    s = s + "name = \"" + name + "\"\n";
    s = s + "version = \"0.1.0\"\n";
    s = s + "kind = \"" + projKind + "\"\n";
    s = s + "\n";
    s = s + "[sources]\n";
    s = s + "include = [\"src/**/*.z42\"]\n";
    if (kind == "test") {
        s = s + "\n";
        s = s + "[dependencies]\n";
        s = s + "z42.test = \"*\"\n";
    }
    return s;
}

void _writeSource(string dir, string name, string kind) {
    string src = Path.Join(dir, "src");
    if (kind == "lib") {
        File.WriteAllText(Path.Join(src, "Lib.z42"), _libSource(name));
        return;
    }
    if (kind == "test") {
        File.WriteAllText(Path.Join(src, "Tests.z42"), _testSource(name));
        return;
    }
    File.WriteAllText(Path.Join(src, "Main.z42"), _exeSource(name));
}

string _exeSource(string name) {
    string s = "";
    s = s + "using Std.IO;\n";
    s = s + "\n";
    s = s + "class Program {\n";
    s = s + "    static void Main() {\n";
    s = s + "        Console.WriteLine(\"Hello from " + name + "!\");\n";
    s = s + "    }\n";
    s = s + "}\n";
    return s;
}

string _libSource(string name) {
    string s = "";
    s = s + "namespace " + _nsOf(name) + ";\n";
    s = s + "\n";
    s = s + "public static class Greeter {\n";
    s = s + "    public static string Hello(string who) {\n";
    s = s + "        return \"Hello, \" + who + \"!\";\n";
    s = s + "    }\n";
    s = s + "}\n";
    return s;
}

string _testSource(string name) {
    string s = "";
    s = s + "using Std.Test;\n";
    s = s + "\n";
    s = s + "class " + _nsOf(name) + "Tests {\n";
    s = s + "    [Test]\n";
    s = s + "    void it_works() {\n";
    s = s + "        Assert.Equal(2, 1 + 1);\n";
    s = s + "    }\n";
    s = s + "}\n";
    return s;
}

string _gitignoreTemplate() {
    string s = "";
    s = s + "/artifacts/\n";
    s = s + "/dist/\n";
    s = s + "*.zsym\n";
    return s;
}

string _readmeTemplate(string name, string kind) {
    string s = "";
    s = s + "# " + name + "\n";
    s = s + "\n";
    s = s + "A z42 " + kind + " project.\n";
    s = s + "\n";
    s = s + "```\n";
    s = s + "z42 build      # compile to dist/" + name + ".zpkg\n";
    if (kind == "exe") { s = s + "z42 run        # run it\n"; }
    if (kind == "test") { s = s + "z42 test       # run [Test] units\n"; }
    s = s + "```\n";
    return s;
}

// ── 辅助 ─────────────────────────────────────────────────────────────────────

// kebab-case 项目名 → PascalCase 命名空间标识（"my-app" → "MyApp"）。
string _nsOf(string name) {
    string r = "";
    bool up = true;
    int i = 0;
    while (i < name.Length) {
        string c = name.Substring(i, 1);
        if (c == "-" || c == "_" || c == ".") { up = true; }
        else {
            r = r + (up ? c.ToUpper() : c);
            up = false;
        }
        i = i + 1;
    }
    if (r.Length == 0) { return "App"; }
    return r;
}

bool _dirNonEmpty(string dir) {
    string[] entries = Directory.Enumerate(dir);
    return entries.Length > 0;
}
