// z42b publish — desktop apphost publish (moved from launcher_export.z42 by
// move-publish-to-z42b). z42b owns the deploy verb; the launcher only forwards
// `z42 publish` here (mirroring test/bench), pre-resolving the desktop workload
// apphost stub and passing it via `Z42_APPHOST_TEMPLATE` (Decision 3.5) so this
// module needs NO installed-runtime/workload resolution.
//
// Layout: `[platform.desktop]` `bin`/`payload` place the apphost binary + payload
// zpkg at explicit relative paths under the deploy root (add-package-layout-config);
// unset → legacy flat (apphost at root/<name>, embed built zpkg in place).
//
// build-if-needed (move-publish-to-z42b stage 3): if the expected zpkg is missing,
// `_pubEnsureBuilt` compiles it via z42c, then publish produces the apphost — so
// `z42 publish` alone does build+deploy. When the zpkg already exists (xtask
// assembly path), no compile runs and bytes stay controlled. Stage 1 ships the
// resolve-or-error form; stage 3 adds the z42c spawn.
namespace Z42Builder;

using Std;
using Std.IO;
using Std.Toml;
// apphost patching is inlined in builder_apphost.z42 (_pubProduceApphost) so z42b
// stays on stdlib-only deps and still builds in the test-runner context. NOT
// `using Z42.Workload.Desktop` (that workload isn't in Z42_LIBS there).

// Entry from builder_cli dispatch (`z42b publish <toml> [--rid <rid>] [--output <dir>]`).
int _cmdPublishZ42b(ParseResult r) {
    string rid = r.GetOption("rid");
    if (rid.Length == 0) {
        ConsoleError.WriteLine("z42b publish: --rid required (run via `z42 publish` to default to host)");
        return 2;
    }
    if (_pubRidCategory(rid) != "desktop") {
        ConsoleError.WriteLine("z42b publish: " + _pubRidCategory(rid)
            + " deployable not yet implemented (B5) — only desktop (apphost) is supported.");
        return 2;
    }
    return _pubDesktop(r, rid);
}

// desktop apphost publish for `rid`. Emits <root>/<bin> (apphost) + optional
// <root>/<payload> (copied zpkg); the apphost embeds the zpkg path relative to itself.
int _pubDesktop(ParseResult r, string rid) {
    string tomlPath = r.GetPositional(0);
    if (tomlPath.Length == 0 || !tomlPath.EndsWith(".toml")) {
        ConsoleError.WriteLine("usage: z42b publish <project.z42.toml> [--rid <rid>] [--output <dir>]");
        return 2;
    }
    if (!File.Exists(tomlPath)) {
        ConsoleError.WriteLine("z42b publish: not found: " + tomlPath);
        return 1;
    }
    TomlValue toml = TomlValue.Parse(File.ReadAllText(tomlPath));
    string projName = _pubTomlStr(toml, "project", "name", "");
    if (projName.Length == 0) {
        ConsoleError.WriteLine("z42b publish: [project].name missing in " + tomlPath);
        return 1;
    }
    // apphost-gate (gate-apphost-on-config): only `[platform.desktop] apphost = true`
    // makes publish emit an apphost. publish_dir / --output are output LOCATION only.
    if (!_pubPlatformBool(toml, "desktop", "apphost", false)) {
        ConsoleError.WriteLine("z42b publish: " + tomlPath + " is not configured to publish a desktop apphost — "
            + "add `apphost = true` under [platform.desktop]");
        return 2;
    }

    // apphost stub: resolved by the launcher (which owns installed-workload resolution)
    // and passed via Z42_APPHOST_TEMPLATE (Decision 3.5). No runtime resolution here.
    string stub = Environment.GetEnvironmentVariable("Z42_APPHOST_TEMPLATE") ?? "";
    if (stub.Length == 0 || !File.Exists(stub)) {
        ConsoleError.WriteLine("z42b publish: desktop apphost not available (the apphost ships with the desktop workload).");
        ConsoleError.WriteLine("       run: z42 workload install desktop");
        ConsoleError.WriteLine("       (publish via `z42 publish` so the launcher resolves the installed workload apphost.)");
        return 1;
    }

    string publishDir = r.GetOption("output");
    if (publishDir.Length == 0) { publishDir = _pubPlatformStr(toml, "desktop", "publish_dir", ""); }
    if (publishDir.Length == 0) { publishDir = "."; }   // default: project dir (location only)
    bool isWin = rid.StartsWith("windows-");
    string projDir = Path.GetDirectoryName(tomlPath);
    // `root` = the deploy root that bin/payload are relative to.
    string root = (projDir.Length > 0) ? Path.Join(projDir, publishDir) : publishDir;

    // build-if-needed: ensure the expected zpkg exists (compile via z42c if missing).
    string zpkgSrc = _pubEnsureBuilt(tomlPath, toml, projName);
    if (zpkgSrc.Length == 0) { return 1; }   // ensure failed (compile error / still missing)

    // deploy layout (add-package-layout-config): optional bin/payload.
    string binRel     = _pubPlatformStr(toml, "desktop", "bin", "");
    string payloadRel = _pubPlatformStr(toml, "desktop", "payload", "");

    string outPath;
    if (binRel.Length > 0) {
        outPath = Path.Join(root, binRel);
        if (isWin && !outPath.EndsWith(".exe")) { outPath = outPath + ".exe"; }
    } else {
        outPath = Path.Join(root, isWin ? (projName + ".exe") : projName);
    }

    // payload zpkg: if set, copy the built zpkg into the layout so the subtree is
    // self-contained; Apphost.Produce embeds it relative to outPath. If unset, embed
    // the built zpkg in place (no copy) — preserves legacy behavior.
    string appZpkg = zpkgSrc;
    if (payloadRel.Length > 0) {
        appZpkg = Path.Join(root, payloadRel);
        string payloadDir = Path.GetDirectoryName(appZpkg);
        if (payloadDir.Length > 0) { Directory.Create(payloadDir); }
        File.Copy(zpkgSrc, appZpkg);

        // add-package-layout-config (2026-07-01): colocate this component's
        // non-stdlib workspace-sibling dependencies (e.g. z42c.driver's 6 z42c.*
        // libs) into the same payload dir — publish emits a self-contained
        // subtree, not just the single entry zpkg. Generic: any z42 app that
        // depends on a sibling project in its workspace gets this for free.
        int dc = _pubBundleProjectDeps(tomlPath, toml, payloadDir);
        if (dc != 0) { return dc; }
    }

    string outDir = Path.GetDirectoryName(outPath);
    if (outDir.Length > 0) { Directory.Create(outDir); }
    Console.WriteLine("z42 publish (" + rid + ") → " + outPath);
    int prc = _pubProduceApphost(appZpkg, outPath, stub, rid);
    if (prc != 0) { return prc; }
    Console.WriteLine("✅ apphost ready: " + outPath);
    return 0;
}

// ── helpers (minimal toml/path set, mirrored from launcher; Decision 4) ─────────

// rid → platform category (desktop / ios / android / wasm); "" if unknown.
string _pubRidCategory(string rid) {
    if (rid.StartsWith("macos-") || rid.StartsWith("linux-") || rid.StartsWith("windows-")) { return "desktop"; }
    if (rid.StartsWith("ios-") || rid.StartsWith("iossim-")) { return "ios"; }
    if (rid.StartsWith("android-")) { return "android"; }
    if (rid == "browser-wasm") { return "wasm"; }
    return "";
}

// Read root.[section].[key] as a string (string and long values).
string _pubTomlStr(TomlValue root, string section, string key, string dflt) {
    if (!root.ContainsKey(section)) { return dflt; }
    TomlValue s = root.Get(section);
    if (!s.IsTable() || !s.ContainsKey(key)) { return dflt; }
    TomlValue v = s.Get(key);
    if (v.IsString()) { return v.AsString(); }
    if (v.IsLong())   { return v.AsLong().ToString(); }
    return dflt;
}

// Read root.platform.[platform].[key] as a string.
string _pubPlatformStr(TomlValue root, string platform, string key, string dflt) {
    if (!root.ContainsKey("platform")) { return dflt; }
    TomlValue pt = root.Get("platform");
    if (!pt.IsTable() || !pt.ContainsKey(platform)) { return dflt; }
    TomlValue p = pt.Get(platform);
    if (!p.IsTable() || !p.ContainsKey(key)) { return dflt; }
    TomlValue v = p.Get(key);
    if (v.IsString()) { return v.AsString(); }
    if (v.IsLong())   { return v.AsLong().ToString(); }
    return dflt;
}

// Read a bool key under [platform.<platform>] (e.g. `apphost = true`).
bool _pubPlatformBool(TomlValue root, string platform, string key, bool dflt) {
    if (!root.ContainsKey("platform")) { return dflt; }
    TomlValue pt = root.Get("platform");
    if (!pt.IsTable() || !pt.ContainsKey(platform)) { return dflt; }
    TomlValue p = pt.Get(platform);
    if (!p.IsTable() || !p.ContainsKey(key)) { return dflt; }
    TomlValue v = p.Get(key);
    if (v.IsBool()) { return v.AsBool(); }
    return dflt;
}

// Ensure the expected zpkg exists, returning its path ("" on failure). build-if-needed
// (move-publish-to-z42b): if the zpkg is missing, compile it via z42c, then re-check
// — so `z42 publish` alone does build+deploy. When the zpkg already exists (the xtask
// assembly path), NO compile runs and the bytes stay controlled by the caller. If
// z42c can't be located, degrade to a build-first hint (the pre-build-if-needed form).
string _pubEnsureBuilt(string tomlPath, TomlValue toml, string projName) {
    string zpkgSrc = _pubResolveZpkg(tomlPath, toml, projName);
    if (File.Exists(zpkgSrc)) { return zpkgSrc; }

    string z42c = _pubFindZ42c();
    if (z42c.Length == 0) {
        ConsoleError.WriteLine("z42b publish: built zpkg not found: " + zpkgSrc
            + "  (build it first: z42 build " + tomlPath + ")");
        return "";
    }
    Console.WriteLine("z42b publish: zpkg not built — compiling via z42c first…");
    ProcessResult pr = new Process(z42c).Arg("build").Arg(tomlPath).Arg("--release")
        .Stdout(Stdio.Inherit()).Stderr(Stdio.Inherit()).Run();
    if (pr.ExitCode != 0) {
        ConsoleError.WriteLine("z42b publish: z42c build failed (rc=" + pr.ExitCode.ToString() + ")");
        return "";
    }
    if (!File.Exists(zpkgSrc)) {
        ConsoleError.WriteLine("z42b publish: zpkg still missing after build: " + zpkgSrc);
        return "";
    }
    return zpkgSrc;
}

// Locate the SDK's `bin/z42c` apphost from Z42_PORTABLE_VM (<home>/bin/z42vm →
// <home>/bin/z42c). "" if not resolvable (then publish degrades to a build-first
// hint). The apphost colocates the driver's siblings + resolves stdlib itself.
string _pubFindZ42c() {
    string vm = Environment.GetEnvironmentVariable("Z42_PORTABLE_VM") ?? "";
    if (vm.Length == 0) { return ""; }
    string home = Path.GetDirectoryName(Path.GetDirectoryName(vm));   // <home>/bin/z42vm → <home>
    if (home.Length == 0) { return ""; }
    string z42c = Path.Join(home, "bin/z42c");
    if (!File.Exists(z42c)) { z42c = z42c + ".exe"; }
    if (!File.Exists(z42c)) { return ""; }
    return z42c;
}

// Resolve the built zpkg via the same dist_dir logic as the launcher used.
// Workspace members that omit their own [build] section (the common case —
// see z42c.core/z42c.semantics/... tomls) inherit `[workspace.build] output_dir`
// from the enclosing z42.workspace.toml instead of falling back to a
// project-relative "dist/" (which does not match where `z42c build --workspace`
// actually writes the zpkg — add-package-layout-config dependency bundling
// exposed this: bundling failed to locate z42c.semantics's zpkg without it).
string _pubResolveZpkg(string tomlPath, TomlValue toml, string name) {
    string projDir = Path.GetDirectoryName(tomlPath);
    string outDir  = _pubTomlStr(toml, "build", "output_dir", "");
    string distDir = _pubTomlStr(toml, "build", "dist_dir", "");
    if (outDir.Length == 0 && distDir.Length == 0) {
        string wsRoot = _pubFindWorkspaceRoot(tomlPath);
        if (wsRoot.Length > 0) {
            string wsOutDir = _pubWorkspaceOutputDir(wsRoot, name);
            if (wsOutDir.Length > 0) {
                return Path.Join(Path.Join(wsRoot, wsOutDir), "dist/" + name + ".zpkg");
            }
        }
    }
    string distRel;
    if (distDir.Length > 0) { distRel = distDir.Replace("${output_dir}", outDir); }
    else if (outDir.Length > 0) { distRel = Path.Join(outDir, "dist"); }
    else { distRel = "dist"; }
    string base = (projDir.Length > 0) ? Path.Join(projDir, distRel) : distRel;
    return Path.Join(base, name + ".zpkg");
}

// `[workspace.build] output_dir` template resolved for `name` at profile
// "release" (mirrors _pubEnsureBuilt's hardcoded `z42c build --release`).
// "" if the workspace declares no such template.
string _pubWorkspaceOutputDir(string wsRoot, string name) {
    string wsToml = Path.Join(wsRoot, "z42.workspace.toml");
    if (!File.Exists(wsToml)) { return ""; }
    TomlValue toml = TomlValue.Parse(File.ReadAllText(wsToml));
    if (!toml.ContainsKey("workspace")) { return ""; }
    TomlValue ws = toml.Get("workspace");
    if (!ws.IsTable() || !ws.ContainsKey("build")) { return ""; }
    TomlValue wb = ws.Get("build");
    if (!wb.IsTable() || !wb.ContainsKey("output_dir")) { return ""; }
    TomlValue v = wb.Get("output_dir");
    if (!v.IsString()) { return ""; }
    string tmpl = v.AsString();
    tmpl = tmpl.Replace("${project_name}", name);
    tmpl = tmpl.Replace("${profile}", "release");
    return tmpl;
}

// ── project-kind (workspace-sibling) dependency bundling (add-package-layout-config) ──
//
// z42.toml `[dependencies]` mixes stdlib deps ("z42.io") and, inside a workspace,
// sibling project deps ("z42c.core") using identical syntax. There is no `Kind`
// field distinguishing them (confirmed: DepScan / DepEntry have none). We derive
// "is this a project dep" by cross-referencing against the enclosing workspace's
// `z42.workspace.toml` `default-members` list — the same source `_compilerMembers`
// (xtask) already reads. z42b must stay stdlib-only (test-runner build context),
// so this is hand-rolled TOML walking, NOT a dependency on z42c.project/pipeline.

// Walk up from `tomlPath`'s directory looking for a sibling `z42.workspace.toml`.
// "" if this project isn't inside a workspace (all its deps are then stdlib).
string _pubFindWorkspaceRoot(string tomlPath) {
    string dir = Path.GetDirectoryName(tomlPath);
    while (dir.Length > 0) {
        if (File.Exists(Path.Join(dir, "z42.workspace.toml"))) { return dir; }
        string parent = Path.GetDirectoryName(dir);
        if (parent.Length == 0 || parent == dir) { return ""; }
        dir = parent;
    }
    return "";
}

// `[workspace] default-members` list from `<wsRoot>/z42.workspace.toml`.
string[] _pubWorkspaceMembers(string wsRoot) {
    string wsToml = Path.Join(wsRoot, "z42.workspace.toml");
    if (!File.Exists(wsToml)) { return new string[0]; }
    TomlValue toml = TomlValue.Parse(File.ReadAllText(wsToml));
    if (!toml.ContainsKey("workspace")) { return new string[0]; }
    TomlValue ws = toml.Get("workspace");
    if (!ws.IsTable() || !ws.ContainsKey("default-members")) { return new string[0]; }
    TomlValue arr = ws.Get("default-members");
    string[] xs = new string[arr.Count()];
    int i = 0;
    while (i < arr.Count()) {
        TomlValue v = arr.At(i);
        xs[i] = v.IsString() ? v.AsString() : "";
        i = i + 1;
    }
    return xs;
}

// This project's own `[dependencies]` key names ("" if the section is missing).
string[] _pubDepNames(TomlValue toml) {
    if (!toml.ContainsKey("dependencies")) { return new string[0]; }
    TomlValue deps = toml.Get("dependencies");
    if (!deps.IsTable()) { return new string[0]; }
    return deps.Keys();
}

bool _pubContains(string[] xs, int count, string v) {
    int i = 0;
    while (i < count) {
        if (xs[i] == v) { return true; }
        i = i + 1;
    }
    return false;
}

// Member dir/toml convention: `<wsRoot>/<name>/<name>.z42.toml` (mirrors the
// convention xtask's `_compilerMembers` callers already assume).
string _pubMemberTomlPath(string wsRoot, string name) {
    return Path.Join(Path.Join(wsRoot, name), name + ".z42.toml");
}

// Transitive closure of `tomlPath`'s workspace-sibling (non-stdlib) dependency
// names — BFS over `[dependencies]` restricted to names that resolve to a
// workspace member. Empty if not inside a workspace or no such deps.
string[] _pubProjectDepNames(string tomlPath, TomlValue toml) {
    string wsRoot = _pubFindWorkspaceRoot(tomlPath);
    if (wsRoot.Length == 0) { return new string[0]; }
    string[] members = _pubWorkspaceMembers(wsRoot);
    if (members.Length == 0) { return new string[0]; }
    string ownName = _pubTomlStr(toml, "project", "name", "");

    string[] closure = new string[members.Length];
    int closureCount = 0;
    string[] queue = new string[members.Length];
    int qTail = 0;

    string[] seed = _pubDepNames(toml);
    int si = 0;
    while (si < seed.Length) {
        string d = seed[si];
        if (d != ownName && _pubContains(members, members.Length, d) && !_pubContains(closure, closureCount, d)) {
            queue[qTail] = d; qTail = qTail + 1;
            closure[closureCount] = d; closureCount = closureCount + 1;
        }
        si = si + 1;
    }

    int qHead = 0;
    while (qHead < qTail) {
        string name = queue[qHead]; qHead = qHead + 1;
        string memberToml = _pubMemberTomlPath(wsRoot, name);
        if (!File.Exists(memberToml)) { continue; }
        TomlValue mt = TomlValue.Parse(File.ReadAllText(memberToml));
        string[] mdeps = _pubDepNames(mt);
        int mi = 0;
        while (mi < mdeps.Length) {
            string d = mdeps[mi];
            if (d != ownName && _pubContains(members, members.Length, d) && !_pubContains(closure, closureCount, d)) {
                queue[qTail] = d; qTail = qTail + 1;
                closure[closureCount] = d; closureCount = closureCount + 1;
            }
            mi = mi + 1;
        }
    }

    string[] result = new string[closureCount];
    int ri = 0;
    while (ri < closureCount) { result[ri] = closure[ri]; ri = ri + 1; }
    return result;
}

// build-if-needed each workspace-sibling dependency of `tomlPath`, then copy its
// zpkg (+ .zsym sidecar if present) into `payloadDir`. 0 on success.
int _pubBundleProjectDeps(string tomlPath, TomlValue toml, string payloadDir) {
    string wsRoot = _pubFindWorkspaceRoot(tomlPath);
    string[] depNames = _pubProjectDepNames(tomlPath, toml);
    int i = 0;
    while (i < depNames.Length) {
        string depName = depNames[i];
        string depTomlPath = _pubMemberTomlPath(wsRoot, depName);
        TomlValue depToml = TomlValue.Parse(File.ReadAllText(depTomlPath));
        string depZpkg = _pubEnsureBuilt(depTomlPath, depToml, depName);
        if (depZpkg.Length == 0) { return 1; }
        File.Copy(depZpkg, Path.Join(payloadDir, depName + ".zpkg"));
        string depSym = Path.Join(Path.GetDirectoryName(depZpkg), depName + ".zsym");
        if (File.Exists(depSym)) { File.Copy(depSym, Path.Join(payloadDir, depName + ".zsym")); }
        i = i + 1;
    }
    return 0;
}
