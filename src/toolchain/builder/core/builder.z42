// z42b — 构建编排器（build orchestrator）。⚠️ PARKED / 未接编译。
//
// 职责：读 z42.toml/--rid → 构造 z42.build 管线（注入 编译器 + workload + hooks）→ 跑。
//   build   → tail no-op（产平台无关 app.zpkg）
//   export  → 跑到 GenerateProject 停（原生 IDE 工程，ios/android）
//   publish → 一路到 Package（可分发件 apphost/.ipa/.aab/wasm）
//
// 关键设计（与 z42c 共享编译实现，见 z42.build/src/ICompiler.z42）：
//   Compile 头相位经 z42.build 的 `ICompiler` 接口**在进程内**调编译器库——和独立 z42c
//   CLI 调的是同一份实现，**不 fork z42c 子进程**。z42b 只负责编排 + 注入。
//
// ⚠️ 未接编译：无 z42.builder.z42.toml，未登记 workspace/xtask/CI，不影响现有构建。
//   _hostCompiler 暂返 NoCompiler（真实 z42c `: ICompiler` 适配器待 extract-compile-pipeline-api
//   落地的 PackageCompiler 封装）；_selectWorkload 暂返 WorkloadBase（真实平台 workload 后续）。
// 命令层在 builder_commands.z42 / builder_new.z42；CLI 路由在 builder_cli.z42。
namespace Z42Builder;

using Std;
using Std.IO;
using Z42.Build;
using Z42.Project;

// 编排入口：命令层解析出 manifest + target + sourceDir 后调本函数。
// 按项目是否带自定义 build/ 选路径。
int _orchestrate(ProjectManifest manifest, Target target, string sourceDir) {
    // 实现期：探测工程 build/ 目录是否存在且非空 → 走自定义 driver 路径。
    if (_hasProjectBuild(sourceDir)) { return _runWithProjectBuild(manifest, target, sourceDir); }
    return _runStandard(manifest, target, sourceDir);
}

// 标准路径（项目无自定义 build/）：全在进程内组合 —— 零子进程、零代码生成。
int _runStandard(ProjectManifest manifest, Target target, string sourceDir) {
    Pipeline p = new Pipeline();
    p.Compiler = _hostCompiler();                  // 共享 z42c 编译实现（ICompiler），in-process
    p.Workload = _selectWorkload(target.Family);   // 标准平台 workload 库
    // p.Hooks 默认空（无自定义编译前后扩展）

    PipelineContext ctx = new PipelineContext();
    ctx.Project     = manifest.Project;
    ctx.Manifest    = manifest;
    ctx.Target      = target;
    ctx.Dirs        = _computeDirs(manifest, sourceDir, target.Profile);
    ctx.Inputs      = _initialInputs(manifest);
    ctx.WorkloadDir = "";                          // 实现期：选中 workload 的安装目录
    return p.Run(ctx);
}

// 自定义路径（项目带 build/：class ProjectHooks : BuildHooks / class iOSBuild : iOSWorkload）：
//   生成一次性 driver 源码（链 z42.build + workload + 项目 build/）→ 用**同一 ICompiler**
//   编译 → 跑产物 zpkg（其 Main 注入 ProjectHooks/自定义 workload 后 Pipeline.Run）。骨架待 spec。
int _runWithProjectBuild(ProjectManifest manifest, Target target, string sourceDir) {
    // 实现期：assemble driver.z42 → _hostCompiler().Compile(driverReq) → 跑产物。
    ConsoleError.WriteLine("z42b: custom build/ path not yet implemented");
    return 1;
}

// ── 注入点（实现期接真实实现）─────────────────────────────────────────────────

// 共享编译实现入口：返回编译器库（z42c）的 ICompiler 实现 —— 与 z42c.driver 同一份。
// 待 extract-compile-pipeline-api 落地 PackageCompiler/CompileResult 后封装为 Z42cCompiler。
ICompiler _hostCompiler() {
    return new NoCompiler();
}

// 按平台族选标准 workload（实现期接各 *.workload 库的 : WorkloadBase 子类）。
WorkloadBase _selectWorkload(string family) {
    // 实现期：ios→iOSWorkload / android→AndroidWorkload / desktop→DesktopWorkload / wasm→WasmWorkload
    return new WorkloadBase();    // no-op 兜底
}

// ── 目录布局 / 输入 ───────────────────────────────────────────────────────────

// 目录布局（镜像 docs/design/compiler/project.md 默认：output_dir = artifacts/<name>/<profile>）。
// Source 只读；写仅落 Cache / Intermediate / Dist。[build] 段显式值优先。
Dirs _computeDirs(ProjectManifest m, string sourceDir, string profile) {
    string outBase;
    if (m.Build.HasOutputDir) { outBase = m.Build.OutputDir; }
    else {
        string artifacts = Path.Join(sourceDir, "artifacts");
        outBase = Path.Join(Path.Join(artifacts, m.Project.Name), profile);
    }
    string cache = m.Build.HasCacheDir ? m.Build.CacheDir : Path.Join(outBase, "cache");
    string inter = Path.Join(outBase, "build");
    string dist  = m.Build.HasDistDir  ? m.Build.DistDir  : Path.Join(outBase, "dist");
    return new Dirs(sourceDir, cache, inter, dist);
}

// compile 相位前的初始输入。Deps zpkg 路径解析待实现期（扫 Z42_LIBS / workspace dist）。
Inputs _initialInputs(ProjectManifest m) {
    return new Inputs("", "", new string[0]);
}

// 工程是否带自定义 build/ 目录（含 z42 文件）。
bool _hasProjectBuild(string sourceDir) {
    string buildDir = Path.Join(sourceDir, "build");
    if (!Directory.Exists(buildDir)) { return false; }
    return Directory.Enumerate(buildDir).Length > 0;
}

// ── RID / family 辅助（镜像 launcher 的 _hostRid / _ridCategory）──────────────

// host RID（os-arch）。不支持的平台返 ""。
string _hostRid() {
    string os = Platform.OS();
    string arch = Platform.Arch();
    string a = "";
    if (arch == "aarch64") { a = "arm64"; }
    else if (arch == "x86_64") { a = "x64"; }
    else { return ""; }
    if (os == "macos" || os == "linux" || os == "windows") { return os + "-" + a; }
    return "";
}

// RID 前缀 → 平台族（TargetFamily.*）；未知返 ""。
string _familyOfRid(string rid) {
    if (rid.StartsWith("macos-") || rid.StartsWith("linux-") || rid.StartsWith("windows-")) {
        return TargetFamily.Desktop;
    }
    if (rid.StartsWith("ios-") || rid.StartsWith("iossim-")) { return TargetFamily.iOS; }
    if (rid.StartsWith("android-")) { return TargetFamily.Android; }
    if (rid == "browser-wasm") { return TargetFamily.Wasm; }
    return "";
}
