// z42 launcher — network commands (add-launcher-install, 2026-06-13).
//
// _cmdInstall   — download a runtime from GitHub Releases into runtimes/<ver>/.
// _cmdSelfUpdate — replace the installed launcher at $Z42_HOME/launcher/ in-place.
//
// Both use manifest-first (release-index.json → per-RID archive + sha256) with
// a SHA256SUMS fallback for older releases that predate the manifest.
// Windows uses .zip (Zip.ExtractAllTo); everything else uses .tar.gz
// (streaming Gzip.WrapRead + Tar.ExtractStream — no full-body decompression).
namespace Z42Launcher;

using Std;
using Std.IO;
using Std.Cli;
using Std.Json;
using Std.Net.Http;
using Std.Compression;
using Std.Archive;
using Std.Crypto;

// ── install ───────────────────────────────────────────────────────────────────

// z42 install <version|nightly> [--rid <rid>]
// --rid overrides the host RID, enabling platform SDK download (e.g. --rid ios-arm64).
void _cmdInstall(ParseResult r) {
    string ver = r.GetPositional(0);
    if (ver.Length == 0) {
        ConsoleError.WriteLine("usage: z42 install <version|nightly> [--rid <rid>]");
        Environment.Exit(2);
        return;
    }
    string ridOpt = r.GetOption("rid");
    string rid = (ridOpt.Length > 0) ? ridOpt : _hostRid();
    if (rid.Length == 0) {
        ConsoleError.WriteLine("z42: unsupported host (" + Platform.OS() + "/" + Platform.Arch() + ")");
        Environment.Exit(2);
        return;
    }
    string tag = (ver == "nightly") ? "nightly" : ("v" + ver);
    string baseUrl = "https://github.com/codesigner-ui/z42/releases/download/" + tag;
    bool isWindows = rid.StartsWith("windows");

    string asset = "";
    string sha = "";
    string[] mf = _fetchManifest(baseUrl, rid, "runtime");
    asset = mf[0]; sha = mf[1];
    if (asset.Length == 0) {
        // Desktop RIDs: sdk archive. Platform RIDs (ios/android/wasm): runtime-only archive.
        bool isDesktop = rid.StartsWith("linux-") || rid.StartsWith("macos-") || rid.StartsWith("windows-");
        if (isDesktop) {
            asset = "z42-" + ver + "-" + rid + (isWindows ? ".zip" : ".tar.gz");
        } else {
            asset = "z42-runtime-" + ver + "-" + rid + ".tar.gz";
        }
    }
    if (sha.Length == 0) {
        HttpClient hc2 = new HttpClient(); hc2.SetMaxRedirects(10);
        HttpResponse sums = hc2.Get(baseUrl + "/SHA256SUMS");
        if (sums.IsSuccess()) { sha = _findSum(sums.BodyAsString(), asset); }
    }

    Console.WriteLine("downloading " + asset + " (" + tag + ") ...");
    byte[] body = _downloadVerified(baseUrl, asset, sha);

    string runtimes = _runtimesDir();
    Directory.Create(runtimes);
    // Platform SDK (non-host RID): install into runtimes/<rid>/<ver>/ so multiple
    // platform SDKs can coexist. Host runtime keeps the legacy runtimes/<ver>/ layout.
    string hostRid = _hostRid();
    string targetBase = (rid == hostRid) ? runtimes : Path.Join(runtimes, rid);
    Directory.Create(targetBase);
    string staging = Path.Join(targetBase, "." + ver + ".stage");
    if (Directory.Exists(staging)) { Directory.Delete(staging, true); }
    Directory.Create(staging);
    _extractArchive(body, isWindows, staging);

    string target = Path.Join(targetBase, ver);
    if (Directory.Exists(target)) { Directory.Delete(target, true); }
    File.Move(staging, target);
    Console.WriteLine("installed " + rid + "/" + ver + " → " + target);
}

// ── self-update ───────────────────────────────────────────────────────────────

// z42 self-update [--channel <ver>]
// Downloads the SDK package and overwrites $Z42_HOME/launcher/ in-place.
// SDK layout: launcher.zpkg + libs/ at root, z42vm in bin/.
// Not supported in portable mode (Z42_PORTABLE_VM set).
void _cmdSelfUpdate(ParseResult r) {
    string portableVm = Environment.GetEnvironmentVariable("Z42_PORTABLE_VM") ?? "";
    if (portableVm.Length > 0) {
        ConsoleError.WriteLine("z42: portable mode — update the package via your distribution channel.");
        Environment.Exit(2);
        return;
    }
    string launcherDir = Path.Join(_home(), "launcher");
    if (!Directory.Exists(launcherDir)) {
        ConsoleError.WriteLine("z42: launcher not installed at " + launcherDir + "; run install-z42.sh to bootstrap.");
        Environment.Exit(2);
        return;
    }
    string chanOpt = r.GetOption("channel");
    string ver = chanOpt.Length > 0 ? chanOpt : "nightly";
    string rid = _hostRid();
    if (rid.Length == 0) {
        ConsoleError.WriteLine("z42: unsupported host (" + Platform.OS() + "/" + Platform.Arch() + ")");
        Environment.Exit(2);
        return;
    }
    string tag = (ver == "nightly") ? "nightly" : ("v" + ver);
    string baseUrl = "https://github.com/codesigner-ui/z42/releases/download/" + tag;
    bool isWindows = rid.StartsWith("windows");

    string asset = "";
    string sha = "";
    string[] mf = _fetchManifest(baseUrl, rid, "sdk");
    asset = mf[0]; sha = mf[1];
    if (asset.Length == 0) {
        asset = "z42-" + ver + "-" + rid + (isWindows ? ".zip" : ".tar.gz");
    }
    if (sha.Length == 0) {
        HttpClient hc2 = new HttpClient(); hc2.SetMaxRedirects(10);
        HttpResponse sums = hc2.Get(baseUrl + "/SHA256SUMS");
        if (sums.IsSuccess()) { sha = _findSum(sums.BodyAsString(), asset); }
    }

    Console.WriteLine("downloading " + asset + " (" + tag + ") ...");
    byte[] body = _downloadVerified(baseUrl, asset, sha);

    // Extract SDK to a temp dir, then reassemble into launcher/ layout.
    // SDK: launcher.zpkg + libs/ at root, z42vm in bin/. launcher/ expects z42vm at root.
    string extract = Path.Join(_home(), ".selfupdate.extract");
    if (Directory.Exists(extract)) { Directory.Delete(extract, true); }
    Directory.Create(extract);
    _extractArchive(body, isWindows, extract);

    string newStage = Path.Join(_home(), ".launcher.stage");
    if (Directory.Exists(newStage)) { Directory.Delete(newStage, true); }
    Directory.Create(newStage);
    string vmName = isWindows ? "z42vm.exe" : "z42vm";
    File.Move(Path.Join(Path.Join(extract, "bin"), vmName), Path.Join(newStage, vmName));
    File.Move(Path.Join(extract, "launcher.zpkg"), Path.Join(newStage, "launcher.zpkg"));
    File.Move(Path.Join(extract, "libs"), Path.Join(newStage, "libs"));

    Directory.Delete(launcherDir, true);
    File.Move(newStage, launcherDir);
    Directory.Delete(extract, true);
    Console.WriteLine("launcher updated → " + launcherDir);
    Console.WriteLine("restart z42 to use the new version.");
}

// ── shared helpers ────────────────────────────────────────────────────────────

// Std.Platform OS/Arch → release RID (aarch64→arm64, x86_64→x64). "" if unsupported.
string _hostRid() {
    string os = Platform.OS();
    string arch = Platform.Arch();
    string a = "";
    if (arch == "aarch64") { a = "arm64"; }
    else if (arch == "x86_64") { a = "x64"; }
    else { return ""; }
    if (os == "macos" || os == "linux" || os == "windows") { return os + "-" + a; }
    return "";
}

// Fetch release-index.json and return [archive, sha256] for (rid, packageType).
// New format: runtimes.<rid>.<packageType> = { archive, sha256 }.
// Old format fallback: runtimes.<rid> = { archive, sha256 } (pre-split releases).
// Returns ["", ""] when the manifest is absent, malformed, or has no matching entry.
string[] _fetchManifest(string baseUrl, string rid, string packageType) {
    string[] empty = new string[2];
    empty[0] = ""; empty[1] = "";
    HttpClient hc = new HttpClient(); hc.SetMaxRedirects(10);
    try {
        HttpResponse resp = hc.Get(baseUrl + "/release-index.json");
        if (!resp.IsSuccess()) { return empty; }
        JsonValue m = JsonValue.Parse(resp.BodyAsString());
        if (!m.IsObject() || !m.ContainsKey("runtimes")) { return empty; }
        JsonValue rts = m.Get("runtimes");
        if (!rts.IsObject() || !rts.ContainsKey(rid)) { return empty; }
        JsonValue ri = rts.Get(rid);
        if (!ri.IsObject()) { return empty; }
        string archive = "";
        string sha = "";
        // New format: runtimes.<rid>.<packageType> = { archive, sha256 }
        if (ri.ContainsKey(packageType)) {
            JsonValue pt = ri.Get(packageType);
            if (pt.IsObject()) {
                if (pt.ContainsKey("archive")) {
                    JsonValue av = pt.Get("archive");
                    if (av.IsString()) { archive = av.AsString(); }
                }
                if (pt.ContainsKey("sha256")) {
                    JsonValue sv = pt.Get("sha256");
                    if (sv.IsString()) { sha = sv.AsString(); }
                }
            }
        }
        // Old format fallback: runtimes.<rid> = { archive, sha256 }
        if (archive.Length == 0 && ri.ContainsKey("archive")) {
            JsonValue av = ri.Get("archive");
            if (av.IsString()) { archive = av.AsString(); }
        }
        if (sha.Length == 0 && ri.ContainsKey("sha256")) {
            JsonValue sv = ri.Get("sha256");
            if (sv.IsString()) { sha = sv.AsString(); }
        }
        string[] result = new string[2];
        result[0] = archive; result[1] = sha;
        return result;
    } catch (Exception e) { return empty; }
}

// Download baseUrl/asset and verify its sha256 (when non-empty). Returns the body
// bytes, or exits the process (non-zero) on HTTP failure / checksum mismatch.
// Shared by _cmdInstall / _cmdSelfUpdate / workload network install.
byte[] _downloadVerified(string baseUrl, string asset, string sha) {
    HttpClient hc = new HttpClient(); hc.SetMaxRedirects(10);
    HttpResponse resp = hc.Get(baseUrl + "/" + asset);
    if (!resp.IsSuccess()) {
        ConsoleError.WriteLine("z42: download failed (HTTP " + resp.StatusCode.ToString() + ") for " + asset);
        Environment.Exit(1);
        return new byte[0];
    }
    byte[] body = resp.Body;
    if (sha.Length > 0) {
        if (Sha256.HashHex(body) != sha) {
            ConsoleError.WriteLine("z42: checksum mismatch for " + asset);
            Environment.Exit(1);
            return new byte[0];
        }
        Console.WriteLine("  ✓ sha256 ok");
    }
    return body;
}

// Fetch release-index.json → the `workloads.<wl>` JSON object (archive / sha256 /
// host / runtimes), or an invalid JsonValue (IsObject()==false) when the manifest
// or workload entry is absent. Caller extracts fields with _jsonStr/_jsonStrArray.
JsonValue _fetchWorkloadEntry(string baseUrl, string wl) {
    JsonValue nullVal = JsonValue.Parse("null");
    HttpClient hc = new HttpClient(); hc.SetMaxRedirects(10);
    try {
        HttpResponse resp = hc.Get(baseUrl + "/release-index.json");
        if (!resp.IsSuccess()) { return nullVal; }
        JsonValue m = JsonValue.Parse(resp.BodyAsString());
        if (!m.IsObject() || !m.ContainsKey("workloads")) { return nullVal; }
        JsonValue wls = m.Get("workloads");
        if (!wls.IsObject() || !wls.ContainsKey(wl)) { return nullVal; }
        JsonValue we = wls.Get(wl);
        if (!we.IsObject()) { return nullVal; }
        return we;
    } catch (Exception e) { return nullVal; }
}

// obj.<key> as a plain string ("" if absent / not a string).
string _jsonStr(JsonValue obj, string key) {
    if (!obj.ContainsKey(key)) { return ""; }
    JsonValue v = obj.Get(key);
    if (!v.IsString()) { return ""; }
    return v.AsString();
}

// obj.<key> as a string[] (empty if absent / not a JSON array of strings).
string[] _jsonStrArray(JsonValue obj, string key) {
    if (!obj.ContainsKey(key)) { return new string[0]; }
    JsonValue a = obj.Get(key);
    if (!a.IsArray()) { return new string[0]; }
    int n = a.Count();
    string[] r = new string[n];
    int i = 0;
    while (i < n) { r[i] = a.At(i).AsString(); i = i + 1; }
    return r;
}

// host gate: empty list = unrestricted (allow); otherwise allow when the list
// holds the wildcard "*" or the current host RID.
bool _hostAllowed(string[] hosts) {
    if (hosts.Length == 0) { return true; }
    string h = _hostRid();
    int i = 0;
    while (i < hosts.Length) {
        if (hosts[i] == "*" || hosts[i] == h) { return true; }
        i = i + 1;
    }
    return false;
}

// Extract body into destDir. Windows archives are .zip; others are .tar.gz
// with streaming decode (Gzip.WrapRead → Tar.ExtractStream, no full decompress).
void _extractArchive(byte[] body, bool isWindows, string destDir) {
    if (isWindows) {
        Zip.ExtractAllTo(body, destDir);
    } else {
        var ms = new MemoryStream(body);
        Stream gz = Gzip.WrapRead(ms);
        Tar.ExtractStream(gz, destDir);
    }
}

// SHA256SUMS body ("<hex>  <filename>" per line) → hex for `asset`, or "".
string _findSum(string text, string asset) {
    string rest = text;
    while (rest.Length > 0) {
        string ln;
        int nl = rest.IndexOf("\n");
        if (nl < 0) { ln = rest; rest = ""; }
        else { ln = rest.Substring(0, nl); rest = rest.Substring(nl + 1); }
        ln = ln.Trim();
        if (ln.Length > 0 && ln.EndsWith(asset)) {
            int sp = ln.IndexOf(" ");
            if (sp > 0) { return ln.Substring(0, sp); }
        }
    }
    return "";
}
