// launcher_export.z42 — `z42 export` entry points + shared helpers (add-export-command, 2026-06-14).
//
// Three entry points dispatched by launcher_cli.z42:
//   _cmdExportIos     → launcher_export_ios.z42 :: _generateIosProject
//   _cmdExportAndroid → launcher_export_android.z42 :: _generateAndroidProject
//   _cmdExportWasm    → launcher_export_wasm.z42 :: _generateWasmProject
//
// Config is read from the project's z42.toml [platform.ios/android/wasm] section.
// CLI flags override toml values. The built .zpkg is resolved via the same dist_dir
// logic as `z42 publish desktop`. Platform SDKs live at ~/.z42/runtimes/<rid>/<ver>/.
namespace Z42Launcher;

using Std;
using Std.IO;
using Std.Toml;
using Z42.Workload.Desktop;   // Apphost.Produce — desktop publish lives in the workload package
using Z42.Workload.Ios;       // IosExport.Generate — iOS export lives in the workload package
using Z42.Workload.Android;   // AndroidExport.Generate — Android export lives in the workload package
using Z42.Workload.Wasm;      // WasmExport.Generate — WASM export lives in the workload package

// ── entry points ──────────────────────────────────────────────────────────────

void _cmdExportIos(ParseResult r) {
    string tomlPath = r.GetPositional(0);
    if (!_expCheckToml("ios", tomlPath)) { return; }
    TomlValue toml = TomlValue.Parse(File.ReadAllText(tomlPath));
    string projName = _expTomlStr(toml, "project", "name", "");
    if (projName.Length == 0) {
        ConsoleError.WriteLine("z42 export ios: [project].name missing in " + tomlPath);
        Environment.Exit(1); return;
    }
    string bundleId = r.GetOption("bundle-id");
    if (bundleId.Length == 0) { bundleId = _platformStr(toml, "ios", "bundle_id", ""); }
    if (bundleId.Length == 0) {
        ConsoleError.WriteLine("z42 export ios: bundle_id required — add [platform.ios] bundle_id in "
            + tomlPath + " or pass --bundle-id");
        Environment.Exit(2); return;
    }
    string displayName = _platformStr(toml, "ios", "display_name", projName);
    string minIos      = _platformStr(toml, "ios", "min_ios",      "15.0");
    string sdkVer      = r.GetOption("sdk-ver");
    if (sdkVer.Length == 0) { sdkVer = _expTomlStr(toml, "project", "version", ""); }

    string outputDir = r.GetOption("output");
    if (outputDir.Length == 0) { outputDir = _expDefaultOutputDir(tomlPath, projName, "-ios"); }
    Directory.Create(outputDir);

    string zpkgSrc = _expResolveZpkg(tomlPath, toml, projName);
    string sdkDir  = _expFindIosSdk(sdkVer);

    Console.WriteLine("z42 export ios → " + outputDir);
    IosExport.Generate(outputDir, projName, bundleId, displayName, minIos, zpkgSrc, sdkDir);
    Console.WriteLine("✅ iOS project ready. Open " + outputDir + "/" + projName + ".xcodeproj in Xcode.");
}

void _cmdExportAndroid(ParseResult r) {
    string tomlPath = r.GetPositional(0);
    if (!_expCheckToml("android", tomlPath)) { return; }
    TomlValue toml = TomlValue.Parse(File.ReadAllText(tomlPath));
    string projName = _expTomlStr(toml, "project", "name", "");
    if (projName.Length == 0) {
        ConsoleError.WriteLine("z42 export android: [project].name missing in " + tomlPath);
        Environment.Exit(1); return;
    }
    string appId = r.GetOption("app-id");
    if (appId.Length == 0) { appId = _platformStr(toml, "android", "app_id", ""); }
    if (appId.Length == 0) {
        ConsoleError.WriteLine("z42 export android: app_id required — add [platform.android] app_id in "
            + tomlPath + " or pass --app-id");
        Environment.Exit(2); return;
    }
    string ver         = _expTomlStr(toml, "project", "version", "1.0.0");
    string displayName = _platformStr(toml, "android", "display_name", projName);
    string versionCode = _platformStr(toml, "android", "version_code", "1");
    string versionName = _platformStr(toml, "android", "version_name", ver);
    string minSdk      = _platformStr(toml, "android", "min_sdk",      "26");
    string targetSdk   = _platformStr(toml, "android", "target_sdk",   "34");
    string sdkVer      = r.GetOption("sdk-ver");
    if (sdkVer.Length == 0) { sdkVer = ver; }

    string outputDir = r.GetOption("output");
    if (outputDir.Length == 0) { outputDir = _expDefaultOutputDir(tomlPath, projName, "-android"); }
    Directory.Create(outputDir);

    string zpkgSrc = _expResolveZpkg(tomlPath, toml, projName);
    string sdkDir  = (sdkVer.Length > 0) ? _platformSdkDir("android-arm64", sdkVer) : "";

    Console.WriteLine("z42 export android → " + outputDir);
    AndroidExport.Generate(outputDir, projName, appId, displayName,
                           versionCode, versionName, minSdk, targetSdk, zpkgSrc, sdkDir);
    Console.WriteLine("✅ Android project ready. Open " + outputDir + " in Android Studio.");
}

void _cmdExportWasm(ParseResult r) {
    string tomlPath = r.GetPositional(0);
    if (!_expCheckToml("wasm", tomlPath)) { return; }
    TomlValue toml = TomlValue.Parse(File.ReadAllText(tomlPath));
    string projName = _expTomlStr(toml, "project", "name", "");
    if (projName.Length == 0) {
        ConsoleError.WriteLine("z42 export wasm: [project].name missing in " + tomlPath);
        Environment.Exit(1); return;
    }
    string ver   = _expTomlStr(toml, "project", "version", "");
    string title = _platformStr(toml, "wasm", "title", projName);

    string sdkVer = r.GetOption("sdk-ver");
    if (sdkVer.Length == 0) { sdkVer = "nightly"; }

    string entryOpt = r.GetOption("entry");
    string tomlEntry = _expTomlStr(toml, "project", "entry", "");
    string entryPoint;
    if (entryOpt.Length > 0) { entryPoint = entryOpt; }
    else if (tomlEntry.Length > 0) { entryPoint = tomlEntry; }
    else { entryPoint = projName + ".Main"; }

    string outputDir = r.GetOption("output");
    if (outputDir.Length == 0) { outputDir = _expDefaultOutputDir(tomlPath, projName, "-wasm"); }
    Directory.Create(outputDir);

    string zbcSrc = _expResolveZbc(tomlPath, toml, projName);
    string sdkDir = _platformSdkDir("browser-wasm", sdkVer);

    Console.WriteLine("z42 export wasm → " + outputDir);
    WasmExport.Generate(outputDir, projName, title, entryPoint, zbcSrc, sdkDir);
    Console.WriteLine("✅ WASM project ready.");
    Console.WriteLine("   Serve with:  python3 -m http.server 8080 --directory " + outputDir);
    Console.WriteLine("   Then open:   http://localhost:8080/");
}

// rid → platform category (desktop / ios / android / wasm); "" if unknown.
string _ridCategory(string rid) {
    if (rid.StartsWith("macos-") || rid.StartsWith("linux-") || rid.StartsWith("windows-")) { return "desktop"; }
    if (rid.StartsWith("ios-") || rid.StartsWith("iossim-")) { return "ios"; }
    if (rid.StartsWith("android-")) { return "android"; }
    if (rid == "browser-wasm") { return "wasm"; }
    return "";
}

// Resolve the apphost stub for `rid` from the installed desktop workload — the
// single RID-agnostic package carries apphost-<rid> for every desktop RID (so any
// host can publish for any desktop target). Env override → else
// runtimes/<ver>/workloads/desktop/apphost-<rid>. "" if not installed / not built.
string _desktopApphostStub(string rid) {
    string ovr = Environment.GetEnvironmentVariable("Z42_APPHOST_TEMPLATE") ?? "";
    if (ovr.Length > 0) { return ovr; }
    string name = rid.StartsWith("windows-") ? ("apphost-" + rid + ".exe") : ("apphost-" + rid);
    foreach (var ver in _installedVersions()) {
        string stub = Path.Join(Path.Join(Path.Join(Path.Join(_runtimesDir(), ver), "workloads"), "desktop"), name);
        if (File.Exists(stub)) { return stub; }
    }
    return "";
}

// Gate: apphost ships with the desktop workload — require it (+ the target's stub).
string _requireDesktopApphost(string cmd, string rid) {
    string stub = _desktopApphostStub(rid);
    if (stub.Length > 0) { return stub; }
    bool wlInstalled = false;
    foreach (var ver in _installedVersions()) {
        if (Directory.Exists(Path.Join(Path.Join(Path.Join(_runtimesDir(), ver), "workloads"), "desktop"))) { wlInstalled = true; }
    }
    if (!wlInstalled) {
        ConsoleError.WriteLine("z42 " + cmd + ": desktop workload not installed (apphost ships with it).");
        ConsoleError.WriteLine("       run: z42 workload install desktop");
    } else {
        ConsoleError.WriteLine("z42 " + cmd + ": apphost for '" + rid + "' not in the installed desktop workload");
        ConsoleError.WriteLine("       (a local single-RID build carries only the host's apphost; install the full desktop workload for cross-output).");
    }
    Environment.Exit(1);
    return "";
}

// publish: produce the RELEASE platform deployable. `--rid`'s category selects the
// platform (default host). desktop → forwarded to z42b, which owns the publish verb
// (move-publish-to-z42b). The launcher resolves the installed desktop workload
// apphost stub and passes it via Z42_APPHOST_TEMPLATE (Decision 3.5); z42b gates
// `apphost = true` + bin/payload layout + build-if-needed. other platforms → B5.
void _cmdPublish(ParseResult r) {
    string rid = r.GetOption("rid");
    if (rid.Length == 0) { rid = _hostRid(); }
    if (rid.Length == 0) {
        ConsoleError.WriteLine("z42 publish: --rid required (could not default to host)");
        Environment.Exit(2); return;
    }
    string cat = _ridCategory(rid);
    if (cat != "desktop") {
        if (cat.Length > 0) {
            ConsoleError.WriteLine("z42 publish: " + cat + " deployable not yet implemented (B5) — only desktop (apphost) is supported.");
        } else {
            ConsoleError.WriteLine("z42 publish: unknown platform for rid '" + rid + "'");
        }
        Environment.Exit(2); return;
    }
    // desktop: resolve the apphost stub (launcher owns installed-workload resolution),
    // forward to z42b with --rid + Z42_APPHOST_TEMPLATE. "" stub → z42b reports the
    // "install the desktop workload" hint after its apphost-gate check.
    string stub = _desktopApphostStub(rid);
    string[] fargv = _publishForwardArgv(r.GetPositional(0), rid, r.GetOption("output"));
    Environment.Exit(_forwardZ42bEnv(fargv, "Z42_APPHOST_TEMPLATE", stub));
}

// Reconstruct the z42b argv: `publish <toml> --rid <rid> [--output <out>]`.
string[] _publishForwardArgv(string tomlPath, string rid, string output) {
    bool hasOut = output.Length > 0;
    int n = 4 + (hasOut ? 2 : 0);
    string[] a = new string[n];
    a[0] = "publish"; a[1] = tomlPath; a[2] = "--rid"; a[3] = rid;
    if (hasOut) { a[4] = "--output"; a[5] = output; }
    return a;
}

// export: generate a native IDE project. `--rid`'s category selects the platform.
void _cmdExport(ParseResult r) {
    string rid = r.GetOption("rid");
    if (rid.Length == 0) {
        ConsoleError.WriteLine("z42 export: --rid required (ios-arm64 / android-arm64 / browser-wasm)");
        Environment.Exit(2); return;
    }
    string cat = _ridCategory(rid);
    if (cat == "ios")     { _cmdExportIos(r);     return; }
    if (cat == "android") { _cmdExportAndroid(r); return; }
    if (cat == "wasm")    { _cmdExportWasm(r);    return; }
    if (cat == "desktop") {
        ConsoleError.WriteLine("z42 export: desktop has no IDE project — use `z42 publish --rid " + rid + "` for the apphost.");
        Environment.Exit(2); return;
    }
    ConsoleError.WriteLine("z42 export: unknown platform for rid '" + rid + "'");
    Environment.Exit(2);
}

// run deploy form: `z42 run <toml> --rid <rid> [-- <app args>]` — produce an
// ephemeral apphost beside the zpkg and exec it (previews the deployed launch).
// `run <app.zpkg>` (no --rid) runs bytecode on the host vm (see _runLauncher).
void _cmdRunDeploy(string[] argv) {
    string tomlPath = "";
    string rid = "";
    int sepIdx = -1;
    int i = 0;
    while (i < argv.Length) {
        if (argv[i] == "--") { sepIdx = i; break; }
        if (argv[i] == "--rid") {
            if (i + 1 < argv.Length) { rid = argv[i + 1]; i = i + 2; continue; }
        } else if (!argv[i].StartsWith("--") && tomlPath.Length == 0) {
            tomlPath = argv[i];
        }
        i = i + 1;
    }
    if (tomlPath.Length == 0 || rid.Length == 0) {
        ConsoleError.WriteLine("usage: z42 run <project.z42.toml> --rid <rid> [-- <app args>]");
        Environment.Exit(2); return;
    }
    string cat = _ridCategory(rid);
    if (cat != "desktop") {
        ConsoleError.WriteLine("z42 run: deploy-form run for " + cat + " not yet implemented (B5); only desktop apphost.");
        Environment.Exit(2); return;
    }
    string[] appArgs = (sepIdx >= 0) ? _tail(argv, sepIdx + 1) : new string[0];
    if (!File.Exists(tomlPath)) {
        ConsoleError.WriteLine("z42 run: not found: " + tomlPath);
        Environment.Exit(1); return;
    }
    TomlValue toml = TomlValue.Parse(File.ReadAllText(tomlPath));
    string projName = _expTomlStr(toml, "project", "name", "");
    if (projName.Length == 0) {
        ConsoleError.WriteLine("z42 run: [project].name missing in " + tomlPath);
        Environment.Exit(1); return;
    }
    string zpkgSrc = _desktopResolveZpkg("run", tomlPath, toml, projName);
    string zpkgDir = Path.GetDirectoryName(zpkgSrc);
    string outName = rid.StartsWith("windows-") ? (projName + ".exe") : projName;
    string outPath = (zpkgDir.Length > 0) ? Path.Join(zpkgDir, outName) : outName;
    string stub = _requireDesktopApphost("run", rid);
    Apphost.Produce(zpkgSrc, outPath, stub, rid);
    Process p = new Process(outPath);
    int j = 0;
    while (j < appArgs.Length) { p = p.Arg(appArgs[j]); j = j + 1; }
    ProcessResult pr = p.Stdout(Stdio.Inherit()).Stderr(Stdio.Inherit()).Run();
    Environment.Exit(pr.ExitCode);
}

// Resolve the built zpkg for a desktop publish/run; exit with a build-first
// hint if absent. `verb` is "publish" / "run" for the error prefix.
string _desktopResolveZpkg(string verb, string tomlPath, TomlValue toml, string projName) {
    string zpkgSrc = _expResolveZpkg(tomlPath, toml, projName);
    if (!File.Exists(zpkgSrc)) {
        ConsoleError.WriteLine("z42 " + verb + " desktop: built zpkg not found: " + zpkgSrc
            + "  (build it first: z42c build " + tomlPath + ")");
        Environment.Exit(1);
    }
    return zpkgSrc;
}

// ── shared helpers ────────────────────────────────────────────────────────────

bool _expCheckToml(string platform, string tomlPath) {
    if (tomlPath.Length == 0 || !tomlPath.EndsWith(".toml")) {
        ConsoleError.WriteLine("usage: z42 export " + platform + " <project.z42.toml> [options]");
        Environment.Exit(2); return false;
    }
    if (!File.Exists(tomlPath)) {
        ConsoleError.WriteLine("z42 export " + platform + ": not found: " + tomlPath);
        Environment.Exit(1); return false;
    }
    return true;
}

// Read root.[section].[key] as a string (handles string and long TOML values).
string _expTomlStr(TomlValue root, string section, string key, string dflt) {
    if (!root.ContainsKey(section)) { return dflt; }
    TomlValue s = root.Get(section);
    if (!s.IsTable() || !s.ContainsKey(key)) { return dflt; }
    TomlValue v = s.Get(key);
    if (v.IsString()) { return v.AsString(); }
    if (v.IsLong())   { return v.AsLong().ToString(); }
    return dflt;
}

// Read root.[platform].[name].[key] as a string.
string _platformStr(TomlValue root, string platform, string key, string dflt) {
    if (!root.ContainsKey("platform")) { return dflt; }
    TomlValue pt = root.Get("platform");
    if (!pt.IsTable() || !pt.ContainsKey(platform)) { return dflt; }
    TomlValue p = pt.Get(platform);
    if (!p.IsTable() || !p.ContainsKey(key)) { return dflt; }
    TomlValue v = p.Get(key);
    if (v.IsString()) { return v.AsString(); }
    if (v.IsLong())   { return v.AsLong().ToString(); }
    return dflt;
}

// Platform SDK directory: ~/.z42/runtimes/<rid>/<ver>/
string _platformSdkDir(string rid, string ver) {
    return Path.Join(Path.Join(_runtimesDir(), rid), ver);
}

// Resolve iOS SDK: check ios-arm64 then iossim-arm64.
string _expFindIosSdk(string ver) {
    if (ver.Length == 0) { return ""; }
    string d1 = _platformSdkDir("ios-arm64", ver);
    if (Directory.Exists(d1)) { return d1; }
    return _platformSdkDir("iossim-arm64", ver);
}

// Default output directory: <projectDir>/<name><suffix>/
string _expDefaultOutputDir(string tomlPath, string name, string suffix) {
    string dir = Path.GetDirectoryName(tomlPath);
    string sub = (name.Length > 0 ? name : "output") + suffix;
    return (dir.Length > 0) ? Path.Join(dir, sub) : sub;
}

// Find the built zpkg via the same dist_dir logic as `z42 publish desktop`.
string _expResolveZpkg(string tomlPath, TomlValue toml, string name) {
    string projDir = Path.GetDirectoryName(tomlPath);
    string outDir  = _expTomlStr(toml, "build", "output_dir", "");
    string distDir = _expTomlStr(toml, "build", "dist_dir", "");
    string distRel;
    if (distDir.Length > 0) { distRel = distDir.Replace("${output_dir}", outDir); }
    else if (outDir.Length > 0) { distRel = Path.Join(outDir, "dist"); }
    else { distRel = "dist"; }
    string base = (projDir.Length > 0) ? Path.Join(projDir, distRel) : distRel;
    return Path.Join(base, name + ".zpkg");
}

// Resolve the compiled .zbc for wasm.
// Search order: [build].output_dir/<name>.zbc → .cache/<name>.zbc → projDir/<name>.zbc
string _expResolveZbc(string tomlPath, TomlValue toml, string name) {
    string projDir = Path.GetDirectoryName(tomlPath);
    string zbcName = name + ".zbc";
    string outDir  = _expTomlStr(toml, "build", "output_dir", "");
    if (outDir.Length > 0) {
        string p = (projDir.Length > 0) ? Path.Join(projDir, outDir) : outDir;
        return Path.Join(p, zbcName);
    }
    // z42c build puts the .zbc in .cache/ beside the toml
    if (projDir.Length > 0) {
        string cached = Path.Join(Path.Join(projDir, ".cache"), zbcName);
        if (File.Exists(cached)) { return cached; }
    }
    return Path.Join(projDir.Length > 0 ? projDir : ".", zbcName);
}
