// z42d CLI 路由 —— Std.Cli 嵌套 router（对照 builder_cli.z42 / launcher_cli.z42）。
//
// SCOPE（scaffold）：本编译单元只**登记命令面**——fmt / doc / dbg / prof / lint
// 五个子命令的名字、help、占位参数已就位，dispatch 一律打 "planned"。各工具的真正
// 引擎按 roadmap 分期落地（fmt → doc → prof → lint → dbg）。本包未登记进
// workspace / xtask / CI，惰性占位，不影响任何现有构建（同 PARKED 的 builder）。
namespace Z42Devtools;

using Std;
using Std.IO;
using Std.Cli;

// exe 入口。standalone（`z42vm z42.devtools.zbc -- <verb> ...`）与 launcher 透传
// （`z42 <verb> ...`）都经 Environment.GetCommandLineArgs() 拿到动词起的 argv。
void Main() {
    Environment.Exit(_runDevtools(Environment.GetCommandLineArgs()));
}

// 入口：launcher 透传的 argv（已去掉 `z42` 前缀的动词起）。
int _runDevtools(string[] argv) {
    if (argv.Length == 0) { Console.WriteLine(_devtoolsRoot().HelpText()); return 0; }

    SubcommandRouter root = _devtoolsRoot();
    CommandResolution res;
    try { res = root.Resolve(argv); }
    catch (CliException e) {
        ConsoleError.WriteLine("z42d: " + e.Message);
        return 2;
    }
    if (res.IsHelp())    { Console.WriteLine(res.HelpText()); return 0; }
    if (res.IsUnknown()) { ConsoleError.WriteLine(res.ErrorMessage()); return 2; }
    return _dispatchDevtools(res);
}

SubcommandRouter _devtoolsRoot() {
    SubcommandRouter root = new SubcommandRouter("z42d", "z42 developer toolchain");

    // fmt — code formatter（planned；roadmap 0.2.4 → 0.4.x，原独立 z42-fmt 收编于此）。
    ArgParser fmt = new ArgParser("z42d fmt", "format z42 source (planned)");
    fmt.AddOptionalPositional("path", "file or directory (default: current dir)");
    root.Add("fmt", "format z42 source files", fmt);

    // doc — doc-comment → site generator（planned；roadmap 0.4.6，原独立 z42-doc）。
    ArgParser doc = new ArgParser("z42d doc", "generate API docs from doc comments (planned)");
    doc.AddOptionalPositional("project", "<project.z42.toml>");
    root.Add("doc", "generate documentation", doc);

    // dbg — debugger（planned；前端在本目录 + VM 断点/单步钩子住 runtime/，DAP 0.8.x）。
    ArgParser dbg = new ArgParser("z42d dbg", "debug a z42 program (planned)");
    dbg.AddOptionalPositional("target", "<app.zpkg> | <project.z42.toml>");
    root.Add("dbg", "debug a z42 program (breakpoints/step)", dbg);

    // prof — profiler front-end（planned；roadmap 0.4.4 Pv4/Pc4 profiling 门控）。
    ArgParser prof = new ArgParser("z42d prof", "profile a z42 program (planned)");
    prof.AddOptionalPositional("target", "<app.zpkg> | <project.z42.toml>");
    root.Add("prof", "profile runtime / compile performance", prof);

    // lint — static analysis（planned；roadmap 0.7.x，原独立 z42-lint）。
    ArgParser lint = new ArgParser("z42d lint", "static analysis / lint (planned)");
    lint.AddOptionalPositional("project", "<project.z42.toml>");
    root.Add("lint", "static analysis", lint);

    return root;
}

// ── dispatch ──────────────────────────────────────────────────────────────

int _dispatchDevtools(CommandResolution res) {
    string[] p = res.Path();
    if (p.Length == 0) { return 0; }
    string top = p[0];
    // scaffold：所有子命令尚未实现，统一报 planned。各工具实现期替换为真实处理。
    ConsoleError.WriteLine("z42d " + top + ": planned — not yet implemented "
        + "(developer toolchain scaffold; see src/toolchain/devtools/README.md)");
    return 1;
}
