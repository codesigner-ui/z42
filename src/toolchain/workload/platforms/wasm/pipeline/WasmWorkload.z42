namespace Z42.Workload;

using Z42.Build;

/// WASM 平台 workload —— 接管 `configure → package` 尾相位。host 任意；
/// runtime pack：wasm（z42vm.wasm + wasm-bindgen glue）。无签名。
///
/// ⚠️ Parked / 接口先行：方法体仅描述每相位**流程**，具体逻辑留待深加工。
public class WasmWorkload : WorkloadBase {

    /// 检查 node / npm / wasm-pack + 确保 wasm runtime 就位。
    public override void Preflight(IPipelineContext ctx) {
        ctx.RequireTool("node", ">=18");
        ctx.RequireTool("wasm-pack", ">=0.12");
        ctx.EnsureRuntimePack(ctx.Target.Rid);          // wasm
    }

    /// 从 [platform.wasm] 应用 title（轻量）。
    public override void Configure(IPipelineContext ctx) {
        // title = ctx.Platform.StrOr("title", ctx.Project.Name)
        // 渲染 package.json（name / version）
    }

    /// 生成 web/npm 工程。export 模式跑到此后停。
    public override void GenerateProject(IPipelineContext ctx) {
        // 1. 渲染 index.html + index.js（经 JS ZpkgResolver 回调加载 app.zpkg）
        // 2. 链 pkg-web / pkg-nodejs
        // 3. app.zpkg + stdlib → js/stdlib/
    }

    /// wasm-pack / npm pack 打包 glue。
    public override void NativeBuild(IPipelineContext ctx) {
        ctx.Exec("npm", new[]{ "pack" });               // 永久脏
    }

    /// 归档为 zip（无签名）。
    public override void Package(IPipelineContext ctx) {
        ctx.Archive(ctx.Dirs.Intermediate, ctx.Dirs.Dist + "/wasm-bundle.zip", "zip");
        ctx.AddOutput("zip", ctx.Dirs.Dist + "/wasm-bundle.zip");
    }
}
