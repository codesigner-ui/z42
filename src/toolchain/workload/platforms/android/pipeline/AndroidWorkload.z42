namespace Z42.Workload;

using Z42.Build;

/// Android 平台 workload —— 接管 `configure → package` 尾相位。host 任意（跨平台）；
/// runtime pack：android-arm64 / android-x64（per-ABI libz42_*.so）。
///
/// ⚠️ Parked / 接口先行：方法体仅描述每相位**流程**，具体逻辑留待深加工。
public class AndroidWorkload : WorkloadBase {

    /// 检查 JDK / Android SDK / NDK / gradle + 确保 android runtime pack 就位。
    public override void Preflight(IPipelineContext ctx) {
        ctx.RequireTool("gradle", ">=8.0");
        // ctx.RequireTool("javac", ">=17");  NDK / SDK 经环境变量定位（实现期校验）
        ctx.EnsureRuntimePack(ctx.Target.Rid);          // android-arm64 / android-x64
    }

    /// 从 [platform.android] 应用身份与权限。
    public override void Configure(IPipelineContext ctx) {
        // 1. 渲染 AndroidManifest.xml（app_id / version_code / version_name / 权限）
        ctx.RenderTemplate(ctx.Template("AndroidManifest.xml.tmpl"),
                           ctx.Dirs.Intermediate + "/AndroidManifest.xml", ctx.Platform);
        // 2. gradle props（min_sdk / target_sdk）—— 实现期写 gradle.properties
    }

    /// 生成 gradle 工程。export 模式跑到此后停。
    public override void GenerateProject(IPipelineContext ctx) {
        // 1. 渲染 gradle 工程（settings.gradle.kts / app/build.gradle.kts）
        // 2. bed per-ABI .so → jniLibs/<abi>/（abi 由 rid 推导）
        // 3. app.zpkg + stdlib → assets/
        // 4. 合并 platform-overrides/android/
    }

    /// gradle bundleRelease → 未签 .aab。
    public override void NativeBuild(IPipelineContext ctx) {
        ctx.Exec("gradle", new[]{ "bundleRelease" });   // 永久脏
    }

    /// apksigner 用 keystore 签名 .aab。
    public override void Package(IPipelineContext ctx) {
        // ctx.Sign(<aab>, <keystore identity>);
        // ctx.AddOutput("aab", <aab path>);
    }
}
