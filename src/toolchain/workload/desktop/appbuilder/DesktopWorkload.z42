namespace Z42.Workload;

using Z42.Build;
using Z42.Project;

/// Desktop 平台 workload —— 接管 `configure → package` 尾相位。host 任意；
/// **无 runtime pack**（复用宿主已装 runtime，apphost 运行时自行定位 z42vm）。
/// 无宿主工具链：NativeBuild 仅 patch 预编 apphost stub。
///
/// ⚠️ Parked / 接口先行：方法体仅描述每相位**流程**，具体逻辑留待深加工。
public class DesktopWorkload : WorkloadBase {

    /// 复用宿主 runtime，无需下载；macOS 仅提示签名证书（实现期）。
    public override void Preflight(IPipelineContext ctx) {
        // 无强制工具；macOS 可探测 codesign 证书并 ctx.Warn
    }

    /// 解析 exe 名 / 图标；macOS 渲染 .app 的 Info.plist。
    public override void Configure(IPipelineContext ctx) {
        DesktopConfig d = ctx.Manifest.Platform.Desktop;  // typed [platform.desktop]
        // exe 名 = ctx.Project.Name；输出目录 = d.PublishDir；图标 = d.Icon（HasIcon 时）
        // macOS：由 d.BundleId（HasBundleId）构造 .app/Contents/Info.plist 的 KV
    }

    /// 摆 apphost 布局（裸 exe 或 macOS .app 骨架），放入 app.zpkg。
    public override void GenerateProject(IPipelineContext ctx) {
        // 1. 取 apphost-<rid> stub 模板
        // 2. macOS：建 <name>.app/Contents/{MacOS,Resources} 骨架
        // 3. app.zpkg 就位
    }

    /// 无宿主工具链：patch apphost stub 的目标 zpkg 路径（经 native / launcher 子命令）。
    public override void NativeBuild(IPipelineContext ctx) {
        // patch apphost-<rid> stub：写入 app.zpkg 相对路径占位
    }

    /// macOS/Windows 签名；Linux 无签名 → 继承基类 copyToDist。
    public override void Package(IPipelineContext ctx) {
        if (ctx.Target.Rid.StartsWith("macos")) {
            // ctx.Sign(<.app>, <identity>);
        } else {
            base.Package(ctx);                          // linux/windows：兜底原样落 dist
        }
        // ctx.AddOutput("exe", <path>);
    }
}
