# Cargo build artifacts (this crate sits outside the runtime workspace
# target redirect; its own target/ here).
rust/target/

# cargo-ndk drops per-ABI .so files here; regenerated by build.sh.
z42vm/src/main/jniLibs/

# Stdlib zpkgs + namespace index copied in from artifacts/build/libs/release
# by build.sh.
z42vm/src/main/assets/stdlib/*.zpkg
z42vm/src/main/assets/stdlib/index.json

# Test fixtures compiled by build.sh from examples/embedding/*.z42.
z42vm/src/androidTest/assets/test-fixtures/*.zbc

# Gradle build artifacts.
.gradle/
build/
z42vm/build/
*.aar

# Android Studio scratch / IDE state.
.idea/
local.properties
*.iml
captures/
.cxx/
