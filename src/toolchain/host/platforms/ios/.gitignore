# Cargo build artifacts (this crate sits outside the runtime workspace
# target redirect — its own target/ here).
rust/target/

# build.sh intermediate (lipo'd simulator universal .a before xcframework).
build/

# SwiftPM build outputs.
.build/
.swiftpm/
.derivedData/
DerivedData/

# xcframework binary (regenerated by build.sh; not tracked).
Z42VM.xcframework/

# stdlib zpkg bundles + namespace index copied in by build.sh from
# artifacts/build/libraries/dist/release/.
Resources/stdlib/*.zpkg
Resources/stdlib/index.json

# Compiled demo fixtures (produced by build.sh).
demo/fixtures/*.zbc

# Test bundle resources (produced by build.sh from examples/embedding/*
# and artifacts/build/libraries/dist/release/). Re-generated on every build.
Tests/Z42VMTests/Resources/test-fixtures/*.zbc
Tests/Z42VMTests/Resources/stdlib/*.zpkg
Tests/Z42VMTests/Resources/stdlib/index.json
