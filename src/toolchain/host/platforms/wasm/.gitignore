# Cargo build artifacts (this crate sits outside the runtime workspace
# target redirect — it produces its own `target/`).
target/

# wasm-pack outputs (regenerated by build.sh).
pkg-web/
pkg-nodejs/
pkg-bundler/

# stdlib zpkg bundles are copied in by build.sh from artifacts/z42/libs/
# at build time; not tracked.
js/stdlib/*.zpkg

# Compiled fixture (produced by build.sh).
demo/fixtures/*.zbc

# Local node demo deps (run.js depends on the workspace via file:).
demo/node/node_modules/
