# Cargo build artifacts (this crate sits outside the runtime workspace
# target redirect — it produces its own `target/`).
target/

# wasm-pack outputs (regenerated by build.sh).
pkg-web/
pkg-nodejs/
pkg-bundler/

# stdlib zpkg bundles + namespace index — copied in by build.sh from
# artifacts/build/libs/release/ at build time; not tracked.
js/stdlib/*.zpkg
js/stdlib/index.json

# Test fixtures compiled by build.sh from examples/embedding/*.z42.
js/fixtures/*.zbc

# Local node demo deps (run.js depends on the workspace via file:).
demo/node/node_modules/

# Test harness deps + playwright artifacts (regenerated by ./test.sh).
tests/node_modules/
tests/test-results/
tests/playwright-report/
