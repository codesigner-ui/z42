// Test: L3-G4b primitive types satisfy IComparable<T> / IEquatable<T>.
// Max<int>(3, 7) dispatches CompareTo to __int_compare_to at runtime.

T Max<T>(T a, T b) where T: IComparable<T> {
    return a.CompareTo(b) > 0 ? a : b;
}

bool Eq<T>(T a, T b) where T: IEquatable<T> {
    return a.Equals(b);
}

void Main() {
    // int — integral compare
    Assert.Equal(7, Max(3, 7));

    // string — lex compare
    Assert.Equal("banana", Max("apple", "banana"));

    // double — floating compare
    Assert.Equal(2.5, Max(1.5, 2.5));

    // Equality across primitives
    Assert.True(Eq(42, 42));
    Assert.False(Eq("a", "b"));
    Assert.True(Eq(true, true));
}
