// Test: L3-G2.5 base class constraint — where T: Animal

class Animal {
    public int legs;
    Animal(int n) { this.legs = n; }
    public virtual string Describe() { return "animal"; }
}

class Dog : Animal {
    Dog() : base(4) { }
    public override string Describe() { return "dog"; }
}

void Introduce<T>(T pet) where T: Animal {
    Assert.Equal(4, pet.legs);
    Assert.Equal("dog", pet.Describe());
}

void Main() {
    Introduce(new Dog());
}
