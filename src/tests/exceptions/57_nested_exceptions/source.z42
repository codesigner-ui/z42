namespace Demo;
using Std.IO;

void Main() {
    // Nested try/catch: inner catches, outer continues
    try {
        Console.WriteLine("outer try");
        try {
            Console.WriteLine("inner try");
            throw new Exception("inner error");
        } catch (Exception e) {
            Console.WriteLine($"inner caught: {e.Message}");
        }
        Console.WriteLine("outer continues");
    } catch (Exception e) {
        Console.WriteLine("outer caught (should not reach)");
    }

    // Nested: inner does NOT catch (rethrows), outer catches
    try {
        try {
            throw new Exception("bubble up");
        } catch (Exception e) {
            Console.WriteLine($"inner: {e.Message}");
            throw new Exception("rethrown");
        }
    } catch (Exception e) {
        Console.WriteLine($"outer: {e.Message}");
    }

    // try/catch/finally combined: finally runs with catch present
    try {
        try {
            throw new Exception("deep");
        } catch (Exception e) {
            Console.WriteLine($"inner caught: {e.Message}");
        } finally {
            Console.WriteLine("inner finally");
        }
    } catch (Exception e) {
        Console.WriteLine("outer should not reach");
    }

    // Exception in function call
    try {
        ThrowHelper();
    } catch (Exception e) {
        Console.WriteLine($"from helper: {e.Message}");
    }

    Console.WriteLine("all done");
}

void ThrowHelper() {
    throw new Exception("helper error");
}
