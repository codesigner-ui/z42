// 2026-05-03 add-interface-event-default (D2c interface 默认) regression golden.
// 端到端验证 interface event 声明 + class 实现 + 通过 interface 接收对象 +=/-=。
namespace Demo;
using Std;
using Std.IO;

public interface IBus {
    event MulticastAction<int> Clicked;
}

public class Bus : IBus {
    public event MulticastAction<int> Clicked;

    public void fire(int x) {
        this.Clicked.Invoke(x);
    }
}

void Main() {
    Bus bus = new Bus();
    IBus iface = bus;          // upcast to interface

    // 通过 interface 引用 +=  → desugar 到 iface.add_Clicked(h)
    iface.Clicked += (int x) => Console.WriteLine($"a:{x}");
    iface.Clicked += (int x) => Console.WriteLine($"b:{x}");

    bus.fire(1);                // a:1 / b:1（vtable dispatch 到 Bus 实现）

    // 通过 interface 引用 -= → desugar 到 iface.remove_Clicked(h)
    Action<int> hC = (int x) => Console.WriteLine($"c:{x}");
    iface.Clicked += hC;
    bus.fire(2);                // a:2 / b:2 / c:2
    iface.Clicked -= hC;
    bus.fire(3);                // a:3 / b:3
}
