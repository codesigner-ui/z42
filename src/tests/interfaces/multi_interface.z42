namespace Demo;

interface IPrintable {
    string Print();
}

interface ISerializable {
    string Serialize();
}

// Implements two interfaces
class Document : IPrintable, ISerializable {
    string Title;

    Document(string title) {
        this.Title = title;
    }

    override string Print() {
        return $"[Document: {this.Title}]";
    }

    override string Serialize() {
        return "title=" + this.Title;
    }

    override string ToString() {
        return this.Title;
    }
}

string PrintIt(IPrintable p) {
    return p.Print();
}

string SerializeIt(ISerializable s) {
    return s.Serialize();
}

void Main() {
    var doc = new Document("Report");

    // Direct method calls
    Assert.Equal("[Document: Report]", doc.Print());
    Assert.Equal("title=Report",       doc.Serialize());

    // Through interface-typed parameters (virtual dispatch)
    Assert.Equal("[Document: Report]", PrintIt(doc));
    Assert.Equal("title=Report",       SerializeIt(doc));

    // ToString via implicit Object base
    Assert.Equal("doc: Report", $"doc: {doc}");
}
