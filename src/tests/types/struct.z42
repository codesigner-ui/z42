namespace Demo;

struct Point {
    int X;
    int Y;

    Point(int x, int y) {
        this.X = x;
        this.Y = y;
    }

    int ManhattanDistance(Point other) {
        int dx = this.X - other.X;
        int dy = this.Y - other.Y;
        if (dx < 0) dx = -dx;
        if (dy < 0) dy = -dy;
        return dx + dy;
    }
}

struct Color {
    int R;
    int G;
    int B;

    Color(int r, int g, int b) {
        this.R = r;
        this.G = g;
        this.B = b;
    }

    bool IsGrayscale() {
        return this.R == this.G && this.G == this.B;
    }
}

void Main() {
    var p1 = new Point(1, 2);
    var p2 = new Point(4, 6);
    Assert.Equal(1, p1.X);
    Assert.Equal(2, p1.Y);
    Assert.Equal(7, p1.ManhattanDistance(p2));

    var white = new Color(255, 255, 255);
    var red   = new Color(255, 0, 0);
    Assert.True(white.IsGrayscale());
    Assert.False(red.IsGrayscale());
}
