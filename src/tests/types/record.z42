namespace Demo;

record Point(int X, int Y);

record Person(string Name, int Age) {
    string Greet() {
        return $"Hi, I'm {this.Name}, age {this.Age}";
    }
}

void Main() {
    var p = new Point(3, 4);
    Assert.Equal(3, p.X);
    Assert.Equal(4, p.Y);

    var person = new Person("Alice", 30);
    Assert.Equal("Hi, I'm Alice, age 30", person.Greet());
    person.Name = "Bob";
    Assert.Equal("Hi, I'm Bob, age 30", person.Greet());
}
