// 2026-05-07 add-array-base-class + add-as-cast-on-arrays:
// arr.Clone() 浅拷贝返回 Object；现在 (int[]) cast 可下行回 T[]。
// 验证副本独立 + 元素共享（C# Array.Clone 语义）。

class Box {
    public int x;
    public Box(int v) { this.x = v; }
}

void Main() {
    // primitive 数组：副本独立
    int[] xs = new int[3];
    xs[0] = 1; xs[1] = 2; xs[2] = 3;
    int[] ys = (int[])xs.Clone();
    ys[0] = 99;
    Assert.Equal(1,  xs[0]);   // 原数组未变
    Assert.Equal(99, ys[0]);   // 副本独立修改

    // 引用元素：副本数组独立，但共享元素引用
    Box[] bs = new Box[2];
    bs[0] = new Box(10);
    bs[1] = new Box(20);
    Box[] cs = (Box[])bs.Clone();
    bs[0].x = 999;
    Assert.Equal(999, cs[0].x); // 共享元素

    // 空数组 Clone
    int[] empty = new int[0];
    int[] emptyClone = (int[])empty.Clone();
    Assert.Equal(0, emptyClone.Length);
}
