// 装箱/拆箱（add-boxing-conversions）：原始值 ↔ object 往返（方案 A：类型系统层，
// Value 已是 tagged union，装箱零分配；拆箱复用 Convert 受检解析）。
namespace Demo;
using Std.IO;

void Main() {
    // 标量装箱 → 受检拆箱
    object o = 5;
    int x = (int)o;
    Console.WriteLine(x);

    object flag = true;          // bool 装箱（拆箱靠 add-boxing-conversions 的 Bool 恒等）
    bool b = (bool)flag;
    Console.WriteLine(b);

    // object[] 逐元素装箱 / 拆箱
    object[] a = new object[2];
    a[0] = 42;
    a[1] = (char)122;
    Console.WriteLine((int)a[0]);
    Console.WriteLine((char)a[1]);
}
