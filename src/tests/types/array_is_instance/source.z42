using Std.IO;

// 2026-05-07 add-array-base-class: T[] is-a Array is-a Object at runtime.
// `is` operator hardcoded for Value::Array against Std.Array / Std.Object.

void Main() {
    int[] xs = new int[3];

    // 真子类型：is Array / is Object 都为 true
    if (xs is Array)  Console.WriteLine("xs is Array");  else Console.WriteLine("xs not Array");
    if (xs is Object) Console.WriteLine("xs is Object"); else Console.WriteLine("xs not Object");

    // 编译器允许 T[] → Object/Array 赋值
    Array a = xs;
    Console.WriteLine(a.Length);
}
