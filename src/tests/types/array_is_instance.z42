// 2026-05-07 add-array-base-class: T[] is-a Array is-a Object at runtime.
// `is` operator hardcoded for Value::Array against Std.Array / Std.Object.

void Main() {
    int[] xs = new int[3];

    // 真子类型：is Array / is Object 都为 true
    Assert.True(xs is Array);
    Assert.True(xs is Object);

    // 编译器允许 T[] → Object/Array 赋值
    Array a = xs;
    Assert.Equal(3, a.Length);
}
