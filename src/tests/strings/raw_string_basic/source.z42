// add-raw-string-literal (2026-05-27): end-to-end golden test for """...""".
using Std.IO;

void Main() {
    string a = """hello""";
    Console.WriteLine(a);

    string b = """line1
line2
line3""";
    Console.WriteLine(b);

    string c = """has "quotes" and "" pairs""";
    Console.WriteLine(c);

    string d = """backslash-n \n stays literal""";
    Console.WriteLine(d);

    string empty = """""";
    Console.WriteLine("[" + empty + "]");

    string joined = """foo""" + "|" + """bar""";
    Console.WriteLine(joined);
}
