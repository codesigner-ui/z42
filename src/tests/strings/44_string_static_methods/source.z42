using Std.IO;
void Main() {
    // string.IsNullOrEmpty (lowercase keyword)
    Console.WriteLine(string.IsNullOrEmpty(""));
    Console.WriteLine(string.IsNullOrEmpty("hi"));

    // string.Join with array
    var parts = new string[] { "a", "b", "c" };
    Console.WriteLine(string.Join(", ", parts));

    // string.Join with individual args
    Console.WriteLine(string.Join("-", "x", "y", "z"));

    // string.Concat
    Console.WriteLine(string.Concat("Hello", ", ", "World"));

    // string.Format
    Console.WriteLine(string.Format("{0} is {1}", "age", 42));

    // int.Parse
    int n = int.Parse("123");
    Console.WriteLine(n);

    // double.Parse
    double d = double.Parse("3.14");
    Console.WriteLine(d);
}
