using Std.IO;
// Test: simplify-string-stdlib (2026-04-24) — script-side String methods.
// Covers Contains / StartsWith / EndsWith / IndexOf / Substring / Replace /
// ToLower / ToUpper / Trim* / IsNullOr* + new CharAt / FromChars intrinsics.
// Each println's expected line is recorded in expected_output.txt.

void Main() {
    // ── CharAt + FromChars intrinsics ────────────────────────────────────
    Console.WriteLine("hello".CharAt(0));          // h
    Console.WriteLine("hello".CharAt(4));          // o
    Console.WriteLine(String.FromChars(new char[] { 'h', 'i' }));     // hi
    Console.WriteLine(String.FromChars(new char[0]).Length);          // 0

    // ── Contains ─────────────────────────────────────────────────────────
    Console.WriteLine("hello world".Contains("world"));   // True
    Console.WriteLine("hello".Contains("xyz"));           // False
    Console.WriteLine("hello".Contains(""));              // True

    // ── StartsWith / EndsWith ────────────────────────────────────────────
    Console.WriteLine("hello".StartsWith("he"));          // True
    Console.WriteLine("hello".StartsWith("hello!"));      // False
    Console.WriteLine("hello".StartsWith(""));            // True
    Console.WriteLine("hello".EndsWith("lo"));            // True
    Console.WriteLine("hello".EndsWith("xlo"));           // False
    Console.WriteLine("hello".EndsWith(""));              // True

    // ── IndexOf ──────────────────────────────────────────────────────────
    Console.WriteLine("hello world".IndexOf("world"));    // 6
    Console.WriteLine("hello".IndexOf("xyz"));            // -1
    Console.WriteLine("aaab".IndexOf("ab"));              // 2
    Console.WriteLine("foo".IndexOf(""));                 // 0

    // ── Substring (single + double arg) ──────────────────────────────────
    Console.WriteLine("hello world".Substring(6));        // world
    Console.WriteLine("hello world".Substring(0, 5));     // hello
    Console.WriteLine("abc".Substring(3));                // (empty)
    Console.WriteLine("abc".Substring(0, 0));             // (empty)

    // ── Replace ──────────────────────────────────────────────────────────
    Console.WriteLine("a.b.c".Replace(".", "-"));         // a-b-c
    Console.WriteLine("foo".Replace("x", "y"));           // foo
    Console.WriteLine("aaa".Replace("a", "bb"));          // bbbbbb

    // ── ToLower / ToUpper (ASCII rule) ───────────────────────────────────
    Console.WriteLine("Hello World".ToLower());           // hello world
    Console.WriteLine("hello world".ToUpper());           // HELLO WORLD
    Console.WriteLine("Hello 123!".ToLower());            // hello 123!

    // ── Trim / TrimStart / TrimEnd ───────────────────────────────────────
    Console.WriteLine("[" + "  hello  ".Trim() + "]");           // [hello]
    Console.WriteLine("[" + "  hello".TrimStart() + "]");        // [hello]
    Console.WriteLine("[" + "hello  ".TrimEnd() + "]");          // [hello]
    Console.WriteLine("[" + "   ".Trim() + "]");                 // []

    // ── IsNullOrEmpty / IsNullOrWhiteSpace ───────────────────────────────
    Console.WriteLine(String.IsNullOrEmpty(null));        // True
    Console.WriteLine(String.IsNullOrEmpty(""));          // True
    Console.WriteLine(String.IsNullOrEmpty("x"));         // False
    Console.WriteLine(String.IsNullOrWhiteSpace("   "));  // True
    Console.WriteLine(String.IsNullOrWhiteSpace(null));   // True
    Console.WriteLine(String.IsNullOrWhiteSpace("  x  ")); // False

    Console.WriteLine("ok");
}
