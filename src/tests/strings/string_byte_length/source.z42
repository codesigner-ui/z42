// review.md C11.1: `ByteLength` is O(1) UTF-8 byte count; differs from
// `Length` (Unicode scalar count) for multibyte strings.

void Main() {
    // ASCII: bytes == chars
    Assert.Equal(5,  "hello".Length);
    Assert.Equal(5,  "hello".ByteLength);
    Assert.Equal(0,  "".Length);
    Assert.Equal(0,  "".ByteLength);

    // 2-byte UTF-8 (Latin-1 supplement): chars=4, bytes=5 (é = 2 bytes)
    Assert.Equal(4,  "café".Length);
    Assert.Equal(5,  "café".ByteLength);

    // 3-byte UTF-8 (CJK): chars=2, bytes=6 (each 3 bytes)
    Assert.Equal(2,  "你好".Length);
    Assert.Equal(6,  "你好".ByteLength);

    // 4-byte UTF-8 (astral / emoji): chars=1, bytes=4
    Assert.Equal(1,  "🎉".Length);
    Assert.Equal(4,  "🎉".ByteLength);

    // Mixed: "a好🎉" = 1 (ASCII) + 3 (CJK) + 4 (emoji) = 8 bytes; 3 chars
    Assert.Equal(3,  "a好🎉".Length);
    Assert.Equal(8,  "a好🎉".ByteLength);
}
