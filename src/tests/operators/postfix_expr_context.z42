void Main() {
    // Postfix ++ returns the OLD value
    var i = 5;
    var j = i++;          // j gets old value (5), i becomes 6
    Assert.Equal(5, j);
    Assert.Equal(6, i);

    // Postfix -- returns the OLD value
    var k = i--;          // k gets old value (6), i becomes 5
    Assert.Equal(6, k);
    Assert.Equal(5, i);

    // Postfix in array index
    var arr = new int[] { 10, 20, 30 };
    var idx = 0;
    var v1 = arr[idx++];  // reads arr[0]=10, then idx becomes 1
    Assert.Equal(10, v1);
    Assert.Equal(1, idx);
    var v2 = arr[idx++];  // reads arr[1]=20, then idx becomes 2
    Assert.Equal(20, v2);
    Assert.Equal(2, idx);

    // Method chaining on string
    var s = "  Hello World  ";
    var result = s.Trim().ToLower();
    Assert.Equal("hello world", result);

    // Chained Contains
    Assert.True("Hello World".ToUpper().Contains("WORLD"));
}
