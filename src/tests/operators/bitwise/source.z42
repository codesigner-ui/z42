using Std.IO;
void Main() {
    // Bitwise AND
    int a = 0b1100 & 0b1010;   // 8
    Console.WriteLine(a);

    // Bitwise OR
    int b = 0b1100 | 0b1010;   // 14
    Console.WriteLine(b);

    // Bitwise XOR
    int c = 0b1100 ^ 0b1010;   // 6
    Console.WriteLine(c);

    // Bitwise NOT
    int d = ~0;                 // -1
    Console.WriteLine(d);

    // Shift left
    int e = 1 << 3;             // 8
    Console.WriteLine(e);

    // Shift right
    int f = 16 >> 2;            // 4
    Console.WriteLine(f);

    // Compound assigns
    int g = 0xFF;
    g &= 0x0F;                  // 15
    Console.WriteLine(g);

    g |= 0x10;                  // 31
    Console.WriteLine(g);

    g ^= 0x01;                  // 30
    Console.WriteLine(g);
}
