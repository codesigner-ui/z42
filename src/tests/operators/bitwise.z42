void Main() {
    // Bitwise AND
    Assert.Equal(8, 0b1100 & 0b1010);

    // Bitwise OR
    Assert.Equal(14, 0b1100 | 0b1010);

    // Bitwise XOR
    Assert.Equal(6, 0b1100 ^ 0b1010);

    // Bitwise NOT
    Assert.Equal(-1, ~0);

    // Shift left
    Assert.Equal(8, 1 << 3);

    // Shift right
    Assert.Equal(4, 16 >> 2);

    // Compound assigns
    int g = 0xFF;
    g &= 0x0F;
    Assert.Equal(15, g);

    g |= 0x10;
    Assert.Equal(31, g);

    g ^= 0x01;
    Assert.Equal(30, g);
}
