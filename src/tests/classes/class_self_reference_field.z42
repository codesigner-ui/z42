// Verify two-phase ImportedSymbolLoader: user code can assign same-typed
// instance to a class's self-reference field (was E0402 before fix).

void Main() {
    var inner = new Exception("root cause");
    var outer = new Exception("wrapped");

    // Same-class self-reference field assignment (the regression target).
    outer.InnerException = inner;

    Assert.Equal("wrapped",    outer.Message);
    Assert.Equal("root cause", outer.InnerException.Message);

    // Chain length 2
    var middle = new Exception("middle");
    middle.InnerException = inner;
    outer.InnerException = middle;
    Assert.Equal("middle",     outer.InnerException.Message);
    Assert.Equal("root cause", outer.InnerException.InnerException.Message);
}
