namespace Demo;

// add-class-arity-overloading: method dispatch on coexisting same-name
// arity-disjoint classes routes correctly via IR-mangled names.

class Pair {
    public string Tag;
    public Pair(string t) { this.Tag = t; }
    public string Describe() {
        return "non-generic Pair: " + this.Tag;
    }
}

class Pair<A, B> {
    public A First;
    public B Second;
    public Pair(A a, B b) {
        this.First = a;
        this.Second = b;
    }
    public string Describe() {
        return "generic Pair<A,B>";
    }
}

void Main() {
    var p0 = new Pair("untyped");
    Assert.Equal("non-generic Pair: untyped", p0.Describe());

    var p2 = new Pair<int, string>(7, "hello");
    Assert.Equal("generic Pair<A,B>", p2.Describe());
    Assert.Equal(7, p2.First);
    Assert.Equal("hello", p2.Second);
}
