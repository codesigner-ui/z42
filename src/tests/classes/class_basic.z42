namespace Demo;

class Point {
    int X;
    int Y;

    Point(int x, int y) {
        this.X = x;
        this.Y = y;
    }

    string ToString() {
        return $"({this.X}, {this.Y})";
    }
}

void Main() {
    var p = new Point(3, 4);
    Assert.Equal("(3, 4)", p.ToString());

    p.X = 10;
    Assert.Equal(10, p.X);
    Assert.Equal(4,  p.Y);
}
