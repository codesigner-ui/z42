namespace Demo;

class Person {
    public string Name { get; set; }
    public int Age { get; set; }

    Person(string name, int age) {
        this.Name = name;
        this.Age = age;
    }

    string Greet() {
        return $"Hi, I'm {this.Name}, age {this.Age}";
    }
}

void Main() {
    var p = new Person("Alice", 30);
    Assert.Equal("Hi, I'm Alice, age 30", p.Greet());

    p.Name = "Bob";
    p.Age = 25;
    Assert.Equal("Hi, I'm Bob, age 25", p.Greet());

    // Verify setter actually wrote backing fields
    Assert.Equal("Bob", p.Name);
    Assert.Equal(25,    p.Age);
}
