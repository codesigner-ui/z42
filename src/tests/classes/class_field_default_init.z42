// 2026-05-02 fix-class-field-default-init regression golden.
// 验证四组场景：
//   A) 全部字段有显式 init  → 隐式 ctor 注入
//   B) 全部字段无显式 init  → VM ObjNew 类型默认值
//   C) init + 显式 ctor body 覆写 → ctor 入口 init → 用户 body 覆盖
//   D) 继承场景 P → Q  → 子类 init 不影响父类 init
namespace Demo;

class A {
    int x = 1;
    string s = "hello";
    bool b = true;
}

class B {
    int n;
    bool flag;
}

class C {
    int n = 5;
    C(int x) { this.n = x; }
}

class P {
    int p = 100;
}

class Q : P {
    int q = 200;
}

void Main() {
    // A: 显式 init 注入
    var a = new A();
    Assert.Equal(1, a.x);
    Assert.Equal("hello", a.s);
    Assert.True(a.b);

    // B: 无 init → VM 类型默认值
    var b = new B();
    Assert.Equal(0, b.n);
    Assert.False(b.flag);

    // C: ctor body 覆盖 init
    var c = new C(99);
    Assert.Equal(99, c.n);

    // D: 继承场景，父子各自 init
    var q = new Q();
    Assert.Equal(100, q.p);
    Assert.Equal(200, q.q);
}
