namespace Demo;
using Std.IO;

// add-class-arity-overloading: same source name `Foo` for non-generic
// (arity 0) and generic `Foo<R>` (arity 1) coexist via shadow registry
// (`Foo` at bare key, `Foo$1` at mangled key when collision detected).

class Foo {
    public int Value;
    public Foo(int v) { this.Value = v; }
}

class Foo<R> {
    public R Item;
    public Foo(R x) { this.Item = x; }
}

void Main() {
    var a = new Foo(42);
    Console.WriteLine($"non-generic.Value={a.Value}");

    var b = new Foo<int>(7);
    Console.WriteLine($"generic-int.Item={b.Item}");

    var c = new Foo<string>("hello");
    Console.WriteLine($"generic-string.Item={c.Item}");
}
