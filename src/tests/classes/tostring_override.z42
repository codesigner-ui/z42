namespace Demo;

class Point {
    int X;
    int Y;

    Point(int x, int y) {
        this.X = x;
        this.Y = y;
    }

    override string ToString() {
        return $"({this.X}, {this.Y})";
    }
}

void Main() {
    var p = new Point(3, 4);

    // ToString() override via vtable dispatch
    Assert.Equal("(3, 4)", p.ToString());

    // String interpolation calls ToStr instruction → vtable dispatch
    Assert.Equal("Point is (3, 4)", $"Point is {p}");

    // String.ToString() returns self
    string s = "hello";
    Assert.Equal("hello", s.ToString());

    // String.Equals() value comparison
    Assert.True(s.Equals("hello"));
    Assert.False(s.Equals("world"));
}
