using Std.IO;
class Node {
    string value;
    Node(string v) {
        this.value = v;
    }
}

string getLength(string s) {
    // Use ?? to provide fallback when s is null
    string result = s ?? "default";
    return result;
}

void main() {
    // ?.  on non-null object returns the field
    var n = new Node("hello");
    var v = n?.value;
    Assert.Equal("hello", v);

    // ?. on null returns null
    Node nullNode = null;
    var v2 = nullNode?.value;
    Assert.Null(v2);

    // ?? chains well with ?.
    string name = null;
    string display = name ?? "anonymous";
    Assert.Equal("anonymous", display);

    // Non-null ?? path
    string realName = "alice";
    string display2 = realName ?? "anonymous";
    Assert.Equal("alice", display2);

    // ?. on string Length
    string s = "hello";
    var len = s?.Length;
    Assert.Equal(5, len);

    Console.WriteLine("null_conditional ok");
}
