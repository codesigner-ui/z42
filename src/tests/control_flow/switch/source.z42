void Main() {
    // switch expression
    var x = 2;
    var label = x switch {
        1 => "one",
        2 => "two",
        3 => "three",
        _ => "other"
    };
    Assert.Equal("two", label);

    Assert.Equal("other", 0 switch { 1 => "one", _ => "other" });

    // switch statement assigns to var
    var day = 3;
    var dayName = day switch {
        1 => "Monday",
        2 => "Tuesday",
        3 => "Wednesday",
        _ => "Other"
    };
    Assert.Equal("Wednesday", dayName);
}
