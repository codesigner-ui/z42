namespace Test;

void main() {
    // Basic do-while: runs at least once
    var i = 0;
    do {
        i = i + 1;
    } while (i < 5);
    Assert.Equal(5, i);

    // Do-while with false condition: body still executes once
    var ran = false;
    do {
        ran = true;
    } while (false);
    Assert.Equal(true, ran);

    // Nested do-while
    var outer = 0;
    var total = 0;
    do {
        outer = outer + 1;
        var inner = 0;
        do {
            inner = inner + 1;
            total = total + 1;
        } while (inner < 3);
    } while (outer < 2);
    Assert.Equal(6, total);

    // Break inside do-while
    var count = 0;
    do {
        count = count + 1;
        if (count == 3) {
            break;
        }
    } while (count < 10);
    Assert.Equal(3, count);

    // Continue inside do-while
    var sum = 0;
    var k = 0;
    do {
        k = k + 1;
        if (k % 2 == 0) {
            continue;
        }
        sum = sum + k;
    } while (k < 6);
    // sum of odd numbers 1,3,5 = 9
    Assert.Equal(9, sum);
}
