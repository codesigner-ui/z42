namespace Demo;

string FizzBuzz(int i) {
    if (i % 15 == 0) return "FizzBuzz";
    if (i % 3  == 0) return "Fizz";
    if (i % 5  == 0) return "Buzz";
    return i.ToString();
}

void Main() {
    string[] expected = new string[] {
        "1", "2", "Fizz", "4", "Buzz",
        "Fizz", "7", "8", "Fizz", "Buzz",
        "11", "Fizz", "13", "14", "FizzBuzz",
        "16", "17", "Fizz", "19", "Buzz"
    };
    for (int i = 1; i <= 20; i++) {
        Assert.Equal(expected[i - 1], FizzBuzz(i));
    }
}
