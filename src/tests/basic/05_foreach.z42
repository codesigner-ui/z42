void Main() {
    int[] nums = new int[] { 1, 2, 3, 4, 5 };

    int sum = 0;
    foreach (var n in nums) {
        sum += n;
    }
    Assert.Equal(15, sum);

    int first = 0;
    foreach (var n in nums) {
        first = n;
        break;
    }
    Assert.Equal(1, first);

    int odds = 0;
    foreach (var n in nums) {
        if (n % 2 == 0) continue;
        odds += n;
    }
    Assert.Equal(9, odds);
}
