void Main() {
    // Assert.Equal — primitives
    Assert.Equal(42, 40 + 2);
    Assert.Equal("hello", "hel" + "lo");
    Assert.Equal(true, 1 < 2);

    // Assert.True / Assert.False
    Assert.True(10 > 5);
    Assert.False(3 > 10);

    // Assert.Contains
    Assert.Contains("world", "hello world");

    // Assert.Null / Assert.NotNull
    Assert.Null(null);
    Assert.NotNull("not null");

    // Expression-level assertions
    var x = 6 * 7;
    Assert.Equal(42, x);

    // String computed value
    var greeting = "Hello, " + "World!";
    Assert.Contains("World", greeting);
    Assert.True(greeting.StartsWith("Hello"));
}
