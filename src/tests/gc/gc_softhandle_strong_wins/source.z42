namespace Demo;
using Std;

// add-gc-softref: strong ref prevents soft-ref target from being cleared
// even when heap pressure >= threshold.

class Box {
    public int Value;
    public Box(int v) { this.Value = v; }
}

void Main() {
    Box strong = new Box(55);
    SoftHandle h = SoftHandle.Create(strong);

    // Set max to current usage — pressure = 1.0 >= 0.80.
    GC.SetMaxHeapBytes(GC.UsedBytes());
    GC.ForceCollect();

    // strong is still in scope — object must not be swept.
    object got = h.Get();
    if (got != null) {
        Console.WriteLine("strong survives: alive");
    } else {
        Console.WriteLine("strong survives: null");
    }

    GC.SetMaxHeapBytes(0);
    Console.WriteLine("done");
}
