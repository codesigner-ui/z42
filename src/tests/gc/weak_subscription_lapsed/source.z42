// 2026-05-04 D-1b add-weak-ref-subscription-wrapper golden.
// 端到端验证 Std.WeakRef<TD>：lapsed listener 在 GC 后被自动短路，多播 invoke
// 不再调用其 handler。复用 D-1a WeakHandle + 新 builtin __delegate_target /
// __delegate_fn_name / __make_closure，配合 D-1b Phase 1 instance method group
// conversion（receiver 进 env[0]）。
namespace Demo;
using Std;
using Std.IO;

public class Listener {
    public int Id;
    public Listener(int id) { this.Id = id; }
    public void OnTick(int x) { Console.WriteLine($"L{this.Id}: {x}"); }
}

// 用独立函数限定 listener 作用域，确保返回后只剩 WeakHandle 持 listener。
// Main 帧的 slot semantics 可能延迟清空 local，独立函数避免这个问题。
void BindWeak(MulticastAction<int> bus, int id) {
    var l = new Listener(id);
    bus.SubscribeAdvanced(new WeakRef<Action<int>>(l.OnTick));
    // l 在函数返回后不再被外部强持
}

void Main() {
    var bus = new MulticastAction<int>();

    // 1) 先订阅 weak listener
    BindWeak(bus, 1);

    // 2) GC 前：listener 可能已被 z42 GC eagerly 收（frame 帧已退出）
    //    但即便没收，正式 GC.ForceCollect() 后必失效
    GC.ForceCollect();

    // 3) Invoke：weak handler 已 lapsed → IsAlive 返回 false → 跳过
    bus.Invoke(42);
    Console.WriteLine("end");
}
