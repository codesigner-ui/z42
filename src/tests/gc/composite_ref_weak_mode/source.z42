// 2026-05-04 D-1b CompositeRef.Mode.Weak golden.
// 验证 CompositeRef(handler, Once | Weak) 复合 mode：
//  - 第一次 invoke：Once 消费 + Weak alive → callback 执行 + flag 设 consumed
//  - 第二次 invoke：consumed 已 true → IsAlive=false → 跳过
//  - listener GC 后：Weak 路径 IsAlive=false 短路（即便没 consumed 也跳过）
namespace Demo;
using Std;
using Std.IO;

public class Listener {
    public int Id;
    public Listener(int id) { this.Id = id; }
    public void OnTick(int x) { Console.WriteLine($"L{this.Id}: {x}"); }
}

void BindOnceWeak(MulticastAction<int> bus, int id) {
    var l = new Listener(id);
    var modes = ModeFlags.Once | ModeFlags.Weak;
    bus.SubscribeAdvanced(new CompositeRef<Action<int>>(l.OnTick, modes));
}

void Main() {
    var bus = new MulticastAction<int>();
    BindOnceWeak(bus, 1);

    // 立即触发：Once + Weak 复合行为
    // 注意：listener 由 BindOnceWeak 局部持有，返回后 weak 是唯一路径；
    // z42 GC 在帧退出时可能 eagerly 收 listener → 测试两种结果都允许。
    GC.ForceCollect();

    bus.Invoke(10);                 // Weak: lapsed → 不调用
    bus.Invoke(20);                 // 同上
    Console.WriteLine("end");
}
