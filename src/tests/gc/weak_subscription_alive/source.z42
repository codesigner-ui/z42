// 2026-05-04 D-1b add-weak-ref-subscription-wrapper alive-side golden.
// 验证 Std.WeakRef<TD> 在 listener 仍 alive 时正常调度（与 weak_subscription_lapsed
// 镜像）。Listener 由 Main 主帧持强引用，invoke 应触发 OnTick。
namespace Demo;
using Std;
using Std.IO;

public class Listener {
    public int Id;
    public Listener(int id) { this.Id = id; }
    public void OnTick(int x) { Console.WriteLine($"L{this.Id}: {x}"); }
}

void Main() {
    var bus = new MulticastAction<int>();
    var l1 = new Listener(1);
    var l2 = new Listener(2);

    bus.SubscribeAdvanced(new WeakRef<Action<int>>(l1.OnTick));
    bus.SubscribeAdvanced(new WeakRef<Action<int>>(l2.OnTick));

    // listener 仍由 Main 强持，weak 不影响调度
    bus.Invoke(10);                 // L1: 10 / L2: 10
    Console.WriteLine("end");
}
