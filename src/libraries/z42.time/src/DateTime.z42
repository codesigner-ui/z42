namespace Std.Time;

// DateTime — UTC 时刻值，内部单位 Unix epoch ms（i64）。
// 直接镜像 __time_now_ms；DateTime - DateTime 返回 TimeSpan（ms × 1_000_000 = ns）。
// add-z42-time (2026-05-14)
public sealed class DateTime {
    private long _unixMs;

    public DateTime(long unixMs) {
        _unixMs = unixMs;
    }

    [Native("__time_now_ms")]
    private static extern long NowMs();

    // ── 工厂方法 ──────────────────────────────────────────────────────────────

    public static DateTime UtcNow() { return new DateTime(NowMs()); }

    public static DateTime FromUnixMs(long unixMs) {
        return new DateTime(unixMs);
    }

    public static DateTime UnixEpoch() { return new DateTime(0); }

    // ── 访问器 ────────────────────────────────────────────────────────────────

    public long UnixMs() { return _unixMs; }

    // ── 日历分解 (add-datetime-calendar 2026-05-28) ──────────────────────────
    //
    // 公开 `_civilFromDays` / `_daysFromCivil` 暗藏的日历能力 — Year /
    // Month / Day 访问器、time-of-day 分解、闰年判定、给定年月的天数、
    // 显式日历分量的 UTC 构造器、月/年加法（month-end 截断匹配 .NET /
    // Python `dateutil.relativedelta`）。
    //
    // 所有访问器均按 UTC 取值。本地时间需要先 `ToIso8601With(tz)` 投影；
    // 计算 `LocalYear()` 等便利方法等待 timezone-future API 演进。

    /// Year (Gregorian, including BCE — returns negative ints for years
    /// before year 1; year 0 doesn't exist in Gregorian, see Howard
    /// Hinnant's `civil_from_days`).
    public int Year() {
        long days = _floorDiv(_unixMs, 86400000L);
        long[] ymd = _civilFromDays(days);
        return (int)ymd[0];
    }

    /// Month, 1..12.
    public int Month() {
        long days = _floorDiv(_unixMs, 86400000L);
        long[] ymd = _civilFromDays(days);
        return (int)ymd[1];
    }

    /// Day of month, 1..31.
    public int Day() {
        long days = _floorDiv(_unixMs, 86400000L);
        long[] ymd = _civilFromDays(days);
        return (int)ymd[2];
    }

    /// Hour of day, 0..23 (UTC).
    public int Hour() {
        return (int)(_floorMod(_unixMs, 86400000L) / 3600000L);
    }

    /// Minute of hour, 0..59 (UTC).
    public int Minute() {
        return (int)((_floorMod(_unixMs, 86400000L) / 60000L) % 60L);
    }

    /// Second of minute, 0..59 (UTC).
    public int Second() {
        return (int)((_floorMod(_unixMs, 86400000L) / 1000L) % 60L);
    }

    /// Millisecond of second, 0..999.
    public int Millisecond() {
        return (int)(_floorMod(_unixMs, 1000L));
    }

    /// Day of week, 0=Sunday .. 6=Saturday (matches .NET / JS `getDay()`).
    /// 1970-01-01 was a Thursday → days mod 7 → 0=Thursday; shift by 4 to
    /// land Sunday at 0.
    public int DayOfWeek() {
        long days = _floorDiv(_unixMs, 86400000L);
        long shifted = _floorMod(days + 4L, 7L);
        return (int)shifted;
    }

    /// Day of year, 1..366 (366 only on leap-year inputs).
    public int DayOfYear() {
        int y = this.Year();
        long startOfYear = _daysFromCivil((long)y, 1L, 1L);
        long thisDay = _floorDiv(_unixMs, 86400000L);
        return (int)(thisDay - startOfYear + 1L);
    }

    /// Gregorian leap-year predicate: year is leap iff divisible by 4
    /// AND (not divisible by 100 OR divisible by 400).
    public static bool IsLeapYear(int year) {
        if (year % 4 != 0) { return false; }
        if (year % 100 != 0) { return true; }
        return year % 400 == 0;
    }

    /// Days in month for a given year. Month 1..12; year affects only
    /// February. Throws `ArgumentException` on out-of-range month.
    public static int DaysInMonth(int year, int month) {
        if (month < 1 || month > 12) {
            throw new ArgumentException(
                "DateTime.DaysInMonth: month must be 1..12, got " + month.ToString());
        }
        if (month == 2) {
            if (DateTime.IsLeapYear(year)) { return 29; }
            return 28;
        }
        // April, June, September, November = 30; rest 31.
        if (month == 4 || month == 6 || month == 9 || month == 11) { return 30; }
        return 31;
    }

    /// Construct a DateTime from explicit calendar components (UTC).
    /// Throws `ArgumentException` on out-of-range components.
    public static DateTime Utc(int year, int month, int day, int hour, int minute, int second, int millis) {
        if (month < 1 || month > 12) {
            throw new ArgumentException("DateTime.Utc: month must be 1..12, got " + month.ToString());
        }
        int dim = DateTime.DaysInMonth(year, month);
        if (day < 1 || day > dim) {
            throw new ArgumentException(
                "DateTime.Utc: day must be 1.." + dim.ToString() + " for " + year.ToString() + "-" + month.ToString() + ", got " + day.ToString());
        }
        if (hour < 0 || hour > 23) {
            throw new ArgumentException("DateTime.Utc: hour must be 0..23, got " + hour.ToString());
        }
        if (minute < 0 || minute > 59) {
            throw new ArgumentException("DateTime.Utc: minute must be 0..59, got " + minute.ToString());
        }
        if (second < 0 || second > 59) {
            throw new ArgumentException("DateTime.Utc: second must be 0..59, got " + second.ToString());
        }
        if (millis < 0 || millis > 999) {
            throw new ArgumentException("DateTime.Utc: millis must be 0..999, got " + millis.ToString());
        }
        long days = _daysFromCivil((long)year, (long)month, (long)day);
        long ms = days * 86400000L
                + (long)hour * 3600000L
                + (long)minute * 60000L
                + (long)second * 1000L
                + (long)millis;
        return new DateTime(ms);
    }

    /// Convenience: midnight UTC of the given date.
    public static DateTime UtcDate(int year, int month, int day) {
        return DateTime.Utc(year, month, day, 0, 0, 0, 0);
    }

    /// Add `days` days. Negative values supported. Calendar-aware via
    /// the underlying millisecond arithmetic.
    public DateTime AddDays(int days) {
        return new DateTime(_unixMs + (long)days * 86400000L);
    }

    public DateTime AddHours(int hours) {
        return new DateTime(_unixMs + (long)hours * 3600000L);
    }

    public DateTime AddMinutes(int minutes) {
        return new DateTime(_unixMs + (long)minutes * 60000L);
    }

    public DateTime AddSeconds(int seconds) {
        return new DateTime(_unixMs + (long)seconds * 1000L);
    }

    public DateTime AddMilliseconds(long millis) {
        return new DateTime(_unixMs + millis);
    }

    /// Add `months` calendar months. The day-of-month clamps to the last
    /// day of the target month (March 31 + 1 month = April 30, not May 1).
    /// Matches .NET `DateTime.AddMonths` / Python `dateutil.relativedelta`.
    /// Time-of-day preserved verbatim.
    public DateTime AddMonths(int months) {
        int y = this.Year();
        int m = this.Month();
        int d = this.Day();
        int totalMonth = m - 1 + months;   // 0-indexed
        // Floor-divide totalMonth by 12 for the year delta (handles negative).
        int yearDelta;
        int newMonthIdx;
        if (totalMonth >= 0) {
            yearDelta = totalMonth / 12;
            newMonthIdx = totalMonth % 12;
        } else {
            yearDelta = -((-totalMonth + 11) / 12);
            newMonthIdx = totalMonth - yearDelta * 12;
        }
        int newYear = y + yearDelta;
        int newMonth = newMonthIdx + 1;
        int dim = DateTime.DaysInMonth(newYear, newMonth);
        int newDay = d;
        if (newDay > dim) { newDay = dim; }
        return DateTime.Utc(newYear, newMonth, newDay,
                            this.Hour(), this.Minute(), this.Second(), this.Millisecond());
    }

    /// Add `years` years. Feb 29 + 1 year in a non-leap year becomes
    /// Feb 28 (clamped to last day of month).
    public DateTime AddYears(int years) {
        return this.AddMonths(years * 12);
    }

    // ── 算术 ──────────────────────────────────────────────────────────────────

    public TimeSpan Subtract(DateTime other) {
        return TimeSpan.FromNanoseconds((_unixMs - other.UnixMs()) * 1000000);
    }

    public DateTime Add(TimeSpan span) {
        return new DateTime(_unixMs + span.TotalMilliseconds());
    }

    public DateTime SubtractSpan(TimeSpan span) {
        return new DateTime(_unixMs - span.TotalMilliseconds());
    }

    // ── 比较 ──────────────────────────────────────────────────────────────────

    public bool IsAfter(DateTime other)  { return _unixMs >  other.UnixMs(); }
    public bool IsBefore(DateTime other) { return _unixMs <  other.UnixMs(); }
    public bool Equals(DateTime other)   { return _unixMs == other.UnixMs(); }

    public override string ToString() {
        return _unixMs.ToString();
    }

    // ── ISO-8601 格式化 (add-datetime-iso8601 2026-05-26) ────────────────────

    // "YYYY-MM-DDTHH:MM:SS.sssZ" — 4-digit year, zero-padded fields, 毫秒 3 位，UTC `Z`。
    // 等价 bash `date -u +%Y-%m-%dT%H:%M:%S.%3NZ`。
    public string ToIso8601() {
        return this._formatIsoDate() + "T" + this._formatIsoTimeOfDay(true);
    }

    // "YYYY-MM-DDTHH:MM:SSZ" — 不带毫秒。等价 bash `date -u +%Y-%m-%dT%H:%M:%SZ`
    // （`scripts/_lib/package_helpers.sh::pkg_emit_manifest` 用法）。
    public string ToIso8601Basic() {
        return this._formatIsoDate() + "T" + this._formatIsoTimeOfDay(false);
    }

    // add-timezone-basics (2026-05-27): render this UTC moment in the
    // given timezone's local clock. Suffix is `±HH:MM` (or `Z` for UTC).
    //
    //   var jst = TimeZone.FromName("JST");
    //   DateTime.FromUnixMs(1700000000000).ToIso8601With(jst)
    //   → "2023-11-15T07:13:20.000+09:00"
    //
    // Always emits milliseconds — symmetric with `ToIso8601`. Pass a
    // `TimeZone.Utc()` to get the same output as `ToIso8601()` modulo the
    // offset rendering (`+00:00` vs `Z`).
    public string ToIso8601With(TimeZone tz) {
        long shifted = _unixMs + (long)tz.OffsetMinutes() * 60000L;
        long days = _floorDiv(shifted, 86400000L);
        long[] ymd = _civilFromDays(days);
        long msInDay = _floorMod(shifted, 86400000L);
        long hour = msInDay / 3600000L;
        long min  = (msInDay / 60000L) % 60L;
        long sec  = (msInDay / 1000L) % 60L;
        long ms   = msInDay % 1000L;
        return _pad4(ymd[0]) + "-" + _pad2(ymd[1]) + "-" + _pad2(ymd[2])
            + "T" + _pad2(hour) + ":" + _pad2(min) + ":" + _pad2(sec)
            + "." + _pad3(ms) + tz.ToOffsetString();
    }

    // ── ISO-8601 解析 (add-datetime-iso8601-parse 2026-05-27) ───────────────

    // Inverse of ToIso8601 / ToIso8601With — accepts a calendar-date prefix
    // optionally followed by a time-of-day, optional fractional seconds,
    // and an optional timezone offset. Returns the resulting moment as
    // unix-epoch UTC.
    //
    // Accepted shapes (RFC 3339 / ISO 8601 subset):
    //   YYYY-MM-DD                              → midnight UTC of that date
    //   YYYY-MM-DDTHH:MM:SS                     → assume UTC (no suffix)
    //   YYYY-MM-DDTHH:MM:SSZ                    → UTC explicit
    //   YYYY-MM-DDTHH:MM:SS.sss                 → millis (1-9 frac digits, truncated to ms)
    //   YYYY-MM-DDTHH:MM:SS.sssZ
    //   YYYY-MM-DDTHH:MM:SS+HH:MM               → with offset (RFC 3339)
    //   YYYY-MM-DDTHH:MM:SS-HH:MM
    //   YYYY-MM-DDTHH:MM:SS.sss±HH:MM
    //   "T" separator may also be a single space (RFC 3339 §5.6 NOTE).
    //
    // Throws `ArgumentException` with the offending span on any malformed
    // input. Missing timezone suffix is treated as UTC (matches the
    // round-trip with `ToIso8601()` whose output ends in `Z`).
    public static DateTime ParseIso8601(string s) {
        if (s == null || s.Length < 10) {
            throw new ArgumentException("ParseIso8601: input too short: '" + (s ?? "") + "'");
        }
        // YYYY-MM-DD
        int year  = _parseFixed(s, 0, 4, "year");
        _expect(s, 4, '-');
        int month = _parseFixed(s, 5, 2, "month");
        _expect(s, 7, '-');
        int day   = _parseFixed(s, 8, 2, "day");
        if (month < 1 || month > 12) {
            throw new ArgumentException("ParseIso8601: month out of range: " + month.ToString());
        }
        if (day < 1 || day > 31) {
            throw new ArgumentException("ParseIso8601: day out of range: " + day.ToString());
        }

        long days = _daysFromCivil((long)year, (long)month, (long)day);
        long unixMs = days * 86400000L;

        if (s.Length == 10) {
            // Date-only — midnight UTC.
            return new DateTime(unixMs);
        }
        // Expect 'T' or space separator at position 10.
        char sep = s.CharAt(10);
        if (sep != 'T' && sep != 't' && sep != ' ') {
            throw new ArgumentException(
                "ParseIso8601: expected 'T' or space at position 10, got '" + _charStr(sep) + "'");
        }
        if (s.Length < 19) {
            throw new ArgumentException("ParseIso8601: truncated time component");
        }
        int hour = _parseFixed(s, 11, 2, "hour");
        _expect(s, 13, ':');
        int minute = _parseFixed(s, 14, 2, "minute");
        _expect(s, 16, ':');
        int second = _parseFixed(s, 17, 2, "second");
        if (hour > 23 || minute > 59 || second > 60) {
            throw new ArgumentException(
                "ParseIso8601: time out of range " + hour.ToString() + ":"
                + minute.ToString() + ":" + second.ToString());
        }
        // Cap second at 59 — leap seconds (60) are accepted but bucketed.
        if (second == 60) { second = 59; }
        unixMs = unixMs
            + (long)hour * 3600000L
            + (long)minute * 60000L
            + (long)second * 1000L;

        int pos = 19;

        // Optional fractional seconds: "." then 1-9 digits → ms (truncated).
        if (pos < s.Length && s.CharAt(pos) == '.') {
            pos = pos + 1;
            int fracStart = pos;
            while (pos < s.Length && _isDigit(s.CharAt(pos))) { pos = pos + 1; }
            int fracLen = pos - fracStart;
            if (fracLen == 0) {
                throw new ArgumentException("ParseIso8601: '.' not followed by fractional digits");
            }
            // Read up to 3 digits as ms; truncate longer (microsecond /
            // nanosecond precision is lost — DateTime is ms-resolution).
            long ms = 0L;
            int i = 0;
            while (i < 3) {
                if (i < fracLen) {
                    ms = ms * 10L + (long)((int)s.CharAt(fracStart + i) - (int)'0');
                } else {
                    ms = ms * 10L;
                }
                i = i + 1;
            }
            unixMs = unixMs + ms;
        }

        // Optional timezone suffix: Z | ±HH:MM | ±HHMM | ±HH
        if (pos >= s.Length) {
            // No suffix — treat as UTC (round-trips with our own ToIso8601
            // which always emits Z, but be lenient on input).
            return new DateTime(unixMs);
        }
        char tz = s.CharAt(pos);
        if (tz == 'Z' || tz == 'z') {
            if (pos + 1 != s.Length) {
                throw new ArgumentException(
                    "ParseIso8601: trailing characters after 'Z': '"
                    + s.Substring(pos + 1, s.Length - pos - 1) + "'");
            }
            return new DateTime(unixMs);
        }
        if (tz != '+' && tz != '-') {
            throw new ArgumentException(
                "ParseIso8601: expected 'Z', '+', or '-' at position "
                + pos.ToString() + ", got '" + _charStr(tz) + "'");
        }
        int sign = (tz == '-') ? -1 : 1;
        pos = pos + 1;
        if (pos + 2 > s.Length) {
            throw new ArgumentException("ParseIso8601: offset truncated");
        }
        int offHours = _parseFixed(s, pos, 2, "offset hours");
        pos = pos + 2;
        int offMinutes = 0;
        if (pos < s.Length) {
            // Optional ':' then minutes.
            if (s.CharAt(pos) == ':') { pos = pos + 1; }
            if (pos + 2 > s.Length) {
                throw new ArgumentException("ParseIso8601: offset minutes truncated");
            }
            offMinutes = _parseFixed(s, pos, 2, "offset minutes");
            pos = pos + 2;
        }
        if (pos != s.Length) {
            throw new ArgumentException(
                "ParseIso8601: trailing characters after offset: '"
                + s.Substring(pos, s.Length - pos) + "'");
        }
        if (offHours > 23 || offMinutes > 59) {
            throw new ArgumentException(
                "ParseIso8601: offset out of range "
                + offHours.ToString() + ":" + offMinutes.ToString());
        }
        long offsetMs = (long)sign * ((long)offHours * 3600000L + (long)offMinutes * 60000L);
        // Local time at offset = UTC + offset, so UTC = local - offset.
        return new DateTime(unixMs - offsetMs);
    }

    // Inverse of `_civilFromDays`: convert (y, m, d) → days since 1970-01-01.
    // Howard Hinnant's `days_from_civil` (matches sibling algorithm).
    static long _daysFromCivil(long y, long m, long d) {
        if (m <= 2L) { y = y - 1L; }
        long era;
        if (y >= 0L) { era = y / 400L; } else { era = (y - 399L) / 400L; }
        long yoe = y - era * 400L;
        long mAdj;
        if (m > 2L) { mAdj = m - 3L; } else { mAdj = m + 9L; }
        long doy = (153L * mAdj + 2L) / 5L + d - 1L;
        long doe = yoe * 365L + yoe / 4L - yoe / 100L + doy;
        return era * 146097L + doe - 719468L;
    }

    static int _parseFixed(string s, int start, int width, string fieldName) {
        if (start + width > s.Length) {
            throw new ArgumentException("ParseIso8601: " + fieldName + " truncated");
        }
        int n = 0;
        int i = 0;
        while (i < width) {
            char c = s.CharAt(start + i);
            if (!_isDigit(c)) {
                throw new ArgumentException(
                    "ParseIso8601: non-digit in " + fieldName + " at position "
                    + (start + i).ToString() + ": '" + _charStr(c) + "'");
            }
            n = n * 10 + ((int)c - (int)'0');
            i = i + 1;
        }
        return n;
    }

    static void _expect(string s, int pos, char want) {
        if (pos >= s.Length || s.CharAt(pos) != want) {
            char got = pos < s.Length ? s.CharAt(pos) : '?';
            throw new ArgumentException(
                "ParseIso8601: expected '" + _charStr(want) + "' at position "
                + pos.ToString() + ", got '" + _charStr(got) + "'");
        }
    }

    static bool _isDigit(char c) { return c >= '0' && c <= '9'; }

    static string _charStr(char c) {
        char[] buf = new char[1];
        buf[0] = c;
        return String.FromChars(buf);
    }

    // ── 内部实现 ─────────────────────────────────────────────────────────────

    private string _formatIsoDate() {
        long days = _floorDiv(_unixMs, 86400000L);
        long[] ymd = _civilFromDays(days);
        return _pad4(ymd[0]) + "-" + _pad2(ymd[1]) + "-" + _pad2(ymd[2]);
    }

    private string _formatIsoTimeOfDay(bool withMillis) {
        long msInDay = _floorMod(_unixMs, 86400000L);
        long hour = msInDay / 3600000L;
        long min  = (msInDay / 60000L) % 60L;
        long sec  = (msInDay / 1000L) % 60L;
        long ms   = msInDay % 1000L;
        string s = _pad2(hour) + ":" + _pad2(min) + ":" + _pad2(sec);
        if (withMillis) {
            s = s + "." + _pad3(ms);
        }
        return s + "Z";
    }

    // Howard Hinnant `civil_from_days` (well-known algorithm; supports negative days).
    // 输入：days since 1970-01-01；输出：[year, month, day] 其中 month ∈ [1,12], day ∈ [1,31]。
    static long[] _civilFromDays(long days) {
        long z = days + 719468L;
        long era;
        if (z >= 0L) { era = z / 146097L; } else { era = (z - 146096L) / 146097L; }
        long doe = z - era * 146097L;                                                       // [0, 146096]
        long yoe = (doe - doe / 1460L + doe / 36524L - doe / 146096L) / 365L;               // [0, 399]
        long y = yoe + era * 400L;
        long doy = doe - (365L * yoe + yoe / 4L - yoe / 100L);                              // [0, 365]
        long mp  = (5L * doy + 2L) / 153L;                                                  // [0, 11]
        long d   = doy - (153L * mp + 2L) / 5L + 1L;                                        // [1, 31]
        long m;
        if (mp < 10L) { m = mp + 3L; } else { m = mp - 9L; }
        if (m <= 2L) { y = y + 1L; }
        long[] result = new long[3];
        result[0] = y;
        result[1] = m;
        result[2] = d;
        return result;
    }

    // Floor division / modulo（处理负数向负无穷舍入；Unix epoch 之前的时刻需要）。
    // C-style `/` 在 z42 跟 .NET 一样 truncates-toward-zero，对负数会算错日界。
    static long _floorDiv(long a, long b) {
        long q = a / b;
        long r = a - q * b;
        if ((r != 0L) && ((r < 0L) != (b < 0L))) { q = q - 1L; }
        return q;
    }
    static long _floorMod(long a, long b) {
        long r = a - _floorDiv(a, b) * b;
        return r;
    }

    static string _pad2(long n) {
        if (n < 10L) { return "0" + n.ToString(); }
        return n.ToString();
    }
    static string _pad3(long n) {
        if (n < 10L)  { return "00" + n.ToString(); }
        if (n < 100L) { return "0"  + n.ToString(); }
        return n.ToString();
    }
    static string _pad4(long n) {
        if (n < 0L)     { return "-" + _pad4(-n); }
        if (n < 10L)    { return "000" + n.ToString(); }
        if (n < 100L)   { return "00"  + n.ToString(); }
        if (n < 1000L)  { return "0"   + n.ToString(); }
        return n.ToString();
    }
}
