// add-datetime-offset (2026-06-03): DateTimeOffset = (DateTime utc, TimeZone tz).
namespace Z42TimeDateTimeOffsetTests;

using Std;
using Std.Test;
using Std.Time;

[Test]
void test_construct_stores_utc_and_offset() {
    DateTime utc = DateTime.Utc(2026, 6, 3, 14, 32, 31, 0);
    TimeZone tz  = TimeZone.FromOffsetMinutes(540);
    DateTimeOffset dto = new DateTimeOffset(utc, tz);
    Assert.True(dto.UtcDateTime().Equals(utc));
    Assert.Equal(540, dto.Offset().OffsetMinutes());
}

[Test]
void test_construct_null_utc_throws() {
    bool caught = false;
    try {
        DateTimeOffset dto = new DateTimeOffset(null, TimeZone.Utc());
    } catch (ArgumentNullException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_construct_null_tz_throws() {
    bool caught = false;
    try {
        DateTimeOffset dto = new DateTimeOffset(DateTime.UnixEpoch(), null);
    } catch (ArgumentNullException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_local_datetime_applies_offset() {
    DateTime utc = DateTime.Utc(2026, 6, 3, 5, 0, 0, 0);
    DateTimeOffset dto = new DateTimeOffset(utc, TimeZone.FromOffsetMinutes(540));
    DateTime local = dto.LocalDateTime();
    Assert.Equal(2026, local.Year());
    Assert.Equal(6,    local.Month());
    Assert.Equal(3,    local.Day());
    Assert.Equal(14,   local.Hour());
}

[Test]
void test_local_field_accessors_match_offset() {
    DateTime utc = DateTime.Utc(2026, 6, 3, 0, 0, 0, 0);
    DateTimeOffset dto = new DateTimeOffset(utc, TimeZone.FromOffsetMinutes(-480));
    Assert.Equal(2026, dto.Year());
    Assert.Equal(6,    dto.Month());
    Assert.Equal(2,    dto.Day());     // prior day in PST
    Assert.Equal(16,   dto.Hour());
}

[Test]
void test_from_local_computes_utc() {
    DateTimeOffset dto = DateTimeOffset.FromLocal(2026, 6, 3, 14, 0, 0, 0,
        TimeZone.FromOffsetMinutes(540));
    Assert.Equal(2026, dto.UtcDateTime().Year());
    Assert.Equal(6,    dto.UtcDateTime().Month());
    Assert.Equal(3,    dto.UtcDateTime().Day());
    Assert.Equal(5,    dto.UtcDateTime().Hour());
    Assert.Equal(14,   dto.Hour());
}

[Test]
void test_parse_utc_suffix_z() {
    DateTimeOffset dto = DateTimeOffset.Parse("2026-06-03T14:32:31Z");
    Assert.Equal(0, dto.Offset().OffsetMinutes());
    Assert.Equal(14, dto.Hour());
}

[Test]
void test_parse_positive_offset() {
    DateTimeOffset dto = DateTimeOffset.Parse("2026-06-03T14:32:31+09:00");
    Assert.Equal(540, dto.Offset().OffsetMinutes());
    Assert.Equal(5, dto.UtcDateTime().Hour());
    Assert.Equal(14, dto.Hour());
    Assert.Equal(32, dto.Minute());
    Assert.Equal(31, dto.Second());
}

[Test]
void test_parse_negative_offset() {
    DateTimeOffset dto = DateTimeOffset.Parse("2026-06-03T09:32:31-05:00");
    Assert.Equal(-300, dto.Offset().OffsetMinutes());
    Assert.Equal(14, dto.UtcDateTime().Hour());
    Assert.Equal(9,  dto.Hour());
}

[Test]
void test_parse_offset_without_colon() {
    DateTimeOffset dto = DateTimeOffset.Parse("2026-06-03T14:32:31+0900");
    Assert.Equal(540, dto.Offset().OffsetMinutes());
}

[Test]
void test_parse_no_offset_throws() {
    bool caught = false;
    try {
        DateTimeOffset dto = DateTimeOffset.Parse("2026-06-03T14:32:31");
    } catch (FormatException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_iso8601_round_trip_positive_offset() {
    string input = "2026-06-03T14:32:31.000+09:00";
    DateTimeOffset dto = DateTimeOffset.Parse(input);
    string output = dto.ToIso8601();
    Assert.Equal(input, output);
}

[Test]
void test_iso8601_round_trip_negative_offset() {
    string input = "2026-06-03T09:32:31.000-05:00";
    DateTimeOffset dto = DateTimeOffset.Parse(input);
    string output = dto.ToIso8601();
    Assert.Equal(input, output);
}

[Test]
void test_equals_same_utc_different_offset_true() {
    DateTimeOffset jst = DateTimeOffset.Parse("2026-06-03T14:00:00+09:00");
    DateTimeOffset utc = DateTimeOffset.Parse("2026-06-03T05:00:00Z");
    Assert.True(jst.Equals(utc));
    Assert.True(utc.Equals(jst));
}

[Test]
void test_equals_exact_same_utc_different_offset_false() {
    DateTimeOffset jst = DateTimeOffset.Parse("2026-06-03T14:00:00+09:00");
    DateTimeOffset utc = DateTimeOffset.Parse("2026-06-03T05:00:00Z");
    Assert.False(jst.EqualsExact(utc));
}

[Test]
void test_equals_null_returns_false() {
    DateTimeOffset dto = DateTimeOffset.Parse("2026-06-03T05:00:00Z");
    Assert.False(dto.Equals(null));
    Assert.False(dto.EqualsExact(null));
}

[Test]
void test_is_after_by_utc() {
    DateTimeOffset a = DateTimeOffset.Parse("2026-06-03T14:00:00+09:00");
    DateTimeOffset b = DateTimeOffset.Parse("2026-06-03T06:00:00Z");
    Assert.True(b.IsAfter(a));
    Assert.True(a.IsBefore(b));
}

[Test]
void test_subtract_returns_timespan() {
    DateTimeOffset a = DateTimeOffset.Parse("2026-06-03T14:00:00+09:00");
    DateTimeOffset b = DateTimeOffset.Parse("2026-06-03T06:00:00Z");
    TimeSpan diff = b.Subtract(a);
    Assert.Equal(3600000L, diff.TotalMilliseconds());
}

[Test]
void test_add_timespan_preserves_offset() {
    DateTimeOffset a = DateTimeOffset.Parse("2026-06-03T14:00:00+09:00");
    DateTimeOffset b = a.Add(TimeSpan.FromHours(1));
    Assert.Equal(540, b.Offset().OffsetMinutes());
    Assert.Equal(15,  b.Hour());
}

[Test]
void test_subtract_span_preserves_offset() {
    DateTimeOffset a = DateTimeOffset.Parse("2026-06-03T14:00:00+09:00");
    DateTimeOffset b = a.SubtractSpan(TimeSpan.FromHours(2));
    Assert.Equal(540, b.Offset().OffsetMinutes());
    Assert.Equal(12,  b.Hour());
}

[Test]
void test_now_returns_offset_zone() {
    DateTimeOffset now = DateTimeOffset.Now(TimeZone.FromOffsetMinutes(540));
    Assert.Equal(540, now.Offset().OffsetMinutes());
}
