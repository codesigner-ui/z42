// add-std-io-directory (2026-05-13)：z42.io.Directory 库本地测试。
// 5 个 extern API 各覆盖 happy path + 必要的边界（不存在 / 非空目录）。
//
// 测试用 /tmp/z42-directory-test-* 隔离写盘（与 process_stdio 同款；
// Windows 兼容由 z42 build-driver 落地后跟 Path.Separator 一并解决）。
namespace Z42IoDirectoryTests;

using Std.Test;
using Std.IO;

// ── Exists ───────────────────────────────────────────────────────────────

[Test]
void test_exists_true_for_dir() {
    // /tmp 在 macOS / Linux 上 ~~一定存在
    Assert.True(Directory.Exists("/tmp"));
}

[Test]
void test_exists_false_for_missing() {
    Assert.False(Directory.Exists("/tmp/__definitely_does_not_exist_z42_x__"));
}

[Test]
void test_exists_false_for_file() {
    // 文件不是目录；Exists 必须 false（区别于 File.Exists）
    string path = "/tmp/z42-directory-test-file-not-dir.txt";
    File.WriteAllText(path, "hi");
    Assert.False(Directory.Exists(path));
    File.Delete(path);
}

// ── Create ────────────────────────────────────────────────────────────────

[Test]
void test_create_simple() {
    string p = "/tmp/z42-directory-test-create-simple";
    Directory.Create(p);
    Assert.True(Directory.Exists(p));
    Directory.Delete(p, false);
}

[Test]
void test_create_recursive() {
    // mkdir -p 语义：中间目录自动建
    string p = "/tmp/z42-directory-test-create-rec/a/b/c";
    Directory.Create(p);
    Assert.True(Directory.Exists(p));
    Assert.True(Directory.Exists("/tmp/z42-directory-test-create-rec/a"));
    Directory.Delete("/tmp/z42-directory-test-create-rec", true);
}

[Test]
void test_create_idempotent() {
    // 已存在不报错
    string p = "/tmp/z42-directory-test-create-idem";
    Directory.Create(p);
    Directory.Create(p);   // 第二次不抛
    Assert.True(Directory.Exists(p));
    Directory.Delete(p, false);
}

// ── Delete ────────────────────────────────────────────────────────────────

[Test]
void test_delete_empty() {
    string p = "/tmp/z42-directory-test-del-empty";
    Directory.Create(p);
    Directory.Delete(p, false);
    Assert.False(Directory.Exists(p));
}

[Test]
void test_delete_recursive() {
    string root = "/tmp/z42-directory-test-del-rec";
    Directory.Create(root + "/sub");
    File.WriteAllText(root + "/sub/a.txt", "x");
    Directory.Delete(root, true);
    Assert.False(Directory.Exists(root));
}

// ── Enumerate ─────────────────────────────────────────────────────────────

[Test]
void test_enumerate_returns_basenames() {
    string root = "/tmp/z42-directory-test-enum";
    Directory.Create(root);
    File.WriteAllText(root + "/b.txt", "");
    File.WriteAllText(root + "/a.txt", "");
    Directory.Create(root + "/d");

    string[] items = Directory.Enumerate(root);
    Assert.Equal(3, items.Length);
    // builtin 已 sort；按字母序断言
    Assert.Equal("a.txt", items[0]);
    Assert.Equal("b.txt", items[1]);
    Assert.Equal("d",     items[2]);

    Directory.Delete(root, true);
}

[Test]
void test_enumerate_empty_dir() {
    string root = "/tmp/z42-directory-test-enum-empty";
    Directory.Create(root);
    string[] items = Directory.Enumerate(root);
    Assert.Equal(0, items.Length);
    Directory.Delete(root, false);
}

// ── EnumerateRecursive ────────────────────────────────────────────────────

[Test]
void test_enumerate_recursive_includes_subtree() {
    string root = "/tmp/z42-directory-test-enum-rec";
    Directory.Create(root + "/sub/deep");
    File.WriteAllText(root + "/top.txt",         "");
    File.WriteAllText(root + "/sub/mid.txt",     "");
    File.WriteAllText(root + "/sub/deep/leaf.txt", "");

    string[] items = Directory.EnumerateRecursive(root);
    // 5 项：top.txt, sub, sub/mid.txt, sub/deep, sub/deep/leaf.txt（顺序由 builtin sort）
    Assert.Equal(5, items.Length);
    Assert.Equal("sub",                items[0]);
    Assert.Equal("sub/deep",           items[1]);
    Assert.Equal("sub/deep/leaf.txt",  items[2]);
    Assert.Equal("sub/mid.txt",        items[3]);
    Assert.Equal("top.txt",            items[4]);

    Directory.Delete(root, true);
}
