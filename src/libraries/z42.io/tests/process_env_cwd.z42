// add-std-process: env + working-directory tests.
namespace Z42IoProcessEnvCwdTests;

using Std.Test;
using Std.IO;

[Test]
void test_env_override_visible_in_child() {
    var r = new Process("sh")
        .Arg("-c").Arg("echo $Z42_TEST_KEY")
        .Env("Z42_TEST_KEY", "hello-from-z42")
        .Run();
    Assert.Equal(0, r.ExitCode);
    Assert.Equal("hello-from-z42\n", r.Stdout);
}

[Test]
void test_clear_env_strips_parent_environment() {
    // After ClearEnv, only what we Env() in is visible.
    var r = new Process("sh")
        .Arg("-c").Arg("echo ${Z42_PARENT_VAR:-empty}-${MY_KEY:-empty}")
        .ClearEnv()
        .Env("PATH", "/usr/bin:/bin")    // sh needs PATH to find echo
        .Env("MY_KEY", "preserved")
        .Run();
    Assert.Equal(0, r.ExitCode);
    // Z42_PARENT_VAR should NOT be inherited; MY_KEY should be set.
    Assert.Equal("empty-preserved\n", r.Stdout);
}

[Test]
void test_working_directory_takes_effect() {
    var r = new Process("pwd")
        .WorkingDirectory("/tmp")
        .Run();
    Assert.Equal(0, r.ExitCode);
    // macOS resolves /tmp through a symlink; either is acceptable.
    string pwdOut = r.Stdout;
    Assert.True(pwdOut == "/tmp\n" || pwdOut == "/private/tmp\n");
}
