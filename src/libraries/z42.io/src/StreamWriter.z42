namespace Std.IO;

using Std;
using Std.Encoding;

// add-encoding-and-stream-text (2026-05-24): char-oriented writer
// over a byte `Stream` via an `Encoding`. Each `Write` encodes its
// argument immediately and pushes bytes through to the destination.
//
// Why encode-on-write (vs buffer-and-flush): the underlying byte
// `Stream` already has whatever buffering it wants (MemoryStream
// grows in-memory; FileStream goes through OS page cache;
// CompressionEncoderStream batches into its codec). Layering another
// char-buffer on top would be redundant. `Flush()` just propagates
// to the dest Stream's `Flush()` so caller can force codec-window
// drains etc.
//
// Lifecycle: `Close()` calls `Flush()` then leaves the dest Stream
// open. Matches `CompressionEncoderStream` / Process*Stream
// conventions — safer for pipeline composition.

public class StreamWriter {
    private Stream   _dest;
    private Encoding _encoding;
    private bool     _closed;

    public StreamWriter(Stream dest) {
        this._dest     = dest;
        this._encoding = Encoding.GetUtf8();
        this._closed   = false;
    }

    public StreamWriter(Stream dest, Encoding encoding) {
        this._dest     = dest;
        this._encoding = encoding;
        this._closed   = false;
    }

    // ── Write ───────────────────────────────────────────────────────────

    public void Write(string s) {
        this.EnsureOpen();
        if (s.Length == 0) { return; }
        byte[] bytes = this._encoding.GetBytes(s);
        this._dest.Write(bytes, 0, bytes.Length);
    }

    public void Write(char[] buffer, int offset, int count) {
        this.EnsureOpen();
        if (offset < 0 || count < 0 || offset + count > buffer.Length) {
            throw new ArgumentException("Write: buffer / offset / count out of range");
        }
        if (count == 0) { return; }
        // Materialise the slice as a string once, then delegate to the
        // string overload. Avoids per-char FromChars + Append overhead.
        char[] slice;
        if (offset == 0 && count == buffer.Length) {
            slice = buffer;
        } else {
            slice = new char[count];
            int i = 0;
            while (i < count) {
                slice[i] = buffer[offset + i];
                i = i + 1;
            }
        }
        this.Write(String.FromChars(slice));
    }

    // ── WriteLine ───────────────────────────────────────────────────────

    public void WriteLine() {
        this.Write("\n");
    }

    public void WriteLine(string s) {
        this.EnsureOpen();
        // Combine encode in one call (cheaper than two Writes) for the
        // common log-line / line-emitter pattern.
        byte[] bytes = this._encoding.GetBytes(s + "\n");
        this._dest.Write(bytes, 0, bytes.Length);
    }

    // ── Flush / Close ───────────────────────────────────────────────────

    /// Propagate to dest Stream — gives byte-side buffering layers a
    /// chance to drain (compression codec window, eventual
    /// BufferedStream). Encoder side is already byte-flushed since we
    /// encode-on-write.
    public void Flush() {
        if (this._closed) { return; }
        this._dest.Flush();
    }

    /// Flush then mark closed. Does NOT close the dest Stream — caller
    /// owns its lifecycle.
    public void Close() {
        if (this._closed) { return; }
        this.Flush();
        this._closed = true;
    }

    // ── Internal ────────────────────────────────────────────────────────

    private void EnsureOpen() {
        if (this._closed) {
            throw new InvalidOperationException("StreamWriter: writer is closed");
        }
    }
}
