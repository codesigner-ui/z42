namespace Std;

// 2026-05-13 add-std-process: 进程启动失败（可执行文件未找到 / 权限不足 /
// fork-exec / CreateProcess 失败等）。**与 ProcessExitException 区别**：
// 这个表示**子进程根本没启动**；如果启动成功但 exit != 0，会用
// `ProcessExitException`（仅在 `.EnsureSuccess()` 时抛出）。
public class ProcessStartException : Exception {
    public ProcessStartException(string message) : base(message) {}

    override string ToString() {
        return "ProcessStartException: " + this.Message;
    }
}
