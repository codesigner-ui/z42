namespace Std;

// add-end-of-stream-exception (2026-05-27): dedicated exception for
// premature stream EOF, replacing v0's reuse of `InvalidOperationException`
// on `Stream.ReadExactly` underflow. Mirrors .NET
// `System.IO.EndOfStreamException` (BCL has had it since v1.0).
//
// Catch this when you want to distinguish "stream ran dry" from generic
// invalid-state errors. Existing code that catches `Exception` continues
// to work because this still inherits Exception.
public class EndOfStreamException : Exception {
    public EndOfStreamException(string message) : base(message) { }

    override string ToString() {
        return "EndOfStreamException: " + this.Message;
    }
}
