namespace Std.IO;

using Std.Encoding;

// 2026-05-13 add-std-process: handle to a live spawned child process.
// Returned by `Process.Spawn()`. The handle carries an opaque slot id
// pointing at VM-managed state in `VmContext.processes`; all operations
// dispatch through `__process_handle_*` builtins.
//
// 必须 `.Dispose()` 或 GC 时让 Native runtime 回收子进程（仍 alive 时
// 走 kill + reap，避免僵尸进程）。z42 `IDisposable` 协议保证两种调用都
// 路由到 `__process_handle_drop`。
public class ProcessHandle : IDisposable {
    private string _program;
    private long _slotId;
    private bool _disposed;
    // add-process-stream-stdio (2026-05-24): cached Stream wrappers
    // so repeated `GetXxxStream()` returns the same object (callers
    // can `==`/identity-compare; matches .NET `Process.StandardOutput`).
    private ProcessStdinStream  _stdinStream;
    private ProcessOutputStream _stdoutStream;
    private ProcessOutputStream _stderrStream;

    public ProcessHandle(string program, long slotId) {
        this._program  = program;
        this._slotId   = slotId;
        this._disposed = false;
    }

    public long Pid() {
        this.EnsureLive();
        object pidObj = ProcessHandleNative.Pid(this._slotId);
        if (pidObj == null) {
            throw new ProcessHandleInvalidException(this._program);
        }
        return (long)pidObj;
    }

    public ProcessResult Wait() {
        this.EnsureLive();
        object[] raw = ProcessHandleNative.Wait(this._slotId);
        return this.HandleWaitResult(raw);
    }

    // Returns null if the child is still running, ProcessResult if exited.
    public ProcessResult? TryWait() {
        this.EnsureLive();
        object resObj = ProcessHandleNative.TryWait(this._slotId);
        if (resObj == null) {
            return null;
        }
        object[] raw = (object[])resObj;
        return this.HandleWaitResult(raw);
    }

    public void Kill() {
        this.EnsureLive();
        object res = ProcessHandleNative.Kill(this._slotId, false);
        this.CheckHandleResponse(res);
    }

    public void KillForce() {
        this.EnsureLive();
        object res = ProcessHandleNative.Kill(this._slotId, true);
        this.CheckHandleResponse(res);
    }

    public void WriteStdin(byte[] bytes) {
        this.EnsureLive();
        object res = ProcessHandleNative.WriteStdin(this._slotId, bytes);
        this.CheckHandleResponse(res);
    }

    // add-process-write-stdin-string (2026-05-27): UTF-8 string convenience.
    // Equivalent to `WriteStdin(Utf8.GetBytes(s))` — saves the boilerplate
    // for line-oriented stdin (printf-style commands, echo replacements).
    //
    // Named `WriteStdinString` rather than overloading `WriteStdin(string)`
    // because z42's compiler doesn't yet resolve overloads by parameter
    // type (tracked as `compiler-future-typed-overload-resolution`).
    public void WriteStdinString(string s) {
        this.WriteStdin(Utf8.GetBytes(s));
    }

    public void CloseStdin() {
        this.EnsureLive();
        object res = ProcessHandleNative.CloseStdin(this._slotId);
        this.CheckHandleResponse(res);
    }

    // ── add-process-stream-stdio (2026-05-24): streaming read API ────────
    //
    // Blocking reads from the child's stdout / stderr pipe. Returns
    // number of bytes actually placed in `buffer[offset..offset+count]`;
    // 0 = EOF (child closed the pipe or already-consumed by Wait).
    //
    // Designed for the `ProcessOutputStream` Stream wrapper —
    // direct callers are welcome but the Stream API composes more
    // cleanly with other `Std.IO.Stream` consumers (pipelines,
    // ReadAllBytes, etc.).

    public int ReadStdout(byte[] buffer, int offset, int count) {
        this.EnsureLive();
        object res = ProcessHandleNative.ReadStdout(this._slotId, buffer, offset, count);
        return this.CheckReadResponse(res);
    }

    public int ReadStderr(byte[] buffer, int offset, int count) {
        this.EnsureLive();
        object res = ProcessHandleNative.ReadStderr(this._slotId, buffer, offset, count);
        return this.CheckReadResponse(res);
    }

    // ── add-process-stream-stdio (2026-05-24): Stream accessors ──────────
    //
    // Lazy + cached: first call constructs, subsequent calls return
    // the same instance. Lets callers store the Stream once and re-use
    // it across loop iterations without paying for per-call construction
    // or accidentally creating multiple "views" with divergent _closed
    // bits.

    public ProcessStdinStream GetStdinStream() {
        if (this._stdinStream == null) {
            this._stdinStream = new ProcessStdinStream(this);
        }
        return this._stdinStream;
    }

    public ProcessOutputStream GetStdoutStream() {
        if (this._stdoutStream == null) {
            this._stdoutStream = new ProcessOutputStream(this, ProcessOutputStream.Stdout);
        }
        return this._stdoutStream;
    }

    public ProcessOutputStream GetStderrStream() {
        if (this._stderrStream == null) {
            this._stderrStream = new ProcessOutputStream(this, ProcessOutputStream.Stderr);
        }
        return this._stderrStream;
    }

    // 实现 IDisposable — 幂等。Dispose 后所有方法抛
    // ProcessHandleInvalidException，子进程在 Native 侧被 kill + reap。
    public void Dispose() {
        if (this._disposed) return;
        this._disposed = true;
        ProcessHandleNative.Drop(this._slotId);
    }

    // ── internals ────────────────────────────────────────────────────────

    private void EnsureLive() {
        if (this._disposed) {
            throw new ProcessHandleInvalidException(this._program);
        }
    }

    private ProcessResult HandleWaitResult(object[] raw) {
        long kind = (long)raw[0];
        if (kind == 3) {
            // KIND_HANDLE_INVALID
            this._disposed = true;
            throw new ProcessHandleInvalidException(this._program);
        }
        // kind == 0 (ok). Wait + TryWait consume the slot on the Native
        // side, so flag local as disposed for future calls.
        this._disposed = true;
        return new ProcessResult(
            this._program,
            (int)(long)raw[1],
            (string)raw[2],
            (string)raw[3],
            (byte[])raw[4],
            (byte[])raw[5]);
    }

    // For ops that return either Value.Null (success) or a kind-tuple
    // (handle invalid). Used by Kill / WriteStdin / CloseStdin.
    private void CheckHandleResponse(object res) {
        if (res == null) return;          // success
        // It's an Array — invalid handle.
        this._disposed = true;
        throw new ProcessHandleInvalidException(this._program);
    }

    // For Read{Stdout,Stderr}: Native returns either Value::I64(n)
    // (success; n=0 means EOF) or Value::Null (slot missing / handle
    // invalid). Z42 sees these as `long` and `null` respectively.
    private int CheckReadResponse(object res) {
        if (res == null) {
            this._disposed = true;
            throw new ProcessHandleInvalidException(this._program);
        }
        return (int)(long)res;
    }
}

public static class ProcessHandleNative {
    [Native("__process_handle_wait")]
    public static extern object[] Wait(long slotId);

    [Native("__process_handle_try_wait")]
    public static extern object TryWait(long slotId);

    [Native("__process_handle_kill")]
    public static extern object Kill(long slotId, bool force);

    [Native("__process_handle_write_stdin")]
    public static extern object WriteStdin(long slotId, byte[] bytes);

    [Native("__process_handle_close_stdin")]
    public static extern object CloseStdin(long slotId);

    [Native("__process_handle_pid")]
    public static extern object Pid(long slotId);

    [Native("__process_handle_drop")]
    public static extern object Drop(long slotId);

    // add-process-stream-stdio (2026-05-24): streaming pipe reads.
    [Native("__process_handle_read_stdout")]
    public static extern object ReadStdout(long slotId, byte[] buffer, int offset, int count);

    [Native("__process_handle_read_stderr")]
    public static extern object ReadStderr(long slotId, byte[] buffer, int offset, int count);
}
