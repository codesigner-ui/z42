namespace Std.IO;

// Path manipulation — pure string operations on `/`-separated paths.
//
// 2026-04-27 wave1-path-script: 5 个方法从 [Native] 迁纯脚本（BCL/Rust 对标 —
// `System.IO.Path` / `std::path::Path` 都是字符串扫描）。
//
// **分隔符**：内部统一用 `/`（Windows 原生 API 也接受 `/`）。`IsRooted`/`Join`
// 额外识别 Windows 根（盘符 `X:\`/`X:/` 与反斜杠），因为自举编译器 z42c 现在要在
// Windows 上跑——`Environment.GetCurrentDirectory()` 返回 `D:\...`，若 rooted 检测
// 漏判会被二次拼接成 `…/D:\…`（中间 `:`）→ 原生 create_dir 报 error 123。
public static class Path {
    // 平台分隔符常量（对应 BCL `Path.DirectorySeparatorChar`）。
    // L1 硬编码 `/`；L3+ 引入 Windows 支持时，可改由 platform HAL 注入。
    //
    // 2026-04-27 add-path-separator: fix-static-field-access 之前导入静态字段
    // 不可用，本常量引入被推迟；现在 `Math.PI` 等已能访问，路径打通。
    public static char Separator = '/';

    // BCL Path.Combine 兼容别名（与 Join 语义相同）。
    public static string Combine(string a, string b) {
        return Path.Join(a, b);
    }

    // 返回路径是否为绝对路径：Unix `/` 开头，或 Windows 根
    // （盘符 `X:\`/`X:/`/`X:` 与反斜杠 `\` 开头的 UNC/当前盘根）。
    public static bool IsRooted(string path) {
        if (path.Length == 0) { return false; }
        char c0 = path.CharAt(0);
        if (c0 == '/' || c0 == '\\') { return true; }
        // Windows 盘符根：字母 + ':'（C:\、D:/、E:foo）
        if (path.Length >= 2 && path.CharAt(1) == ':'
            && ((c0 >= 'A' && c0 <= 'Z') || (c0 >= 'a' && c0 <= 'z'))) {
            return true;
        }
        return false;
    }

    // 拼接两段路径。如果 b 是绝对路径（Unix `/` 或 Windows 根）则替换 a；
    // 否则用 `/` 分隔（a 已有尾随 `/` 或 `\` 时不重复）。
    public static string Join(string a, string b) {
        if (b.Length == 0) return a;
        if (Path.IsRooted(b)) return b;
        if (a.Length == 0) return b;
        char last = a.CharAt(a.Length - 1);
        if (last == '/' || last == '\\') return a + b;
        return a + "/" + b;
    }

    // 返回路径最后一段（filename）。末尾 `/` 视为目录分隔符，被跳过。
    // 路径全是 `/` 时返回 ""。
    public static string GetFileName(string path) {
        int n = path.Length;
        if (n == 0) return "";
        int end = n;
        while (end > 0 && path.CharAt(end - 1) == '/') {
            end = end - 1;
        }
        if (end == 0) return "";
        int start = end;
        while (start > 0 && path.CharAt(start - 1) != '/') {
            start = start - 1;
        }
        return Path.Slice(path, start, end);
    }

    // 返回 filename 中最后一个 `.` 之后的部分（不含 `.`）。
    // ".bashrc" / "foo" / "" → ""（leading dot 不算扩展名）
    public static string GetExtension(string path) {
        string name = Path.GetFileName(path);
        int n = name.Length;
        int dot = -1;
        for (int i = n - 1; i > 0; i = i - 1) {
            if (name.CharAt(i) == '.') {
                dot = i;
                break;
            }
        }
        if (dot < 0) return "";
        return Path.Slice(name, dot + 1, n);
    }

    // 返回 filename 去除最后扩展名（保留 leading dot 的整体名）。
    public static string GetFileNameWithoutExtension(string path) {
        string name = Path.GetFileName(path);
        int n = name.Length;
        int dot = -1;
        for (int i = n - 1; i > 0; i = i - 1) {
            if (name.CharAt(i) == '.') {
                dot = i;
                break;
            }
        }
        if (dot < 0) return name;
        return Path.Slice(name, 0, dot);
    }

    // 返回路径父目录。无 `/` 时返回 ""；以 `/` 开头时根目录返回 "/"。
    public static string GetDirectoryName(string path) {
        int n = path.Length;
        if (n == 0) return "";
        int end = n;
        while (end > 0 && path.CharAt(end - 1) == '/') {
            end = end - 1;
        }
        if (end == 0) return "";
        int sep = end - 1;
        while (sep >= 0 && path.CharAt(sep) != '/') {
            sep = sep - 1;
        }
        if (sep < 0) return "";
        int dirEnd = sep;
        while (dirEnd > 0 && path.CharAt(dirEnd - 1) == '/') {
            dirEnd = dirEnd - 1;
        }
        if (dirEnd == 0) return "/";
        return Path.Slice(path, 0, dirEnd);
    }

    // extend-z42-io-glob-temp (2026-05-16)：Glob 匹配。
    //
    // 直接子项（不递归）。pattern 支持 `*`（任意序列）和 `?`（单字符），
    // 大小写敏感。pattern 不应含 `/`。返回 sorted 全路径数组。
    //
    // 示例：
    //   Path.Glob("/tmp/build", "*.zpkg")  → ["/tmp/build/a.zpkg", "/tmp/build/b.zpkg"]
    //   Path.Glob("/tmp/build", "z42.?")   → ["/tmp/build/z42.a", "/tmp/build/z42.b"]
    //
    // 递归 glob（`**`）留 follow-up；当前用 `Directory.EnumerateRecursive` +
    // 调用方 filter 等价。
    [Native("__path_glob")]
    public static extern string[] Glob(string dir, string pattern);

    // add-z42-io-ergonomics-bytes-glob (2026-05-27): 递归 glob 便利方法。
    //
    // 在 `dir` 下递归找所有匹配 `pattern` 的文件，返回**绝对路径**排序数组。
    // pattern 支持：
    //   - `*` 匹配除 `/` 外任意字符序列
    //   - `?` 匹配单字符
    //   - 不带 `/` 时只匹配 basename（如 `*.z42` = 所有 .z42 文件）
    //   - 带 `/` 时匹配相对 dir 的完整子路径（如 `tests/*.z42` = 名为
    //     tests 的子目录下的 .z42 文件）
    //
    // 示例：
    //   GlobRecursive("src/libraries", "*.z42") → 所有 stdlib 源文件
    //   GlobRecursive("src/tests", "source.z42") → 所有 golden test 入口
    //
    // 不支持 `**` 显式 wildcard —— 递归本身就是"全展开"，再加 `**` 语义重复。
    public static string[] GlobRecursive(string dir, string pattern) {
        if (!Directory.Exists(dir)) return new string[0];
        string[] rels = Directory.EnumerateRecursive(dir);
        // First pass: count matches
        int n = 0;
        bool patternHasSlash = _containsChar(pattern, '/');
        int i = 0;
        while (i < rels.Length) {
            if (_matchesGlob(rels[i], pattern, patternHasSlash)) {
                n = n + 1;
            }
            i = i + 1;
        }
        // Second pass: collect absolute paths
        string[] hits = new string[n];
        int j = 0;
        i = 0;
        while (i < rels.Length) {
            if (_matchesGlob(rels[i], pattern, patternHasSlash)) {
                hits[j] = Path.Join(dir, rels[i]);
                j = j + 1;
            }
            i = i + 1;
        }
        // Sort for determinism (EnumerateRecursive order is OS-dependent
        // per .claude/rules/common-pitfalls.md §1).
        _sortStrings(hits);
        return hits;
    }

    // Glob matcher: pattern over either full relative path or just basename.
    static bool _matchesGlob(string rel, string pattern, bool patternHasSlash) {
        string target;
        if (patternHasSlash) {
            target = rel;
        } else {
            target = Path.GetFileName(rel);
        }
        return _globMatch(target, 0, pattern, 0);
    }

    // Recursive glob match — `*` matches any (except `/` would, but we
    // already split). `?` matches one char. Simple backtracking suffices
    // for stdlib script-level use; not a hot path.
    static bool _globMatch(string s, int si, string p, int pi) {
        while (pi < p.Length) {
            char pc = p.CharAt(pi);
            if (pc == '*') {
                // Skip consecutive *s
                while (pi < p.Length && p.CharAt(pi) == '*') {
                    pi = pi + 1;
                }
                if (pi == p.Length) return true;  // trailing * matches anything
                // Try every possible position for `s[si..]` to start the
                // remaining pattern.
                while (si <= s.Length) {
                    if (_globMatch(s, si, p, pi)) return true;
                    si = si + 1;
                }
                return false;
            }
            if (si >= s.Length) return false;
            char sc = s.CharAt(si);
            if (pc == '?') {
                si = si + 1; pi = pi + 1; continue;
            }
            if (pc != sc) return false;
            si = si + 1; pi = pi + 1;
        }
        return si == s.Length;
    }

    static bool _containsChar(string s, char c) {
        int i = 0;
        while (i < s.Length) {
            if (s.CharAt(i) == c) return true;
            i = i + 1;
        }
        return false;
    }

    // Simple insertion sort (z42.collections has no public Sort yet;
    // glob result sets are small — typical < 200 paths).
    static void _sortStrings(string[] arr) {
        int i = 1;
        while (i < arr.Length) {
            string key = arr[i];
            int j = i - 1;
            while (j >= 0 && _strLess(key, arr[j])) {
                arr[j + 1] = arr[j];
                j = j - 1;
            }
            arr[j + 1] = key;
            i = i + 1;
        }
    }

    static bool _strLess(string a, string b) {
        return a.CompareTo(b) < 0;
    }

    // 内部 helper：切片 [start, end)。
    static string Slice(string s, int start, int end) {
        int len = end - start;
        char[] chars = new char[len];
        for (int i = 0; i < len; i = i + 1) {
            chars[i] = s.CharAt(start + i);
        }
        return String.FromChars(chars);
    }
}
