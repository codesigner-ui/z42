namespace Std.IO;

using Std;
using Std.Text;

// add-console-ansi-color (2026-06-01): ANSI SGR (Select Graphic
// Rendition) helpers for terminal output. Each wrapper produces
// `ESC [ <code> m … ESC [ 0 m` when enabled, or returns the input
// string unchanged when not. Auto-detect at first use:
// `Console.IsTerminal()` AND the `NO_COLOR` env var is not set
// (no-color.org convention). Callers can override with `SetEnabled`.
//
// Usage:
//     Console.WriteLine(Ansi.Red("error: file not found"));
//     Console.WriteLine(Ansi.BrightGreen("ok"));
//     Console.WriteLine(Ansi.Bold(Ansi.Yellow("WARN")));
//
// Composition is nesting-safe: terminals interpret repeated `ESC[0m`
// resets as no-ops after the first.
public static class Ansi {
    // Lazy-init flags. `_detected` is true after the first auto-detect
    // run. `_manual` is true after any explicit `SetEnabled` call —
    // once manual, auto-detect is bypassed for the life of the process.
    private static bool _detected = false;
    private static bool _manual   = false;
    private static bool _enabled  = false;

    // Cached escape strings — built once on first use to avoid
    // rebuilding the `char[]` → string each wrap call.
    private static string _csi   = "";   // "ESC ["
    private static string _reset = "";   // "ESC [ 0 m"
    private static bool   _cached = false;

    /// True iff colour output is enabled for this run.
    ///
    /// First call performs auto-detect:
    ///   `Console.IsTerminal()` AND `NO_COLOR` env var unset/empty
    /// Subsequent calls return the cached / manually-set value.
    public static bool Enabled() {
        if (Ansi._manual) { return Ansi._enabled; }
        if (Ansi._detected) { return Ansi._enabled; }
        bool tty = Console.IsTerminal();
        string? noColor = Environment.GetEnvironmentVariable("NO_COLOR");
        bool noColorSet = (noColor != null && noColor.Length > 0);
        Ansi._enabled = (tty && !noColorSet);
        Ansi._detected = true;
        return Ansi._enabled;
    }

    /// Explicit override — bypasses TTY / NO_COLOR auto-detect.
    /// Useful for scripts that want unconditional colour (piped into
    /// `less -R`) or unconditional disable (CI logs with parsers
    /// that choke on escape codes).
    public static void SetEnabled(bool b) {
        Ansi._manual = true;
        Ansi._enabled = b;
    }

    // ── Foreground colours (codes 30–37) ─────────────────────────────
    public static string Black  (string s) { return Ansi._Wrap(30, s); }
    public static string Red    (string s) { return Ansi._Wrap(31, s); }
    public static string Green  (string s) { return Ansi._Wrap(32, s); }
    public static string Yellow (string s) { return Ansi._Wrap(33, s); }
    public static string Blue   (string s) { return Ansi._Wrap(34, s); }
    public static string Magenta(string s) { return Ansi._Wrap(35, s); }
    public static string Cyan   (string s) { return Ansi._Wrap(36, s); }
    public static string White  (string s) { return Ansi._Wrap(37, s); }

    // ── Bright foreground (codes 90–97) ──────────────────────────────
    public static string BrightBlack  (string s) { return Ansi._Wrap(90, s); }
    public static string BrightRed    (string s) { return Ansi._Wrap(91, s); }
    public static string BrightGreen  (string s) { return Ansi._Wrap(92, s); }
    public static string BrightYellow (string s) { return Ansi._Wrap(93, s); }
    public static string BrightBlue   (string s) { return Ansi._Wrap(94, s); }
    public static string BrightMagenta(string s) { return Ansi._Wrap(95, s); }
    public static string BrightCyan   (string s) { return Ansi._Wrap(96, s); }
    public static string BrightWhite  (string s) { return Ansi._Wrap(97, s); }

    // ── Styles (codes 1 / 2 / 3 / 4 / 7) ─────────────────────────────
    public static string Bold     (string s) { return Ansi._Wrap(1, s); }
    public static string Dim      (string s) { return Ansi._Wrap(2, s); }
    public static string Italic   (string s) { return Ansi._Wrap(3, s); }
    public static string Underline(string s) { return Ansi._Wrap(4, s); }
    public static string Reverse  (string s) { return Ansi._Wrap(7, s); }

    /// Strip ANSI CSI escape sequences (`ESC [ … <final-byte>`) from
    /// `s`. Useful when a caller needs to compute the display width
    /// of a coloured string or write a copy to a log without colour.
    ///
    /// Removes any sequence starting with `ESC [` and ending at the
    /// next byte in the CSI final-byte range `0x40 .. 0x7E`. SGR codes
    /// (`m`) are the common case; cursor-move codes (`H`, `J`, `K`)
    /// and others also stripped.
    public static string Strip(string s) {
        StringBuilder sb = new StringBuilder();
        char esc = (char)0x1B;
        int i = 0;
        int n = s.Length;
        while (i < n) {
            char c = s.CharAt(i);
            if (c == esc && i + 1 < n && s.CharAt(i + 1) == '[') {
                // Scan past parameters / intermediates to a final byte.
                int j = i + 2;
                while (j < n) {
                    char f = s.CharAt(j);
                    if (f >= (char)0x40 && f <= (char)0x7E) { break; }
                    j = j + 1;
                }
                // Skip the whole CSI sequence including the final byte.
                if (j < n) { i = j + 1; } else { i = n; }
            } else {
                char[] one = new char[1];
                one[0] = c;
                sb.Append(String.FromChars(one));
                i = i + 1;
            }
        }
        return sb.ToString();
    }

    // ── Internals ────────────────────────────────────────────────────

    private static void _BuildCache() {
        if (Ansi._cached) { return; }
        char[] escArr = new char[1];
        escArr[0] = (char)0x1B;
        string esc = String.FromChars(escArr);
        Ansi._csi   = esc + "[";
        Ansi._reset = esc + "[0m";
        Ansi._cached = true;
    }

    private static string _Wrap(int code, string s) {
        if (!Ansi.Enabled()) { return s; }
        Ansi._BuildCache();
        return Ansi._csi + code.ToString() + "m" + s + Ansi._reset;
    }
}
