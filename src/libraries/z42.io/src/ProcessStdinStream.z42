namespace Std.IO;

using Std;

// add-process-stream-stdio (2026-05-24): write-only Std.IO.Stream
// wrapper over a live ProcessHandle's stdin pipe.
//
// Owned by the ProcessHandle that produced it — `Close()` closes the
// child's stdin (so the child sees EOF) but does NOT dispose the
// handle. Caller still must `handle.Wait()` (or `Dispose()`) to reap
// the child.
//
// Construction failure: if the underlying handle was spawned without
// `Stdin(Stdio.Pipe())` the writer is `None` on the Native side and
// the first Write will surface `ProcessHandleInvalidException` via
// the existing `__process_handle_write_stdin` handle-invalid path.
// Cheap defensive check before the FFI roundtrip: callers can
// inspect `CanWrite()` (always true until `Close()`).

public class ProcessStdinStream : Stream {
    private ProcessHandle _handle;
    private bool          _closed;

    public ProcessStdinStream(ProcessHandle handle) {
        this._handle = handle;
        this._closed = false;
    }

    // ── Capability ───────────────────────────────────────────────────────

    public override bool CanWrite() { return !this._closed; }
    public override bool CanRead()  { return false; }
    public override bool CanSeek()  { return false; }

    // ── Write ────────────────────────────────────────────────────────────

    public override void Write(byte[] buffer, int offset, int count) {
        if (this._closed) {
            throw new InvalidOperationException("ProcessStdinStream: stream is closed");
        }
        if (offset < 0 || count < 0 || offset + count > buffer.Length) {
            throw new ArgumentException("Write: buffer / offset / count out of range");
        }
        if (count == 0) { return; }
        // Slice into a tight byte[] so the FFI sees exactly the
        // payload (existing __process_handle_write_stdin takes a
        // whole-array, no offset/count). Future: extend FFI to
        // accept slice params — minor optimisation, deferred.
        byte[] chunk;
        if (offset == 0 && count == buffer.Length) {
            chunk = buffer;
        } else {
            chunk = new byte[count];
            int i = 0;
            while (i < count) {
                chunk[i] = buffer[offset + i];
                i = i + 1;
            }
        }
        this._handle.WriteStdin(chunk);
    }

    // ── Flush / Close ────────────────────────────────────────────────────

    public override void Flush() {
        // OS pipe writes are unbuffered on our side — `WriteStdin`
        // already called `write_all` synchronously. No-op.
    }

    public override void Close() {
        if (this._closed) { return; }
        this._closed = true;
        this._handle.CloseStdin();
    }
}
