// add-reflection-mvp (2026-06-08): read-only reflection over GetType().
// Covers Type handle → GetFields/GetMethods/BaseType/GetGenericArguments and
// the Std.Reflection.{FieldInfo,MethodInfo,ParameterInfo} member objects.
namespace Z42CoreReflectionTests;

using Std;
using Std.Test;
using Std.Reflection;

class Base {
    public int a;
}

class Derived : Base {
    public int b;

    public int Add(int x, int y) {
        return x + y;
    }

    public static int Helper() {
        return 42;
    }
}

class Box<T> {
    public T value;
}

// add-reflection-properties: GetProperties() derives PropertyInfo from the
// get_/set_ accessor convention.
class PropHolder {
    public int Size { get; set; }   // read-write → get_Size + set_Size
    public string Tag { get; }      // read-only  → get_Tag only
}

class PropChild : PropHolder {
    public bool Active { get; set; }
}

// add-reflection-type-flags: Type.IsAbstract / IsSealed reflect class modifiers.
abstract class AbstractThing {
    public int n;
}

sealed class SealedThing {
    public int n;
}

// add-reflection-value-record-flags: struct → IsValueType, record → IsRecord.
struct ValueThing {
    public int v;
}

record RecordThing(int a, int b);

// add-reflection-static-fields: GetFields() includes static fields + IsStatic.
class FieldHolder {
    public int instanceVal;
    public static int staticVal;
}

// add-field-attribute-reflection: field-level user attributes.
class FieldTag : Attribute {   // unqualified (via `using Std`) — qualified `Std.Attribute` base trips a typechecker FQN-upcast gap, see reflection.md Deferred
    public string Note;
    public FieldTag(string note) { this.Note = note; }
}

class TaggedFields {
    [FieldTag("hot")] public int marked;
    public int unmarked;
}

// add-parameter-attribute-reflection: parameter-level user attributes.
class TaggedParams {
    public void Op([FieldTag("first")] int a, int b, [FieldTag("third")] string c) { }
}

[Test]
void test_gettype_name_and_fullname() {
    Derived d = new Derived();
    Type t = d.GetType();
    Assert.Equal("Derived", t.Name);
    Assert.Equal("Z42CoreReflectionTests.Derived", t.FullName);
}

// align-type-memberinfo-hierarchy: Type : MemberInfo.
[Test]
void test_type_is_memberinfo() {
    Type t = typeof(Derived);
    Assert.True(t is MemberInfo);
    // Name resolves via the inherited MemberInfo field (no native getter)
    MemberInfo m = t;
    Assert.Equal("Derived", m.Name);
    Assert.Equal("Derived", t.Name);
    // GetType() instances are MemberInfo too
    Derived d = new Derived();
    Assert.True(d.GetType() is MemberInfo);
}

[Test]
void test_getfields_includes_inherited() {
    Derived d = new Derived();
    FieldInfo[] fields = d.GetType().GetFields();
    bool hasA = false;
    bool hasB = false;
    foreach (var f in fields) {
        if (f.Name == "a") { hasA = true; }
        if (f.Name == "b") { hasB = true; }
    }
    Assert.True(hasA);
    Assert.True(hasB);
}

[Test]
void test_field_type_is_type_object() {
    Derived d = new Derived();
    foreach (var f in d.GetType().GetFields()) {
        if (f.Name == "a") {
            Type ft = f.FieldType;
            Assert.Equal("int", ft.Name);
        }
    }
}

[Test]
void test_basetype() {
    Derived d = new Derived();
    Type t = d.GetType();
    Type bt = t.BaseType;
    Assert.Equal("Base", bt.Name);
}

[Test]
void test_getmethods_add_signature() {
    Derived d = new Derived();
    bool hasAdd = false;
    foreach (var m in d.GetType().GetMethods()) {
        if (m.Name == "Add") {
            hasAdd = true;
            Type rt = m.ReturnType;
            Assert.Equal("int", rt.Name);
            Assert.Equal(2, m.GetParameters().Length);
        }
    }
    Assert.True(hasAdd);
}

[Test]
void test_method_is_static_flag() {
    Derived d = new Derived();
    foreach (var m in d.GetType().GetMethods()) {
        if (m.Name == "Helper") { Assert.True(m.IsStatic); }
        if (m.Name == "Add") { Assert.False(m.IsStatic); }
    }
}

[Test]
void test_getmembers_combines_fields_and_methods() {
    Derived d = new Derived();
    MemberInfo[] members = d.GetType().GetMembers();
    // At least: fields a, b + methods Add, Helper (plus inherited Object methods).
    Assert.True(members.Length >= 4);
}

[Test]
void test_generic_arguments_best_effort() {
    Box<int> box = new Box<int>();
    Type[] args = box.GetType().GetGenericArguments();
    // Monomorphized TypeDesc carries type_args; when present, the first is int.
    // (Best-effort for MVP — see reflection.md.)
    if (args.Length == 1) {
        Assert.Equal("int", args[0].Name);
    }
}

[Test]
void test_getproperties_readwrite() {
    Type t = typeof(PropHolder);
    PropertyInfo[] props = t.GetProperties();
    bool found = false;
    foreach (var p in props) {
        if (p.Name == "Size") {
            found = true;
            Assert.True(p.CanRead);
            Assert.True(p.CanWrite);
            Type pt = p.PropertyType;   // local receiver (chained-getter footgun)
            Assert.Equal("int", pt.Name);
        }
    }
    Assert.True(found);
}

[Test]
void test_getproperties_readonly() {
    Type t = typeof(PropHolder);
    PropertyInfo[] props = t.GetProperties();
    bool found = false;
    foreach (var p in props) {
        if (p.Name == "Tag") {
            found = true;
            Assert.True(p.CanRead);
            Assert.False(p.CanWrite);
            Type pt = p.PropertyType;
            Assert.Equal("string", pt.Name);
        }
    }
    Assert.True(found);
}

[Test]
void test_getproperties_includes_inherited() {
    Type t = typeof(PropChild);
    PropertyInfo[] props = t.GetProperties();
    bool hasInheritedSize = false;
    bool hasOwnActive = false;
    foreach (var p in props) {
        if (p.Name == "Size") { hasInheritedSize = true; }
        if (p.Name == "Active") { hasOwnActive = true; }
    }
    Assert.True(hasInheritedSize);
    Assert.True(hasOwnActive);
}

[Test]
void test_getproperties_empty_for_no_props() {
    // Base declares only a field (no get_/set_) → no properties.
    Type t = typeof(Base);
    PropertyInfo[] props = t.GetProperties();
    Assert.Equal(0, props.Length);
}

[Test]
void test_type_is_abstract() {
    Type ta = typeof(AbstractThing);
    Assert.True(ta.IsAbstract);
    Assert.False(ta.IsSealed);
    Type tp = typeof(Base);    // plain class
    Assert.False(tp.IsAbstract);
}

[Test]
void test_type_is_sealed() {
    Type ts = typeof(SealedThing);
    Assert.True(ts.IsSealed);
    Assert.False(ts.IsAbstract);
}

[Test]
void test_type_is_value_type() {
    Type tv = typeof(ValueThing);
    Assert.True(tv.IsValueType);
    Assert.False(tv.IsRecord);
    Type tc = typeof(Base);   // plain class
    Assert.False(tc.IsValueType);
}

[Test]
void test_type_is_record() {
    Type tr = typeof(RecordThing);
    Assert.True(tr.IsRecord);
    Assert.False(tr.IsValueType);
}

[Test]
void test_getfields_includes_static() {
    Type t = typeof(FieldHolder);
    FieldInfo[] fields = t.GetFields();
    bool sawInstance = false;
    bool sawStatic = false;
    foreach (var f in fields) {
        if (f.Name == "instanceVal") { sawInstance = true; Assert.False(f.IsStatic); }
        if (f.Name == "staticVal") { sawStatic = true; Assert.True(f.IsStatic); }
    }
    Assert.True(sawInstance);
    Assert.True(sawStatic);
}

[Test]
void test_field_custom_attributes() {
    Type t = typeof(TaggedFields);
    FieldInfo[] fields = t.GetFields();
    bool checkedMarked = false;
    foreach (var f in fields) {
        if (f.Name == "marked") {
            checkedMarked = true;
            Std.Attribute[] attrs = f.GetCustomAttributes();
            Assert.Equal(1, attrs.Length);
            FieldTag tag = (FieldTag) f.GetAttribute(typeof(FieldTag));
            Assert.Equal("hot", tag.Note);
        }
        if (f.Name == "unmarked") {
            Std.Attribute[] noneAttrs = f.GetCustomAttributes();
            Assert.Equal(0, noneAttrs.Length);
        }
    }
    Assert.True(checkedMarked);
}

[Test]
void test_param_custom_attributes() {
    Type t = typeof(TaggedParams);
    MethodInfo[] methods = t.GetMethods();
    bool checkedOp = false;
    foreach (var m in methods) {
        if (m.Name == "Op") {
            checkedOp = true;
            ParameterInfo[] ps = m.GetParameters();
            Assert.Equal(3, ps.Length);

            // param 0 (a): [FieldTag("first")]
            Std.Attribute[] a0 = ps[0].GetCustomAttributes();
            Assert.Equal(1, a0.Length);
            FieldTag g0 = (FieldTag) ps[0].GetAttribute(typeof(FieldTag));
            Assert.Equal("first", g0.Note);

            // param 1 (b): none
            Assert.Equal(0, ps[1].GetCustomAttributes().Length);

            // param 2 (c): [FieldTag("third")]
            FieldTag g2 = (FieldTag) ps[2].GetAttribute(typeof(FieldTag));
            Assert.Equal("third", g2.Note);
        }
    }
    Assert.True(checkedOp);
}
