namespace z42.core;

// Type conversion helpers.
// Native bindings delegate to VM intrinsics.
public static class Convert {
    [Native("__int_parse")]
    public static extern int ToInt32(string s);

    [Native("__long_parse")]
    public static extern long ToInt64(string s);

    [Native("__double_parse")]
    public static extern double ToDouble(string s);

    [Native("__to_str")]
    public static extern string ToString(object value);
}
