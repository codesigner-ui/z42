namespace Std;

// 2026-05-03 fix-delegate-reference-equality (D-5)：delegate 引用相等 API。
//
// z42 类型系统中 `Action<T>` / `Func<T,R>` / `Predicate<T>` 等 delegate
// 类型在运行时是 `Z42FuncType` 值（VM `Value::FuncRef` / `Value::Closure`
// / `Value::StackClosure`）。本类暴露 reference equality 判断，用于
// `MulticastAction.Unsubscribe(handler)` 等 by-handler 场景以及未来
// `event` 关键字 `-=` desugar。
//
// 三个 Value 变体按各自身份语义比较：
//   FuncRef(name)            —— fn name 字符串相等
//   Closure(env, fn_name)    —— fn_name 相等 + env GC ptr_eq
//   StackClosure(idx, name)  —— fn_name 相等 + env_idx 相等
// 跨变体不等；非 delegate 值返回 false 不报错。
//
// 命名独立于 `Std.Object` —— SymbolTable.cs:111 跳过 Object 跨 CU 导出
// （synthetic stub），其他 stdlib 文件无法 `Object.X` 调用 static 方法。
public static class DelegateOps {
    [Native("__delegate_eq")]
    public static extern bool ReferenceEquals(object a, object b);

    // 2026-05-04 D-1b：从 delegate 提取 captured target（receiver 对象）。
    // 用于 `Std.WeakRef<TD>` 在 ctor 时拿到 target 后做 `WeakHandle.MakeWeak`。
    //
    // - Closure with env=[obj, ...] where obj is Object/Array → 返回 obj
    // - Closure with env=[] / env[0] 非 Object → null
    // - StackClosure / FuncRef / 非 delegate → null（lenient）
    [Native("__delegate_target")]
    public static extern object GetTarget(object delegateValue);

    // 2026-05-04 D-1b：提取 delegate 的 fn_name（thunk 函数全限定名）。
    // 与 GetTarget + MakeClosure 配套：WeakRef 不强持原 handler（那会反向锁住
    // receiver，weak 无效），而是存 (WeakHandle, fnName)，Get 时重建 Closure。
    [Native("__delegate_fn_name")]
    public static extern string GetFnName(object delegateValue);

    // 2026-05-04 D-1b：用 fn_name + env 数组重建 Closure。
    // env[0] 通常是 receiver 对象（与 instance method group conversion 的
    // thunk 协议一致：reg 0 = env，env[0] = receiver）。
    [Native("__make_closure")]
    public static extern object MakeClosure(string fnName, object[] env);
}
