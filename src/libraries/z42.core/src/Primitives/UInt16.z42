namespace Std;

// rename-primitives-to-pascal-case (2026-05-24): primitive struct now named
// `UInt16` per BCL convention; source keyword `u16` is preserved as alias.
//
// add-narrow-int-primitives (2026-05-15): `u16` / `ushort` (unsigned 16-bit,
// 0..=65535). Underlying runtime Value is i64; Parse range-checks input.
// Equals / GetHashCode / ToString share `__int32_*` builtins (Value::I64 storage).
public struct UInt16 : IComparable<u16>, IEquatable<u16>, INumber<u16> {
    [Native("__uint16_parse")]     public static extern u16 Parse(string s);
    [Native("__int32_equals")]     public extern bool Equals(u16 other);
    [Native("__int32_hash_code")]  public extern int GetHashCode();
    [Native("__int32_to_string")]  public extern string ToString();

    public int CompareTo(u16 other) {
        if (this < other) return -1;
        if (this > other) return 1;
        return 0;
    }

    public static override u16 op_Add(u16 a, u16 b)      { return (u16)(a + b); }
    public static override u16 op_Subtract(u16 a, u16 b) { return (u16)(a - b); }
    public static override u16 op_Multiply(u16 a, u16 b) { return (u16)(a * b); }
    public static override u16 op_Divide(u16 a, u16 b)   { return (u16)(a / b); }
    public static override u16 op_Modulo(u16 a, u16 b)   { return (u16)(a % b); }
}
