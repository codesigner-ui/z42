namespace Std;

// rename-primitives-to-pascal-case (2026-05-24): primitive struct now named
// `Byte` per BCL convention; source keyword `u8` is preserved as alias.
//
// add-narrow-int-primitives (2026-05-15): `u8` / `byte` (unsigned 8-bit,
// 0..=255). Underlying runtime Value is i64; Parse range-checks input.
// Equals / GetHashCode / ToString share `__int32_*` builtins (Value::I64 storage).
public struct Byte : IComparable<u8>, IEquatable<u8>, INumber<u8> {
    [Native("__byte_parse")]       public static extern u8 Parse(string s);
    [Native("__int32_equals")]     public extern bool Equals(u8 other);
    [Native("__int32_hash_code")]  public extern int GetHashCode();
    [Native("__int32_to_string")]  public extern string ToString();

    public int CompareTo(u8 other) {
        if (this < other) return -1;
        if (this > other) return 1;
        return 0;
    }

    public static override u8 op_Add(u8 a, u8 b)      { return (u8)(a + b); }
    public static override u8 op_Subtract(u8 a, u8 b) { return (u8)(a - b); }
    public static override u8 op_Multiply(u8 a, u8 b) { return (u8)(a * b); }
    public static override u8 op_Divide(u8 a, u8 b)   { return (u8)(a / b); }
    public static override u8 op_Modulo(u8 a, u8 b)   { return (u8)(a % b); }
}
