namespace Std;

// 2026-05-04 expose-weak-ref-builtin (D-1a):
// 不透明弱引用句柄。GC 不持目标的强引用 —— 当所有强引用 dropped 后，
// 目标可被回收，此时 Upgrade() 返回 null。
//
// 原子值（int / string / bool / FuncRef / Closure / Null 等）不可弱化 ——
// MakeWeak 返回 null。
//
// 用户视角：
//     var weak = WeakHandle.MakeWeak(target);
//     if (weak != null) {
//         var alive = WeakHandle.Upgrade(weak);
//         if (alive != null) { /* still alive */ }
//     }
//
// `Std.WeakRef<TD>` ISubscription wrapper（包装 delegate 的 .Target）留
// D-1b follow-up；本类是底层原料。
public class WeakHandle {
    [Native("__obj_make_weak")]
    public static extern WeakHandle MakeWeak(object target);

    [Native("__obj_upgrade_weak")]
    public static extern object Upgrade(WeakHandle handle);
}
