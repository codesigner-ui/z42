namespace Std;

// 数值运算结果超出目标类型容量。典型场景：
//   - `BigInt.ToInt32()` 当值超出 i32 范围
//   - `Int32.Parse(...)` 数字过大
//   - checked arithmetic 溢出
// 镜像 .NET BCL `System.OverflowException`。
public class OverflowException : Exception {
    public OverflowException(string message) : base(message) {}

    override string ToString() {
        return "OverflowException: " + this.Message;
    }
}
