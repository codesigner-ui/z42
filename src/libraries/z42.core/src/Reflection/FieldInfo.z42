namespace Std.Reflection;

// Reflected field. Populated by `Type.GetFields()` (`__type_fields`).
// Mirrors C# `System.Reflection.FieldInfo` (read-only subset).
public class FieldInfo : MemberInfo {
    // The field's declared type, e.g. typeof(int). Written by the VM.
    public Std.Type FieldType;

    // True for static fields, false for instance. (add-reflection-static-fields)
    public bool IsStatic;
}
