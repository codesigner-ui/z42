namespace Std.Reflection;

// Reflected field. Populated by `Type.GetFields()` (`__type_fields`).
// Mirrors C# `System.Reflection.FieldInfo` (read-only subset).
public class FieldInfo : MemberInfo {
    // The field's declared type, e.g. typeof(int). Written by the VM.
    public Std.Type FieldType;

    // True for static fields, false for instance. (add-reflection-static-fields)
    public bool IsStatic;

    // ── Custom attributes (add-field-attribute-reflection) ──────────────────

    // Qualified field name (VM-written, "<Class>.<Field>"), used to resolve
    // this field's attribute factories.
    public string __qualified;

    // Cached attribute instances (see Type.GetCustomAttributes for rationale).
    public Std.Attribute[] __attrCache;

    [Native("__field_custom_attributes")]
    public extern Std.Attribute[] __customAttributes(string qualified);

    // User attributes applied to this field, as live instances. Cached.
    public Std.Attribute[] GetCustomAttributes() {
        if (this.__attrCache != null) {
            return this.__attrCache;
        }
        this.__attrCache = this.__customAttributes(this.__qualified);
        return this.__attrCache;
    }

    // The single attribute of the given type, or null if absent. Compares by
    // the instance's runtime type (FullName), so subclass attributes match too.
    public Std.Attribute GetAttribute(Std.Type attributeType) {
        Std.Attribute[] all = this.GetCustomAttributes();
        int i = 0;
        while (i < all.Length) {
            Std.Attribute a = all[i];
            Std.Type at = a.GetType();
            if (at.FullName == attributeType.FullName) {
                return a;
            }
            i = i + 1;
        }
        return null;
    }
}
