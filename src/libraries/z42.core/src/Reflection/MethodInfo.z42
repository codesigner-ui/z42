namespace Std.Reflection;

// Reflected method. Populated by `Type.GetMethods()` (`__type_methods`).
// Mirrors C# `System.Reflection.MethodInfo`. Non-generic `Invoke` lands 0.3.12
// (add-method-invoke-non-generic); generic-method Invoke waits on generic
// instantiation (0.4.x G).
public class MethodInfo : MemberInfo {
    // Return type, e.g. typeof(int) / typeof(void). Written by the VM.
    public Std.Type ReturnType;

    // True for static methods (no implicit `this`).
    public bool IsStatic;

    // True for virtual / inherited (vtable) methods.
    public bool IsVirtual;

    // Backing parameter array written by the VM; exposed via GetParameters().
    public ParameterInfo[] __parameters;

    // The method's parameters, in declaration order.
    public ParameterInfo[] GetParameters() {
        return this.__parameters;
    }

    // ── Custom attributes (C3b add-attribute-reflection-methods) ────────────

    // Qualified function name (VM-written), used to resolve this method's
    // attribute factories.
    public string __qualified;

    // Cached attribute instances (see Type.GetCustomAttributes for rationale).
    public Std.Attribute[] __attrCache;

    [Native("__method_custom_attributes")]
    public extern Std.Attribute[] __customAttributes(string qualified);

    // User attributes applied to this method, as live instances. Cached.
    public Std.Attribute[] GetCustomAttributes() {
        if (this.__attrCache != null) {
            return this.__attrCache;
        }
        this.__attrCache = this.__customAttributes(this.__qualified);
        return this.__attrCache;
    }

    // The single attribute of the given type, or null if absent. Compares by
    // the instance's runtime type (FullName), so subclass attributes match too.
    public Std.Attribute GetAttribute(Std.Type attributeType) {
        Std.Attribute[] all = this.GetCustomAttributes();
        int i = 0;
        while (i < all.Length) {
            Std.Attribute a = all[i];
            Std.Type at = a.GetType();
            if (at.FullName == attributeType.FullName) {
                return a;
            }
            i = i + 1;
        }
        return null;
    }

    // ── Reflective invocation (add-method-invoke-non-generic, 0.3.12) ───────
    // Invoke this method: `obj` is the receiver for instance methods (ignored —
    // pass null — for static methods); `args` map to the parameters in order.
    // Returns the method's return value (void → null). A `throw` inside the
    // invoked method propagates with its original type (catchable). Non-generic
    // only. The VM reads __qualified / IsStatic from this MethodInfo.
    [Native("__method_invoke")]
    public extern object Invoke(object obj, object[] args);
}
