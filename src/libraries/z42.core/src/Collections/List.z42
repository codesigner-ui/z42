namespace Std.Collections;

// `List<T>` — 纯源码级泛型动态数组（L3-G4h step 3：取代 pseudo-class 实现）。
//
// 摊还 O(1) Add / indexer，O(n) RemoveAt / Insert / Contains / IndexOf / Remove。
// Sort 为插入排序（O(n^2)，后续可升级为归并排序 / 快排）。
//
// 约束：
//   T: IEquatable<T>   —— 为 Contains / IndexOf / Remove 提供相等判定
//   T: IComparable<T>  —— 为 Sort 提供大小比较
// primitive 类型（int / long / double / char / string）通过 VM builtin 同时满足两个接口。
public class List<T> where T: IEquatable<T> + IComparable<T> {
    T[] items;
    public int Count;
    int capacity;

    public List() {
        this.capacity = 4;
        this.items = new T[4];
        this.Count = 0;
    }

    public bool IsEmpty() { return this.Count == 0; }

    public T this[int i] {
        get { return this.items[i]; }
        set { this.items[i] = value; }
    }

    public void Add(T item) {
        if (this.Count == this.capacity) this.Grow();
        this.items[this.Count] = item;
        this.Count = this.Count + 1;
    }

    public void Insert(int index, T item) {
        if (this.Count == this.capacity) this.Grow();
        int i = this.Count;
        while (i > index) {
            this.items[i] = this.items[i - 1];
            i = i - 1;
        }
        this.items[index] = item;
        this.Count = this.Count + 1;
    }

    public void RemoveAt(int index) {
        int i = index;
        while (i < this.Count - 1) {
            this.items[i] = this.items[i + 1];
            i = i + 1;
        }
        this.Count = this.Count - 1;
    }

    public bool Remove(T item) {
        int i = this.IndexOf(item);
        if (i < 0) return false;
        this.RemoveAt(i);
        return true;
    }

    public bool Contains(T item) { return this.IndexOf(item) >= 0; }

    public int IndexOf(T item) {
        int i = 0;
        while (i < this.Count) {
            if (this.items[i].Equals(item)) return i;
            i = i + 1;
        }
        return -1;
    }

    public void Clear() { this.Count = 0; }

    // Insertion sort — stable, in-place, O(n^2).
    public void Sort() {
        int i = 1;
        while (i < this.Count) {
            T v = this.items[i];
            int j = i - 1;
            while (j >= 0 && this.items[j].CompareTo(v) > 0) {
                this.items[j + 1] = this.items[j];
                j = j - 1;
            }
            this.items[j + 1] = v;
            i = i + 1;
        }
    }

    public void Reverse() {
        int i = 0;
        int j = this.Count - 1;
        while (i < j) {
            T tmp = this.items[i];
            this.items[i] = this.items[j];
            this.items[j] = tmp;
            i = i + 1;
            j = j - 1;
        }
    }

    public void Grow() {
        int newCap = this.capacity * 2;
        T[] bigger = new T[newCap];
        int i = 0;
        while (i < this.Count) {
            bigger[i] = this.items[i];
            i = i + 1;
        }
        this.items = bigger;
        this.capacity = newCap;
    }
}
