// add-uri-resolve (2026-05-27): RFC 3986 §5.3 reference resolution.
namespace Z42UriResolveTests;

using Std;
using Std.Test;
using Std.Uri;

[Test]
void test_resolve_dotdot_climbs_one_segment() {
    var b = Uri.Parse("http://a.com/x/y/z");
    Assert.Equal("http://a.com/x/w", Uri.Resolve(b, "../w").ToString());
}

[Test]
void test_resolve_relative_with_trailing_slash_base() {
    var b = Uri.Parse("http://a.com/x/");
    Assert.Equal("http://a.com/x/y", Uri.Resolve(b, "y").ToString());
}

[Test]
void test_resolve_relative_without_trailing_slash_replaces_last_segment() {
    var b = Uri.Parse("http://a.com/x/y");
    Assert.Equal("http://a.com/x/z", Uri.Resolve(b, "z").ToString());
}

[Test]
void test_resolve_absolute_path_replaces_path() {
    var b = Uri.Parse("http://a.com/x/y");
    Assert.Equal("http://a.com/z", Uri.Resolve(b, "/z").ToString());
}

[Test]
void test_resolve_protocol_relative_swaps_host() {
    var b = Uri.Parse("http://a.com/x");
    Assert.Equal("http://b.com/y", Uri.Resolve(b, "//b.com/y").ToString());
}

[Test]
void test_resolve_query_only_keeps_base_path() {
    var b = Uri.Parse("http://a.com/x");
    Assert.Equal("http://a.com/x?q=1", Uri.Resolve(b, "?q=1").ToString());
}

[Test]
void test_resolve_fragment_only_keeps_base_path_and_query() {
    var b = Uri.Parse("http://a.com/x?p=1");
    Assert.Equal("http://a.com/x?p=1#sec", Uri.Resolve(b, "#sec").ToString());
}

[Test]
void test_resolve_absolute_reference_passes_through() {
    var b = Uri.Parse("http://a.com/x");
    Assert.Equal("https://x.example/p", Uri.Resolve(b, "https://x.example/p").ToString());
}

[Test]
void test_resolve_empty_reference_strips_fragment() {
    var b = Uri.Parse("http://a.com/x#frag");
    // RFC says empty ref → base, but fragment is reset.
    Assert.Equal("http://a.com/x", Uri.Resolve(b, "").ToString());
}

[Test]
void test_resolve_multiple_dotdot_collapses() {
    var b = Uri.Parse("http://a.com/a/b/c/d");
    Assert.Equal("http://a.com/a/e", Uri.Resolve(b, "../../e").ToString());
}

[Test]
void test_resolve_dotdot_at_root_clamps() {
    // RFC says climbing past root is silently clamped.
    var b = Uri.Parse("http://a.com/x");
    Assert.Equal("http://a.com/y", Uri.Resolve(b, "../../y").ToString());
}

[Test]
void test_resolve_current_dir_dot_skipped() {
    var b = Uri.Parse("http://a.com/x/y");
    Assert.Equal("http://a.com/x/z", Uri.Resolve(b, "./z").ToString());
}

[Test]
void test_resolve_relative_preserves_scheme_and_authority() {
    var b = Uri.Parse("https://user:pass@host.com:8080/x");
    var r = Uri.Resolve(b, "/abs");
    Assert.Equal("https", r.GetScheme());
    Assert.Equal("host.com", r.GetHost());
    Assert.Equal(8080, r.GetPort());
    Assert.Equal("user:pass", r.GetUserInfo());
    Assert.Equal("/abs", r.GetPath());
}
