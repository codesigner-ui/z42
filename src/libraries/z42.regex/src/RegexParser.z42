namespace Std.Regex;
using Std;

// add-z42-regex (2026-05-16)：pattern string → RegexNode[] AST。
//
// 手写递归下降 parser，cursor 风格。Grammar:
//
//   pattern := alt
//   alt     := concat ('|' concat)*
//   concat  := quantified*
//   quantified := atom ('?' | '*' | '+' | '{' n '}' | '{' n ',' m? '}')?
//   atom    := '(' alt ')' | '[' charset ']' | '.' | '^' | '$' | escape | literal
//   escape  := '\' (metachar | 'n' | 't' | 'r' | 'd' | 'D' | 'w' | 'W' | 's' | 'S')
//
// 失败抛 `Std.RegexException`。capturing group 编号从 1 开始，按 '(' 出现顺序分配。
public class RegexParser {
    private string _src;
    private int _pos;
    private int _nextGroup;
    public int GroupCount;       // 解析完成后 = 已分配的 group 数（不含 group 0 = 整个 match）

    public RegexParser(string src) {
        this._src       = src;
        this._pos       = 0;
        this._nextGroup = 1;
        this.GroupCount = 0;
    }

    /// 入口：parse 完整 pattern，返回 RegexNode[] + 实际 count（通过 _resultCount 字段）。
    /// 调用方先 ParsePattern，再读 ResultNodes / ResultCount / GroupCount。
    public RegexNode[] ResultNodes;
    public int ResultCount;

    public void ParsePattern() {
        this.ParseAlt(false);
        if (this._pos < this._src.Length) {
            throw new RegexException("unexpected character '" + this.Peek().ToString() +
                "' at pos " + this._pos.ToString());
        }
        this.GroupCount = this._nextGroup - 1;
    }

    // 解析 alt 表达式；inGroup=true 时遇到 ')' 返回。结果写入 ResultNodes/ResultCount。
    private void ParseAlt(bool inGroup) {
        // _parseConcat 直接写 ResultNodes/ResultCount（z42 array reassignment 不
        // 跨方法调用栈传递 — pass-by-value 引用槽位；早期版本用 `buf` 参数 +
        // return count，结果 grow 后的新 array 丢在 callee local 里，导致大 pattern
        // 触发 array index OOB（fix-regex-parser-buffer-grow, 2026-05-16）。
        this.ParseConcat(inGroup);
        RegexNode[] leftBuf = this.ResultNodes;
        int leftN = this.ResultCount;
        if (this.Eof() || this.Peek() != '|') {
            // ResultNodes/Count already set by _parseConcat
            return;
        }
        // 有 '|' — 右折叠：alt = left | (rest_alt)
        this.Advance();
        this.ParseAlt(inGroup);
        RegexNode altNode = RegexNode.Alt(leftBuf, leftN, this.ResultNodes, this.ResultCount);
        RegexNode[] wrap = new RegexNode[1];
        wrap[0] = altNode;
        this.ResultNodes = wrap;
        this.ResultCount = 1;
    }

    // 解析 concat（无 '|'）：解析 atom+quant 直到 '|' / ')' / EOF。结果写入
    // this.ResultNodes / this.ResultCount（避免 grown buffer 跨调用栈丢失）。
    private void ParseConcat(bool inGroup) {
        RegexNode[] buf = new RegexNode[8];
        int n = 0;
        while (!this.Eof()) {
            char c = this.Peek();
            if (c == '|') { break; }
            if (inGroup && c == ')') { break; }
            RegexNode atom = this.ParseAtom();
            RegexNode quantified = this.MaybeWrapQuant(atom);
            if (n >= buf.Length) {
                buf = this.GrowNodes(buf, n);
            }
            buf[n] = quantified;
            n = n + 1;
        }
        this.ResultNodes = buf;
        this.ResultCount = n;
    }

    // 若 atom 后跟 quantifier，包装为 QUANT 节点。
    private RegexNode MaybeWrapQuant(RegexNode atom) {
        if (this.Eof()) { return atom; }
        char c = this.Peek();
        int min = 0;
        int max = 0;
        bool isQuant = false;
        if (c == '?') { min = 0; max =  1; isQuant = true; this.Advance(); }
        else if (c == '*') { min = 0; max = -1; isQuant = true; this.Advance(); }
        else if (c == '+') { min = 1; max = -1; isQuant = true; this.Advance(); }
        else if (c == '{') {
            this.Advance();
            int n = this.ParseInt();
            min = n;
            if (!this.Eof() && this.Peek() == ',') {
                this.Advance();
                if (!this.Eof() && this.Peek() == '}') {
                    max = -1;
                } else {
                    max = this.ParseInt();
                }
            } else {
                max = n;
            }
            if (this.Eof() || this.Peek() != '}') {
                throw new RegexException("expected '}' at pos " + this._pos.ToString());
            }
            this.Advance();
            isQuant = true;
        }
        if (!isQuant) { return atom; }
        // Non-greedy marker: `?` after a quantifier (`*?`, `+?`, `??`,
        // `{n,m}?`). add-regex-non-greedy (2026-05-26).
        bool greedy = true;
        if (!this.Eof() && this.Peek() == '?') {
            greedy = false;
            this.Advance();
        }
        RegexNode[] child = new RegexNode[1];
        child[0] = atom;
        if (greedy) {
            return RegexNode.Quant(child, 1, min, max);
        }
        return RegexNode.QuantLazy(child, 1, min, max);
    }

    private int ParseInt() {
        int start = this._pos;
        while (!this.Eof()) {
            char c = this.Peek();
            int cc = (int)c;
            if (cc < 48 || cc > 57) { break; }
            this.Advance();
        }
        if (this._pos == start) {
            throw new RegexException("expected digit at pos " + this._pos.ToString());
        }
        return int.Parse(this._src.Substring(start, this._pos - start));
    }

    private RegexNode ParseAtom() {
        char c = this.Peek();
        if (c == '(') {
            this.Advance();
            // Non-capturing group `(?:…)` — add-regex-non-capturing-group
            // (2026-05-26). Skip capture-index allocation; matcher detects
            // `_groupIndex == -1` and bypasses the slot write.
            bool nonCapturing = false;
            if (!this.Eof() && this.Peek() == '?') {
                int save = this._pos;
                this.Advance();
                if (!this.Eof() && this.Peek() == ':') {
                    this.Advance();
                    nonCapturing = true;
                } else {
                    // `(?` followed by something else — not a valid v0 atom;
                    // restore position and let the dispatch fall through to
                    // the normal error path below.
                    this._pos = save;
                    throw new RegexException("unsupported '(?…)' construct at pos " + this._pos.ToString());
                }
            }
            int idx;
            if (nonCapturing) {
                idx = -1;
            } else {
                idx = this._nextGroup;
                this._nextGroup = this._nextGroup + 1;
            }
            this.ParseAlt(true);
            RegexNode[] body = this.ResultNodes;
            int bodyN = this.ResultCount;
            if (this.Eof() || this.Peek() != ')') {
                throw new RegexException("expected ')' at pos " + this._pos.ToString());
            }
            this.Advance();
            return RegexNode.Group(body, bodyN, idx);
        }
        if (c == '[') {
            this.Advance();
            return this.ParseCharset();
        }
        if (c == '.') { this.Advance(); return RegexNode.Any(); }
        if (c == '^') { this.Advance(); return RegexNode.AnchorStart(); }
        if (c == '$') { this.Advance(); return RegexNode.AnchorEnd(); }
        if (c == '\\') {
            this.Advance();
            return this.ParseEscape();
        }
        if (c == ')' || c == '|' || c == '?' || c == '*' || c == '+' || c == '{' || c == '}') {
            throw new RegexException("unexpected '" + c.ToString() + "' at pos " + this._pos.ToString());
        }
        this.Advance();
        return RegexNode.Lit((int)c);
    }

    // 处理 `\d \D \w \W \s \S \n \t \r \\ \. \( \) \[ \] \{ \} \| \? \* \+ \^ \$`
    private RegexNode ParseEscape() {
        if (this.Eof()) {
            throw new RegexException("trailing backslash at end of pattern");
        }
        char e = this.Peek();
        this.Advance();
        if (e == 'n')  { return RegexNode.Lit(10); }
        if (e == 't')  { return RegexNode.Lit(9); }
        if (e == 'r')  { return RegexNode.Lit(13); }
        if (e == 'd' || e == 'D') {
            int[] s = new int[1]; int[] f = new int[1];
            s[0] = 48; f[0] = 57;  // 0-9
            return RegexNode.Charset(e == 'D', s, f, 1);
        }
        if (e == 'w' || e == 'W') {
            int[] s = new int[4]; int[] f = new int[4];
            s[0] = 48; f[0] = 57;   // 0-9
            s[1] = 65; f[1] = 90;   // A-Z
            s[2] = 97; f[2] = 122;  // a-z
            s[3] = 95; f[3] = 95;   // _
            return RegexNode.Charset(e == 'W', s, f, 4);
        }
        if (e == 's' || e == 'S') {
            int[] s = new int[4]; int[] f = new int[4];
            s[0] = 32; f[0] = 32;   // space
            s[1] = 9;  f[1] = 9;    // tab
            s[2] = 10; f[2] = 10;   // \n
            s[3] = 13; f[3] = 13;   // \r
            return RegexNode.Charset(e == 'S', s, f, 4);
        }
        // metachar literal escape：\. \\ \* 等
        return RegexNode.Lit((int)e);
    }

    private RegexNode ParseCharset() {
        bool negated = false;
        if (!this.Eof() && this.Peek() == '^') {
            negated = true;
            this.Advance();
        }
        int[] starts = new int[8];
        int[] ends   = new int[8];
        int n = 0;
        while (!this.Eof() && this.Peek() != ']') {
            int a = this.ParseCharsetChar();
            int b = a;
            if (!this.Eof() && this.Peek() == '-' && this._pos + 1 < this._src.Length
                && this._src.CharAt(this._pos + 1) != ']') {
                this.Advance();  // '-'
                b = this.ParseCharsetChar();
            }
            if (n >= starts.Length) {
                starts = this.GrowInts(starts, n);
                ends   = this.GrowInts(ends, n);
            }
            starts[n] = a;
            ends[n]   = b;
            n = n + 1;
        }
        if (this.Eof()) {
            throw new RegexException("unterminated character class");
        }
        this.Advance();  // ']'
        if (n == 0) {
            throw new RegexException("empty character class");
        }
        return RegexNode.Charset(negated, starts, ends, n);
    }

    private int ParseCharsetChar() {
        char c = this.Peek();
        if (c == '\\') {
            this.Advance();
            if (this.Eof()) {
                throw new RegexException("trailing backslash in character class");
            }
            char e = this.Peek();
            this.Advance();
            if (e == 'n')  { return 10; }
            if (e == 't')  { return 9; }
            if (e == 'r')  { return 13; }
            return (int)e;  // literal escape
        }
        this.Advance();
        return (int)c;
    }

    // ── Internals ─────────────────────────────────────────────────────────

    private bool Eof()      { return this._pos >= this._src.Length; }
    private char Peek()     { return this._src.CharAt(this._pos); }
    private void Advance()  { this._pos = this._pos + 1; }

    private RegexNode[] GrowNodes(RegexNode[] old, int used) {
        int newCap = old.Length * 2;
        if (newCap < used + 1) { newCap = used + 1; }
        RegexNode[] grown = new RegexNode[newCap];
        int i = 0;
        while (i < used) { grown[i] = old[i]; i = i + 1; }
        return grown;
    }

    private int[] GrowInts(int[] old, int used) {
        int newCap = old.Length * 2;
        if (newCap < used + 1) { newCap = used + 1; }
        int[] grown = new int[newCap];
        int i = 0;
        while (i < used) { grown[i] = old[i]; i = i + 1; }
        return grown;
    }
}
