namespace Std.Encoding;

using Std;

// RFC 4648 §7 "Base32 hex" variant — same bit packing as standard Base32
// (5-byte input → 8-char output, padding to multiple of 8 with `=`) but
// the alphabet is `0-9A-V` so the natural ordering of encoded strings
// preserves the natural ordering of decoded byte values. Most notable
// real-world use: DNS NSEC3 (RFC 5155) hashed owner-name encoding.
//
// Alphabet: 0123456789ABCDEFGHIJKLMNOPQRSTUV  (32 chars; A=10..V=31)
// Padding count rules identical to standard Base32: {0, 1, 3, 4, 6}.
// Strict uppercase; lowercase rejected (use s.ToUpper() to normalise).

public static class Base32Hex {
    private static string _alpha = "0123456789ABCDEFGHIJKLMNOPQRSTUV";

    public static string Encode(byte[] bytes) {
        if (bytes.Length == 0) return "";
        string alpha = Base32Hex._alpha;
        int outLen = ((bytes.Length + 4) / 5) * 8;
        char[] result = new char[outLen];
        int srcI = 0;
        int dstI = 0;
        long MASK5     = 31;
        long MASK_BYTE = 255;
        while (srcI + 5 <= bytes.Length) {
            long b0 = (long)((int)bytes[srcI])     & MASK_BYTE;
            long b1 = (long)((int)bytes[srcI + 1]) & MASK_BYTE;
            long b2 = (long)((int)bytes[srcI + 2]) & MASK_BYTE;
            long b3 = (long)((int)bytes[srcI + 3]) & MASK_BYTE;
            long b4 = (long)((int)bytes[srcI + 4]) & MASK_BYTE;
            long block = (b0 << 32) | (b1 << 24) | (b2 << 16) | (b3 << 8) | b4;
            result[dstI]     = alpha.CharAt((int)((block >> 35) & MASK5));
            result[dstI + 1] = alpha.CharAt((int)((block >> 30) & MASK5));
            result[dstI + 2] = alpha.CharAt((int)((block >> 25) & MASK5));
            result[dstI + 3] = alpha.CharAt((int)((block >> 20) & MASK5));
            result[dstI + 4] = alpha.CharAt((int)((block >> 15) & MASK5));
            result[dstI + 5] = alpha.CharAt((int)((block >> 10) & MASK5));
            result[dstI + 6] = alpha.CharAt((int)((block >> 5)  & MASK5));
            result[dstI + 7] = alpha.CharAt((int)(block & MASK5));
            srcI = srcI + 5;
            dstI = dstI + 8;
        }
        int rem = bytes.Length - srcI;
        if (rem > 0) {
            long block = 0;
            int i = 0;
            while (i < rem) {
                block = (block << 8) | ((long)((int)bytes[srcI + i]) & MASK_BYTE);
                i = i + 1;
            }
            int padBytes = 5 - rem;
            block = block << (8 * padBytes);
            int chars = 0;
            if (rem == 1) chars = 2;
            if (rem == 2) chars = 4;
            if (rem == 3) chars = 5;
            if (rem == 4) chars = 7;
            int j = 0;
            while (j < chars) {
                int shift = 35 - (j * 5);
                result[dstI + j] = alpha.CharAt((int)((block >> shift) & MASK5));
                j = j + 1;
            }
            while (j < 8) {
                result[dstI + j] = '=';
                j = j + 1;
            }
        }
        return String.FromChars(result);
    }

    public static byte[] Decode(string s) {
        if (s.Length == 0) return new byte[0];
        if ((s.Length % 8) != 0) {
            throw new FormatException("invalid base32hex length (must be multiple of 8)");
        }
        int padCount = 0;
        int idx = s.Length - 1;
        while (idx >= 0 && s.CharAt(idx) == '=') {
            padCount = padCount + 1;
            idx = idx - 1;
        }
        bool padOk = false;
        if (padCount == 0 || padCount == 1 || padCount == 3 || padCount == 4 || padCount == 6) {
            padOk = true;
        }
        if (!padOk) {
            throw new FormatException("invalid base32hex padding count");
        }
        int outPerLast = 5;
        if (padCount == 1) outPerLast = 4;
        if (padCount == 3) outPerLast = 3;
        if (padCount == 4) outPerLast = 2;
        if (padCount == 6) outPerLast = 1;
        int blocks = s.Length / 8;
        int outLen = (blocks - 1) * 5 + outPerLast;
        byte[] result = new byte[outLen];
        long MASK_BYTE = 255;
        int srcI = 0;
        int dstI = 0;
        int endBlock = s.Length - 8;
        while (srcI < endBlock) {
            long block = 0;
            int j = 0;
            while (j < 8) {
                block = (block << 5) | (long)decodeChar(s.CharAt(srcI + j));
                j = j + 1;
            }
            result[dstI]     = (byte)((block >> 32) & MASK_BYTE);
            result[dstI + 1] = (byte)((block >> 24) & MASK_BYTE);
            result[dstI + 2] = (byte)((block >> 16) & MASK_BYTE);
            result[dstI + 3] = (byte)((block >> 8)  & MASK_BYTE);
            result[dstI + 4] = (byte)(block         & MASK_BYTE);
            srcI = srcI + 8;
            dstI = dstI + 5;
        }
        long lastBlock = 0;
        int validChars = 8 - padCount;
        int k = 0;
        while (k < validChars) {
            lastBlock = (lastBlock << 5) | (long)decodeChar(s.CharAt(srcI + k));
            k = k + 1;
        }
        lastBlock = lastBlock << (5 * padCount);
        int m = 0;
        while (m < outPerLast) {
            int shift = 32 - (m * 8);
            result[dstI + m] = (byte)((lastBlock >> shift) & MASK_BYTE);
            m = m + 1;
        }
        return result;
    }

    /// Base32-hex char → 5-bit value (0..31). Strict uppercase per RFC §7.
    private static int decodeChar(char c) {
        int code = (int)c;
        if (code >= 48 && code <= 57) return code - 48;            // '0'..'9' → 0..9
        if (code >= 65 && code <= 86) return code - 65 + 10;       // 'A'..'V' → 10..31
        throw new FormatException($"invalid base32hex character '{c}'");
    }
}
