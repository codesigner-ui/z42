namespace Std.Encoding;

using Std;

// RFC 4648 §5: URL- and Filename-safe Base64.
//   字母表 = A-Z a-z 0-9 - _      (`+/` → `-_`)
//   padding = `=`，但默认输出 unpadded（RFC 4648 §3.2 允许；JWT / RFC 7515
//             Appendix C 强制要求 unpadded）
//   Decode 接受 padded 和 unpadded 两种输入（用户拿到的可能任一）
//   严格拒绝标准 base64 字符（`+/`）— 提示用 `Std.Encoding.Base64`
//
// 实现策略：复用 `Std.Encoding.Base64` 的核心算法，只在边界做 char-table 翻译
// + padding 处理。比重复 100 行算法清晰；perf 开销在 stdlib 用例下可忽略。

public static class Base64Url {

    /// Base64-URL encode `bytes` using RFC 4648 §5 alphabet (`+/` → `-_`)
    /// without trailing `=` padding. JWT / RFC 7515 Appendix C 兼容。
    public static string Encode(byte[] bytes) {
        // Reuse standard encoder, then char-translate + strip padding.
        string std    = Base64.Encode(bytes);
        string noPlus = std.Replace("+", "-");
        string noSlsh = noPlus.Replace("/", "_");
        // Strip trailing `=` (up to 2). Linear scan from end; common case 0-2 chars.
        int n = noSlsh.Length;
        int stripped = n;
        while (stripped > 0 && noSlsh.CharAt(stripped - 1) == '=') {
            stripped = stripped - 1;
        }
        if (stripped == n) return noSlsh;
        return noSlsh.Substring(0, stripped);
    }

    /// Decode a Base64-URL string back to bytes. Accepts both padded and
    /// unpadded input. Rejects characters `+` / `/` (those belong to the
    /// standard variant — caller should use `Std.Encoding.Base64`).
    public static byte[] Decode(string s) {
        if (s.Length == 0) return new byte[0];
        // Validate that no `+` / `/` appears (catches wrong-variant usage early).
        int i = 0;
        while (i < s.Length) {
            char c = s.CharAt(i);
            if (c == '+' || c == '/') {
                throw new FormatException($"invalid base64url character '{c}' — use Std.Encoding.Base64 for standard variant");
            }
            i = i + 1;
        }
        // Translate to standard alphabet for delegation.
        string p1 = s.Replace("-", "+");
        string p2 = p1.Replace("_", "/");
        // Pad to multiple of 4 if needed (decode is permissive about
        // unpadded input). RFC 4648 §3.5 says padding 0..2 chars is valid;
        // 3 chars padding is illegal — leave it to Base64.Decode to reject.
        int rem = p2.Length % 4;
        if (rem == 1) {
            throw new FormatException("invalid base64url length (length mod 4 == 1 is impossible)");
        }
        string padded = p2;
        if (rem == 2) padded = p2 + "==";
        if (rem == 3) padded = p2 + "=";
        return Base64.Decode(padded);
    }
}
