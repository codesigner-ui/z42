// Spec add-z42-encoding — UTF-8 unit tests.
namespace Z42EncodingTests.Utf8Tests;

using Std.Test;
using Std.Encoding;

[Test]
void test_get_bytes_empty() {
    Assert.Equal(0, Utf8.GetBytes("").Length);
}

[Test]
void test_get_string_empty() {
    Assert.Equal("", Utf8.GetString(new byte[0]));
}

// ── ASCII (1 byte per char) ─────────────────────────────────────────────────

[Test]
void test_get_bytes_ascii() {
    byte[] result = Utf8.GetBytes("Hello");
    Assert.Equal(5, result.Length);
    Assert.Equal(72,  (int)result[0]);  // 'H'
    Assert.Equal(101, (int)result[1]);  // 'e'
    Assert.Equal(108, (int)result[2]);  // 'l'
    Assert.Equal(108, (int)result[3]);  // 'l'
    Assert.Equal(111, (int)result[4]);  // 'o'
}

[Test]
void test_get_string_ascii() {
    byte[] bytes = new byte[5];
    bytes[0] = 72; bytes[1] = 101; bytes[2] = 108; bytes[3] = 108; bytes[4] = 111;
    Assert.Equal("Hello", Utf8.GetString(bytes));
}

// ── 2-byte UTF-8 (U+0080 ~ U+07FF) ──────────────────────────────────────────

[Test]
void test_get_bytes_2byte() {
    // U+00E9 = 'é' → 0xC3 0xA9
    byte[] result = Utf8.GetBytes("é");
    Assert.Equal(2, result.Length);
    Assert.Equal(0xC3, (int)result[0]);
    Assert.Equal(0xA9, (int)result[1]);
}

[Test]
void test_get_string_2byte() {
    byte[] bytes = new byte[2];
    bytes[0] = (byte)0xC3; bytes[1] = (byte)0xA9;
    Assert.Equal("é", Utf8.GetString(bytes));
}

// ── 3-byte UTF-8 (U+0800 ~ U+FFFF, BMP excl. surrogates) ────────────────────

[Test]
void test_get_bytes_3byte() {
    // U+4E2D = '中' → 0xE4 0xB8 0xAD
    byte[] result = Utf8.GetBytes("中");
    Assert.Equal(3, result.Length);
    Assert.Equal(0xE4, (int)result[0]);
    Assert.Equal(0xB8, (int)result[1]);
    Assert.Equal(0xAD, (int)result[2]);
}

[Test]
void test_get_string_3byte() {
    byte[] bytes = new byte[3];
    bytes[0] = (byte)0xE4; bytes[1] = (byte)0xB8; bytes[2] = (byte)0xAD;
    Assert.Equal("中", Utf8.GetString(bytes));
}

// ── 4-byte UTF-8 (U+10000 ~ U+10FFFF, supplementary planes) ─────────────────

[Test]
void test_get_bytes_4byte() {
    // U+1F600 = '😀' → 0xF0 0x9F 0x98 0x80
    byte[] result = Utf8.GetBytes("😀");
    Assert.Equal(4, result.Length);
    Assert.Equal(0xF0, (int)result[0]);
    Assert.Equal(0x9F, (int)result[1]);
    Assert.Equal(0x98, (int)result[2]);
    Assert.Equal(0x80, (int)result[3]);
}

[Test]
void test_get_string_4byte() {
    byte[] bytes = new byte[4];
    bytes[0] = (byte)0xF0; bytes[1] = (byte)0x9F; bytes[2] = (byte)0x98; bytes[3] = (byte)0x80;
    Assert.Equal("😀", Utf8.GetString(bytes));
}

// ── Error cases ─────────────────────────────────────────────────────────────

[Test]
void test_truncated_2byte_throws() {
    byte[] bytes = new byte[1];
    bytes[0] = (byte)0xC3;  // 2-byte leader, no continuation
    Assert.Throws("FormatException", () => Utf8.GetString(bytes));
}

[Test]
void test_truncated_3byte_throws() {
    byte[] bytes = new byte[2];
    bytes[0] = (byte)0xE4; bytes[1] = (byte)0xB8;  // 3-byte, missing 3rd
    Assert.Throws("FormatException", () => Utf8.GetString(bytes));
}

[Test]
void test_surrogate_in_3byte_throws() {
    // U+D800 surrogate encoded as 0xED 0xA0 0x80 — illegal UTF-8
    byte[] bytes = new byte[3];
    bytes[0] = (byte)0xED; bytes[1] = (byte)0xA0; bytes[2] = (byte)0x80;
    Assert.Throws("FormatException", () => Utf8.GetString(bytes));
}

[Test]
void test_invalid_leading_byte_throws() {
    byte[] bytes = new byte[1];
    bytes[0] = (byte)0x80;  // continuation byte as leader
    Assert.Throws("FormatException", () => Utf8.GetString(bytes));
}

// ── Roundtrip mixed content ─────────────────────────────────────────────────

[Test]
void test_roundtrip_mixed() {
    string original = "Hello, 中文 😀!";
    byte[] encoded = Utf8.GetBytes(original);
    string decoded = Utf8.GetString(encoded);
    Assert.Equal(original, decoded);
}
