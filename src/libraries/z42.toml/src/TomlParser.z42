namespace Std.Toml;
using Std;
using Std.Text;

// add-z42-toml (2026-05-14)：TOML 1.0 subset parser（tokenizer + 递归下降）。
//
// 状态：
//   _root   全文档 root TomlValue（Table）
//   _active 当前活跃 table —— `[a.b]` / `[[c]]` 改变它的指向
//   _src    源字符串
//   _pos    当前字符索引
//   _line/_col 1-based 行 / 列号（用于报错）
//
// 不实现：datetime / multiline string / hex/oct/bin int / 下划线分隔符。
// 见 docs/design/stdlib/toml.md "Deferred" 段。
public sealed class TomlParser {
    private string _src;
    private int _pos;
    private int _line;
    private int _col;
    private TomlValue _root;
    private TomlValue _active;
    // 定义过的 [section] / [[aot]] 头集合（FQ "a.b.c"）。
    // 用平铺 string[] + 线性扫描 —— z42 类字段不支持泛型类型参数（Dictionary<...>
    // 会被解析为裸 Dictionary），manifest 文件 section 数通常 <50，线性可接受。
    private string[] _definedSections;
    private int _definedSectionsCount;
    // 通过 [[aot]] 创建的 key（不可再用 [section]）。
    private string[] _aotKeys;
    private int _aotKeysCount;

    public TomlParser(string src) {
        this._src = src;
        this._pos = 0;
        this._line = 1;
        this._col = 1;
        this._root = TomlValue.OfTable();
        this._active = this._root;
        this._definedSections = new string[8];
        this._definedSectionsCount = 0;
        this._aotKeys = new string[8];
        this._aotKeysCount = 0;
    }

    private bool HasDefinedSection(string fq) {
        int i = 0;
        while (i < this._definedSectionsCount) {
            if (this._definedSections[i] == fq) { return true; }
            i = i + 1;
        }
        return false;
    }

    private void MarkDefinedSection(string fq) {
        if (this._definedSectionsCount == this._definedSections.Length) {
            string[] g = new string[this._definedSections.Length * 2];
            int j = 0;
            while (j < this._definedSectionsCount) { g[j] = this._definedSections[j]; j = j + 1; }
            this._definedSections = g;
        }
        this._definedSections[this._definedSectionsCount] = fq;
        this._definedSectionsCount = this._definedSectionsCount + 1;
    }

    private bool IsAotKey(string fq) {
        int i = 0;
        while (i < this._aotKeysCount) {
            if (this._aotKeys[i] == fq) { return true; }
            i = i + 1;
        }
        return false;
    }

    private void MarkAotKey(string fq) {
        if (this._aotKeysCount == this._aotKeys.Length) {
            string[] g = new string[this._aotKeys.Length * 2];
            int j = 0;
            while (j < this._aotKeysCount) { g[j] = this._aotKeys[j]; j = j + 1; }
            this._aotKeys = g;
        }
        this._aotKeys[this._aotKeysCount] = fq;
        this._aotKeysCount = this._aotKeysCount + 1;
    }

    // ── Public entry ─────────────────────────────────────────────────────

    public TomlValue ParseDocument() {
        while (this._pos < this._src.Length) {
            this.SkipWhitespaceAndComments(true);
            if (this._pos >= this._src.Length) { break; }
            char c = this.Peek();
            if (c == '[') {
                if (this.PeekAt(1) == '[') {
                    this.ParseArrayOfTablesHeader();
                } else {
                    this.ParseTableHeader();
                }
            } else {
                this.ParseKeyValue(this._active);
            }
            this.SkipInlineWhitespace();
            this.ExpectLineEnd();
        }
        return this._root;
    }

    // ── Cursor helpers ───────────────────────────────────────────────────

    private char Peek() {
        if (this._pos >= this._src.Length) { return '\0'; }
        return this._src.CharAt(this._pos);
    }

    private char PeekAt(int offset) {
        int p = this._pos + offset;
        if (p >= this._src.Length) { return '\0'; }
        return this._src.CharAt(p);
    }

    private char Advance() {
        char c = this.Peek();
        this._pos = this._pos + 1;
        if (c == '\n') {
            this._line = this._line + 1;
            this._col = 1;
        } else {
            this._col = this._col + 1;
        }
        return c;
    }

    private bool Eof() { return this._pos >= this._src.Length; }

    private TomlException Err(string msg) {
        return new TomlException(msg, this._line, this._col);
    }

    private void Expect(char c, string what) {
        if (this.Peek() != c) {
            throw this.Err("expected " + what + " but got '" + this.CharToString(this.Peek()) + "'");
        }
        this.Advance();
    }

    private string CharToString(char c) {
        char[] arr = new char[1];
        arr[0] = c;
        return String.FromChars(arr);
    }

    // ── Whitespace + comments ────────────────────────────────────────────

    /// Skip spaces / tabs (+ optional newlines + comments).
    private void SkipWhitespaceAndComments(bool includeNewlines) {
        while (!this.Eof()) {
            char c = this.Peek();
            if (c == ' ' || c == '\t') {
                this.Advance();
            } else if (includeNewlines && (c == '\n' || c == '\r')) {
                this.Advance();
            } else if (c == '#') {
                while (!this.Eof() && this.Peek() != '\n') { this.Advance(); }
            } else {
                break;
            }
        }
    }

    private void SkipInlineWhitespace() {
        while (!this.Eof()) {
            char c = this.Peek();
            if (c == ' ' || c == '\t') {
                this.Advance();
            } else if (c == '#') {
                while (!this.Eof() && this.Peek() != '\n') { this.Advance(); }
            } else {
                break;
            }
        }
    }

    private void ExpectLineEnd() {
        if (this.Eof()) { return; }
        char c = this.Peek();
        if (c == '\n') {
            this.Advance();
            return;
        }
        if (c == '\r') {
            this.Advance();
            if (!this.Eof() && this.Peek() == '\n') { this.Advance(); }
            return;
        }
        throw this.Err("expected newline or EOF after value");
    }

    // ── Section / AoT headers ────────────────────────────────────────────

    private void ParseTableHeader() {
        this.Expect('[', "'['");
        this.SkipInlineWhitespace();
        string[] path = this.ParseKeyPath();
        this.SkipInlineWhitespace();
        this.Expect(']', "']'");

        string fq = this.JoinPath(path);
        if (this.HasDefinedSection(fq)) {
            throw this.Err("duplicate table definition: [" + fq + "]");
        }
        // Disallow targeting an AoT root with plain [section].
        if (this.IsAotKey(fq)) {
            throw this.Err("cannot redefine array-of-tables `" + fq + "` as plain table");
        }
        this.MarkDefinedSection(fq);
        this._active = this.EnsureTablePath(this._root, path);
    }

    private void ParseArrayOfTablesHeader() {
        this.Expect('[', "'['");
        this.Expect('[', "'[' (second of [[ )");
        this.SkipInlineWhitespace();
        string[] path = this.ParseKeyPath();
        this.SkipInlineWhitespace();
        this.Expect(']', "']'");
        this.Expect(']', "']' (second of ]] )");

        string fq = this.JoinPath(path);
        // Conflict with plain [section]?
        if (this.HasDefinedSection(fq)) {
            throw this.Err("cannot redefine table `" + fq + "` as array-of-tables");
        }
        this.MarkAotKey(fq);

        // Walk path: create intermediate tables; last segment must be (or become) an array.
        if (path.Length == 0) {
            throw this.Err("empty array-of-tables header");
        }
        TomlValue parent = this.EnsurePathParent(this._root, path);
        string lastKey = path[path.Length - 1];
        TomlValue arr;
        if (parent.ContainsKey(lastKey)) {
            arr = parent.Get(lastKey);
            if (!arr.IsArray()) {
                throw this.Err("key `" + fq + "` already exists as " + arr.KindName());
            }
        } else {
            arr = TomlValue.OfArray();
            parent.Set(lastKey, arr);
        }
        TomlValue elem = TomlValue.OfTable();
        arr.Add(elem);
        this._active = elem;
    }

    /// Parse a dotted key path: `a.b.c` → ["a", "b", "c"]. Each segment
    /// may be an unquoted bare key or a quoted "string" / 'literal' key.
    private string[] ParseKeyPath() {
        string[] segs = new string[4];
        int count = 0;
        segs = this.AppendStr(segs, count, this.ParseKeySegment());
        count = count + 1;
        this.SkipInlineWhitespace();
        while (!this.Eof() && this.Peek() == '.') {
            this.Advance();
            this.SkipInlineWhitespace();
            segs = this.AppendStr(segs, count, this.ParseKeySegment());
            count = count + 1;
            this.SkipInlineWhitespace();
        }
        // Trim to exact size for downstream `.Length` usage.
        string[] tight = new string[count];
        int k = 0;
        while (k < count) { tight[k] = segs[k]; k = k + 1; }
        return tight;
    }

    /// Grow-on-overflow append. Returns same array or a doubled-capacity copy.
    private string[] AppendStr(string[] arr, int count, string v) {
        if (count < arr.Length) {
            arr[count] = v;
            return arr;
        }
        int newCap = arr.Length * 2;
        if (newCap < 4) { newCap = 4; }
        string[] g = new string[newCap];
        int i = 0;
        while (i < count) { g[i] = arr[i]; i = i + 1; }
        g[count] = v;
        return g;
    }

    private string ParseKeySegment() {
        char c = this.Peek();
        if (c == '"') {
            return this.ParseBasicString();
        }
        if (c == '\'') {
            return this.ParseLiteralString();
        }
        // Bare key: A-Za-z0-9_-
        int start = this._pos;
        while (!this.Eof()) {
            char ch = this.Peek();
            int code = (int)ch;
            bool isBareChar = (code >= 65 && code <= 90)     // A-Z
                || (code >= 97 && code <= 122)               // a-z
                || (code >= 48 && code <= 57)                // 0-9
                || ch == '_' || ch == '-';
            if (!isBareChar) { break; }
            this.Advance();
        }
        if (this._pos == start) {
            throw this.Err("expected key, got '" + this.CharToString(c) + "'");
        }
        return this._src.Substring(start, this._pos - start);
    }

    private string JoinPath(string[] path) {
        string s = "";
        int i = 0;
        while (i < path.Length) {
            if (i > 0) { s = s + "."; }
            s = s + path[i];
            i = i + 1;
        }
        return s;
    }

    /// Walk path creating intermediate tables; return the FINAL table.
    private TomlValue EnsureTablePath(TomlValue root, string[] path) {
        TomlValue cur = root;
        int i = 0;
        while (i < path.Length) {
            string seg = path[i];
            if (cur.ContainsKey(seg)) {
                TomlValue child = cur.Get(seg);
                if (child.IsTable()) {
                    cur = child;
                } else if (child.IsArray()) {
                    // Walk into the last AoT element.
                    int last = child.Length() - 1;
                    if (last < 0 || !child.At(last).IsTable()) {
                        throw this.Err("cannot descend into non-table element of `" + this.JoinPath(path) + "`");
                    }
                    cur = child.At(last);
                } else {
                    throw this.Err("path segment `" + seg + "` is a " + child.KindName() + ", not a table");
                }
            } else {
                TomlValue tbl = TomlValue.OfTable();
                cur.Set(seg, tbl);
                cur = tbl;
            }
            i = i + 1;
        }
        return cur;
    }

    /// Walk all-but-last segments, returning the parent table (where the
    /// final key will be created/looked-up). Used by AoT header.
    private TomlValue EnsurePathParent(TomlValue root, string[] path) {
        if (path.Length <= 1) { return root; }
        string[] parentPath = new string[path.Length - 1];
        int i = 0;
        while (i < path.Length - 1) {
            parentPath[i] = path[i];
            i = i + 1;
        }
        return this.EnsureTablePath(root, parentPath);
    }

    // ── key = value ──────────────────────────────────────────────────────

    private void ParseKeyValue(TomlValue dst) {
        string[] keyPath = this.ParseKeyPath();
        this.SkipInlineWhitespace();
        this.Expect('=', "'='");
        this.SkipInlineWhitespace();
        TomlValue val = this.ParseValue();

        // Dotted-key assignment: walk path under `dst`.
        TomlValue target = dst;
        int i = 0;
        while (i < keyPath.Length - 1) {
            string seg = keyPath[i];
            if (target.ContainsKey(seg)) {
                TomlValue next = target.Get(seg);
                if (!next.IsTable()) {
                    throw this.Err("dotted key conflicts with existing " + next.KindName());
                }
                target = next;
            } else {
                TomlValue t = TomlValue.OfTable();
                target.Set(seg, t);
                target = t;
            }
            i = i + 1;
        }
        string finalKey = keyPath[keyPath.Length - 1];
        if (target.ContainsKey(finalKey)) {
            throw this.Err("duplicate key: " + finalKey);
        }
        target.Set(finalKey, val);
    }

    // ── Value parsing ────────────────────────────────────────────────────

    private TomlValue ParseValue() {
        char c = this.Peek();
        if (c == '"') {
            return TomlValue.OfString(this.ParseBasicString());
        }
        if (c == '\'') {
            return TomlValue.OfString(this.ParseLiteralString());
        }
        if (c == 't' || c == 'f') {
            return this.ParseBool();
        }
        if (c == '[') {
            return this.ParseArray();
        }
        if (c == '{') {
            return this.ParseInlineTable();
        }
        // Numbers (including +/- prefix, nan/inf).
        return this.ParseNumber();
    }

    private TomlValue ParseBool() {
        if (this.TryLiteral("true")) { return TomlValue.OfBool(true); }
        if (this.TryLiteral("false")) { return TomlValue.OfBool(false); }
        throw this.Err("unrecognised value");
    }

    private bool TryLiteral(string lit) {
        int len = lit.Length;
        if (this._pos + len > this._src.Length) { return false; }
        int i = 0;
        while (i < len) {
            if (this._src.CharAt(this._pos + i) != lit.CharAt(i)) { return false; }
            i = i + 1;
        }
        // ensure boundary — next char isn't a bare-key continuation
        if (this._pos + len < this._src.Length) {
            char after = this._src.CharAt(this._pos + len);
            int ac = (int)after;
            bool isContinuation = (ac >= 65 && ac <= 90)        // A-Z
                || (ac >= 97 && ac <= 122)                       // a-z
                || (ac >= 48 && ac <= 57)                        // 0-9
                || after == '_';
            if (isContinuation) { return false; }
        }
        int j = 0;
        while (j < len) { this.Advance(); j = j + 1; }
        return true;
    }

    // ── String parsing ───────────────────────────────────────────────────

    private string ParseBasicString() {
        this.Expect('"', "'\"'");
        StringBuilder sb = new StringBuilder();
        while (!this.Eof()) {
            char c = this.Peek();
            if (c == '"') {
                this.Advance();
                return sb.ToString();
            }
            if (c == '\n') {
                throw this.Err("newline in basic string (use multi-line \"\"\" — unsupported in v0)");
            }
            if (c == '\\') {
                this.Advance();
                char esc = this.Peek();
                if (this.Eof()) { throw this.Err("unterminated string escape"); }
                this.Advance();
                if (esc == '"')  { sb.Append("\""); }
                else if (esc == '\\') { sb.Append("\\"); }
                else if (esc == 'n') { sb.Append("\n"); }
                else if (esc == 't') { sb.Append("\t"); }
                else if (esc == 'r') { sb.Append("\r"); }
                else if (esc == '0') { char[] z = new char[1]; z[0] = '\0'; sb.Append(String.FromChars(z)); }
                else if (esc == 'b') { char[] z = new char[1]; z[0] = '\b'; sb.Append(String.FromChars(z)); }
                else if (esc == 'f') { char[] z = new char[1]; z[0] = '\f'; sb.Append(String.FromChars(z)); }
                else if (esc == 'u') {
                    sb.Append(this.ParseUnicodeEscape(4));
                } else if (esc == 'U') {
                    sb.Append(this.ParseUnicodeEscape(8));
                } else {
                    throw this.Err("unknown escape: \\" + this.CharToString(esc));
                }
            } else {
                this.Advance();
                sb.Append(this.CharToString(c));
            }
        }
        throw this.Err("unterminated basic string");
    }

    private string ParseLiteralString() {
        this.Expect('\'', "'\\''");
        StringBuilder sb = new StringBuilder();
        while (!this.Eof()) {
            char c = this.Peek();
            if (c == '\'') {
                this.Advance();
                return sb.ToString();
            }
            if (c == '\n') {
                throw this.Err("newline in literal string (multi-line ''' unsupported in v0)");
            }
            this.Advance();
            sb.Append(this.CharToString(c));
        }
        throw this.Err("unterminated literal string");
    }

    /// Parse N hex digits and return the resulting Unicode codepoint as a 1-char string.
    /// (BMP only — codepoints above 0xFFFF require surrogate pair encoding,
    /// which z42's char type stores as a single primitive. Errors above U+10FFFF.)
    private string ParseUnicodeEscape(int width) {
        int v = 0;
        int i = 0;
        while (i < width) {
            char c = this.Peek();
            int d = this.HexDigit(c);
            if (d < 0) { throw this.Err("invalid hex digit in \\u escape"); }
            v = v * 16 + d;
            this.Advance();
            i = i + 1;
        }
        if (v > 0x10FFFF) {
            throw this.Err("Unicode escape out of range (>U+10FFFF)");
        }
        char[] arr = new char[1];
        arr[0] = (char)v;
        return String.FromChars(arr);
    }

    private int HexDigit(char c) {
        int code = (int)c;
        if (code >= 48 && code <= 57)  { return code - 48; }       // '0'..'9'
        if (code >= 97 && code <= 102) { return 10 + code - 97; }  // 'a'..'f'
        if (code >= 65 && code <= 70)  { return 10 + code - 65; }  // 'A'..'F'
        return -1;
    }

    // ── Number parsing ───────────────────────────────────────────────────

    /// Scan a numeric token and dispatch to int vs float by content.
    /// Handles: optional `+`/`-`, decimal digits, `.`, `eE` exponent,
    /// `nan` / `inf` literals.
    private TomlValue ParseNumber() {
        int start = this._pos;
        bool isFloat = false;

        // Special-case nan / inf with optional sign.
        if (this.Peek() == '+' || this.Peek() == '-') {
            // Peek ahead to detect inf/nan.
            int p = this._pos + 1;
            if (p + 2 < this._src.Length) {
                string ahead = this._src.Substring(p, 3);
                if (ahead == "inf" || ahead == "nan") {
                    bool neg = (this.Peek() == '-');
                    this.Advance(); // sign
                    this.Advance(); this.Advance(); this.Advance(); // inf / nan
                    if (ahead == "nan") {
                        // Z42 has no NaN literal; produce 0.0 / 0.0 via __math?
                        // Use a known sentinel: positive nan via parse.
                        return TomlValue.OfDouble(double.Parse("nan"));
                    }
                    double d = double.Parse("inf");
                    if (neg) { d = 0.0 - d; }
                    return TomlValue.OfDouble(d);
                }
            }
            this.Advance();
        }
        if (this._pos + 2 < this._src.Length) {
            string ahead = this._src.Substring(this._pos, 3);
            if (ahead == "inf") {
                this.Advance(); this.Advance(); this.Advance();
                return TomlValue.OfDouble(double.Parse("inf"));
            }
            if (ahead == "nan") {
                this.Advance(); this.Advance(); this.Advance();
                return TomlValue.OfDouble(double.Parse("nan"));
            }
        }

        while (!this.Eof()) {
            char c = this.Peek();
            int cc = (int)c;
            if (cc >= 48 && cc <= 57) {       // 0-9
                this.Advance();
            } else if (c == '.') {
                isFloat = true;
                this.Advance();
            } else if (c == 'e' || c == 'E') {
                isFloat = true;
                this.Advance();
                if (!this.Eof() && (this.Peek() == '+' || this.Peek() == '-')) {
                    this.Advance();
                }
            } else {
                break;
            }
        }
        if (this._pos == start) {
            throw this.Err("expected number");
        }
        string raw = this._src.Substring(start, this._pos - start);
        if (isFloat) {
            return TomlValue.OfDouble(double.Parse(raw));
        }
        return TomlValue.OfLong(long.Parse(raw));
    }

    // ── Array ────────────────────────────────────────────────────────────

    private TomlValue ParseArray() {
        this.Expect('[', "'['");
        TomlValue arr = TomlValue.OfArray();
        while (true) {
            this.SkipWhitespaceAndComments(true);
            if (this.Peek() == ']') {
                this.Advance();
                return arr;
            }
            TomlValue v = this.ParseValue();
            arr.Add(v);
            this.SkipWhitespaceAndComments(true);
            char c = this.Peek();
            if (c == ',') {
                this.Advance();
                continue;
            }
            if (c == ']') {
                this.Advance();
                return arr;
            }
            throw this.Err("expected ',' or ']' in array");
        }
        return arr;
    }

    // ── Inline table ─────────────────────────────────────────────────────

    private TomlValue ParseInlineTable() {
        this.Expect('{', "'{'");
        TomlValue tbl = TomlValue.OfTable();
        this.SkipInlineWhitespace();
        if (this.Peek() == '}') {
            this.Advance();
            return tbl;
        }
        while (true) {
            this.SkipInlineWhitespace();
            this.ParseKeyValue(tbl);
            this.SkipInlineWhitespace();
            char c = this.Peek();
            if (c == ',') {
                this.Advance();
                continue;
            }
            if (c == '}') {
                this.Advance();
                return tbl;
            }
            throw this.Err("expected ',' or '}' in inline table");
        }
        return tbl;
    }
}
