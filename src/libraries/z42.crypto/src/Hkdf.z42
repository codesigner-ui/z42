namespace Std.Crypto;

using Std;
using Std.Encoding;

// add-hkdf (2026-05-27): HKDF (RFC 5869) — Extract-then-Expand HMAC-based
// Key Derivation Function. Industry-standard KDF used by TLS 1.3,
// Signal, Noise protocols, JWT, etc.
//
// Pure-script over the existing HmacSha256 / HmacSha512 (which themselves
// are pure-script over Sha256 / Sha512). No FFI, no native deps.
//
// Naming follows the rest of z42.crypto: distinct named methods per
// hash flavor (HkdfSha256.Derive / HkdfSha512.Derive). The two flavours
// share helpers via internal `_extract*` / `_expand*` functions.
//
// API shape mirrors Python's `cryptography.hazmat.primitives.kdf.hkdf` +
// .NET 5+ `System.Security.Cryptography.HKDF`:
//
//   byte[] okm = HkdfSha256.Derive(salt, ikm, info, length);
//
// where `salt` may be empty (substituted with HashLen zero bytes per
// RFC 5869 §2.2), `info` may be empty (no context binding), and
// `length` must be ≤ 255 × HashLen.
//
// Tested against RFC 5869 §A.1-A.3 + a SHA-512 vector pair.
public static class HkdfSha256 {
    static int HashLen = 32;
    static int MaxLength = 255 * 32;  // 8160

    /// One-shot Extract + Expand. The two phases are separately exposed
    /// (`Extract` / `Expand`) for callers (e.g. TLS 1.3 key schedule)
    /// that interleave with other state between them.
    public static byte[] Derive(byte[] salt, byte[] ikm, byte[] info, int length) {
        if (length < 0 || length > HkdfSha256.MaxLength) {
            throw new ArgumentException(
                "HkdfSha256.Derive: length out of range [0, " + HkdfSha256.MaxLength.ToString() + "]");
        }
        byte[] prk = HkdfSha256.Extract(salt, ikm);
        return HkdfSha256.Expand(prk, info, length);
    }

    /// HKDF-Extract (RFC 5869 §2.2): PRK = HMAC-Hash(salt, IKM).
    /// Empty salt → 32 zero bytes. Output is HashLen (32) bytes.
    public static byte[] Extract(byte[] salt, byte[] ikm) {
        byte[] key;
        if (salt == null || salt.Length == 0) {
            key = new byte[HkdfSha256.HashLen];
        } else {
            key = salt;
        }
        return HmacSha256.Compute(key, ikm);
    }

    /// HKDF-Expand (RFC 5869 §2.3): expand PRK into `length` bytes of
    /// output keying material using `info` as context binding.
    public static byte[] Expand(byte[] prk, byte[] info, int length) {
        if (length < 0 || length > HkdfSha256.MaxLength) {
            throw new ArgumentException(
                "HkdfSha256.Expand: length out of range [0, " + HkdfSha256.MaxLength.ToString() + "]");
        }
        byte[] infoBytes;
        if (info == null) { infoBytes = new byte[0]; } else { infoBytes = info; }

        // N = ceil(length / HashLen). Build T(1), T(2), ..., T(N) iteratively:
        //   T(0) = empty
        //   T(i) = HMAC(PRK, T(i-1) || info || byte(i))
        // Output = T(1) || T(2) || ... || T(N), truncated to `length`.
        int n = (length + HkdfSha256.HashLen - 1) / HkdfSha256.HashLen;
        byte[] okm = new byte[length];
        byte[] prev = new byte[0];
        int written = 0;
        int i = 1;
        while (i <= n) {
            // input = prev || info || single-byte counter
            int inputLen = prev.Length + infoBytes.Length + 1;
            byte[] input = new byte[inputLen];
            int k = 0;
            while (k < prev.Length) { input[k] = prev[k]; k = k + 1; }
            int p = prev.Length;
            int j = 0;
            while (j < infoBytes.Length) { input[p + j] = infoBytes[j]; j = j + 1; }
            input[inputLen - 1] = (byte)i;
            byte[] t = HmacSha256.Compute(prk, input);
            // Copy up to HashLen or remaining length, whichever is smaller.
            int copy = length - written;
            if (copy > HkdfSha256.HashLen) { copy = HkdfSha256.HashLen; }
            int x = 0;
            while (x < copy) { okm[written + x] = t[x]; x = x + 1; }
            written = written + copy;
            prev = t;
            i = i + 1;
        }
        return okm;
    }

    /// Convenience hex variant for documentation / debugging.
    public static string DeriveHex(byte[] salt, byte[] ikm, byte[] info, int length) {
        return Hex.Encode(HkdfSha256.Derive(salt, ikm, info, length));
    }
}

// HKDF-SHA-512 — same algorithm, 64-byte HashLen.
public static class HkdfSha512 {
    static int HashLen = 64;
    static int MaxLength = 255 * 64;  // 16320

    public static byte[] Derive(byte[] salt, byte[] ikm, byte[] info, int length) {
        if (length < 0 || length > HkdfSha512.MaxLength) {
            throw new ArgumentException(
                "HkdfSha512.Derive: length out of range [0, " + HkdfSha512.MaxLength.ToString() + "]");
        }
        byte[] prk = HkdfSha512.Extract(salt, ikm);
        return HkdfSha512.Expand(prk, info, length);
    }

    public static byte[] Extract(byte[] salt, byte[] ikm) {
        byte[] key;
        if (salt == null || salt.Length == 0) {
            key = new byte[HkdfSha512.HashLen];
        } else {
            key = salt;
        }
        return HmacSha512.Compute(key, ikm);
    }

    public static byte[] Expand(byte[] prk, byte[] info, int length) {
        if (length < 0 || length > HkdfSha512.MaxLength) {
            throw new ArgumentException(
                "HkdfSha512.Expand: length out of range [0, " + HkdfSha512.MaxLength.ToString() + "]");
        }
        byte[] infoBytes;
        if (info == null) { infoBytes = new byte[0]; } else { infoBytes = info; }
        int n = (length + HkdfSha512.HashLen - 1) / HkdfSha512.HashLen;
        byte[] okm = new byte[length];
        byte[] prev = new byte[0];
        int written = 0;
        int i = 1;
        while (i <= n) {
            int inputLen = prev.Length + infoBytes.Length + 1;
            byte[] input = new byte[inputLen];
            int k = 0;
            while (k < prev.Length) { input[k] = prev[k]; k = k + 1; }
            int p = prev.Length;
            int j = 0;
            while (j < infoBytes.Length) { input[p + j] = infoBytes[j]; j = j + 1; }
            input[inputLen - 1] = (byte)i;
            byte[] t = HmacSha512.Compute(prk, input);
            int copy = length - written;
            if (copy > HkdfSha512.HashLen) { copy = HkdfSha512.HashLen; }
            int x = 0;
            while (x < copy) { okm[written + x] = t[x]; x = x + 1; }
            written = written + copy;
            prev = t;
            i = i + 1;
        }
        return okm;
    }

    public static string DeriveHex(byte[] salt, byte[] ikm, byte[] info, int length) {
        return Hex.Encode(HkdfSha512.Derive(salt, ikm, info, length));
    }
}
