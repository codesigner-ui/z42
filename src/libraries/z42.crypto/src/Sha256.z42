namespace Std.Crypto;

using Std.Encoding;

// add-z42-crypto (2026-05-17): SHA-256 hash (FIPS 180-4).
//
// Pure-script implementation. State held as `long` (i64), masked to 32
// bits at every op boundary — z42 `int` is signed i32, overflows on the
// schedule additions.
//
// Tested against NIST FIPS 180-2 test vectors (see tests/sha256_vectors.z42).
public static class Sha256 {
    // ── Public API ───────────────────────────────────────────────────────────

    public static byte[] Hash(byte[] data) {
        byte[] padded = _pad(data);
        long[] h = _initialHash();
        int blocks = padded.Length / 64;
        int b = 0;
        while (b < blocks) {
            _processBlock(h, padded, b * 64);
            b = b + 1;
        }
        byte[] digest = new byte[32];
        int i = 0;
        while (i < 8) {
            long v = h[i];
            digest[i * 4 + 0] = (byte)((v >> 24) & 0xFFL);
            digest[i * 4 + 1] = (byte)((v >> 16) & 0xFFL);
            digest[i * 4 + 2] = (byte)((v >> 8)  & 0xFFL);
            digest[i * 4 + 3] = (byte)( v        & 0xFFL);
            i = i + 1;
        }
        return digest;
    }

    public static byte[] HashString(string s) {
        return Hash(Utf8.GetBytes(s));
    }

    public static string HashHex(byte[] data) {
        return Hex.Encode(Hash(data));
    }

    public static string HashStringHex(string s) {
        if (s.Length == 0) return Hex.Encode(Hash(new byte[0]));
        return Hex.Encode(Hash(Utf8.GetBytes(s)));
    }

    // ── FIPS 180-4 constants ─────────────────────────────────────────────────

    static long[] _initialHash() {
        long[] h = new long[8];
        h[0] = 0x6A09E667L; h[1] = 0xBB67AE85L; h[2] = 0x3C6EF372L; h[3] = 0xA54FF53AL;
        h[4] = 0x510E527FL; h[5] = 0x9B05688CL; h[6] = 0x1F83D9ABL; h[7] = 0x5BE0CD19L;
        return h;
    }

    static long[] _roundConstants() {
        long[] k = new long[64];
        k[0]  = 0x428A2F98L; k[1]  = 0x71374491L; k[2]  = 0xB5C0FBCFL; k[3]  = 0xE9B5DBA5L;
        k[4]  = 0x3956C25BL; k[5]  = 0x59F111F1L; k[6]  = 0x923F82A4L; k[7]  = 0xAB1C5ED5L;
        k[8]  = 0xD807AA98L; k[9]  = 0x12835B01L; k[10] = 0x243185BEL; k[11] = 0x550C7DC3L;
        k[12] = 0x72BE5D74L; k[13] = 0x80DEB1FEL; k[14] = 0x9BDC06A7L; k[15] = 0xC19BF174L;
        k[16] = 0xE49B69C1L; k[17] = 0xEFBE4786L; k[18] = 0x0FC19DC6L; k[19] = 0x240CA1CCL;
        k[20] = 0x2DE92C6FL; k[21] = 0x4A7484AAL; k[22] = 0x5CB0A9DCL; k[23] = 0x76F988DAL;
        k[24] = 0x983E5152L; k[25] = 0xA831C66DL; k[26] = 0xB00327C8L; k[27] = 0xBF597FC7L;
        k[28] = 0xC6E00BF3L; k[29] = 0xD5A79147L; k[30] = 0x06CA6351L; k[31] = 0x14292967L;
        k[32] = 0x27B70A85L; k[33] = 0x2E1B2138L; k[34] = 0x4D2C6DFCL; k[35] = 0x53380D13L;
        k[36] = 0x650A7354L; k[37] = 0x766A0ABBL; k[38] = 0x81C2C92EL; k[39] = 0x92722C85L;
        k[40] = 0xA2BFE8A1L; k[41] = 0xA81A664BL; k[42] = 0xC24B8B70L; k[43] = 0xC76C51A3L;
        k[44] = 0xD192E819L; k[45] = 0xD6990624L; k[46] = 0xF40E3585L; k[47] = 0x106AA070L;
        k[48] = 0x19A4C116L; k[49] = 0x1E376C08L; k[50] = 0x2748774CL; k[51] = 0x34B0BCB5L;
        k[52] = 0x391C0CB3L; k[53] = 0x4ED8AA4AL; k[54] = 0x5B9CCA4FL; k[55] = 0x682E6FF3L;
        k[56] = 0x748F82EEL; k[57] = 0x78A5636FL; k[58] = 0x84C87814L; k[59] = 0x8CC70208L;
        k[60] = 0x90BEFFFAL; k[61] = 0xA4506CEBL; k[62] = 0xBEF9A3F7L; k[63] = 0xC67178F2L;
        return k;
    }

    // ── Pre-processing: pad + length-encode ──────────────────────────────────

    static byte[] _pad(byte[] data) {
        long bitLen = (long)data.Length * 8L;
        int padZeros = (56 - (data.Length + 1) % 64 + 64) % 64;
        int totalLen = data.Length + 1 + padZeros + 8;
        byte[] padded = new byte[totalLen];
        int i = 0;
        while (i < data.Length) { padded[i] = data[i]; i = i + 1; }
        padded[data.Length] = (byte)0x80;
        int lenOffset = totalLen - 8;
        padded[lenOffset + 0] = (byte)((bitLen >> 56) & 0xFFL);
        padded[lenOffset + 1] = (byte)((bitLen >> 48) & 0xFFL);
        padded[lenOffset + 2] = (byte)((bitLen >> 40) & 0xFFL);
        padded[lenOffset + 3] = (byte)((bitLen >> 32) & 0xFFL);
        padded[lenOffset + 4] = (byte)((bitLen >> 24) & 0xFFL);
        padded[lenOffset + 5] = (byte)((bitLen >> 16) & 0xFFL);
        padded[lenOffset + 6] = (byte)((bitLen >> 8)  & 0xFFL);
        padded[lenOffset + 7] = (byte)( bitLen        & 0xFFL);
        return padded;
    }

    // ── Per-block compression ────────────────────────────────────────────────

    static void _processBlock(long[] h, byte[] block, int offset) {
        long[] k = _roundConstants();
        long[] w = new long[64];

        int t = 0;
        while (t < 16) {
            int o = offset + t * 4;
            long b0 = (long)((int)block[o]     & 0xFF);
            long b1 = (long)((int)block[o + 1] & 0xFF);
            long b2 = (long)((int)block[o + 2] & 0xFF);
            long b3 = (long)((int)block[o + 3] & 0xFF);
            w[t] = ((b0 << 24) | (b1 << 16) | (b2 << 8) | b3) & 0xFFFFFFFFL;
            t = t + 1;
        }
        while (t < 64) {
            long s0 = (_rotr(w[t - 15], 7) ^ _rotr(w[t - 15], 18) ^ (w[t - 15] >> 3)) & 0xFFFFFFFFL;
            long s1 = (_rotr(w[t - 2],  17) ^ _rotr(w[t - 2],  19) ^ (w[t - 2]  >> 10)) & 0xFFFFFFFFL;
            w[t] = (w[t - 16] + s0 + w[t - 7] + s1) & 0xFFFFFFFFL;
            t = t + 1;
        }

        long a = h[0]; long b = h[1]; long c = h[2]; long d = h[3];
        long e = h[4]; long f = h[5]; long g = h[6]; long hh = h[7];

        int i = 0;
        while (i < 64) {
            long S1 = (_rotr(e, 6) ^ _rotr(e, 11) ^ _rotr(e, 25)) & 0xFFFFFFFFL;
            long ch = ((e & f) ^ ((e ^ 0xFFFFFFFFL) & g)) & 0xFFFFFFFFL;
            long t1 = (hh + S1 + ch + k[i] + w[i]) & 0xFFFFFFFFL;
            long S0 = (_rotr(a, 2) ^ _rotr(a, 13) ^ _rotr(a, 22)) & 0xFFFFFFFFL;
            long maj = ((a & b) ^ (a & c) ^ (b & c)) & 0xFFFFFFFFL;
            long t2 = (S0 + maj) & 0xFFFFFFFFL;

            hh = g;
            g = f;
            f = e;
            e = (d + t1) & 0xFFFFFFFFL;
            d = c;
            c = b;
            b = a;
            a = (t1 + t2) & 0xFFFFFFFFL;

            i = i + 1;
        }

        h[0] = (h[0] + a)  & 0xFFFFFFFFL;
        h[1] = (h[1] + b)  & 0xFFFFFFFFL;
        h[2] = (h[2] + c)  & 0xFFFFFFFFL;
        h[3] = (h[3] + d)  & 0xFFFFFFFFL;
        h[4] = (h[4] + e)  & 0xFFFFFFFFL;
        h[5] = (h[5] + f)  & 0xFFFFFFFFL;
        h[6] = (h[6] + g)  & 0xFFFFFFFFL;
        h[7] = (h[7] + hh) & 0xFFFFFFFFL;
    }

    static long _rotr(long x, int n) {
        long masked = x & 0xFFFFFFFFL;
        return ((masked >> n) | (masked << (32 - n))) & 0xFFFFFFFFL;
    }
}
