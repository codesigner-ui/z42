namespace Std.Crypto;

using Std;
using Std.Encoding;
using Std.Numerics;

// add-ecdsa-p256 (2026-05-28): ECDSA over the NIST P-256 (secp256r1) curve
// per FIPS 186-4 + RFC 6979 deterministic nonce. P-256 is the default
// curve for JWT ES256, TLS 1.3 default key share, X.509 cert PKI, etc.
//
// optimize-ecdsa-jacobian-coords (2026-06-05): scalar multiplication now
// runs in Jacobian coordinates (Z=1 lift on entry, single ModInverse on
// exit). For a = -3 the doubling specialisation uses the
// `M = 3·(X − Z²)·(X + Z²)` factorisation (≡ 3X² + a·Z⁴ when a = -3),
// avoiding the explicit `-3·Z⁴` term. Curve constants are parsed once per
// public entry. Output is byte-identical to the affine version — all
// existing test vectors pass unchanged.
//
// Curve: short Weierstrass `y² = x³ - 3x + b mod p`, a = -3.
//   p  = ffffffff00000001000000000000000000000000ffffffffffffffffffffffff
//   b  = 5ac635d8aa3a93e7b3ebbd55769886bc651d06b0cc53b0f63bce3c3e27d2604b
//   Gx = 6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296
//   Gy = 4fe342e2fe1a7f9b8ee7eb4a7c0f9e162bce33576b315ececbb6406837bf51f5
//   n  = ffffffff00000000ffffffffffffffffbce6faada7179e84f3b9cac2fc632551
//
// API surface mirrors `EcdsaSecp256k1` exactly — only the curve constants
// + the doubling formula differ.

public static class EcdsaP256 {
    // ── Public API ───────────────────────────────────────────────────────────

    public static byte[] GeneratePublicKey(byte[] privateScalar) {
        if (privateScalar.Length != 32) {
            throw new ArgumentException(
                "EcdsaP256: private scalar must be 32 bytes, got " + privateScalar.Length.ToString());
        }
        BigInt p = EcdsaP256._curvePrime();
        BigInt n = EcdsaP256._curveOrder();
        BigInt d = EcdsaP256._readBEBigInt(privateScalar);
        if (d.IsZero() || d.CompareTo(n) >= 0) {
            throw new ArgumentException("EcdsaP256: private scalar must be in [1, n-1]");
        }
        BigInt[] Q = EcdsaP256._scalarMultBase(d, p);
        if (Q == null) {
            throw new ArgumentException("EcdsaP256: degenerate public key (scalar produced identity)");
        }
        return EcdsaP256._pointToBytes(Q);
    }

    public static byte[] Sign(byte[] privateScalar, byte[] message) {
        if (privateScalar.Length != 32) {
            throw new ArgumentException(
                "EcdsaP256: private scalar must be 32 bytes, got " + privateScalar.Length.ToString());
        }
        BigInt p = EcdsaP256._curvePrime();
        BigInt n = EcdsaP256._curveOrder();
        BigInt d = EcdsaP256._readBEBigInt(privateScalar);
        if (d.IsZero() || d.CompareTo(n) >= 0) {
            throw new ArgumentException("EcdsaP256: private scalar must be in [1, n-1]");
        }
        byte[] hash = Sha256.Hash(message);
        BigInt e = EcdsaP256._truncateHash(hash, n);
        int attempt = 0;
        while (attempt < 16) {
            BigInt k = EcdsaP256._deterministicK(d, hash, n, attempt);
            BigInt[] R = EcdsaP256._scalarMultBase(k, p);
            if (R != null) {
                BigInt r = EcdsaP256._modN(R[0], n);
                if (!r.IsZero()) {
                    BigInt kInv = k.ModInverse(n);
                    BigInt s = EcdsaP256._modN(kInv.Multiply(e.Add(r.Multiply(d))), n);
                    if (!s.IsZero()) {
                        byte[] sig = new byte[64];
                        byte[] rBytes = EcdsaP256._writeBEBigInt(r, 32);
                        byte[] sBytes = EcdsaP256._writeBEBigInt(s, 32);
                        int i = 0;
                        while (i < 32) { sig[i] = rBytes[i]; sig[32 + i] = sBytes[i]; i = i + 1; }
                        return sig;
                    }
                }
            }
            attempt = attempt + 1;
        }
        throw new InvalidOperationException(
            "EcdsaP256.Sign: RFC 6979 candidate exhaustion (astronomically improbable)");
    }

    public static bool Verify(byte[] publicKey, byte[] message, byte[] signature) {
        if (publicKey.Length != 64) {
            throw new ArgumentException(
                "EcdsaP256.Verify: public key must be 64 bytes (X || Y), got " + publicKey.Length.ToString());
        }
        if (signature.Length != 64) {
            throw new ArgumentException(
                "EcdsaP256.Verify: signature must be 64 bytes (r || s), got " + signature.Length.ToString());
        }
        BigInt p = EcdsaP256._curvePrime();
        BigInt n = EcdsaP256._curveOrder();
        byte[] xBytes = new byte[32];
        byte[] yBytes = new byte[32];
        int i = 0;
        while (i < 32) { xBytes[i] = publicKey[i]; yBytes[i] = publicKey[32 + i]; i = i + 1; }
        BigInt qx = EcdsaP256._readBEBigInt(xBytes);
        BigInt qy = EcdsaP256._readBEBigInt(yBytes);
        if (qx.CompareTo(p) >= 0 || qy.CompareTo(p) >= 0) { return false; }
        BigInt[] Q = new BigInt[2];
        Q[0] = qx; Q[1] = qy;
        if (!EcdsaP256._isOnCurve(Q, p)) { return false; }
        byte[] rBytes = new byte[32];
        byte[] sBytes = new byte[32];
        int j = 0;
        while (j < 32) { rBytes[j] = signature[j]; sBytes[j] = signature[32 + j]; j = j + 1; }
        BigInt r = EcdsaP256._readBEBigInt(rBytes);
        BigInt s = EcdsaP256._readBEBigInt(sBytes);
        if (r.IsZero() || r.CompareTo(n) >= 0) { return false; }
        if (s.IsZero() || s.CompareTo(n) >= 0) { return false; }
        byte[] hash = Sha256.Hash(message);
        BigInt e = EcdsaP256._truncateHash(hash, n);
        BigInt sInv = s.ModInverse(n);
        BigInt u1 = EcdsaP256._modN(e.Multiply(sInv), n);
        BigInt u2 = EcdsaP256._modN(r.Multiply(sInv), n);
        BigInt[] u1G = EcdsaP256._scalarMultBase(u1, p);
        BigInt[] u2Q = EcdsaP256._scalarMult(u2, Q, p);
        BigInt[] R = EcdsaP256._pointAdd(u1G, u2Q, p);
        if (R == null) { return false; }
        BigInt x1ModN = EcdsaP256._modN(R[0], n);
        return x1ModN.CompareTo(r) == 0;
    }

    // ── Curve constants ──────────────────────────────────────────────────────

    static BigInt _curvePrime() {
        return BigInt.ParseHex("ffffffff00000001000000000000000000000000ffffffffffffffffffffffff");
    }
    static BigInt _curveOrder() {
        return BigInt.ParseHex("ffffffff00000000ffffffffffffffffbce6faada7179e84f3b9cac2fc632551");
    }
    static BigInt _curveB() {
        return BigInt.ParseHex("5ac635d8aa3a93e7b3ebbd55769886bc651d06b0cc53b0f63bce3c3e27d2604b");
    }
    static BigInt[] _basePoint() {
        BigInt[] G = new BigInt[2];
        G[0] = BigInt.ParseHex("6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296");
        G[1] = BigInt.ParseHex("4fe342e2fe1a7f9b8ee7eb4a7c0f9e162bce33576b315ececbb6406837bf51f5");
        return G;
    }

    // ── Field helpers ────────────────────────────────────────────────────────

    static BigInt _modP(BigInt a, BigInt p) {
        BigInt r = a.Mod(p);
        if (r._sign < 0) { r = r.Add(p); }
        return r;
    }
    static BigInt _modN(BigInt a, BigInt n) {
        BigInt r = a.Mod(n);
        if (r._sign < 0) { r = r.Add(n); }
        return r;
    }

    /// Verify `(x, y)` lies on the curve `y² = x³ - 3x + b mod p`.
    static bool _isOnCurve(BigInt[] P, BigInt p) {
        if (P == null) { return false; }
        BigInt x = P[0]; BigInt y = P[1];
        BigInt lhs = EcdsaP256._modP(y.Multiply(y), p);
        BigInt three = new BigInt(3L);
        BigInt rhs = EcdsaP256._modP(x.Multiply(x).Multiply(x).Subtract(three.Multiply(x)).Add(EcdsaP256._curveB()), p);
        return lhs.CompareTo(rhs) == 0;
    }

    /// Truncate / convert SHA-256 hash to a scalar mod n. For P-256 the
    /// hash and curve order are both 256-bit, so this is just a big-
    /// endian read + range check (no truncation in practice).
    static BigInt _truncateHash(byte[] hash, BigInt n) {
        BigInt e = EcdsaP256._readBEBigInt(hash);
        // For SHA-256 + P-256 sizes match; nothing to truncate.
        // If e ≥ n we reduce (FIPS 186-4 step 5 mod-n is implicit).
        if (e.CompareTo(n) >= 0) {
            e = e.Mod(n);
        }
        return e;
    }

    // ── Affine point arithmetic ──────────────────────────────────────────────
    // Used only for the final 2-point sum in Verify. Internal scalar mult
    // goes through Jacobian.

    /// Affine doubling on `y² = x³ - 3x + b` (a = -3 specialisation).
    static BigInt[] _pointDouble(BigInt[] P, BigInt p) {
        if (P == null) { return null; }
        BigInt y = P[1];
        if (y.IsZero()) { return null; }
        BigInt x = P[0];
        // λ = (3x² + a) / (2y); a = -3 → 3x² - 3 = 3(x-1)(x+1).
        BigInt three = new BigInt(3L);
        BigInt num = EcdsaP256._modP(three.Multiply(x.Multiply(x).Subtract(BigInt.One)), p);
        BigInt den = EcdsaP256._modP(y.Multiply(new BigInt(2L)), p);
        BigInt lam = EcdsaP256._modP(num.Multiply(den.ModInverse(p)), p);
        BigInt x3 = EcdsaP256._modP(lam.Multiply(lam).Subtract(x.Multiply(new BigInt(2L))), p);
        BigInt y3 = EcdsaP256._modP(lam.Multiply(x.Subtract(x3)).Subtract(y), p);
        BigInt[] R = new BigInt[2];
        R[0] = x3; R[1] = y3;
        return R;
    }

    /// Affine addition — handles P + (-Q) = identity, P + identity, identity + Q.
    static BigInt[] _pointAdd(BigInt[] P, BigInt[] Q, BigInt p) {
        if (P == null) { return Q; }
        if (Q == null) { return P; }
        BigInt px = P[0]; BigInt py = P[1];
        BigInt qx = Q[0]; BigInt qy = Q[1];
        if (px.CompareTo(qx) == 0) {
            BigInt sumY = EcdsaP256._modP(py.Add(qy), p);
            if (sumY.IsZero()) { return null; }
            return EcdsaP256._pointDouble(P, p);
        }
        BigInt num = EcdsaP256._modP(qy.Subtract(py), p);
        BigInt den = EcdsaP256._modP(qx.Subtract(px), p);
        BigInt lam = EcdsaP256._modP(num.Multiply(den.ModInverse(p)), p);
        BigInt x3 = EcdsaP256._modP(lam.Multiply(lam).Subtract(px).Subtract(qx), p);
        BigInt y3 = EcdsaP256._modP(lam.Multiply(px.Subtract(x3)).Subtract(py), p);
        BigInt[] R = new BigInt[2];
        R[0] = x3; R[1] = y3;
        return R;
    }

    // ── Jacobian point arithmetic (a = -3) ───────────────────────────────────
    // Jacobian rep `[X, Y, Z]` maps to affine `(x, y) = (X/Z², Y/Z³)`.
    // `Z = 0` represents the point at infinity. All field arithmetic stays
    // mod p; the single ModInverse is paid at `_jacToAffine` exit.

    /// Jacobian doubling, a = -3 specialisation using
    /// `M = 3·X² + a·Z⁴ = 3·(X − Z²)·(X + Z²)`:
    ///   A  = X − Z²
    ///   B  = X + Z²
    ///   M  = 3 A B
    ///   S  = 4 X Y²
    ///   X' = M² − 2 S
    ///   Y' = M (S − X') − 8 Y⁴
    ///   Z' = 2 Y Z
    /// One squaring (Z²) replaced one multiplication versus the generic
    /// `3X² − 3Z⁴` form — small but the M-trick is the canonical NIST
    /// curve recipe and matches the FIPS 186-4 reference implementations.
    static BigInt[] _jacDouble(BigInt[] J, BigInt p) {
        BigInt Y = J[1];
        BigInt Z = J[2];
        if (Z.IsZero() || Y.IsZero()) {
            BigInt[] inf = new BigInt[3];
            inf[0] = BigInt.One; inf[1] = BigInt.One; inf[2] = BigInt.Zero;
            return inf;
        }
        BigInt X = J[0];
        BigInt two   = new BigInt(2L);
        BigInt three = new BigInt(3L);
        BigInt four  = new BigInt(4L);
        BigInt eight = new BigInt(8L);
        BigInt Y2  = EcdsaP256._modP(Y.Multiply(Y), p);
        BigInt Y4  = EcdsaP256._modP(Y2.Multiply(Y2), p);
        BigInt Z2  = EcdsaP256._modP(Z.Multiply(Z), p);
        BigInt A   = EcdsaP256._modP(X.Subtract(Z2), p);
        BigInt B   = EcdsaP256._modP(X.Add(Z2), p);
        BigInt M   = EcdsaP256._modP(three.Multiply(A).Multiply(B), p);
        BigInt S   = EcdsaP256._modP(four.Multiply(X).Multiply(Y2), p);
        BigInt X3  = EcdsaP256._modP(M.Multiply(M).Subtract(two.Multiply(S)), p);
        BigInt Y3  = EcdsaP256._modP(M.Multiply(S.Subtract(X3)).Subtract(eight.Multiply(Y4)), p);
        BigInt Z3  = EcdsaP256._modP(two.Multiply(Y).Multiply(Z), p);
        BigInt[] R = new BigInt[3];
        R[0] = X3; R[1] = Y3; R[2] = Z3;
        return R;
    }

    /// Jacobian addition (generic; identical to secp256k1's — the curve
    /// parameter `a` does not appear in the addition formula).
    static BigInt[] _jacAdd(BigInt[] J1, BigInt[] J2, BigInt p) {
        if (J1[2].IsZero()) { return J2; }
        if (J2[2].IsZero()) { return J1; }
        BigInt X1 = J1[0]; BigInt Y1 = J1[1]; BigInt Z1 = J1[2];
        BigInt X2 = J2[0]; BigInt Y2 = J2[1]; BigInt Z2 = J2[2];
        BigInt Z1sq = EcdsaP256._modP(Z1.Multiply(Z1), p);
        BigInt Z2sq = EcdsaP256._modP(Z2.Multiply(Z2), p);
        BigInt Z1cu = EcdsaP256._modP(Z1sq.Multiply(Z1), p);
        BigInt Z2cu = EcdsaP256._modP(Z2sq.Multiply(Z2), p);
        BigInt U1   = EcdsaP256._modP(X1.Multiply(Z2sq), p);
        BigInt U2   = EcdsaP256._modP(X2.Multiply(Z1sq), p);
        BigInt S1   = EcdsaP256._modP(Y1.Multiply(Z2cu), p);
        BigInt S2   = EcdsaP256._modP(Y2.Multiply(Z1cu), p);
        if (U1.CompareTo(U2) == 0) {
            if (S1.CompareTo(S2) != 0) {
                BigInt[] inf = new BigInt[3];
                inf[0] = BigInt.One; inf[1] = BigInt.One; inf[2] = BigInt.Zero;
                return inf;
            }
            return EcdsaP256._jacDouble(J1, p);
        }
        BigInt H   = EcdsaP256._modP(U2.Subtract(U1), p);
        BigInt Rc  = EcdsaP256._modP(S2.Subtract(S1), p);
        BigInt H2  = EcdsaP256._modP(H.Multiply(H), p);
        BigInt H3  = EcdsaP256._modP(H2.Multiply(H), p);
        BigInt U1H2 = EcdsaP256._modP(U1.Multiply(H2), p);
        BigInt two  = new BigInt(2L);
        BigInt X3  = EcdsaP256._modP(Rc.Multiply(Rc).Subtract(H3).Subtract(two.Multiply(U1H2)), p);
        BigInt Y3  = EcdsaP256._modP(Rc.Multiply(U1H2.Subtract(X3)).Subtract(S1.Multiply(H3)), p);
        BigInt Z3  = EcdsaP256._modP(H.Multiply(Z1).Multiply(Z2), p);
        BigInt[] Rr = new BigInt[3];
        Rr[0] = X3; Rr[1] = Y3; Rr[2] = Z3;
        return Rr;
    }

    /// Convert Jacobian `[X, Y, Z]` back to affine `(x, y) = (X·Z⁻², Y·Z⁻³)`.
    /// Returns `null` (affine identity convention) when `Z == 0`.
    static BigInt[] _jacToAffine(BigInt[] J, BigInt p) {
        if (J[2].IsZero()) { return null; }
        BigInt Zinv  = J[2].ModInverse(p);
        BigInt Zinv2 = EcdsaP256._modP(Zinv.Multiply(Zinv), p);
        BigInt Zinv3 = EcdsaP256._modP(Zinv2.Multiply(Zinv), p);
        BigInt x = EcdsaP256._modP(J[0].Multiply(Zinv2), p);
        BigInt y = EcdsaP256._modP(J[1].Multiply(Zinv3), p);
        BigInt[] R = new BigInt[2];
        R[0] = x; R[1] = y;
        return R;
    }

    /// Scalar multiplication via Jacobian double-and-add (LSB-first). Lifts
    /// affine `P` to Jacobian `(X, Y, 1)`, runs the loop in Jacobian coords
    /// (zero ModInverse per iteration), then converts back to affine for the
    /// caller — preserving the old null-or-affine return convention.
    ///
    /// Not constant-time — adequate for verify-side public scalars; the
    /// sign-side scalar comes from RFC 6979 deterministic derivation so the
    /// leak surface is bounded to that mix.
    static BigInt[] _scalarMult(BigInt k, BigInt[] P, BigInt p) {
        BigInt[] R = new BigInt[3];
        R[0] = BigInt.One; R[1] = BigInt.One; R[2] = BigInt.Zero;   // Jacobian identity
        BigInt[] cur = new BigInt[3];
        cur[0] = P[0]; cur[1] = P[1]; cur[2] = BigInt.One;          // lift affine → Jacobian
        int bitLen = k.BitLength();
        int i = 0;
        while (i < bitLen) {
            if (k.TestBit(i)) {
                R = EcdsaP256._jacAdd(R, cur, p);
            }
            cur = EcdsaP256._jacDouble(cur, p);
            i = i + 1;
        }
        return EcdsaP256._jacToAffine(R, p);
    }

    static BigInt[] _scalarMultBase(BigInt k, BigInt p) {
        return EcdsaP256._scalarMult(k, EcdsaP256._basePoint(), p);
    }

    // ── Point serialisation ──────────────────────────────────────────────────

    /// Emit a non-identity point as 64-byte uncompressed `X || Y`.
    static byte[] _pointToBytes(BigInt[] P) {
        byte[] out_ = new byte[64];
        byte[] xBytes = EcdsaP256._writeBEBigInt(P[0], 32);
        byte[] yBytes = EcdsaP256._writeBEBigInt(P[1], 32);
        int i = 0;
        while (i < 32) { out_[i] = xBytes[i]; out_[32 + i] = yBytes[i]; i = i + 1; }
        return out_;
    }

    // ── RFC 6979 deterministic nonce (HMAC-SHA-256 based) ────────────────────
    //
    // Implements RFC 6979 §3.2 with HMAC-SHA-256. The `attempt` parameter
    // routes the rare retry loop: attempt 0 produces the "first candidate"
    // per the RFC; higher values re-enter the K/V update step.

    static BigInt _deterministicK(BigInt privateScalar, byte[] msgHash, BigInt n, int attempt) {
        // qlen = bit length of n (256 for P-256). rlen = 8 * ceil(qlen/8) = 256.
        // For P-256 qlen = rlen = 256, so int2octets and bits2octets are
        // identical mod-n conversion → 32-byte BE.
        byte[] x = EcdsaP256._writeBEBigInt(privateScalar, 32);
        byte[] h1 = EcdsaP256._writeBEBigInt(EcdsaP256._truncateHash(msgHash, n), 32);
        // V = 0x01 0x01 ... 0x01 (32 bytes); K = 0x00 ... 0x00 (32 bytes).
        byte[] V = new byte[32];
        byte[] K = new byte[32];
        int i = 0;
        while (i < 32) { V[i] = (byte)0x01; i = i + 1; }
        // K = HMAC_K(V || 0x00 || x || h1)
        byte[] inp = EcdsaP256._concat4(V, EcdsaP256._oneByte(0x00), x, h1);
        K = HmacSha256.Compute(K, inp);
        // V = HMAC_K(V)
        V = HmacSha256.Compute(K, V);
        // K = HMAC_K(V || 0x01 || x || h1)
        inp = EcdsaP256._concat4(V, EcdsaP256._oneByte(0x01), x, h1);
        K = HmacSha256.Compute(K, inp);
        // V = HMAC_K(V)
        V = HmacSha256.Compute(K, V);
        // Each retry loop iteration: T = HMAC_K(V); candidate = bits2int(T) mod n.
        // `attempt` lets the caller force later iterations if the first
        // produced r=0 or s=0 in the signing loop.
        int retry = 0;
        while (true) {
            V = HmacSha256.Compute(K, V);
            BigInt cand = EcdsaP256._readBEBigInt(V);
            // bits2int truncates / mods into [0, n).
            if (cand.CompareTo(n) >= 0) {
                cand = cand.Mod(n);
            }
            if (!cand.IsZero() && retry >= attempt) {
                return cand;
            }
            // Update K/V per RFC 6979 §3.2 step h.3.
            byte[] retryInp = EcdsaP256._concat2(V, EcdsaP256._oneByte(0x00));
            K = HmacSha256.Compute(K, retryInp);
            V = HmacSha256.Compute(K, V);
            retry = retry + 1;
            if (retry > 256) {
                throw new InvalidOperationException("EcdsaP256: RFC 6979 retry overflow");
            }
        }
        // Unreachable but z42 type-checker may want it.
        return BigInt.Zero;
    }

    // ── Helpers ──────────────────────────────────────────────────────────────

    static byte[] _oneByte(int v) {
        byte[] b = new byte[1];
        b[0] = (byte)(v & 0xFF);
        return b;
    }

    static byte[] _concat2(byte[] a, byte[] b) {
        byte[] r = new byte[a.Length + b.Length];
        int i = 0;
        while (i < a.Length) { r[i] = a[i]; i = i + 1; }
        int j = 0;
        while (j < b.Length) { r[a.Length + j] = b[j]; j = j + 1; }
        return r;
    }

    static byte[] _concat4(byte[] a, byte[] b, byte[] c, byte[] d) {
        byte[] r = new byte[a.Length + b.Length + c.Length + d.Length];
        int i = 0;
        while (i < a.Length) { r[i] = a[i]; i = i + 1; }
        int off = a.Length;
        int j = 0;
        while (j < b.Length) { r[off + j] = b[j]; j = j + 1; }
        off = off + b.Length;
        int k = 0;
        while (k < c.Length) { r[off + k] = c[k]; k = k + 1; }
        off = off + c.Length;
        int m = 0;
        while (m < d.Length) { r[off + m] = d[m]; m = m + 1; }
        return r;
    }

    static BigInt _readBEBigInt(byte[] bytes) {
        BigInt acc = BigInt.Zero;
        int i = 0;
        while (i < bytes.Length) {
            acc = acc.ShiftLeft(8).Add(new BigInt((long)((int)bytes[i] & 0xFF)));
            i = i + 1;
        }
        return acc;
    }

    static byte[] _writeBEBigInt(BigInt v, int n) {
        byte[] out_ = new byte[n];
        BigInt mask8 = new BigInt(255L);
        BigInt cur = v;
        int i = n - 1;
        while (i >= 0) {
            BigInt low = cur.And(mask8);
            out_[i] = (byte)(low.ToInt64() & 0xFFL);
            cur = cur.ShiftRight(8);
            i = i - 1;
        }
        return out_;
    }
}
