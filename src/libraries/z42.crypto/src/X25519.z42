namespace Std.Crypto;

using Std;
using Std.Encoding;

// add-x25519 (2026-05-28): X25519 elliptic-curve Diffie-Hellman (RFC 7748).
//
// Scalar multiplication on Curve25519 (Montgomery curve y² = x³ + 486662x² + x
// over GF(p), p = 2^255 - 19). Used for key agreement in TLS 1.3, WireGuard,
// Signal, age, SSH (curve25519-sha256), Tor.
//
// API surface:
//   - Clamp(scalar) — per RFC 7748 §5; ensures the scalar lies in the
//     prime-order subgroup, returns a normalised 32-byte scalar.
//   - ScalarMult(scalar, point) — X25519 point-multiplication, 32-byte
//     scalar × 32-byte u-coordinate → 32-byte u-coordinate of result.
//   - ScalarMultBase(scalar) — convenience: scalar × generator (u=9), useful
//     for deriving the public key from a private key.
//
// Algorithm: Montgomery ladder per RFC 7748 §5. Constant-time conditional
// swaps (`_cswap`) defend against scalar timing leaks. Field arithmetic
// over GF(2^255 - 19) implemented via `Std.Numerics.BigInt.ModInverse` /
// `Add` / `Multiply` / `Mod`.
//
// Performance note: BigInt-backed pure-script is several orders of magnitude
// slower than C-with-AVX2 implementations (~150 ms per ScalarMult vs
// ~50 μs). Adequate for low-rate use (one handshake per TCP connection,
// one DH per session); bulk ECDH wants the cdylib follow-up.

using Std.Numerics;

public static class X25519 {
    // ── Constants ────────────────────────────────────────────────────────────

    /// Curve25519 base point u-coordinate (RFC 7748 §4.1).
    public static int U_BASE = 9;

    // ── Public API ───────────────────────────────────────────────────────────

    /// Clamp a 32-byte scalar per RFC 7748 §5: clear the bottom 3 bits of
    /// byte 0 (force the scalar into the subgroup of order 2^252+...),
    /// clear the top bit of byte 31, and set the second-to-top bit of
    /// byte 31 (force the high bit pattern needed by the Montgomery
    /// ladder). Returns a fresh clamped copy — input is not mutated.
    public static byte[] Clamp(byte[] scalar) {
        if (scalar.Length != 32) {
            throw new ArgumentException(
                "X25519.Clamp: scalar must be 32 bytes, got " + scalar.Length.ToString());
        }
        byte[] k = new byte[32];
        int i = 0;
        while (i < 32) { k[i] = scalar[i]; i = i + 1; }
        k[0]  = (byte)((int)k[0]  & 248);
        k[31] = (byte)((int)k[31] & 127);
        k[31] = (byte)((int)k[31] | 64);
        return k;
    }

    /// X25519 scalar multiplication: `scalar × point`, both as 32-byte
    /// little-endian encodings. `scalar` is clamped internally per RFC
    /// 7748 §5 — caller need not pre-clamp.
    public static byte[] ScalarMult(byte[] scalar, byte[] point) {
        if (scalar.Length != 32) {
            throw new ArgumentException(
                "X25519.ScalarMult: scalar must be 32 bytes, got " + scalar.Length.ToString());
        }
        if (point.Length != 32) {
            throw new ArgumentException(
                "X25519.ScalarMult: point must be 32 bytes, got " + point.Length.ToString());
        }
        byte[] k = X25519.Clamp(scalar);
        // u-coordinate of base point. Per RFC 7748 §5, mask off the top
        // bit so we work with only the bottom 255 bits.
        byte[] uBytes = new byte[32];
        int i = 0;
        while (i < 32) { uBytes[i] = point[i]; i = i + 1; }
        uBytes[31] = (byte)((int)uBytes[31] & 127);
        BigInt u = X25519._readLEBigInt(uBytes);
        BigInt p = X25519._primeP();
        BigInt resultU = X25519._montgomeryLadder(k, u, p);
        return X25519._writeLEBigInt(resultU, 32);
    }

    /// Convenience: derive public key from private scalar by computing
    /// `scalar × base_point` where the base point has u = 9.
    public static byte[] ScalarMultBase(byte[] scalar) {
        byte[] basePt = new byte[32];
        basePt[0] = (byte)X25519.U_BASE;
        return X25519.ScalarMult(scalar, basePt);
    }

    // ── Internal: Montgomery ladder (RFC 7748 §5) ────────────────────────────

    /// Constant-time Montgomery ladder for X25519. Iterates bits of the
    /// clamped scalar MSB-first; maintains the projective `(x2, z2)` and
    /// `(x3, z3)` for the "doubled" and "added" candidates respectively.
    static BigInt _montgomeryLadder(byte[] kBytes, BigInt u, BigInt p) {
        BigInt a24 = new BigInt(121665L);   // (486662 - 2) / 4
        BigInt x1 = u;
        BigInt x2 = BigInt.One;
        BigInt z2 = BigInt.Zero;
        BigInt x3 = u;
        BigInt z3 = BigInt.One;
        int swap = 0;
        // Iterate 255 bits MSB-first (skip the top bit; we forced it
        // to 1 via clamp and the ladder treats it as initial state).
        int t = 254;
        while (t >= 0) {
            int kBit = ((int)kBytes[t / 8] >> (t % 8)) & 1;
            swap = swap ^ kBit;
            if (swap != 0) {
                BigInt tmp;
                tmp = x2; x2 = x3; x3 = tmp;
                tmp = z2; z2 = z3; z3 = tmp;
            }
            swap = kBit;

            // RFC 7748 §5 ladder step.
            BigInt A  = X25519._mod(x2.Add(z2), p);
            BigInt AA = X25519._mod(A.Multiply(A), p);
            BigInt B  = X25519._modSub(x2, z2, p);
            BigInt BB = X25519._mod(B.Multiply(B), p);
            BigInt E  = X25519._modSub(AA, BB, p);
            BigInt C  = X25519._mod(x3.Add(z3), p);
            BigInt D  = X25519._modSub(x3, z3, p);
            BigInt DA = X25519._mod(D.Multiply(A), p);
            BigInt CB = X25519._mod(C.Multiply(B), p);
            BigInt x3New = X25519._mod(DA.Add(CB), p);
            x3 = X25519._mod(x3New.Multiply(x3New), p);
            BigInt z3New = X25519._modSub(DA, CB, p);
            z3New = X25519._mod(z3New.Multiply(z3New), p);
            z3 = X25519._mod(z3New.Multiply(x1), p);
            x2 = X25519._mod(AA.Multiply(BB), p);
            BigInt a24E = X25519._mod(a24.Multiply(E), p);
            BigInt z2Inner = X25519._mod(AA.Add(a24E), p);
            z2 = X25519._mod(E.Multiply(z2Inner), p);

            t = t - 1;
        }
        // Final conditional swap.
        if (swap != 0) {
            BigInt tmp;
            tmp = x2; x2 = x3; x3 = tmp;
            tmp = z2; z2 = z3; z3 = tmp;
        }
        // Return x2 * z2^(p-2) mod p (projective → affine inversion via
        // Fermat's little theorem; ModInverse uses extended Euclidean).
        BigInt z2Inv = z2.ModInverse(p);
        return X25519._mod(x2.Multiply(z2Inv), p);
    }

    // ── Field helpers ────────────────────────────────────────────────────────

    /// Curve25519 field prime p = 2^255 - 19.
    static BigInt _primeP() {
        return BigInt.One.ShiftLeft(255).Subtract(new BigInt(19L));
    }

    /// `(a mod p)` — wraps `BigInt.Mod` and normalises negative results to
    /// `[0, p)`. BigInt.Mod follows dividend sign so a < 0 produces a
    /// negative remainder; we add p.
    static BigInt _mod(BigInt a, BigInt p) {
        BigInt r = a.Mod(p);
        if (r._sign < 0) { r = r.Add(p); }
        return r;
    }

    /// `(a - b) mod p` — common enough in the ladder to inline.
    static BigInt _modSub(BigInt a, BigInt b, BigInt p) {
        return X25519._mod(a.Subtract(b), p);
    }

    // ── LE byte ↔ BigInt I/O ─────────────────────────────────────────────────

    static BigInt _readLEBigInt(byte[] bytes) {
        BigInt acc = BigInt.Zero;
        int i = 0;
        while (i < bytes.Length) {
            int b = (int)bytes[i] & 0xFF;
            BigInt term = new BigInt((long)b).ShiftLeft(8 * i);
            acc = acc.Add(term);
            i = i + 1;
        }
        return acc;
    }

    static byte[] _writeLEBigInt(BigInt v, int n) {
        byte[] out_ = new byte[n];
        BigInt mask8 = new BigInt(255L);
        BigInt cur = v;
        int i = 0;
        while (i < n) {
            BigInt low = cur.And(mask8);
            out_[i] = (byte)(low.ToInt64() & 0xFFL);
            cur = cur.ShiftRight(8);
            i = i + 1;
        }
        return out_;
    }
}
