namespace Std.Crypto;

using Std;
using Std.Encoding;

// add-aes (2026-05-27): AES (FIPS 197) — Rijndael 128-bit block, 128 /
// 192 / 256-bit keys. Pure-script implementation (no FFI), matching the
// rest of z42.crypto. Tested against FIPS 197 Appendix C vectors +
// NIST SP 800-38A §F.5.1 CTR-mode vector.
//
// v0 scope:
//   - Single-block encrypt / decrypt (ECB primitive)
//   - CTR mode (RFC 3686-style: nonce || counter, counter starts at 0)
//
// Out of scope (separate follow-ups):
//   - CBC mode (caller can compose from EncryptBlock + XOR; native CBC
//     wrapper deferred to `aes-future-cbc`)
//   - GCM / AEAD (GHASH polynomial mul in pure-script is slow; native
//     cdylib path deferred to `aes-future-gcm`)
//   - Key Wrap (RFC 3394)
//   - HW-accelerated path (AES-NI / ARMv8 Crypto Extensions) — would
//     require cdylib backend (`aes-future-hw-accel`)
//
// Performance note: pure-script AES at z42-interp speeds is fine for
// low-rate use (token decryption, small-payload AEAD, protocol-message
// envelopes). Bulk encryption (>1 MB) wants the cdylib follow-up.

public static class Aes {
    // ── Public API ───────────────────────────────────────────────────────

    /// Encrypt one 16-byte block. `key` is 16, 24, or 32 bytes selecting
    /// AES-128 / AES-192 / AES-256. Throws `ArgumentException` on
    /// wrong-size key or non-16-byte plaintext.
    public static byte[] EncryptBlock(byte[] key, byte[] plaintext) {
        if (plaintext.Length != 16) {
            throw new ArgumentException("AES.EncryptBlock: plaintext must be 16 bytes");
        }
        int[] roundKeys = Aes._keyExpansion(key);
        int nr = (roundKeys.Length / 16) - 1;
        int[] state = Aes._bytesToState(plaintext);
        Aes._addRoundKey(state, roundKeys, 0);
        int r = 1;
        while (r < nr) {
            Aes._subBytes(state);
            Aes._shiftRows(state);
            Aes._mixColumns(state);
            Aes._addRoundKey(state, roundKeys, r * 16);
            r = r + 1;
        }
        Aes._subBytes(state);
        Aes._shiftRows(state);
        Aes._addRoundKey(state, roundKeys, nr * 16);
        return Aes._stateToBytes(state);
    }

    /// Decrypt one 16-byte block. Same key sizing as EncryptBlock.
    public static byte[] DecryptBlock(byte[] key, byte[] ciphertext) {
        if (ciphertext.Length != 16) {
            throw new ArgumentException("AES.DecryptBlock: ciphertext must be 16 bytes");
        }
        int[] roundKeys = Aes._keyExpansion(key);
        int nr = (roundKeys.Length / 16) - 1;
        int[] state = Aes._bytesToState(ciphertext);
        Aes._addRoundKey(state, roundKeys, nr * 16);
        int r = nr - 1;
        while (r > 0) {
            Aes._invShiftRows(state);
            Aes._invSubBytes(state);
            Aes._addRoundKey(state, roundKeys, r * 16);
            Aes._invMixColumns(state);
            r = r - 1;
        }
        Aes._invShiftRows(state);
        Aes._invSubBytes(state);
        Aes._addRoundKey(state, roundKeys, 0);
        return Aes._stateToBytes(state);
    }

    /// AES-CTR encrypt/decrypt (the same operation in CTR mode — XOR
    /// with the keystream).
    ///
    /// IV layout: 8-byte nonce || 8-byte big-endian counter starting at 0.
    /// Each block of plaintext is XOR'd with `AES(key, nonce||counter)`,
    /// counter increments per block. Total plaintext length ≤ 2^64 × 16
    /// bytes (i.e. effectively unbounded).
    ///
    /// Pass the same `nonce` and `key` for decrypt — the keystream is
    /// deterministic.
    public static byte[] EncryptCtr(byte[] key, byte[] nonce, byte[] data) {
        if (nonce.Length != 8) {
            throw new ArgumentException("AES.EncryptCtr: nonce must be 8 bytes");
        }
        byte[] out_ = new byte[data.Length];
        byte[] iv = new byte[16];
        int i = 0;
        while (i < 8) { iv[i] = nonce[i]; i = i + 1; }
        // Counter (bytes 8..15) starts at 0.
        long counter = 0L;
        int blocks = (data.Length + 15) / 16;
        int b = 0;
        while (b < blocks) {
            // Write counter big-endian into iv[8..15].
            iv[8]  = (byte)((counter >> 56) & 0xFFL);
            iv[9]  = (byte)((counter >> 48) & 0xFFL);
            iv[10] = (byte)((counter >> 40) & 0xFFL);
            iv[11] = (byte)((counter >> 32) & 0xFFL);
            iv[12] = (byte)((counter >> 24) & 0xFFL);
            iv[13] = (byte)((counter >> 16) & 0xFFL);
            iv[14] = (byte)((counter >> 8)  & 0xFFL);
            iv[15] = (byte)(counter & 0xFFL);
            byte[] keystream = Aes.EncryptBlock(key, iv);
            int off = b * 16;
            int blockLen = data.Length - off;
            if (blockLen > 16) { blockLen = 16; }
            int j = 0;
            while (j < blockLen) {
                out_[off + j] = (byte)((int)data[off + j] ^ (int)keystream[j]);
                j = j + 1;
            }
            counter = counter + 1L;
            b = b + 1;
        }
        return out_;
    }

    /// CTR is symmetric — decrypt is the same as encrypt.
    public static byte[] DecryptCtr(byte[] key, byte[] nonce, byte[] data) {
        return Aes.EncryptCtr(key, nonce, data);
    }

    /// AES-CBC encrypt with PKCS#7 padding (RFC 5652 §6.3 — pad to next
    /// 16-byte boundary; if input already aligned, append a full 16-byte
    /// padding block so unpad is always unambiguous).
    ///
    /// `iv` must be exactly 16 bytes. Output length is always
    /// `((data.Length / 16) + 1) * 16` due to mandatory padding.
    public static byte[] EncryptCbcPkcs7(byte[] key, byte[] iv, byte[] data) {
        if (iv.Length != 16) {
            throw new ArgumentException("AES.EncryptCbcPkcs7: IV must be 16 bytes");
        }
        int padLen = 16 - (data.Length % 16);
        int totalLen = data.Length + padLen;
        byte[] padded = new byte[totalLen];
        int i = 0;
        while (i < data.Length) { padded[i] = data[i]; i = i + 1; }
        // Pad bytes hold the pad length per PKCS#7.
        while (i < totalLen) { padded[i] = (byte)padLen; i = i + 1; }

        byte[] out_ = new byte[totalLen];
        byte[] prev = new byte[16];
        int k = 0;
        while (k < 16) { prev[k] = iv[k]; k = k + 1; }
        int blocks = totalLen / 16;
        int b = 0;
        while (b < blocks) {
            // XOR plaintext block with previous ciphertext block (IV for b=0).
            byte[] xored = new byte[16];
            int off = b * 16;
            int j = 0;
            while (j < 16) {
                xored[j] = (byte)((int)padded[off + j] ^ (int)prev[j]);
                j = j + 1;
            }
            byte[] enc = Aes.EncryptBlock(key, xored);
            j = 0;
            while (j < 16) { out_[off + j] = enc[j]; prev[j] = enc[j]; j = j + 1; }
            b = b + 1;
        }
        return out_;
    }

    /// AES-CBC decrypt with PKCS#7 unpadding. Throws `ArgumentException`
    /// if input length isn't a multiple of 16, or if padding is malformed
    /// (likely indicating wrong key / IV / corrupted ciphertext).
    public static byte[] DecryptCbcPkcs7(byte[] key, byte[] iv, byte[] data) {
        if (iv.Length != 16) {
            throw new ArgumentException("AES.DecryptCbcPkcs7: IV must be 16 bytes");
        }
        if (data.Length == 0 || data.Length % 16 != 0) {
            throw new ArgumentException(
                "AES.DecryptCbcPkcs7: ciphertext length must be a positive multiple of 16");
        }
        byte[] plain = new byte[data.Length];
        byte[] prev = new byte[16];
        int k = 0;
        while (k < 16) { prev[k] = iv[k]; k = k + 1; }
        int blocks = data.Length / 16;
        int b = 0;
        while (b < blocks) {
            int off = b * 16;
            byte[] ctBlock = new byte[16];
            int j = 0;
            while (j < 16) { ctBlock[j] = data[off + j]; j = j + 1; }
            byte[] dec = Aes.DecryptBlock(key, ctBlock);
            j = 0;
            while (j < 16) {
                plain[off + j] = (byte)((int)dec[j] ^ (int)prev[j]);
                prev[j] = ctBlock[j];
                j = j + 1;
            }
            b = b + 1;
        }
        // Validate + strip PKCS#7 padding.
        int padLen = (int)plain[data.Length - 1] & 0xFF;
        if (padLen < 1 || padLen > 16) {
            throw new ArgumentException(
                "AES.DecryptCbcPkcs7: invalid PKCS#7 padding length " + padLen.ToString());
        }
        int padStart = data.Length - padLen;
        int p = padStart;
        while (p < data.Length) {
            if (((int)plain[p] & 0xFF) != padLen) {
                throw new ArgumentException(
                    "AES.DecryptCbcPkcs7: corrupt PKCS#7 padding bytes");
            }
            p = p + 1;
        }
        byte[] out_ = new byte[padStart];
        int q = 0;
        while (q < padStart) { out_[q] = plain[q]; q = q + 1; }
        return out_;
    }

    // ── AES-CCM AEAD (NIST SP 800-38C / RFC 3610) ────────────────────────
    //
    // add-aes-ccm (2026-05-28): authenticated encryption with associated
    // data using CTR mode + CBC-MAC over a structured authentication
    // header. The "Counter with CBC-MAC" name describes the two-piece
    // construction.
    //
    // Used in: WPA2-CCMP (Wi-Fi link encryption), Bluetooth LE Secure
    // Connections, Zigbee, IEEE 802.15.4, TLS_PSK_WITH_AES_128_CCM_8,
    // many constrained-device protocols. Simpler than GCM (no GHASH
    // polynomial — uses standard CBC-MAC) which makes it more attractive
    // for resource-constrained hardware.
    //
    // Parameters:
    //   nonce   — N bytes, N in [7..13]. Length N determines max
    //             payload size: 2^(8*(15-N)) - 1 bytes
    //             (e.g. 13-byte nonce → max 65535 bytes payload).
    //   tagLen  — M bytes, M in {4, 6, 8, 10, 12, 14, 16}. RFC 3610
    //             permits these even values only.
    //   aad     — associated data of any length (authenticated, not
    //             encrypted).
    //
    // Output = ciphertext (len(plaintext) bytes) || tag (tagLen bytes).

    /// Encrypt + authenticate via AES-CCM. `nonce` length determines
    /// max payload size; `tagLen` controls auth-tag truncation.
    public static byte[] EncryptCcm(byte[] key, byte[] nonce, byte[] aad, byte[] plaintext, int tagLen) {
        Aes._ccmValidate(nonce, tagLen, plaintext.Length, aad.Length);
        byte[] tag = Aes._ccmComputeTag(key, nonce, aad, plaintext, tagLen);
        // S_0 = AES(key, CTR0); S_i = AES(key, CTRi) for i >= 1.
        // Ciphertext = plaintext XOR keystream (CTR0 reserved for tag).
        byte[] ciphertext = Aes._ccmCtrEncrypt(key, nonce, plaintext);
        // Encrypted tag = tag XOR S_0[0..tagLen]
        byte[] s0 = Aes._ccmCounterBlock(nonce, 0);
        byte[] s0enc = Aes.EncryptBlock(key, s0);
        byte[] encTag = new byte[tagLen];
        int t = 0;
        while (t < tagLen) {
            encTag[t] = (byte)((int)tag[t] ^ (int)s0enc[t]);
            t = t + 1;
        }
        byte[] out_ = new byte[ciphertext.Length + tagLen];
        int p = 0;
        while (p < ciphertext.Length) { out_[p] = ciphertext[p]; p = p + 1; }
        int q = 0;
        while (q < tagLen) { out_[ciphertext.Length + q] = encTag[q]; q = q + 1; }
        return out_;
    }

    /// Decrypt + verify via AES-CCM. Input = `ciphertext || encTag`
    /// where encTag is tagLen bytes. Throws `ArgumentException` on
    /// tag mismatch (do NOT swallow — tampering signal).
    public static byte[] DecryptCcm(byte[] key, byte[] nonce, byte[] aad, byte[] ctAndTag, int tagLen) {
        if (ctAndTag.Length < tagLen) {
            throw new ArgumentException("AES.DecryptCcm: input shorter than tag");
        }
        int ctLen = ctAndTag.Length - tagLen;
        Aes._ccmValidate(nonce, tagLen, ctLen, aad.Length);
        byte[] ciphertext = new byte[ctLen];
        int i = 0;
        while (i < ctLen) { ciphertext[i] = ctAndTag[i]; i = i + 1; }
        byte[] encTag = new byte[tagLen];
        int j = 0;
        while (j < tagLen) { encTag[j] = ctAndTag[ctLen + j]; j = j + 1; }
        // Decrypt ciphertext via CTR (same keystream as encrypt — CTR is
        // symmetric).
        byte[] plaintext = Aes._ccmCtrEncrypt(key, nonce, ciphertext);
        // Decrypt tag: expected = encTag XOR S_0[0..tagLen]
        byte[] s0 = Aes._ccmCounterBlock(nonce, 0);
        byte[] s0enc = Aes.EncryptBlock(key, s0);
        byte[] expected = new byte[tagLen];
        int t = 0;
        while (t < tagLen) {
            expected[t] = (byte)((int)encTag[t] ^ (int)s0enc[t]);
            t = t + 1;
        }
        byte[] actual = Aes._ccmComputeTag(key, nonce, aad, plaintext, tagLen);
        int diff = 0;
        int u = 0;
        while (u < tagLen) {
            diff = diff | ((int)expected[u] ^ (int)actual[u]);
            u = u + 1;
        }
        if (diff != 0) {
            throw new ArgumentException(
                "AES.DecryptCcm: authentication tag mismatch — ciphertext or AAD tampered");
        }
        return plaintext;
    }

    /// Input validation. nonce in [7..13]; tagLen in {4,6,8,10,12,14,16}.
    /// Plaintext-length cap = 2^(8 * (15 - nonceLen)) - 1.
    static void _ccmValidate(byte[] nonce, int tagLen, int ptLen, int aadLen) {
        int nLen = nonce.Length;
        if (nLen < 7 || nLen > 13) {
            throw new ArgumentException(
                "AES.CCM: nonce must be 7..13 bytes, got " + nLen.ToString());
        }
        bool tagOk = tagLen == 4 || tagLen == 6 || tagLen == 8 || tagLen == 10
                  || tagLen == 12 || tagLen == 14 || tagLen == 16;
        if (!tagOk) {
            throw new ArgumentException(
                "AES.CCM: tag length must be in {4,6,8,10,12,14,16}, got " + tagLen.ToString());
        }
        int qBytes = 15 - nLen;
        // Max ptLen = 2^(8 * qBytes) - 1. For qBytes >= 4 this is > 2^31 and
        // can't be exceeded by an int-sized length. For smaller qBytes:
        if (qBytes < 4) {
            long maxPt = (1L << (8 * qBytes)) - 1L;
            if ((long)ptLen > maxPt) {
                throw new ArgumentException(
                    "AES.CCM: plaintext length " + ptLen.ToString()
                    + " exceeds max " + maxPt.ToString() + " for nonce length " + nLen.ToString());
            }
        }
    }

    /// Build counter block: 1-byte flags || nonce || counter (qBytes BE).
    /// Flags byte for counters (RFC 3610 §2.3): top 3 bits 0; bottom 3 bits
    /// = qBytes - 1 (length-of-length-of-payload field).
    static byte[] _ccmCounterBlock(byte[] nonce, int counter) {
        int nLen  = nonce.Length;
        int qLen  = 15 - nLen;
        byte[] cb = new byte[16];
        cb[0] = (byte)(qLen - 1);   // flags
        int i = 0;
        while (i < nLen) { cb[1 + i] = nonce[i]; i = i + 1; }
        // Counter in last qLen bytes, big-endian. For our int counter
        // we only fill the low 4 bytes (rest stay zero).
        int p = qLen - 1;
        int j = 0;
        while (j < 4 && p >= 0) {
            cb[1 + nLen + p] = (byte)((counter >> (j * 8)) & 0xFF);
            p = p - 1;
            j = j + 1;
        }
        return cb;
    }

    /// CTR encryption / decryption with the CCM counter format.
    /// Counter starts at 1 (counter 0 is reserved for tag encryption).
    static byte[] _ccmCtrEncrypt(byte[] key, byte[] nonce, byte[] data) {
        byte[] out_ = new byte[data.Length];
        int blocks = (data.Length + 15) / 16;
        int b = 0;
        while (b < blocks) {
            byte[] cb = Aes._ccmCounterBlock(nonce, b + 1);
            byte[] ks = Aes.EncryptBlock(key, cb);
            int off = b * 16;
            int blockLen = data.Length - off;
            if (blockLen > 16) { blockLen = 16; }
            int j = 0;
            while (j < blockLen) {
                out_[off + j] = (byte)((int)data[off + j] ^ (int)ks[j]);
                j = j + 1;
            }
            b = b + 1;
        }
        return out_;
    }

    /// Compute the un-encrypted CCM authentication tag via CBC-MAC over
    /// the formatted authentication blocks (B_0 || L(aad) || aad ||
    /// pad || plaintext || pad).
    static byte[] _ccmComputeTag(byte[] key, byte[] nonce, byte[] aad, byte[] plaintext, int tagLen) {
        int nLen = nonce.Length;
        int qLen = 15 - nLen;
        // B_0: flags || nonce || Q (qLen bytes, BE plaintext length).
        // Flags byte: bit 6 = adata-flag (set if aad non-empty); bits 3-5 =
        // (tagLen - 2) / 2; bits 0-2 = qLen - 1.
        byte[] b0 = new byte[16];
        int flags = 0;
        if (aad.Length > 0) { flags = flags | 0x40; }
        flags = flags | (((tagLen - 2) / 2) << 3);
        flags = flags | (qLen - 1);
        b0[0] = (byte)flags;
        int i = 0;
        while (i < nLen) { b0[1 + i] = nonce[i]; i = i + 1; }
        // Plaintext length in last qLen bytes, big-endian.
        int ptLen = plaintext.Length;
        int p = qLen - 1;
        int j = 0;
        while (j < 4 && p >= 0) {
            b0[1 + nLen + p] = (byte)((ptLen >> (j * 8)) & 0xFF);
            p = p - 1;
            j = j + 1;
        }
        // CBC-MAC: X_0 = 0; X_{i+1} = AES(key, X_i XOR B_i)
        byte[] x = Aes.EncryptBlock(key, b0);
        // AAD blocks: prefix with length encoding per RFC 3610 §2.2:
        //   - 0 < L < 2^16 - 2^8:    2 bytes BE
        //   - 2^16 - 2^8 ≤ L < 2^32: 6 bytes 0xFFFE || 4-byte BE
        //   - L >= 2^32:             10 bytes 0xFFFF || 8-byte BE
        // Then the aad bytes themselves, then zero-pad to 16-byte boundary.
        if (aad.Length > 0) {
            byte[] aadBlock = Aes._ccmFormatAad(aad);
            int abks = aadBlock.Length / 16;
            int ai = 0;
            while (ai < abks) {
                int k = 0;
                while (k < 16) { x[k] = (byte)((int)x[k] ^ (int)aadBlock[ai * 16 + k]); k = k + 1; }
                x = Aes.EncryptBlock(key, x);
                ai = ai + 1;
            }
        }
        // Plaintext blocks: zero-pad to 16-byte boundary.
        int ptBlocks = (plaintext.Length + 15) / 16;
        int pi = 0;
        while (pi < ptBlocks) {
            int off = pi * 16;
            int remaining = plaintext.Length - off;
            if (remaining > 16) { remaining = 16; }
            int k = 0;
            while (k < remaining) { x[k] = (byte)((int)x[k] ^ (int)plaintext[off + k]); k = k + 1; }
            // Bytes beyond `remaining` XOR with 0 — no-op.
            x = Aes.EncryptBlock(key, x);
            pi = pi + 1;
        }
        // Truncate to tagLen.
        byte[] tag = new byte[tagLen];
        int t = 0;
        while (t < tagLen) { tag[t] = x[t]; t = t + 1; }
        return tag;
    }

    /// Format AAD with length prefix per RFC 3610 §2.2, then pad to
    /// 16-byte boundary. Returns the padded block array.
    static byte[] _ccmFormatAad(byte[] aad) {
        int aLen = aad.Length;
        int prefixLen;
        byte[] prefix;
        if (aLen < 0xFF00) {
            // 2-byte BE length.
            prefixLen = 2;
            prefix = new byte[2];
            prefix[0] = (byte)((aLen >> 8) & 0xFF);
            prefix[1] = (byte)(aLen & 0xFF);
        } else {
            // 0xFF 0xFE || 4-byte BE length. (z42 int max is 2^31, so the
            // 8-byte variant for L >= 2^32 isn't reachable.)
            prefixLen = 6;
            prefix = new byte[6];
            prefix[0] = (byte)0xFF;
            prefix[1] = (byte)0xFE;
            prefix[2] = (byte)((aLen >> 24) & 0xFF);
            prefix[3] = (byte)((aLen >> 16) & 0xFF);
            prefix[4] = (byte)((aLen >> 8)  & 0xFF);
            prefix[5] = (byte)(aLen & 0xFF);
        }
        int total = prefixLen + aLen;
        int padded = ((total + 15) / 16) * 16;
        byte[] out_ = new byte[padded];
        int i = 0;
        while (i < prefixLen) { out_[i] = prefix[i]; i = i + 1; }
        int j = 0;
        while (j < aLen) { out_[prefixLen + j] = aad[j]; j = j + 1; }
        // Pad bytes already zero.
        return out_;
    }

    // ── AES-GCM AEAD (NIST SP 800-38D) ───────────────────────────────────
    //
    // add-aes-gcm (2026-05-27): authenticated encryption with associated
    // data. Tag length fixed at 16 bytes (NIST recommends ≥ 12; we don't
    // expose shorter tags to dodge the truncation footguns documented in
    // RFC 5116 §5.3).
    //
    // IV: 12 bytes recommended (96-bit IV path of NIST SP 800-38D §7.1 —
    // a single AES block J0 = IV || 0x00000001 with the bottom 32 bits
    // serving as the counter). Other IV lengths route through the GHASH
    // derivation but the 96-bit path is the only "fast" and widely-used
    // form so v0 hard-requires it; callers wanting non-96-bit IV should
    // wait for the cdylib backend (aes-future-hw-accel) or compose
    // manually via GHASH + EncryptBlock.
    //
    // Pure-script GHASH (bit-by-bit, no PCLMUL) is slow — bulk encryption
    // (> tens of KB) wants the cdylib follow-up. For low-rate use (token
    // envelopes, single-message AEAD, protocol headers) pure-script
    // throughput is adequate.

    /// Encrypt + authenticate. Output = ciphertext (same length as
    /// `plaintext`) || tag (16 bytes appended at the end).
    ///
    /// IV length: 12 bytes (96-bit) is the recommended common case and
    /// gets the fast J0 = IV || 0x00000001 path. Other IV lengths route
    /// through the GHASH-derived J0 formula per NIST SP 800-38D §7.1 —
    /// adds 1 extra GHASH chain pass over the IV. IV.Length == 0 is
    /// rejected (the all-zero J0 case is a security pitfall — same key
    /// across messages would all use the same counter stream).
    public static byte[] EncryptGcm(byte[] key, byte[] iv, byte[] aad, byte[] plaintext) {
        if (iv.Length == 0) {
            throw new ArgumentException("AES.EncryptGcm: IV must be non-empty");
        }
        byte[] h = Aes.EncryptBlock(key, new byte[16]);
        byte[] j0 = Aes._gcmDeriveJ0(h, iv);
        // Encrypt with counter incremented from J0.
        byte[] counter = new byte[16];
        int k = 0;
        while (k < 16) { counter[k] = j0[k]; k = k + 1; }
        Aes._gcmInc32(counter);
        byte[] ciphertext = Aes._gcmCtr(key, counter, plaintext);
        byte[] tag = Aes._gcmComputeTag(key, h, j0, aad, ciphertext);
        // Concatenate ciphertext || tag.
        byte[] out_ = new byte[ciphertext.Length + 16];
        int p = 0;
        while (p < ciphertext.Length) { out_[p] = ciphertext[p]; p = p + 1; }
        int q = 0;
        while (q < 16) { out_[ciphertext.Length + q] = tag[q]; q = q + 1; }
        return out_;
    }

    /// Decrypt + verify. Input = ciphertext || 16-byte tag. Throws
    /// `ArgumentException` if the tag mismatches (DO NOT swallow this —
    /// a tag failure means the ciphertext or AAD was tampered with).
    public static byte[] DecryptGcm(byte[] key, byte[] iv, byte[] aad, byte[] ctAndTag) {
        if (iv.Length == 0) {
            throw new ArgumentException("AES.DecryptGcm: IV must be non-empty");
        }
        if (ctAndTag.Length < 16) {
            throw new ArgumentException("AES.DecryptGcm: input shorter than 16-byte tag");
        }
        int ctLen = ctAndTag.Length - 16;
        byte[] ciphertext = new byte[ctLen];
        int i = 0;
        while (i < ctLen) { ciphertext[i] = ctAndTag[i]; i = i + 1; }
        byte[] expected = new byte[16];
        int j = 0;
        while (j < 16) { expected[j] = ctAndTag[ctLen + j]; j = j + 1; }

        byte[] h = Aes.EncryptBlock(key, new byte[16]);
        byte[] j0 = Aes._gcmDeriveJ0(h, iv);

        byte[] actual = Aes._gcmComputeTag(key, h, j0, aad, ciphertext);
        // Constant-time compare to avoid leaking position of mismatch.
        int diff = 0;
        int t = 0;
        while (t < 16) {
            diff = diff | ((int)actual[t] ^ (int)expected[t]);
            t = t + 1;
        }
        if (diff != 0) {
            throw new ArgumentException(
                "AES.DecryptGcm: authentication tag mismatch — ciphertext or AAD tampered");
        }
        // Tag OK — decrypt.
        byte[] counter = new byte[16];
        int m = 0;
        while (m < 16) { counter[m] = j0[m]; m = m + 1; }
        Aes._gcmInc32(counter);
        return Aes._gcmCtr(key, counter, ciphertext);
    }

    /// Derive J0 from a variable-length IV per NIST SP 800-38D §7.1.
    /// 96-bit IV (12 bytes): fast path J0 = IV || 0x00000001.
    /// Other lengths: J0 = GHASH_H(IV || pad-zeros || len(IV)_64-bit-BE
    /// in bits). The GHASH-derived path adds one extra chain pass over
    /// the IV but otherwise composes with the same downstream code.
    static byte[] _gcmDeriveJ0(byte[] h, byte[] iv) {
        if (iv.Length == 12) {
            byte[] j0 = new byte[16];
            int i = 0;
            while (i < 12) { j0[i] = iv[i]; i = i + 1; }
            j0[15] = (byte)1;
            return j0;
        }
        // GHASH derivation path. Construct the input: IV padded to
        // 128-bit boundary || 8 zero bytes || len(IV)_64-bit-BE in bits.
        int ivPad = (16 - (iv.Length % 16)) % 16;
        int total = iv.Length + ivPad + 16;
        byte[] buf = new byte[total];
        int i = 0;
        while (i < iv.Length) { buf[i] = iv[i]; i = i + 1; }
        // Pad bytes already zero.
        // Length field: bits 0..63 = 0; bits 64..127 = iv length in bits, BE.
        long ivBits = ((long)iv.Length) * 8L;
        Aes._gcmWriteBE64(buf, total - 8, ivBits);
        // Run GHASH over the buffer.
        long[] hLong = Aes._gcmBytesToLongs(h);
        long[] y = new long[2];
        int blocks = total / 16;
        int b = 0;
        while (b < blocks) {
            long[] x = Aes._gcmBytesToLongs128(buf, b * 16);
            y[0] = y[0] ^ x[0];
            y[1] = y[1] ^ x[1];
            long[] r = Aes._gcmGfMul(y, hLong);
            y[0] = r[0]; y[1] = r[1];
            b = b + 1;
        }
        return Aes._gcmLongsToBytes(y);
    }

    /// 32-bit big-endian increment of the last 4 bytes of `block`.
    /// Wraps modulo 2^32 (NIST SP 800-38D §6.2).
    static void _gcmInc32(byte[] block) {
        long c = ((long)((int)block[12] & 0xFF) << 24)
               | ((long)((int)block[13] & 0xFF) << 16)
               | ((long)((int)block[14] & 0xFF) << 8)
               |  (long)((int)block[15] & 0xFF);
        c = (c + 1L) & 0xFFFFFFFFL;
        block[12] = (byte)((c >> 24) & 0xFFL);
        block[13] = (byte)((c >> 16) & 0xFFL);
        block[14] = (byte)((c >>  8) & 0xFFL);
        block[15] = (byte)( c        & 0xFFL);
    }

    /// GCTR with explicit starting counter (`counter` is the FIRST counter
    /// used — not J0, but the post-inc32(J0) value for AEAD).
    static byte[] _gcmCtr(byte[] key, byte[] counter, byte[] data) {
        byte[] out_ = new byte[data.Length];
        byte[] cb = new byte[16];
        int k = 0;
        while (k < 16) { cb[k] = counter[k]; k = k + 1; }
        int blocks = (data.Length + 15) / 16;
        int b = 0;
        while (b < blocks) {
            byte[] ks = Aes.EncryptBlock(key, cb);
            int off = b * 16;
            int blockLen = data.Length - off;
            if (blockLen > 16) { blockLen = 16; }
            int j = 0;
            while (j < blockLen) {
                out_[off + j] = (byte)((int)data[off + j] ^ (int)ks[j]);
                j = j + 1;
            }
            Aes._gcmInc32(cb);
            b = b + 1;
        }
        return out_;
    }

    /// Compute GCM authentication tag:
    ///   S = GHASH_H(AAD || 0^v || C || 0^u || len(AAD) || len(C))
    ///   T = AES_K(J0) XOR S
    /// Lengths are encoded as 64-bit big-endian *bit* counts.
    static byte[] _gcmComputeTag(byte[] key, byte[] h, byte[] j0, byte[] aad, byte[] ciphertext) {
        // Build the GHASH input — AAD padded to 16 + ciphertext padded to
        // 16 + length-field block (8 bytes AAD bits BE, 8 bytes CT bits BE).
        int aadPad = (16 - (aad.Length % 16)) % 16;
        int ctPad  = (16 - (ciphertext.Length % 16)) % 16;
        int total  = aad.Length + aadPad + ciphertext.Length + ctPad + 16;
        byte[] buf = new byte[total];
        int off = 0;
        int i = 0;
        while (i < aad.Length) { buf[off + i] = aad[i]; i = i + 1; }
        off = off + aad.Length + aadPad;
        int j = 0;
        while (j < ciphertext.Length) { buf[off + j] = ciphertext[j]; j = j + 1; }
        off = off + ciphertext.Length + ctPad;
        // Length fields (in BITS, 64-bit big-endian).
        long aadBits = ((long)aad.Length) * 8L;
        long ctBits  = ((long)ciphertext.Length) * 8L;
        Aes._gcmWriteBE64(buf, off,      aadBits);
        Aes._gcmWriteBE64(buf, off + 8,  ctBits);
        // Chain GHASH over the buffer.
        long[] hLong = Aes._gcmBytesToLongs(h);
        long[] y = new long[2];   // accumulator, starts at 0
        int blocks = total / 16;
        int b = 0;
        while (b < blocks) {
            long[] x = Aes._gcmBytesToLongs128(buf, b * 16);
            y[0] = y[0] ^ x[0];
            y[1] = y[1] ^ x[1];
            long[] r = Aes._gcmGfMul(y, hLong);
            y[0] = r[0]; y[1] = r[1];
            b = b + 1;
        }
        byte[] s = Aes._gcmLongsToBytes(y);
        // T = AES(K, J0) XOR S
        byte[] ej0 = Aes.EncryptBlock(key, j0);
        byte[] tag = new byte[16];
        int t = 0;
        while (t < 16) {
            tag[t] = (byte)((int)ej0[t] ^ (int)s[t]);
            t = t + 1;
        }
        return tag;
    }

    /// GHASH polynomial multiplication in GF(2^128) with reduction by
    /// `x^128 + x^7 + x^2 + x + 1`. NIST SP 800-38D §6.3. Bit-by-bit —
    /// slow but correct; cdylib path (PCLMUL) is `aes-future-hw-accel`.
    ///
    /// Convention: x[0] is the MS 64 bits (bit 127 is x[0]'s top bit),
    /// x[1] is the LS 64 bits. Shifting toward LSB corresponds to
    /// dividing by `x` in the field; reduction polynomial R = 0xE1 << 120.
    static long[] _gcmGfMul(long[] x, long[] y) {
        long z0 = 0L;
        long z1 = 0L;
        long v0 = y[0];
        long v1 = y[1];
        int i = 0;
        while (i < 128) {
            // Test bit i of x in MSB-first order.
            long bit;
            if (i < 64) {
                bit = Aes._lshr64(x[0], 63 - i) & 1L;
            } else {
                bit = Aes._lshr64(x[1], 127 - i) & 1L;
            }
            if (bit != 0L) {
                z0 = z0 ^ v0;
                z1 = z1 ^ v1;
            }
            // v >>>= 1 (across the 128-bit value), then conditional XOR
            // with the reduction polynomial in the high byte if LSB was 1.
            long carry = v1 & 1L;
            v1 = Aes._lshr64(v1, 1) | (v0 << 63);
            v0 = Aes._lshr64(v0, 1);
            if (carry != 0L) {
                // R = 0xE1 placed at the top byte = 0xE100000000000000
                v0 = v0 ^ 0xE100000000000000L;
            }
            i = i + 1;
        }
        long[] out_ = new long[2];
        out_[0] = z0;
        out_[1] = z1;
        return out_;
    }

    /// Logical right shift on long (`>>` arithmetic-extends for negative).
    static long _lshr64(long x, int n) {
        if (n == 0) return x;
        if (x >= 0L) return x >> n;
        return (x >> n) ^ ((-1L) << (64 - n));
    }

    /// 16-byte block → (hi64, lo64) big-endian.
    static long[] _gcmBytesToLongs(byte[] b) {
        long[] out_ = new long[2];
        out_[0] = Aes._gcmReadBE64(b, 0);
        out_[1] = Aes._gcmReadBE64(b, 8);
        return out_;
    }

    static long[] _gcmBytesToLongs128(byte[] b, int offset) {
        long[] out_ = new long[2];
        out_[0] = Aes._gcmReadBE64(b, offset);
        out_[1] = Aes._gcmReadBE64(b, offset + 8);
        return out_;
    }

    static byte[] _gcmLongsToBytes(long[] x) {
        byte[] out_ = new byte[16];
        Aes._gcmWriteBE64(out_, 0, x[0]);
        Aes._gcmWriteBE64(out_, 8, x[1]);
        return out_;
    }

    static long _gcmReadBE64(byte[] b, int o) {
        long b0 = (long)((int)b[o]     & 0xFF);
        long b1 = (long)((int)b[o + 1] & 0xFF);
        long b2 = (long)((int)b[o + 2] & 0xFF);
        long b3 = (long)((int)b[o + 3] & 0xFF);
        long b4 = (long)((int)b[o + 4] & 0xFF);
        long b5 = (long)((int)b[o + 5] & 0xFF);
        long b6 = (long)((int)b[o + 6] & 0xFF);
        long b7 = (long)((int)b[o + 7] & 0xFF);
        return (b0 << 56) | (b1 << 48) | (b2 << 40) | (b3 << 32)
             | (b4 << 24) | (b5 << 16) | (b6 <<  8) | b7;
    }

    static void _gcmWriteBE64(byte[] b, int o, long v) {
        b[o]     = (byte)(Aes._lshr64(v, 56) & 0xFFL);
        b[o + 1] = (byte)(Aes._lshr64(v, 48) & 0xFFL);
        b[o + 2] = (byte)(Aes._lshr64(v, 40) & 0xFFL);
        b[o + 3] = (byte)(Aes._lshr64(v, 32) & 0xFFL);
        b[o + 4] = (byte)(Aes._lshr64(v, 24) & 0xFFL);
        b[o + 5] = (byte)(Aes._lshr64(v, 16) & 0xFFL);
        b[o + 6] = (byte)(Aes._lshr64(v,  8) & 0xFFL);
        b[o + 7] = (byte)(v & 0xFFL);
    }

    // ── Key Expansion (FIPS 197 §5.2) ────────────────────────────────────

    /// Returns flat int[] of (Nr+1) * 16 bytes — round key R occupies
    /// indices [R*16 .. R*16+15]. z42 lacks `int[][]` jagged arrays, so
    /// we flatten and let callers index by round number.
    /// Nr = 10 for AES-128, 12 for AES-192, 14 for AES-256.
    static int[] _keyExpansion(byte[] key) {
        int nk;
        int nr;
        if (key.Length == 16)      { nk = 4;  nr = 10; }
        else if (key.Length == 24) { nk = 6;  nr = 12; }
        else if (key.Length == 32) { nk = 8;  nr = 14; }
        else {
            throw new ArgumentException(
                "AES: key length must be 16 / 24 / 32 bytes, got " + key.Length.ToString());
        }

        // Per FIPS 197: total 4 × (Nr + 1) 32-bit words. We store as
        // 4-byte rows in a flat int[] (one int per byte) for easy access.
        int totalWords = 4 * (nr + 1);  // e.g. 44 / 52 / 60
        int[] w = new int[totalWords * 4];  // flat byte view

        // Copy original key into the first Nk words.
        int i = 0;
        while (i < nk * 4) {
            w[i] = (int)key[i] & 0xFF;
            i = i + 1;
        }

        // Round constants (Rcon[1..]) — leading high byte of each Rcon
        // word; the lower 3 bytes are zero. Computed as powers of 2 in
        // GF(2^8) per FIPS 197 §5.2.
        int[] rcon = Aes._rconTable();

        int wordIdx = nk;
        while (wordIdx < totalWords) {
            // Take the previous word (4 bytes at offset (wordIdx-1)*4).
            int p = (wordIdx - 1) * 4;
            int t0 = w[p];     int t1 = w[p + 1];
            int t2 = w[p + 2]; int t3 = w[p + 3];

            if (wordIdx % nk == 0) {
                // RotWord: cyclic left shift by 1 byte.
                int tmp = t0; t0 = t1; t1 = t2; t2 = t3; t3 = tmp;
                // SubWord: S-box each byte.
                int[] sb = Aes._sbox();
                t0 = sb[t0]; t1 = sb[t1]; t2 = sb[t2]; t3 = sb[t3];
                // XOR with round constant.
                t0 = t0 ^ rcon[wordIdx / nk];
            } else if (nk > 6 && wordIdx % nk == 4) {
                // AES-256 extra SubWord step every Nk=8 words.
                int[] sb = Aes._sbox();
                t0 = sb[t0]; t1 = sb[t1]; t2 = sb[t2]; t3 = sb[t3];
            }

            // w[wordIdx] = w[wordIdx - nk] XOR t (byte-wise).
            int q = (wordIdx - nk) * 4;
            int o = wordIdx * 4;
            w[o]     = w[q]     ^ t0;
            w[o + 1] = w[q + 1] ^ t1;
            w[o + 2] = w[q + 2] ^ t2;
            w[o + 3] = w[q + 3] ^ t3;
            wordIdx = wordIdx + 1;
        }

        // w is already the flat layout (one int per byte) the cipher loop
        // wants — `w[R*16 + k]` is byte k of round key R.
        return w;
    }

    // ── State transforms (FIPS 197 §5.1) ─────────────────────────────────

    /// State is 16 ints (0..255 each), column-major: state[c*4 + r] is
    /// the byte at row r, column c. Matches FIPS 197's diagram.
    static int[] _bytesToState(byte[] input) {
        int[] s = new int[16];
        int i = 0;
        while (i < 16) {
            s[i] = (int)input[i] & 0xFF;
            i = i + 1;
        }
        return s;
    }

    static byte[] _stateToBytes(int[] state) {
        byte[] out_ = new byte[16];
        int i = 0;
        while (i < 16) { out_[i] = (byte)(state[i] & 0xFF); i = i + 1; }
        return out_;
    }

    static void _addRoundKey(int[] state, int[] roundKeys, int off) {
        int i = 0;
        while (i < 16) {
            state[i] = state[i] ^ roundKeys[off + i];
            i = i + 1;
        }
    }

    static void _subBytes(int[] state) {
        int[] sb = Aes._sbox();
        int i = 0;
        while (i < 16) { state[i] = sb[state[i]]; i = i + 1; }
    }

    static void _invSubBytes(int[] state) {
        int[] isb = Aes._invSbox();
        int i = 0;
        while (i < 16) { state[i] = isb[state[i]]; i = i + 1; }
    }

    /// ShiftRows: row r is cyclically shifted left by r positions
    /// (over the 4 columns). FIPS 197 §5.1.2.
    /// State indexing: state[c*4 + r] is (row r, column c).
    static void _shiftRows(int[] state) {
        // Row 1: shift left by 1 → (1,0)←(1,1), (1,1)←(1,2), ...
        int t = state[0*4 + 1];
        state[0*4 + 1] = state[1*4 + 1];
        state[1*4 + 1] = state[2*4 + 1];
        state[2*4 + 1] = state[3*4 + 1];
        state[3*4 + 1] = t;
        // Row 2: shift left by 2 → swap (col0↔col2) and (col1↔col3).
        t = state[0*4 + 2]; state[0*4 + 2] = state[2*4 + 2]; state[2*4 + 2] = t;
        t = state[1*4 + 2]; state[1*4 + 2] = state[3*4 + 2]; state[3*4 + 2] = t;
        // Row 3: shift left by 3 (≡ shift right by 1).
        t = state[3*4 + 3];
        state[3*4 + 3] = state[2*4 + 3];
        state[2*4 + 3] = state[1*4 + 3];
        state[1*4 + 3] = state[0*4 + 3];
        state[0*4 + 3] = t;
    }

    static void _invShiftRows(int[] state) {
        // Row 1: shift right by 1.
        int t = state[3*4 + 1];
        state[3*4 + 1] = state[2*4 + 1];
        state[2*4 + 1] = state[1*4 + 1];
        state[1*4 + 1] = state[0*4 + 1];
        state[0*4 + 1] = t;
        // Row 2: shift right by 2 ≡ same as forward shift by 2.
        t = state[0*4 + 2]; state[0*4 + 2] = state[2*4 + 2]; state[2*4 + 2] = t;
        t = state[1*4 + 2]; state[1*4 + 2] = state[3*4 + 2]; state[3*4 + 2] = t;
        // Row 3: shift right by 3 (≡ shift left by 1).
        t = state[0*4 + 3];
        state[0*4 + 3] = state[1*4 + 3];
        state[1*4 + 3] = state[2*4 + 3];
        state[2*4 + 3] = state[3*4 + 3];
        state[3*4 + 3] = t;
    }

    /// MixColumns: per column c, multiply the 4-byte vector by the
    /// matrix [[2,3,1,1],[1,2,3,1],[1,1,2,3],[3,1,1,2]] over GF(2^8).
    static void _mixColumns(int[] state) {
        int c = 0;
        while (c < 4) {
            int s0 = state[c*4 + 0];
            int s1 = state[c*4 + 1];
            int s2 = state[c*4 + 2];
            int s3 = state[c*4 + 3];
            state[c*4 + 0] = Aes._xtime(s0) ^ (Aes._xtime(s1) ^ s1) ^ s2 ^ s3;
            state[c*4 + 1] = s0 ^ Aes._xtime(s1) ^ (Aes._xtime(s2) ^ s2) ^ s3;
            state[c*4 + 2] = s0 ^ s1 ^ Aes._xtime(s2) ^ (Aes._xtime(s3) ^ s3);
            state[c*4 + 3] = (Aes._xtime(s0) ^ s0) ^ s1 ^ s2 ^ Aes._xtime(s3);
            c = c + 1;
        }
    }

    /// Inverse MixColumns: matrix [[14,11,13,9],[9,14,11,13],[13,9,14,11],
    /// [11,13,9,14]] over GF(2^8).
    static void _invMixColumns(int[] state) {
        int c = 0;
        while (c < 4) {
            int s0 = state[c*4 + 0];
            int s1 = state[c*4 + 1];
            int s2 = state[c*4 + 2];
            int s3 = state[c*4 + 3];
            state[c*4 + 0] = Aes._gmul(s0, 14) ^ Aes._gmul(s1, 11) ^ Aes._gmul(s2, 13) ^ Aes._gmul(s3, 9);
            state[c*4 + 1] = Aes._gmul(s0, 9)  ^ Aes._gmul(s1, 14) ^ Aes._gmul(s2, 11) ^ Aes._gmul(s3, 13);
            state[c*4 + 2] = Aes._gmul(s0, 13) ^ Aes._gmul(s1, 9)  ^ Aes._gmul(s2, 14) ^ Aes._gmul(s3, 11);
            state[c*4 + 3] = Aes._gmul(s0, 11) ^ Aes._gmul(s1, 13) ^ Aes._gmul(s2, 9)  ^ Aes._gmul(s3, 14);
            c = c + 1;
        }
    }

    // ── GF(2^8) helpers ──────────────────────────────────────────────────

    /// xtime: multiply by 2 in GF(2^8) with reduction by AES polynomial
    /// x^8 + x^4 + x^3 + x + 1 (0x11B). If high bit set, XOR 0x1B after shift.
    static int _xtime(int b) {
        int shifted = (b << 1) & 0xFF;
        if ((b & 0x80) != 0) { return shifted ^ 0x1B; }
        return shifted;
    }

    /// Russian-peasant multiplication in GF(2^8) (FIPS 197 §4.2.1).
    static int _gmul(int a, int b) {
        int result = 0;
        int aa = a;
        int bb = b;
        int i = 0;
        while (i < 8) {
            if ((bb & 1) != 0) { result = result ^ aa; }
            aa = Aes._xtime(aa);
            bb = bb >> 1;
            i = i + 1;
        }
        return result & 0xFF;
    }

    // ── Tables ───────────────────────────────────────────────────────────

    /// AES S-box (FIPS 197 Table 4).
    static int[] _sbox() {
        int[] s = new int[256];
        // Row 0
        s[0x00]=0x63; s[0x01]=0x7c; s[0x02]=0x77; s[0x03]=0x7b; s[0x04]=0xf2; s[0x05]=0x6b; s[0x06]=0x6f; s[0x07]=0xc5;
        s[0x08]=0x30; s[0x09]=0x01; s[0x0a]=0x67; s[0x0b]=0x2b; s[0x0c]=0xfe; s[0x0d]=0xd7; s[0x0e]=0xab; s[0x0f]=0x76;
        s[0x10]=0xca; s[0x11]=0x82; s[0x12]=0xc9; s[0x13]=0x7d; s[0x14]=0xfa; s[0x15]=0x59; s[0x16]=0x47; s[0x17]=0xf0;
        s[0x18]=0xad; s[0x19]=0xd4; s[0x1a]=0xa2; s[0x1b]=0xaf; s[0x1c]=0x9c; s[0x1d]=0xa4; s[0x1e]=0x72; s[0x1f]=0xc0;
        s[0x20]=0xb7; s[0x21]=0xfd; s[0x22]=0x93; s[0x23]=0x26; s[0x24]=0x36; s[0x25]=0x3f; s[0x26]=0xf7; s[0x27]=0xcc;
        s[0x28]=0x34; s[0x29]=0xa5; s[0x2a]=0xe5; s[0x2b]=0xf1; s[0x2c]=0x71; s[0x2d]=0xd8; s[0x2e]=0x31; s[0x2f]=0x15;
        s[0x30]=0x04; s[0x31]=0xc7; s[0x32]=0x23; s[0x33]=0xc3; s[0x34]=0x18; s[0x35]=0x96; s[0x36]=0x05; s[0x37]=0x9a;
        s[0x38]=0x07; s[0x39]=0x12; s[0x3a]=0x80; s[0x3b]=0xe2; s[0x3c]=0xeb; s[0x3d]=0x27; s[0x3e]=0xb2; s[0x3f]=0x75;
        s[0x40]=0x09; s[0x41]=0x83; s[0x42]=0x2c; s[0x43]=0x1a; s[0x44]=0x1b; s[0x45]=0x6e; s[0x46]=0x5a; s[0x47]=0xa0;
        s[0x48]=0x52; s[0x49]=0x3b; s[0x4a]=0xd6; s[0x4b]=0xb3; s[0x4c]=0x29; s[0x4d]=0xe3; s[0x4e]=0x2f; s[0x4f]=0x84;
        s[0x50]=0x53; s[0x51]=0xd1; s[0x52]=0x00; s[0x53]=0xed; s[0x54]=0x20; s[0x55]=0xfc; s[0x56]=0xb1; s[0x57]=0x5b;
