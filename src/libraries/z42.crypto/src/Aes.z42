    /// Rcon table — high byte of each round constant word.
    /// rcon[i] = 2^(i-1) in GF(2^8) for i >= 1; rcon[0] unused.
    static int[] _rconTable() {
        // For AES-128/192/256, max needed Rcon index is 10 (AES-128 uses
        // up to rcon[10]). Compute up to 11 to be safe.
        int[] r = new int[11];
        r[0] = 0x00;  // unused
        r[1] = 0x01;
        int i = 2;
        while (i < 11) {
            r[i] = Aes._xtime(r[i - 1]);
            i = i + 1;
        }
        return r;
    }
}
