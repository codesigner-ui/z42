namespace Std.Crypto;

using Std;
using Std.Encoding;

// add-crypto-pbkdf2 (2026-05-27): PBKDF2-HMAC-SHA256 (RFC 8018 §5.2).
//
// 用于密码哈希 / KDF 场景。比 SHA-256 直接哈希慢约 `iterations` 倍 —
// 典型生产值 100 000；本实现 pure-z42 over `HmacSha256`，比 Rust 原生 ~20×
// 慢，但对 password verification 100 ms 级别完全够用。
//
// API mirror BCL `Rfc2898DeriveBytes` (但 z42 不引入对应类型，直接用 static
// 方法 + byte[] in/out)。
//
// Algorithm (RFC 8018):
//   T(i) = U1 XOR U2 XOR ... XOR Uc      (c = iterations)
//     U1 = HMAC(P, S || INT(i))           (INT is 4-byte big-endian)
//     U2 = HMAC(P, U1) ... Uc = HMAC(P, Uc-1)
//   DK = T(1) || T(2) || ... || T(l)      (l = ceil(dkLen / hLen))
//
// Output truncated to `dkLen` bytes.
public static class Pbkdf2 {
    // ── Public API ───────────────────────────────────────────────────────────

    /// PBKDF2-HMAC-SHA256. Returns `dkLen` derived bytes.
    /// Throws `ArgumentException` for `iterations < 1` or `dkLen < 1`.
    public static byte[] DeriveKey(byte[] password, byte[] salt, int iterations, int dkLen) {
        if (iterations < 1) {
            throw new ArgumentException(
                "Pbkdf2: iterations must be >= 1, got " + Int32.ToString(iterations));
        }
        if (dkLen < 1) {
            throw new ArgumentException(
                "Pbkdf2: dkLen must be >= 1, got " + Int32.ToString(dkLen));
        }
        // RFC limit: dkLen <= (2^32 - 1) * hLen — for SHA-256 (hLen=32) that's
        // effectively 137 GB, far beyond any sane caller. No runtime check.

        int hLen = 32;                                  // SHA-256 output size
        int blocks = (dkLen + hLen - 1) / hLen;         // ceil(dkLen / hLen)
        byte[] result = new byte[dkLen];
        int copied = 0;

        int blockIdx = 1;
        while (blockIdx <= blocks) {
            byte[] T = _computeBlock(password, salt, iterations, blockIdx);
            int take = hLen;
            if (copied + take > dkLen) {
                take = dkLen - copied;
            }
            int i = 0;
            while (i < take) {
                result[copied + i] = T[i];
                i = i + 1;
            }
            copied = copied + take;
            blockIdx = blockIdx + 1;
        }
        return result;
    }

    /// String-password / string-salt convenience. Encodes as UTF-8.
    public static byte[] DeriveKeyString(
        string password, string salt, int iterations, int dkLen) {
        return DeriveKey(Utf8.GetBytes(password), Utf8.GetBytes(salt), iterations, dkLen);
    }

    /// Returns lowercase hex (length = 2 * dkLen).
    public static string DeriveKeyHex(
        byte[] password, byte[] salt, int iterations, int dkLen) {
        return Hex.Encode(DeriveKey(password, salt, iterations, dkLen));
    }

    public static string DeriveKeyStringHex(
        string password, string salt, int iterations, int dkLen) {
        return Hex.Encode(DeriveKeyString(password, salt, iterations, dkLen));
    }

    // ── Internals ────────────────────────────────────────────────────────────

    // T(i) — one 32-byte block of derived key material.
    static byte[] _computeBlock(byte[] password, byte[] salt, int iterations, int blockIdx) {
        // U1 = HMAC(P, S || INT(blockIdx))  — INT is 4-byte big-endian.
        byte[] saltExt = new byte[salt.Length + 4];
        int i = 0;
        while (i < salt.Length) { saltExt[i] = salt[i]; i = i + 1; }
        saltExt[salt.Length + 0] = (byte)((blockIdx >> 24) & 0xFF);
        saltExt[salt.Length + 1] = (byte)((blockIdx >> 16) & 0xFF);
        saltExt[salt.Length + 2] = (byte)((blockIdx >> 8)  & 0xFF);
        saltExt[salt.Length + 3] = (byte)( blockIdx        & 0xFF);

        byte[] u = HmacSha256.Compute(password, saltExt);
        byte[] T = new byte[32];
        int k = 0;
        while (k < 32) { T[k] = u[k]; k = k + 1; }

        // U2..Uc — chain HMAC over previous U; XOR into T.
        int c = 2;
        while (c <= iterations) {
            u = HmacSha256.Compute(password, u);
            k = 0;
            while (k < 32) {
                T[k] = (byte)((int)T[k] ^ (int)u[k]);
                k = k + 1;
            }
            c = c + 1;
        }
        return T;
    }
}
