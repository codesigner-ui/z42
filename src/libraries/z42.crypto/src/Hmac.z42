namespace Std.Crypto;

using Std;
using Std.Encoding;

// add-hmac-sha256 (2026-05-24): HMAC-SHA256 (RFC 2104).
//
// Pure-script over `Sha256`. Naming mirrors `Sha256` convention exactly —
// distinct method names per parameter type rather than overloads (z42 当前
// overload 解析对 byte[] vs string 有 ambiguity，参考 BinaryWriter /
// JsonValue.Parse 同一坑；与 Sha256 / HashString / HashHex / HashStringHex
// 命名风格一致是 stdlib 既定方向）。
//
// Algorithm (RFC 2104):
//   K'    = if len(K) > 64 then SHA256(K) else K right-padded with 0x00 to 64
//   inner = SHA256( (K' XOR 0x36 repeated 64) || msg )
//   HMAC  = SHA256( (K' XOR 0x5C repeated 64) || inner )
//
// Class name mirrors .NET BCL `HMACSHA256`. Future SHA-384/512 variants
// land as `HmacSha384` / `HmacSha512` sibling classes.
//
// Tested against RFC 4231 §4.2-4.4, §4.5, §4.7, §4.8 test vectors. §4.6
// (truncation HMAC-SHA-256-128) skipped — users can `result[:16]` if needed.
public static class HmacSha256 {
    // ── Public API ───────────────────────────────────────────────────────────

    /// HMAC-SHA256 of `message` keyed by `key`. Returns 32-byte digest.
    public static byte[] Compute(byte[] key, byte[] message) {
        byte[] paddedKey = _padKey(key);

        // Inner: SHA256( (K' XOR ipad) || message )
        byte[] inner = new byte[64 + message.Length];
        int i = 0;
        while (i < 64) {
            inner[i] = (byte)((int)paddedKey[i] ^ 0x36);
            i = i + 1;
        }
        i = 0;
        while (i < message.Length) {
            inner[64 + i] = message[i];
            i = i + 1;
        }
        byte[] innerHash = Sha256.Hash(inner);

        // Outer: SHA256( (K' XOR opad) || innerHash )
        byte[] outer = new byte[64 + 32];
        i = 0;
        while (i < 64) {
            outer[i] = (byte)((int)paddedKey[i] ^ 0x5C);
            i = i + 1;
        }
        i = 0;
        while (i < 32) {
            outer[64 + i] = innerHash[i];
            i = i + 1;
        }
        return Sha256.Hash(outer);
    }

    /// HMAC-SHA256 with string key + string message (UTF-8 encoded). Returns 32 bytes.
    public static byte[] ComputeString(string key, string message) {
        byte[] keyBytes = Utf8.GetBytes(key);
        byte[] msgBytes = Utf8.GetBytes(message);
        return Compute(keyBytes, msgBytes);
    }

    /// HMAC-SHA256 returning lowercase hex (64 chars).
    public static string ComputeHex(byte[] key, byte[] message) {
        return Hex.Encode(Compute(key, message));
    }

    /// HMAC-SHA256 with string key + message, returning lowercase hex.
    public static string ComputeStringHex(string key, string message) {
        byte[] keyBytes = Utf8.GetBytes(key);
        byte[] msgBytes = Utf8.GetBytes(message);
        return Hex.Encode(Compute(keyBytes, msgBytes));
    }

    // ── Internals ────────────────────────────────────────────────────────────

    /// Normalise key to exactly 64 bytes (SHA-256 block size):
    /// - longer  → SHA-256 the key first (32 bytes), then 0x00-pad to 64
    /// - shorter → right-pad with 0x00
    /// - exact   → copy (defensive — XOR pad will mutate the buffer)
    static byte[] _padKey(byte[] key) {
        byte[] padded = new byte[64];
        if (key.Length > 64) {
            byte[] digest = Sha256.Hash(key);
            int i = 0;
            while (i < 32) {
                padded[i] = digest[i];
                i = i + 1;
            }
            // bytes [32..63] already 0 from `new byte[64]`
        } else {
            int i = 0;
            while (i < key.Length) {
                padded[i] = key[i];
                i = i + 1;
            }
            // bytes [key.Length..63] already 0
        }
        return padded;
    }
}

// add-sha1-to-crypto (2026-05-25): HMAC-SHA-1 (RFC 2104) — mirrors
// HmacSha256 layout exactly. Block size 64 same as SHA-256; digest 20 bytes.
//
// ⚠️ Use HMAC-SHA-1 only when interoperability with legacy systems requires
// it (TOTP RFC 6238 default, AWS Signature V2, etc.). Prefer HMAC-SHA-256
// for new designs — see Sha1.z42 SHAttered note.
public static class HmacSha1 {
    public static byte[] Compute(byte[] key, byte[] message) {
        return _computeCore(key, message);
    }

    static byte[] _computeCore(byte[] key, byte[] message) {
        byte[] paddedKey = _padKey(key);

        // Inner: SHA1( (K' XOR ipad) || message )
        byte[] inner = new byte[64 + message.Length];
        int i = 0;
        while (i < 64) {
            inner[i] = (byte)((int)paddedKey[i] ^ 0x36);
            i = i + 1;
        }
        i = 0;
        while (i < message.Length) {
            inner[64 + i] = message[i];
            i = i + 1;
        }
        byte[] innerHash = Sha1.Hash(inner);

        // Outer: SHA1( (K' XOR opad) || innerHash )  (20-byte inner digest)
        byte[] outer = new byte[64 + 20];
        i = 0;
        while (i < 64) {
            outer[i] = (byte)((int)paddedKey[i] ^ 0x5C);
            i = i + 1;
        }
        i = 0;
        while (i < 20) {
            outer[64 + i] = innerHash[i];
            i = i + 1;
        }
        return Sha1.Hash(outer);
    }

    public static byte[] ComputeString(string key, string message) {
        byte[] keyBytes = Utf8.GetBytes(key);
        byte[] msgBytes = Utf8.GetBytes(message);
        return _computeCore(keyBytes, msgBytes);
    }

    public static string ComputeHex(byte[] key, byte[] message) {
        return Hex.Encode(_computeCore(key, message));
    }

    public static string ComputeStringHex(string key, string message) {
        byte[] keyBytes = Utf8.GetBytes(key);
        byte[] msgBytes = Utf8.GetBytes(message);
        return Hex.Encode(_computeCore(keyBytes, msgBytes));
    }

    /// Normalise key to 64 bytes — longer hash via SHA-1 (20 bytes) then
    /// zero-pad to 64; shorter right-pad with 0x00.
    static byte[] _padKey(byte[] key) {
        byte[] padded = new byte[64];
        if (key.Length > 64) {
            byte[] digest = Sha1.Hash(key);
            int i = 0;
            while (i < 20) {
                padded[i] = digest[i];
                i = i + 1;
            }
        } else {
            int i = 0;
            while (i < key.Length) {
                padded[i] = key[i];
                i = i + 1;
            }
        }
        return padded;
    }
}

// add-hmac-sha512-sha384 (2026-05-27): HMAC-SHA-512 (RFC 2104).
//
// Block size 128 (vs SHA-256's 64); digest 64 bytes. Same naming
// convention as HmacSha256 — distinct method names per param-type to
// dodge z42's name-only overload resolution.
//
// Tested against RFC 4231 §4.2-4.8 test vectors.
public static class HmacSha512 {
    public static byte[] Compute(byte[] key, byte[] message) {
        return HmacSha512._computeCore(key, message);
    }

    static byte[] _computeCore(byte[] key, byte[] message) {
        byte[] paddedKey = HmacSha512._padKey(key);

        // Inner: SHA512( (K' XOR ipad 128 bytes) || message )
        byte[] inner = new byte[128 + message.Length];
        int i = 0;
        while (i < 128) {
            inner[i] = (byte)((int)paddedKey[i] ^ 0x36);
            i = i + 1;
        }
        i = 0;
        while (i < message.Length) {
            inner[128 + i] = message[i];
            i = i + 1;
        }
        byte[] innerHash = Sha512.Hash(inner);

        // Outer: SHA512( (K' XOR opad 128 bytes) || innerHash 64 bytes )
        byte[] outer = new byte[128 + 64];
        i = 0;
        while (i < 128) {
            outer[i] = (byte)((int)paddedKey[i] ^ 0x5C);
            i = i + 1;
        }
        i = 0;
        while (i < 64) {
            outer[128 + i] = innerHash[i];
            i = i + 1;
        }
        return Sha512.Hash(outer);
    }

    public static byte[] ComputeString(string key, string message) {
        byte[] keyBytes = Utf8.GetBytes(key);
        byte[] msgBytes = Utf8.GetBytes(message);
        return HmacSha512._computeCore(keyBytes, msgBytes);
    }

    public static string ComputeHex(byte[] key, byte[] message) {
        return Hex.Encode(HmacSha512._computeCore(key, message));
    }

    public static string ComputeStringHex(string key, string message) {
        byte[] keyBytes = Utf8.GetBytes(key);
        byte[] msgBytes = Utf8.GetBytes(message);
        return Hex.Encode(HmacSha512._computeCore(keyBytes, msgBytes));
    }

    /// Normalise key to 128 bytes (SHA-512 block size):
    /// - longer (> 128) → SHA-512 the key (64 bytes), zero-pad to 128
    /// - shorter → right-pad with 0x00
    static byte[] _padKey(byte[] key) {
        byte[] padded = new byte[128];
        if (key.Length > 128) {
            byte[] digest = Sha512.Hash(key);
            int i = 0;
            while (i < 64) {
                padded[i] = digest[i];
                i = i + 1;
            }
        } else {
            int i = 0;
            while (i < key.Length) {
                padded[i] = key[i];
                i = i + 1;
            }
        }
        return padded;
    }
}

// add-hmac-sha512-sha384 (2026-05-27): HMAC-SHA-384 (RFC 2104).
//
// Same block size (128 bytes) as HMAC-SHA-512 — SHA-384 shares the
// compression function. Inner / outer hashes use SHA-384 so the digest
// is 48 bytes instead of 64.
public static class HmacSha384 {
    public static byte[] Compute(byte[] key, byte[] message) {
        return HmacSha384._computeCore(key, message);
    }

    static byte[] _computeCore(byte[] key, byte[] message) {
        byte[] paddedKey = HmacSha384._padKey(key);

        byte[] inner = new byte[128 + message.Length];
        int i = 0;
        while (i < 128) {
            inner[i] = (byte)((int)paddedKey[i] ^ 0x36);
            i = i + 1;
        }
        i = 0;
        while (i < message.Length) {
            inner[128 + i] = message[i];
            i = i + 1;
        }
        byte[] innerHash = Sha384.Hash(inner);

        // Outer: SHA384( (K' XOR opad) || innerHash 48 bytes )
        byte[] outer = new byte[128 + 48];
        i = 0;
        while (i < 128) {
            outer[i] = (byte)((int)paddedKey[i] ^ 0x5C);
            i = i + 1;
        }
        i = 0;
        while (i < 48) {
            outer[128 + i] = innerHash[i];
            i = i + 1;
        }
        return Sha384.Hash(outer);
    }

    public static byte[] ComputeString(string key, string message) {
        byte[] keyBytes = Utf8.GetBytes(key);
        byte[] msgBytes = Utf8.GetBytes(message);
        return HmacSha384._computeCore(keyBytes, msgBytes);
    }

    public static string ComputeHex(byte[] key, byte[] message) {
        return Hex.Encode(HmacSha384._computeCore(key, message));
    }

    public static string ComputeStringHex(string key, string message) {
        byte[] keyBytes = Utf8.GetBytes(key);
        byte[] msgBytes = Utf8.GetBytes(message);
        return Hex.Encode(HmacSha384._computeCore(keyBytes, msgBytes));
    }

    /// Same 128-byte block as HMAC-SHA-512; long key hashed via SHA-384
    /// (48 bytes) then zero-padded.
    static byte[] _padKey(byte[] key) {
        byte[] padded = new byte[128];
        if (key.Length > 128) {
            byte[] digest = Sha384.Hash(key);
            int i = 0;
            while (i < 48) {
                padded[i] = digest[i];
                i = i + 1;
            }
        } else {
            int i = 0;
            while (i < key.Length) {
                padded[i] = key[i];
                i = i + 1;
            }
        }
        return padded;
    }
}
