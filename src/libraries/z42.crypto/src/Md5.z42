namespace Std.Crypto;

using Std;
using Std.Encoding;

// add-md5-to-crypto (2026-05-31): MD5 hash (RFC 1321).
//
// ⚠️ MD5 is COMPROMISED for collision-resistant uses (Wang et al 2004;
// chosen-prefix collision Stevens 2007). Do NOT use MD5 for any new
// content addressing, signing, or password storage. The function exists
// in stdlib only for legacy-interop scenarios where the protocol or
// data format mandates it:
//
//   - HTTP Digest authentication (RFC 2617 / RFC 7616 algorithm=MD5)
//   - HTTP ETag headers compatible with Apache / nginx defaults
//   - Git "dumb HTTP" protocol pack object IDs
//   - MySQL `OLD_PASSWORD()`, APR1, CRAM-MD5 SASL legacy auth
//   - Torrent .info hashes (BitTorrent v1)
//
// Pure-script implementation mirroring `Sha1`. State held as `long` (i64)
// masked to 32 bits at every op boundary — z42 `int` is signed i32 and
// overflows on the message schedule additions. Byte order is
// little-endian throughout (RFC 1321 §3.4) — opposite of SHA-1.
//
// Tested against RFC 1321 §A.5 + NIST CAVP `MD5LongMsg` vectors.
public static class Md5 {
    // ── Public API ───────────────────────────────────────────────────────

    public static byte[] Hash(byte[] data) {
        byte[] padded = _pad(data);
        long[] h = _initialHash();
        int blocks = padded.Length / 64;
        int b = 0;
        while (b < blocks) {
            _processBlock(h, padded, b * 64);
            b = b + 1;
        }
        byte[] digest = new byte[16];
        int i = 0;
        while (i < 4) {
            long v = h[i];
            // Little-endian output (RFC 1321 §3.5)
            digest[i * 4 + 0] = (byte)( v        & 0xFFL);
            digest[i * 4 + 1] = (byte)((v >> 8)  & 0xFFL);
            digest[i * 4 + 2] = (byte)((v >> 16) & 0xFFL);
            digest[i * 4 + 3] = (byte)((v >> 24) & 0xFFL);
            i = i + 1;
        }
        return digest;
    }

    public static byte[] HashString(string s) {
        return Hash(Utf8.GetBytes(s));
    }

    public static string HashHex(byte[] data) {
        return Hex.Encode(Hash(data));
    }

    public static string HashStringHex(string s) {
        if (s.Length == 0) return Hex.Encode(Hash(new byte[0]));
        return Hex.Encode(Hash(Utf8.GetBytes(s)));
    }

    // ── RFC 1321 §3.3 initial hash values (little-endian) ───────────────

    static long[] _initialHash() {
        long[] h = new long[4];
        h[0] = 0x67452301L;
        h[1] = 0xEFCDAB89L;
        h[2] = 0x98BADCFEL;
        h[3] = 0x10325476L;
        return h;
    }

    // ── RFC 1321 §3.1-3.2 pre-processing: pad + LE length ──────────────

    static byte[] _pad(byte[] data) {
        long bitLen = (long)data.Length * 8L;
        int padZeros = (56 - (data.Length + 1) % 64 + 64) % 64;
        int totalLen = data.Length + 1 + padZeros + 8;
        byte[] padded = new byte[totalLen];
        int i = 0;
        while (i < data.Length) { padded[i] = data[i]; i = i + 1; }
        padded[data.Length] = (byte)0x80;
        // Length appended as 64-bit LITTLE-endian (RFC 1321 §3.2) —
        // opposite of SHA-1/2's big-endian length.
        int lenOffset = totalLen - 8;
        padded[lenOffset + 0] = (byte)( bitLen        & 0xFFL);
        padded[lenOffset + 1] = (byte)((bitLen >> 8)  & 0xFFL);
        padded[lenOffset + 2] = (byte)((bitLen >> 16) & 0xFFL);
        padded[lenOffset + 3] = (byte)((bitLen >> 24) & 0xFFL);
        padded[lenOffset + 4] = (byte)((bitLen >> 32) & 0xFFL);
        padded[lenOffset + 5] = (byte)((bitLen >> 40) & 0xFFL);
        padded[lenOffset + 6] = (byte)((bitLen >> 48) & 0xFFL);
        padded[lenOffset + 7] = (byte)((bitLen >> 56) & 0xFFL);
        return padded;
    }

    // ── RFC 1321 §3.4 K[i] sine table (precomputed) ─────────────────────

    static long[] _sineTable() {
        long[] k = new long[64];
        k[ 0] = 0xD76AA478L; k[ 1] = 0xE8C7B756L; k[ 2] = 0x242070DBL; k[ 3] = 0xC1BDCEEEL;
        k[ 4] = 0xF57C0FAFL; k[ 5] = 0x4787C62AL; k[ 6] = 0xA8304613L; k[ 7] = 0xFD469501L;
        k[ 8] = 0x698098D8L; k[ 9] = 0x8B44F7AFL; k[10] = 0xFFFF5BB1L; k[11] = 0x895CD7BEL;
        k[12] = 0x6B901122L; k[13] = 0xFD987193L; k[14] = 0xA679438EL; k[15] = 0x49B40821L;
        k[16] = 0xF61E2562L; k[17] = 0xC040B340L; k[18] = 0x265E5A51L; k[19] = 0xE9B6C7AAL;
        k[20] = 0xD62F105DL; k[21] = 0x02441453L; k[22] = 0xD8A1E681L; k[23] = 0xE7D3FBC8L;
        k[24] = 0x21E1CDE6L; k[25] = 0xC33707D6L; k[26] = 0xF4D50D87L; k[27] = 0x455A14EDL;
        k[28] = 0xA9E3E905L; k[29] = 0xFCEFA3F8L; k[30] = 0x676F02D9L; k[31] = 0x8D2A4C8AL;
        k[32] = 0xFFFA3942L; k[33] = 0x8771F681L; k[34] = 0x6D9D6122L; k[35] = 0xFDE5380CL;
        k[36] = 0xA4BEEA44L; k[37] = 0x4BDECFA9L; k[38] = 0xF6BB4B60L; k[39] = 0xBEBFBC70L;
        k[40] = 0x289B7EC6L; k[41] = 0xEAA127FAL; k[42] = 0xD4EF3085L; k[43] = 0x04881D05L;
        k[44] = 0xD9D4D039L; k[45] = 0xE6DB99E5L; k[46] = 0x1FA27CF8L; k[47] = 0xC4AC5665L;
        k[48] = 0xF4292244L; k[49] = 0x432AFF97L; k[50] = 0xAB9423A7L; k[51] = 0xFC93A039L;
        k[52] = 0x655B59C3L; k[53] = 0x8F0CCC92L; k[54] = 0xFFEFF47DL; k[55] = 0x85845DD1L;
        k[56] = 0x6FA87E4FL; k[57] = 0xFE2CE6E0L; k[58] = 0xA3014314L; k[59] = 0x4E0811A1L;
        k[60] = 0xF7537E82L; k[61] = 0xBD3AF235L; k[62] = 0x2AD7D2BBL; k[63] = 0xEB86D391L;
        return k;
    }

    // ── RFC 1321 §3.4 shift amounts table ────────────────────────────────

    static int[] _shifts() {
        int[] s = new int[64];
        // Round 1: 7, 12, 17, 22
        s[ 0] = 7; s[ 1] = 12; s[ 2] = 17; s[ 3] = 22;
        s[ 4] = 7; s[ 5] = 12; s[ 6] = 17; s[ 7] = 22;
        s[ 8] = 7; s[ 9] = 12; s[10] = 17; s[11] = 22;
        s[12] = 7; s[13] = 12; s[14] = 17; s[15] = 22;
        // Round 2: 5, 9, 14, 20
        s[16] = 5; s[17] =  9; s[18] = 14; s[19] = 20;
        s[20] = 5; s[21] =  9; s[22] = 14; s[23] = 20;
        s[24] = 5; s[25] =  9; s[26] = 14; s[27] = 20;
        s[28] = 5; s[29] =  9; s[30] = 14; s[31] = 20;
        // Round 3: 4, 11, 16, 23
        s[32] = 4; s[33] = 11; s[34] = 16; s[35] = 23;
        s[36] = 4; s[37] = 11; s[38] = 16; s[39] = 23;
        s[40] = 4; s[41] = 11; s[42] = 16; s[43] = 23;
        s[44] = 4; s[45] = 11; s[46] = 16; s[47] = 23;
        // Round 4: 6, 10, 15, 21
        s[48] = 6; s[49] = 10; s[50] = 15; s[51] = 21;
        s[52] = 6; s[53] = 10; s[54] = 15; s[55] = 21;
        s[56] = 6; s[57] = 10; s[58] = 15; s[59] = 21;
        s[60] = 6; s[61] = 10; s[62] = 15; s[63] = 21;
        return s;
    }

    // ── RFC 1321 §3.4 per-block compression ──────────────────────────────

    static void _processBlock(long[] h, byte[] block, int offset) {
        // Decode 16 LE 32-bit words from the 64-byte block (RFC 1321 §3.4)
        long[] m = new long[16];
        int t = 0;
        while (t < 16) {
            int o = offset + t * 4;
            long b0 = (long)((int)block[o]     & 0xFF);
            long b1 = (long)((int)block[o + 1] & 0xFF);
            long b2 = (long)((int)block[o + 2] & 0xFF);
            long b3 = (long)((int)block[o + 3] & 0xFF);
            // Little-endian word
            m[t] = (b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)) & 0xFFFFFFFFL;
            t = t + 1;
        }

        long a = h[0]; long b = h[1]; long c = h[2]; long d = h[3];
        long[] k = Md5._sineTable();
        int[] s  = Md5._shifts();

        int i = 0;
        while (i < 64) {
            long f;
            int  g;
            if (i < 16) {
                // F(B,C,D) = (B AND C) OR ((NOT B) AND D)
                f = ((b & c) | ((b ^ 0xFFFFFFFFL) & d)) & 0xFFFFFFFFL;
                g = i;
            } else if (i < 32) {
                // G(B,C,D) = (D AND B) OR ((NOT D) AND C)
                f = ((d & b) | ((d ^ 0xFFFFFFFFL) & c)) & 0xFFFFFFFFL;
                g = (5 * i + 1) % 16;
            } else if (i < 48) {
                // H(B,C,D) = B XOR C XOR D
                f = (b ^ c ^ d) & 0xFFFFFFFFL;
                g = (3 * i + 5) % 16;
            } else {
                // I(B,C,D) = C XOR (B OR (NOT D))
                f = (c ^ (b | (d ^ 0xFFFFFFFFL))) & 0xFFFFFFFFL;
                g = (7 * i) % 16;
            }
            long temp = d;
            d = c;
            c = b;
            long sum = (a + f + k[i] + m[g]) & 0xFFFFFFFFL;
            b = (b + Md5._rotl(sum, s[i])) & 0xFFFFFFFFL;
            a = temp;
            i = i + 1;
        }

        h[0] = (h[0] + a) & 0xFFFFFFFFL;
        h[1] = (h[1] + b) & 0xFFFFFFFFL;
        h[2] = (h[2] + c) & 0xFFFFFFFFL;
        h[3] = (h[3] + d) & 0xFFFFFFFFL;
    }

    /// 32-bit rotate-left. `x` is treated as the low 32 bits of a `long`.
    static long _rotl(long x, int n) {
        long masked = x & 0xFFFFFFFFL;
        return ((masked << n) | (masked >> (32 - n))) & 0xFFFFFFFFL;
    }
}
