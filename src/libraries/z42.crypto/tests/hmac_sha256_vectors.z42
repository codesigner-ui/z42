// add-hmac-sha256 (2026-05-24): RFC 4231 HMAC-SHA-256 test vectors.
namespace Z42CryptoHmacSha256VectorsTests;

using Std;
using Std.Test;
using Std.Crypto;
using Std.Encoding;

// ── RFC 4231 §4.2 Test Case 1 ──
// Key  = 20 bytes 0x0b
// Data = "Hi There"
[Test]
void test_rfc4231_case1() {
    byte[] key = new byte[20];
    int i = 0;
    while (i < 20) { key[i] = (byte)0x0b; i = i + 1; }
    byte[] data = Utf8.GetBytes("Hi There");
    Assert.Equal("b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7",
                 HmacSha256.ComputeHex(key, data));
}

// ── RFC 4231 §4.3 Test Case 2 ──
// Key  = "Jefe"
// Data = "what do ya want for nothing?"
[Test]
void test_rfc4231_case2() {
    Assert.Equal("5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843",
                 HmacSha256.ComputeStringHex("Jefe", "what do ya want for nothing?"));
}

// ── RFC 4231 §4.4 Test Case 3 ──
// Key  = 20 bytes 0xaa
// Data = 50 bytes 0xdd
[Test]
void test_rfc4231_case3() {
    byte[] key = new byte[20];
    int i = 0;
    while (i < 20) { key[i] = (byte)0xaa; i = i + 1; }
    byte[] data = new byte[50];
    i = 0;
    while (i < 50) { data[i] = (byte)0xdd; i = i + 1; }
    Assert.Equal("773ea91e36800e46854db8ebd09181a72959098b3ef8c122d9635514ced565fe",
                 HmacSha256.ComputeHex(key, data));
}

// ── RFC 4231 §4.5 Test Case 4 ──
// Key  = 0x010203...0x19 (25 bytes)
// Data = 50 bytes 0xcd
[Test]
void test_rfc4231_case4() {
    byte[] key = new byte[25];
    int i = 0;
    while (i < 25) { key[i] = (byte)(i + 1); i = i + 1; }
    byte[] data = new byte[50];
    i = 0;
    while (i < 50) { data[i] = (byte)0xcd; i = i + 1; }
    Assert.Equal("82558a389a443c0ea4cc819899f2083a85f0faa3e578f8077a2e3ff46729665b",
                 HmacSha256.ComputeHex(key, data));
}

// ── RFC 4231 §4.7 Test Case 6 ──
// Key  = 131 bytes 0xaa (> 64-byte block → triggers SHA256(key) preprocessing)
// Data = "Test Using Larger Than Block-Size Key - Hash Key First"
[Test]
void test_rfc4231_case6_key_longer_than_block() {
    byte[] key = new byte[131];
    int i = 0;
    while (i < 131) { key[i] = (byte)0xaa; i = i + 1; }
    byte[] data = Utf8.GetBytes("Test Using Larger Than Block-Size Key - Hash Key First");
    Assert.Equal("60e431591ee0b67f0d8a26aacbf5b77f8e0bc6213728c5140546040f0ee37f54",
                 HmacSha256.ComputeHex(key, data));
}

// ── RFC 4231 §4.8 Test Case 7 ──
// Key  = 131 bytes 0xaa
// Data = long sentence ("This is a test using a larger...")
[Test]
void test_rfc4231_case7_key_and_data_longer_than_block() {
    byte[] key = new byte[131];
    int i = 0;
    while (i < 131) { key[i] = (byte)0xaa; i = i + 1; }
    byte[] data = Utf8.GetBytes("This is a test using a larger than block-size key and a larger than block-size data. The key needs to be hashed before being used by the HMAC algorithm.");
    Assert.Equal("9b09ffa71b942fcb27635fbcd5b0e944bfdc63644f0713938a7f51535c3a35e2",
                 HmacSha256.ComputeHex(key, data));
}

// ── API surface coverage ──

[Test]
void test_byte_array_overload_returns_32_bytes() {
    byte[] key = new byte[8];
    byte[] data = new byte[16];
    byte[] mac = HmacSha256.Compute(key, data);
    Assert.Equal(32, mac.Length);
}

[Test]
void test_string_string_overload_byte_form() {
    // HMAC-SHA-256("key", "msg") = 2d93cbc1be167bcb1637a4a23cbff01a7878f0c50ee833954ea5221bb1b8c628
    byte[] mac = HmacSha256.ComputeString("key", "msg");
    Assert.Equal(32, mac.Length);
    Assert.Equal(0x2d, (int)mac[0]);
    Assert.Equal(0x28, (int)mac[31]);
}

[Test]
void test_empty_key_empty_msg() {
    // HMAC-SHA-256("", "") = b613679a0814d9ec772f95d778c35fc5ff1697c493715653c6c712144292c5ad
    Assert.Equal("b613679a0814d9ec772f95d778c35fc5ff1697c493715653c6c712144292c5ad",
                 HmacSha256.ComputeStringHex("", ""));
}

[Test]
void test_byte_key_string_msg_via_utf8() {
    // Caller pattern when only the message is text: Utf8.GetBytes(msg) then Compute.
    byte[] key = Utf8.GetBytes("key");
    byte[] data = Utf8.GetBytes("msg");
    Assert.Equal("2d93cbc1be167bcb1637a4a23cbff01a7878f0c50ee833954ea5221bb1b8c628",
                 HmacSha256.ComputeHex(key, data));
}
