// add-sha1-to-crypto (2026-05-25): FIPS 180-2 §B SHA-1 test vectors.
namespace Z42CryptoSha1VectorsTests;

using Std;
using Std.Test;
using Std.Crypto;
using Std.Encoding;

[Test]
void test_empty_string() {
    // SHA-1("") = da39a3ee5e6b4b0d3255bfef95601890afd80709
    Assert.Equal("da39a3ee5e6b4b0d3255bfef95601890afd80709",
                 Sha1.HashStringHex(""));
}

[Test]
void test_abc() {
    // FIPS 180-2 §B.1: SHA-1("abc") = a9993e364706816aba3e25717850c26c9cd0d89d
    Assert.Equal("a9993e364706816aba3e25717850c26c9cd0d89d",
                 Sha1.HashStringHex("abc"));
}

[Test]
void test_56_byte_message() {
    // FIPS 180-2 §B.2: "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq" (56 bytes)
    // → 84983e441c3bd26ebaae4aa1f95129e5e54670f1
    Assert.Equal("84983e441c3bd26ebaae4aa1f95129e5e54670f1",
                 Sha1.HashStringHex(
                     "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"));
}

[Test]
void test_single_char_a() {
    // SHA-1("a") = 86f7e437faa5a7fce15d1ddcb9eaeaea377667b8
    Assert.Equal("86f7e437faa5a7fce15d1ddcb9eaeaea377667b8",
                 Sha1.HashStringHex("a"));
}

[Test]
void test_hash_returns_20_bytes() {
    Assert.Equal(20, Sha1.Hash(new byte[0]).Length);
    Assert.Equal(20, Sha1.HashString("anything").Length);
}

[Test]
void test_long_input_multi_block() {
    // Sentence > 64 bytes (one block boundary). Compared against openssl.
    // SHA-1("The quick brown fox jumps over the lazy dog") = 2fd4e1c67a2d28fced849ee1bb76e7391b93eb12
    Assert.Equal("2fd4e1c67a2d28fced849ee1bb76e7391b93eb12",
                 Sha1.HashStringHex("The quick brown fox jumps over the lazy dog"));
}

[Test]
void test_known_block_boundary() {
    // 64-byte input exactly fills one block before padding.
    // SHA-1(64 'a' chars) = 0098ba824b5c16427bd7a1122a5a442a25ec644d
    Assert.Equal("0098ba824b5c16427bd7a1122a5a442a25ec644d",
                 Sha1.HashStringHex(
                     "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"));
}
