// add-z42-crypto (2026-05-17): NIST FIPS 180-2 SHA-256 test vectors.
namespace Z42CryptoSha256VectorsTests;

using Std.Test;
using Std.Crypto;

[Test]
void test_empty_string() {
    // SHA-256("") = e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
    Assert.Equal("e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
                 Sha256.HashStringHex(""));
}

[Test]
void test_abc() {
    // FIPS 180-2 Appendix B.1
    Assert.Equal("ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad",
                 Sha256.HashStringHex("abc"));
}

[Test]
void test_two_block_message() {
    // FIPS 180-2 Appendix B.2 — 56 chars, pads to 2 blocks.
    string msg = "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq";
    Assert.Equal("248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1",
                 Sha256.HashStringHex(msg));
}

[Test]
void test_single_char_a() {
    Assert.Equal("ca978112ca1bbdcafac231b39a23dc4da786eff8147c4e72b9807785afee48bb",
                 Sha256.HashStringHex("a"));
}

[Test]
void test_hash_returns_32_bytes() {
    byte[] digest = Sha256.HashString("hello");
    Assert.Equal(32, digest.Length);
}

[Test]
void test_long_input_multi_block() {
    // 1000 × "a" — known digest from sha256sum.
    string msg = "";
    int i = 0;
    while (i < 1000) {
        msg = msg + "a";
        i = i + 1;
    }
    Assert.Equal("41edece42d63e8d9bf515a9ba6932e1c20cbc9f5a5d134645adb5db1b9737ea3",
                 Sha256.HashStringHex(msg));
}
