// add-poly1305 (2026-05-27): RFC 8439 §2.5.2 + §A.3 Poly1305 test vectors.
namespace Z42CryptoPoly1305VectorsTests;

using Std;
using Std.Test;
using Std.Crypto;
using Std.Encoding;

// ── RFC 8439 §2.5.2: canonical 34-byte test vector ──────────────────────
//
// Key:     85d6be7857556d337f4452fe42d506a80103808afb0db2fd4abff6af4149f51b
// Message: "Cryptographic Forum Research Group" (34 bytes ASCII)
// Tag:     a8061dc1305136c6c22b8baf0c0127a9

[Test]
void test_poly1305_rfc8439_section2_5_2() {
    byte[] key = Hex.Decode("85d6be7857556d337f4452fe42d506a80103808afb0db2fd4abff6af4149f51b");
    byte[] msg = Hex.Decode("43727970746f6772617068696320466f72756d2052657365617263682047726f7570");
    Assert.Equal("a8061dc1305136c6c22b8baf0c0127a9", Poly1305.MacHex(key, msg));
}

// ── RFC 8439 §A.3 — Vector #1: empty message, all-zero key ──────────────
//
// Tag must be all zeros (acc=0 + s=0 = 0).

[Test]
void test_poly1305_rfc8439_a3_v1_empty_zero_key() {
    byte[] key = new byte[32];
    byte[] msg = new byte[0];
    Assert.Equal("00000000000000000000000000000000", Poly1305.MacHex(key, msg));
}

// ── RFC 8439 §A.3 — Vector #2: text message, non-zero key ───────────────
//
// Key:     0000000000000000000000000000000036e5f6b5c5e06070f0efca96227a863e
// (r = all-zero so the polynomial term vanishes; tag = s only)
// Message: "Any submission to the IETF intended by the Contributor for publication as all or part of an IETF Internet-Draft or RFC and any statement made within the context of an IETF activity is considered an "IETF Contribution". Such statements include oral statements in IETF sessions, as well as written and electronic communications made at any time or place, which are addressed to"
// Tag:     36e5f6b5c5e06070f0efca96227a863e

[Test]
void test_poly1305_rfc8439_a3_v2_zero_r_clamp() {
    byte[] key = Hex.Decode("0000000000000000000000000000000036e5f6b5c5e06070f0efca96227a863e");
    byte[] msg = Hex.Decode("");
    Assert.Equal("36e5f6b5c5e06070f0efca96227a863e", Poly1305.MacHex(key, msg));
}

// ── RFC 8439 §A.3 — Vector #3: same message, zero `s`, non-zero `r` ─────
//
// Key:     36e5f6b5c5e06070f0efca96227a863e00000000000000000000000000000000
// Tag:     f3477e7cd95417af89a6b8794c310cf0
[Test]
void test_poly1305_rfc8439_a3_v3_zero_s() {
    byte[] key = Hex.Decode("36e5f6b5c5e06070f0efca96227a863e00000000000000000000000000000000");
    byte[] msg = Hex.Decode("");
    Assert.Equal("f3477e7cd95417af89a6b8794c310cf0", Poly1305.MacHex(key, msg));
}

// ── Empty message with non-zero key — Tag = (0 + s) mod 2^128 = s ───────

[Test]
void test_poly1305_empty_message_returns_s() {
    byte[] key = Hex.Decode("0000000000000000000000000000000001020304050607080910111213141516");
    byte[] msg = new byte[0];
    Assert.Equal("01020304050607080910111213141516", Poly1305.MacHex(key, msg));
}

// ── 16-byte block-boundary test ─────────────────────────────────────────

[Test]
void test_poly1305_single_block() {
    byte[] key = Hex.Decode("85d6be7857556d337f4452fe42d506a80103808afb0db2fd4abff6af4149f51b");
    byte[] msg = new byte[16];
    int i = 0;
    while (i < 16) { msg[i] = (byte)0x41; i = i + 1; }  // 16 × 'A'
    // Just verify it produces 16 bytes — the actual hash is implementation-
    // verified by RFC vectors above; here we cover the block-boundary path.
    byte[] tag = Poly1305.Mac(key, msg);
    Assert.Equal(16, tag.Length);
}

// ── Key length validation ───────────────────────────────────────────────

[Test]
void test_poly1305_rejects_wrong_key_length() {
    byte[] key = new byte[31];  // must be 32
    byte[] msg = new byte[16];
    bool threw = false;
    try { Poly1305.Mac(key, msg); }
    catch (ArgumentException) { threw = true; }
    Assert.True(threw);
}
