// add-ecdsa-p256 (2026-05-28): RFC 6979 §A.2.5 test vectors for ECDSA
// over NIST P-256 with SHA-256 + deterministic-k.
namespace Z42CryptoEcdsaP256VectorsTests;

using Std;
using Std.Test;
using Std.Crypto;
using Std.Encoding;

// ── RFC 6979 §A.2.5: ECDSA P-256 + SHA-256 with private key d ───────────
//
// private key d  = C9AFA9D845BA75166B5C215767B1D6934E50C3DB36E89B127B8A622B120F6721
// public key Ux  = 60FED4BA255A9D31C961EB74C6356D68C049B8923B61FA6CE669622E60F29FB6
// public key Uy  = 7903FE1008B8BC99A41AE9E95628BC64F2F1B20C2D7E9F5177A3C294D4462299
//
// For msg = "sample" (ASCII):
//   k = A6E3C57DD01ABE90086538398355DD4C3B17AA873382B0F24D6129493D8AAD60
//   r = EFD48B2AACB6A8FD1140DD9CD45E81D69D2C877B56AAF991C34D0EA84EAF3716
//   s = F7CB1C942D657C41D436C7A1B6E29F65F3E900DBB9AFF4064DC4AB2F843ACDA8
//
// For msg = "test" (ASCII):
//   r = F1ABB023518351CD71D881567B1EA663ED3EFCF6C5132B354F28D3B0B7D38367
//   s = 019F4113742A2B14BD25926B49C649155F267E60D3814B4C0CC84250E46F0083

[Test]
void test_ecdsa_p256_rfc6979_public_key_from_d() {
    byte[] d  = Hex.Decode("c9afa9d845ba75166b5c215767b1d6934e50c3db36e89b127b8a622b120f6721");
    byte[] pk = EcdsaP256.GeneratePublicKey(d);
    Assert.Equal(
        "60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299",
        Hex.Encode(pk)
    );
}

[Test]
void test_ecdsa_p256_rfc6979_sample_signature() {
    byte[] d   = Hex.Decode("c9afa9d845ba75166b5c215767b1d6934e50c3db36e89b127b8a622b120f6721");
    byte[] msg = Utf8.GetBytes("sample");
    byte[] sig = EcdsaP256.Sign(d, msg);
    Assert.Equal(
        "efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8",
        Hex.Encode(sig)
    );
}

[Test]
void test_ecdsa_p256_rfc6979_sample_verify() {
    byte[] pk  = Hex.Decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299");
    byte[] msg = Utf8.GetBytes("sample");
    byte[] sig = Hex.Decode("efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8");
    Assert.True(EcdsaP256.Verify(pk, msg, sig));
}

[Test]
void test_ecdsa_p256_rfc6979_test_signature() {
    byte[] d   = Hex.Decode("c9afa9d845ba75166b5c215767b1d6934e50c3db36e89b127b8a622b120f6721");
    byte[] msg = Utf8.GetBytes("test");
    byte[] sig = EcdsaP256.Sign(d, msg);
    Assert.Equal(
        "f1abb023518351cd71d881567b1ea663ed3efcf6c5132b354f28d3b0b7d38367019f4113742a2b14bd25926b49c649155f267e60d3814b4c0cc84250e46f0083",
        Hex.Encode(sig)
    );
}

[Test]
void test_ecdsa_p256_rfc6979_test_verify() {
    byte[] pk  = Hex.Decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299");
    byte[] msg = Utf8.GetBytes("test");
    byte[] sig = Hex.Decode("f1abb023518351cd71d881567b1ea663ed3efcf6c5132b354f28d3b0b7d38367019f4113742a2b14bd25926b49c649155f267e60d3814b4c0cc84250e46f0083");
    Assert.True(EcdsaP256.Verify(pk, msg, sig));
}

// ── Tampering detection ─────────────────────────────────────────────────

[Test]
void test_ecdsa_p256_rejects_tampered_signature() {
    byte[] pk  = Hex.Decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299");
    byte[] msg = Utf8.GetBytes("sample");
    byte[] sig = Hex.Decode("efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8");
    sig[0] = (byte)((int)sig[0] ^ 0x01);
    Assert.True(!EcdsaP256.Verify(pk, msg, sig));
}

[Test]
void test_ecdsa_p256_rejects_tampered_message() {
    byte[] pk  = Hex.Decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299");
    byte[] msg = Utf8.GetBytes("sampLe");
    byte[] sig = Hex.Decode("efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8");
    Assert.True(!EcdsaP256.Verify(pk, msg, sig));
}

[Test]
void test_ecdsa_p256_rejects_off_curve_public_key() {
    // Take valid public key, flip a byte in X — almost certainly off-curve.
    byte[] pk = Hex.Decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299");
    pk[0] = (byte)((int)pk[0] ^ 0x01);
    byte[] msg = Utf8.GetBytes("sample");
    byte[] sig = Hex.Decode("efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8");
    Assert.True(!EcdsaP256.Verify(pk, msg, sig));
}

[Test]
void test_ecdsa_p256_rejects_zero_signature_component() {
    byte[] pk  = Hex.Decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299");
    byte[] msg = Utf8.GetBytes("sample");
    byte[] sig = new byte[64];   // r = 0, s = 0
    Assert.True(!EcdsaP256.Verify(pk, msg, sig));
}

// ── Sign / Verify round trip with a different scalar ────────────────────

[Test]
void test_ecdsa_p256_round_trip_with_different_key() {
    byte[] d = new byte[32];
    int i = 0;
    while (i < 32) { d[i] = (byte)(i + 1); i = i + 1; }   // d = 0x01..0x20
    byte[] pk = EcdsaP256.GeneratePublicKey(d);
    byte[] msg = Utf8.GetBytes("round-trip");
    byte[] sig = EcdsaP256.Sign(d, msg);
    Assert.Equal(64, sig.Length);
    Assert.True(EcdsaP256.Verify(pk, msg, sig));
}

// ── Determinism (RFC 6979) ──────────────────────────────────────────────

[Test]
void test_ecdsa_p256_sign_is_deterministic() {
    byte[] d   = Hex.Decode("c9afa9d845ba75166b5c215767b1d6934e50c3db36e89b127b8a622b120f6721");
    byte[] msg = Utf8.GetBytes("anything");
    byte[] sig1 = EcdsaP256.Sign(d, msg);
    byte[] sig2 = EcdsaP256.Sign(d, msg);
    Assert.Equal(Hex.Encode(sig1), Hex.Encode(sig2));
}

// ── Length validation ───────────────────────────────────────────────────

[Test]
void test_ecdsa_p256_rejects_wrong_signature_length() {
    byte[] pk  = Hex.Decode("60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb67903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299");
    byte[] msg = Utf8.GetBytes("x");
    byte[] bad = new byte[63];
    bool threw = false;
    try { EcdsaP256.Verify(pk, msg, bad); }
    catch (ArgumentException) { threw = true; }
    Assert.True(threw);
}

[Test]
void test_ecdsa_p256_rejects_wrong_scalar_length() {
    byte[] bad = new byte[31];
    bool threw = false;
    try { EcdsaP256.Sign(bad, new byte[0]); }
    catch (ArgumentException) { threw = true; }
    Assert.True(threw);
}
