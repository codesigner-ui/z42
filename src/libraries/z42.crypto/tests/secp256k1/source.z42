// add-tests-bench-manifest-config Phase 5 (2026-06-06): first multi-file
// `tests/<name>/source.z42` demo. Unblocked by aggregate-zpkg-tidx (same
// date) which makes the packed test zpkg's TIDX discoverable by the
// in-process VM.
//
//   tests/secp256k1/
//     source.z42    ← [Test] methods, this file (the dir-mode entry)
//     vectors.z42   ← SecpVectors static class with hex fixtures
//
// Both files share `namespace Z42CryptoEcdsaSecp256k1VectorsTests` and
// get globbed into one synthetic test zpkg `z42.crypto.test.secp256k1`
// by xtask Phase 3. Replaces the original flat
// `tests/ecdsa_secp256k1_vectors.z42` which used to inline its hex
// constants alongside the test logic.
namespace Z42CryptoEcdsaSecp256k1VectorsTests;

using Std;
using Std.Test;
using Std.Crypto;
using Std.Encoding;

// ── Trivial curve-constants check: d = 1 → public key = G ───────────────

[Test]
void test_secp256k1_scalar_1_yields_generator() {
    byte[] pk = EcdsaSecp256k1.GeneratePublicKey(SecpVectors.PrivateScalarOne());
    Assert.Equal(SecpVectors.GeneratorHex(), Hex.Encode(pk));
}

// ── 2 × G test ──────────────────────────────────────────────────────────

[Test]
void test_secp256k1_scalar_2_yields_2g() {
    byte[] pk = EcdsaSecp256k1.GeneratePublicKey(SecpVectors.PrivateScalarTwo());
    Assert.Equal(SecpVectors.TwoGHex(), Hex.Encode(pk));
}

// ── Sign / verify round trip ────────────────────────────────────────────
//
// Timeout calibration history (kept here because it's a runner-visible
// attribute, not a fixture value):
//
// - 240 ms (initial) — calibrated to affine EC math on local Apple
//   Silicon, but blew past on shared CI (4-vCPU ubuntu-x64 wall=240564 ms).
// - 600 ms (recalibrate-secp256k1-timeout, 2026-06-01) — stopgap to
//   unblock CI; loose ceiling over affine worst-case contention until
//   the projective/Jacobian fix landed.
// - 60 ms (optimize-ecdsa-jacobian-coords, 2026-06-05) — current.
//   Jacobian-coordinate scalar mult cut the round-trip wall from ~60 s
//   (affine, local M-series) to ~5.5 s (Jacobian, same hardware). With
//   3-4× CI contention headroom that fits comfortably inside 60 s, well
//   away from any plausible cap. Tighter caps risk false positives
//   under runner contention; 60 s is the lowest round-number ceiling
//   that stays clear.
[Test]
[Timeout(milliseconds: 60000)]
void test_secp256k1_sign_verify_round_trip() {
    byte[] d = SecpVectors.BitcoinSamplePrivateKey();
    byte[] pk = EcdsaSecp256k1.GeneratePublicKey(d);
    byte[] msg = Utf8.GetBytes("Bitcoin transaction payload");
    byte[] sig = EcdsaSecp256k1.Sign(d, msg);
    Assert.Equal(64, sig.Length);
    Assert.True(EcdsaSecp256k1.Verify(pk, msg, sig));
}

[Test]
void test_secp256k1_sign_is_deterministic() {
    // RFC 6979 → same (d, msg) must produce identical signature bytes.
    byte[] d = SecpVectors.BitcoinSamplePrivateKey();
    byte[] msg = Utf8.GetBytes("determinism");
    byte[] sig1 = EcdsaSecp256k1.Sign(d, msg);
    byte[] sig2 = EcdsaSecp256k1.Sign(d, msg);
    Assert.Equal(Hex.Encode(sig1), Hex.Encode(sig2));
}

// ── Tampering rejection ─────────────────────────────────────────────────

[Test]
void test_secp256k1_rejects_tampered_signature() {
    byte[] d = SecpVectors.BitcoinSamplePrivateKey();
    byte[] pk = EcdsaSecp256k1.GeneratePublicKey(d);
    byte[] msg = Utf8.GetBytes("payload");
    byte[] sig = EcdsaSecp256k1.Sign(d, msg);
    sig[0] = (byte)((int)sig[0] ^ 0x01);
    Assert.True(!EcdsaSecp256k1.Verify(pk, msg, sig));
}

[Test]
void test_secp256k1_rejects_tampered_message() {
    byte[] d = SecpVectors.BitcoinSamplePrivateKey();
    byte[] pk = EcdsaSecp256k1.GeneratePublicKey(d);
    byte[] msg = Utf8.GetBytes("original");
    byte[] sig = EcdsaSecp256k1.Sign(d, msg);
    byte[] tampered = Utf8.GetBytes("originaL");
    Assert.True(!EcdsaSecp256k1.Verify(pk, tampered, sig));
}

[Test]
void test_secp256k1_rejects_p256_signature_under_secp256k1_curve() {
    // Sanity check: signatures from a different curve must not validate
    // under secp256k1, even if both use 64-byte (r || s) encoding.
    byte[] d = SecpVectors.BitcoinSamplePrivateKey();
    byte[] pk = EcdsaSecp256k1.GeneratePublicKey(d);
    byte[] msg = Utf8.GetBytes("sample");
    Assert.True(!EcdsaSecp256k1.Verify(pk, msg, SecpVectors.P256ForeignSignature()));
}

[Test]
void test_secp256k1_rejects_off_curve_public_key() {
    byte[] msg = Utf8.GetBytes("anything");
    Assert.True(!EcdsaSecp256k1.Verify(
        SecpVectors.OffCurvePseudoPublicKey(),
        msg,
        SecpVectors.TrivialUnitSignature()));
}

// ── Length validation ───────────────────────────────────────────────────

[Test]
void test_secp256k1_rejects_wrong_signature_length() {
    byte[] pk = EcdsaSecp256k1.GeneratePublicKey(SecpVectors.PrivateScalarOne());
    byte[] bad = new byte[63];
    bool threw = false;
    try { EcdsaSecp256k1.Verify(pk, new byte[0], bad); }
    catch (ArgumentException) { threw = true; }
    Assert.True(threw);
}

[Test]
void test_secp256k1_rejects_wrong_scalar_length() {
    byte[] bad = new byte[31];
    bool threw = false;
    try { EcdsaSecp256k1.Sign(bad, new byte[0]); }
    catch (ArgumentException) { threw = true; }
    Assert.True(threw);
}
