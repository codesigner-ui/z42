// Micro-benchmarks for z42.collections hot paths (2026-05-31) — dogfoods
// the [Benchmark] + Bencher machinery on SortedSet insert / lookup.
// (List<T> / Dictionary<K,V> live in z42.core; their benchmarks belong in
//  that lib's tests/.) Modest sample counts keep the correctness wave fast;
// run benchmarks only via `z42-test-runner <zbc> --filter bench_`.

namespace Z42CollectionsBench;

using Std;
using Std.Test;
using Std.Collections;

[Benchmark]
void bench_sortedset_add() {
    var b = new Bencher(2, 20);
    b.iter(() => {
        var s = new SortedSet<int>();
        int i = 0;
        while (i < 64) {
            // SortedSet.Add returns bool (false on dup); consume it via
            // blackBox so we don't rely on z42 allowing a discarded return.
            BenchHelpers.blackBox(s.Add(i * 7 % 101));   // collisions + ordering work
            i = i + 1;
        }
        BenchHelpers.blackBox(s.Count());
    });
    b.printSummary("sortedset_add_64");
}

[Benchmark]
void bench_sortedset_contains() {
    var b = new Bencher(2, 20);
    var s = new SortedSet<int>();
    int n = 0;
    while (n < 64) { BenchHelpers.blackBox(s.Add(n)); n = n + 1; }
    b.iter(() => {
        bool hit = s.Contains(48);
        BenchHelpers.blackBox(hit);
    });
    b.printSummary("sortedset_contains");
}

[Test]
void test_collection_bench_bodies_run() {
    var b = new Bencher(1, 3);
    b.iter(() => {
        var s = new SortedSet<int>();
        BenchHelpers.blackBox(s.Add(1));
        BenchHelpers.blackBox(s.Count());
    });
    Assert.Equal(3, b.Samples);
    Assert.True(b.TotalNs > 0L);
}
