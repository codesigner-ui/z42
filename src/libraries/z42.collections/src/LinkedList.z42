namespace Std.Collections;

// Generic doubly-linked list (L3-G4d — stdlib generic export, 2026-04-28).
//
// O(1) AddFirst / AddLast / RemoveFirst / RemoveLast / First / Last; O(n)
// Find / Contains. Each node carries `prev` / `next` references; the list
// keeps `head` / `tail` / `count` for constant-time end operations.
//
// Constraint:
//   T: IEquatable<T>   — for Find / Contains equality check (mirrors
//                        Std.Collections.List<T>).
// Primitive types (int / long / double / char / string) auto-satisfy via
// stdlib `struct int : IEquatable<int>` etc. (L3-G4b primitive-as-struct).
public class LinkedListNode<T> {
    public T Value;

    // Links accessed via Next() / Previous() / SetNext() / SetPrevious().
    // Owning `LinkedList<T>` mutates them during splicing; user code should
    // treat the setters as "package-internal" by convention (z42 has no
    // `internal` cross-class visibility primitive yet — see
    // `docs/design/access-control.md`).
    //
    // Reference-type fields default to null in Phase 1 (no `?` suffix needed).
    LinkedListNode<T> next;
    LinkedListNode<T> prev;

    public LinkedListNode(T value) {
        this.Value = value;
        this.next = null;
        this.prev = null;
    }

    public LinkedListNode<T> Next()     { return this.next; }
    public LinkedListNode<T> Previous() { return this.prev; }

    public void SetNext(LinkedListNode<T> n)     { this.next = n; }
    public void SetPrevious(LinkedListNode<T> p) { this.prev = p; }
}

public class LinkedList<T> where T: IEquatable<T> {
    LinkedListNode<T> head;
    LinkedListNode<T> tail;
    int count;

    public LinkedList() {
        this.head = null;
        this.tail = null;
        this.count = 0;
    }

    public int Count() { return this.count; }
    public bool IsEmpty() { return this.count == 0; }

    // Front / back accessors — return null on empty list (idiomatic for
    // a query method; throwers are RemoveFirst / RemoveLast below).
    public LinkedListNode<T> First() { return this.head; }
    public LinkedListNode<T> Last()  { return this.tail; }

    // ── Insertions ──────────────────────────────────────────────────────────

    public LinkedListNode<T> AddFirst(T value) {
        var node = new LinkedListNode<T>(value);
        if (this.head == null) {
            // Empty list — node becomes both head and tail.
            this.head = node;
            this.tail = node;
        } else {
            node.SetNext(this.head);
            this.head.SetPrevious(node);
            this.head = node;
        }
        this.count = this.count + 1;
        return node;
    }

    public LinkedListNode<T> AddLast(T value) {
        var node = new LinkedListNode<T>(value);
        if (this.tail == null) {
            this.head = node;
            this.tail = node;
        } else {
            node.SetPrevious(this.tail);
            this.tail.SetNext(node);
            this.tail = node;
        }
        this.count = this.count + 1;
        return node;
    }

    // ── Removals ────────────────────────────────────────────────────────────

    public T RemoveFirst() {
        var node = this.head;
        if (node == null) {
            throw new Exception("LinkedList is empty");
        }
        var v = node.Value;
        this.head = node.Next();
        if (this.head == null) {
            this.tail = null;
        } else {
            this.head.SetPrevious(null);
        }
        this.count = this.count - 1;
        return v;
    }

    public T RemoveLast() {
        var node = this.tail;
        if (node == null) {
            throw new Exception("LinkedList is empty");
        }
        var v = node.Value;
        this.tail = node.Previous();
        if (this.tail == null) {
            this.head = null;
        } else {
            this.tail.SetNext(null);
        }
        this.count = this.count - 1;
        return v;
    }

    // Remove the first node whose value equals `value`. Returns true on success.
    public bool Remove(T value) {
        var cur = this.head;
        while (cur != null) {
            if (cur.Value.Equals(value)) {
                LinkedListNode<T> p = cur.Previous();
                LinkedListNode<T> n = cur.Next();
                if (p == null) {
                    this.head = n;
                } else {
                    p.SetNext(n);
                }
                if (n == null) {
                    this.tail = p;
                } else {
                    n.SetPrevious(p);
                }
                this.count = this.count - 1;
                return true;
            }
            cur = cur.Next();
        }
        return false;
    }

    public void Clear() {
        this.head = null;
        this.tail = null;
        this.count = 0;
    }

    // ── Search ──────────────────────────────────────────────────────────────

    public bool Contains(T value) { return this.Find(value) != null; }

    public LinkedListNode<T> Find(T value) {
        var cur = this.head;
        while (cur != null) {
            if (cur.Value.Equals(value)) {
                return cur;
            }
            cur = cur.Next();
        }
        return null;
    }

}
