namespace Std.Collections;

// Generic LIFO stack (L3-G4d — stdlib generic export).
// Backing T[] with amortised O(1) Push/Pop and exponential growth.
public class Stack<T> {
    T[] items;
    int count;
    int capacity;

    public Stack() {
        this.capacity = 4;
        this.items = new T[4];
        this.count = 0;
    }

    public int Count() { return this.count; }
    public bool IsEmpty() { return this.count == 0; }

    public void Push(T item) {
        if (this.count == this.capacity) this.Grow();
        this.items[this.count] = item;
        this.count = this.count + 1;
    }

    public T Pop() {
        this.count = this.count - 1;
        return this.items[this.count];
    }

    public T Peek() {
        return this.items[this.count - 1];
    }

    public void Clear() {
        this.count = 0;
    }

    public void Grow() {
        int newCap = this.capacity * 2;
        T[] bigger = new T[newCap];
        int i = 0;
        while (i < this.count) {
            bigger[i] = this.items[i];
            i = i + 1;
        }
        this.items = bigger;
        this.capacity = newCap;
    }
}
