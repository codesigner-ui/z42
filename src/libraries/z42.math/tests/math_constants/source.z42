using Std.IO;
using Std.Math;
// Test: Math.Pi / Math.E / Math.Tau 静态字段访问 (fix-static-field-access, 2026-04-27)
//
// 修复前：用户代码 `Math.Pi` 编译为 `static.get @Math.Pi`（缺 Std.Math
// 命名空间前缀），运行时返回 null。
// 修复后：编译为 `static.get @Std.Math.Math.Pi`，且 VM 启动时跑所有
// `*.__static_init__` 函数（含导入 zpkg 的），常量被正确赋值。

void Main() {
    Console.WriteLine(Math.Pi);
    Console.WriteLine(Math.E);
    Console.WriteLine(Math.Tau);
}
