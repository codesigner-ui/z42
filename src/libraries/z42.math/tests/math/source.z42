using Std.Math;
void Main() {
    // Abs (int-preserving via AbsInt; double via Abs).
    // fix-math-int-overload-collision (2026-05-24): Abs/Min/Max int
    // overloads renamed to AbsInt/MinInt/MaxInt — see Math.z42 notes.
    Assert.Equal(5, Math.AbsInt(-5));
    Assert.Equal(5, Math.AbsInt(5));

    // Max / Min (int-preserving via MaxInt / MinInt)
    Assert.Equal(10, Math.MaxInt(3, 10));
    Assert.Equal(3, Math.MinInt(3, 10));

    // Pow
    Assert.Equal(8, Math.Pow(2, 3));
    Assert.Equal(1, Math.Pow(7, 0));

    // Floor / Ceiling / Round (float)
    var f = 3.7;
    Assert.Equal(3.0, Math.Floor(f));
    Assert.Equal(4.0, Math.Ceiling(f));
    Assert.Equal(4.0, Math.Round(f));

    var g = 3.2;
    Assert.Equal(3.0, Math.Floor(g));
    Assert.Equal(4.0, Math.Ceiling(g));
    Assert.Equal(3.0, Math.Round(g));
}
