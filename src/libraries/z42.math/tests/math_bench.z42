// Micro-benchmarks for z42.math hot paths (2026-05-31) — dogfoods the
// [Benchmark] + Bencher machinery on Sqrt / Pow / Abs. Modest sample counts
// keep the correctness wave fast; run benchmarks only via
// `z42-test-runner <zbc> --filter bench_`.

namespace Z42MathBench;

using Std;
using Std.Test;
using Std.Math;

[Benchmark]
void bench_sqrt() {
    var b = new Bencher(2, 20);
    b.iter(() => {
        double r = Math.Sqrt(2.0) + Math.Sqrt(3.0) + Math.Sqrt(5.0);
        BenchHelpers.blackBox(r);
    });
    b.printSummary("sqrt");
}

[Benchmark]
void bench_pow() {
    var b = new Bencher(2, 20);
    b.iter(() => {
        double r = Math.Pow(2.0, 10.0);
        BenchHelpers.blackBox(r);
    });
    b.printSummary("pow");
}

[Benchmark]
void bench_abs_loop(Bencher b) {
    // Bencher-arg form (compiler-desugared); default 10/100 samples.
    b.iter(() => {
        int acc = 0;
        int i = -50;
        while (i < 50) {
            acc = acc + Math.AbsInt(i);
            i = i + 1;
        }
        BenchHelpers.blackBox(acc);
    });
}

[Test]
void test_math_bench_bodies_run() {
    var b = new Bencher(1, 3);
    b.iter(() => {
        double r = Math.Sqrt(4.0);
        BenchHelpers.blackBox(r);
    });
    Assert.Equal(3, b.Samples);
    Assert.True(b.TotalNs > 0L);
}
