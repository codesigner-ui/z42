namespace Std.Test;

// `Std.Test.TestIO` — capture stdout/stderr emitted by code under test (R2 完整版).
//
// Implementation: each capture pushes a thread-local buffer; on take, the
// buffer is popped and returned as a string. Nested calls compose via the
// stack (inner sees inner output only; outer sees only what executed at
// the outer level outside of inner's capture window). See
// docs/design/testing.md "TestIO".
//
// 异常路径：被测代码抛出时，sink 也必须卸载。所有方法都先 install，try
// body()；catch 路径里 take 一次（discard buffer），再 throw 透传异常。
// 这样调用方拿到 string 只在成功路径下，sink stack 始终一致。

public class CaptureResult {
    public string Stdout { get; private set; }
    public string Stderr { get; private set; }

    public CaptureResult(string stdout, string stderr) {
        this.Stdout = stdout;
        this.Stderr = stderr;
    }
}

public static class TestIO {
    // Capture stdout produced during `body()`. Returns the captured text.
    // Any exception thrown by `body` is rethrown after the sink is cleaned up.
    public static string captureStdout(Action body) {
        __install_stdout_sink();
        try {
            body();
            return __take_stdout_buffer();
        } catch (Exception e) {
            __take_stdout_buffer();
            throw e;
        }
    }

    // Capture stderr only. stdout passes through to the process.
    public static string captureStderr(Action body) {
        __install_stderr_sink();
        try {
            body();
            return __take_stderr_buffer();
        } catch (Exception e) {
            __take_stderr_buffer();
            throw e;
        }
    }

    // Capture both channels independently.
    public static CaptureResult captureBoth(Action body) {
        __install_stdout_sink();
        __install_stderr_sink();
        try {
            body();
            var s = __take_stdout_buffer();
            var e = __take_stderr_buffer();
            return new CaptureResult(s, e);
        } catch (Exception ex) {
            __take_stdout_buffer();
            __take_stderr_buffer();
            throw ex;
        }
    }

    // ── Native bindings ───────────────────────────────────────────────────
    // Internal — exposed via the public capture* methods above.

    [Native("__test_io_install_stdout_sink")]
    private static extern void __install_stdout_sink();

    [Native("__test_io_take_stdout_buffer")]
    private static extern string __take_stdout_buffer();

    [Native("__test_io_install_stderr_sink")]
    private static extern void __install_stderr_sink();

    [Native("__test_io_take_stderr_buffer")]
    private static extern string __take_stderr_buffer();
}
