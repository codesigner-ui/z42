namespace Std.Test;

// `Std.Test.Assert` — test-aware assertion helpers (spec R2.D).
//
// Mirrors the API shape of `Std.Assert` (z42.core) but throws `TestFailure` /
// `SkipSignal` instead of bare `Exception`. Lets the R3 z42-test-runner
// distinguish "intentional test failure" (TestFailure) from "unexpected runtime
// error" (other Exception) at the catch boundary.
//
// 与 z42.core.Assert 的关系：
// - `Std.Assert` (z42.core) 保留作为通用断言（`Debug.Assert` 风格），抛
//   `Exception("AssertionError: ...")`
// - `Std.Test.Assert` (本文件) 是测试框架专用，抛结构化的 `TestFailure`
// - 测试代码推荐：`import z42.test.Assert as TAssert` 显式区分
// - 非测试代码：继续用 `Std.Assert`
//
// 选型说明：直接修改 `Std.Assert` 抛 TestFailure 会让 z42.core 依赖 z42.test
// （TestFailure 在 z42.test），破坏 prelude 包不依赖任何包的约定。所以新增
// 平行 API 而非升级。
//
// R2 完整版（2026-05-05）：补齐 lambda 依赖的方法：
// - `Throws(typeName, action)`：z42 generic-E 反射受限，API 用 string 比对类型名
// - `DoesNotThrow(action)`：lambda 直接接 Action
// - `EqualApprox(actual, expected, eps)`：浮点容差（不依赖 closure，本期顺带加）
//
// 仍未支持（需要更深的反射 / 泛型约束）：
// - `Throws<E>` 真正泛型版本（typeof(E) 在 generic body 内当前是 parse-time
//   string desugar，返回字面 "E"；`is E` 同样在 IR 层固定为编译期类名）
// - `Equal<T: Equatable>` 泛型约束（object 重载够用）

public static class Assert {
    // ── 相等性 ────────────────────────────────────────────────────────────
    public static void Equal(object expected, object actual) {
        if (!expected.Equals(actual)) {
            throw new TestFailure(
                "values not equal",
                actual.ToString(),
                expected.ToString());
        }
    }

    public static void NotEqual(object expected, object actual) {
        if (expected.Equals(actual)) {
            throw new TestFailure(
                $"expected values to differ but both were {expected}");
        }
    }

    // ── 布尔 ──────────────────────────────────────────────────────────────
    public static void True(bool condition) {
        if (!condition) {
            throw new TestFailure("expected true but got false", "false", "true");
        }
    }

    public static void False(bool condition) {
        if (condition) {
            throw new TestFailure("expected false but got true", "true", "false");
        }
    }

    public static void Null(object? value) {
        if (value != null) {
            throw new TestFailure(
                $"expected null but got {value}",
                value.ToString(),
                "null");
        }
    }

    public static void NotNull(object? value) {
        if (value == null) {
            throw new TestFailure("expected non-null but got null", "null", "<non-null>");
        }
    }

    // ── 字符串包含 ────────────────────────────────────────────────────────
    public static void Contains(string expected, string actual) {
        if (!actual.Contains(expected)) {
            throw new TestFailure(
                $"expected substring not found",
                actual,
                $"<contains \"{expected}\">");
        }
    }

    // ── 主动控制 ──────────────────────────────────────────────────────────
    // Test-method-side 显式失败（如不可达分支）。
    public static void Fail(string message) {
        throw new TestFailure(message);
    }

    // 运行时跳过（与 [Skip(...)] 编译时跳过互补：本方法用于运行期才能判定的
    // 跳过条件，例如"环境变量缺失"、"硬件不支持"等）。
    public static void Skip(string reason) {
        throw new SkipSignal(reason);
    }

    // ── 异常断言 (R2 完整版) ──────────────────────────────────────────────
    //
    // 2026-05-05 update：早期 R2 完整版因 z42 三个反射限制（is-cross-module /
    // GetType vtable / generic-extern infer）改为 untyped Throws；同会话后续
    // fix-is-cross-module + fix-vcall-cross-zpkg 修好前两条，于是补回类型敏感
    // 版本。`Throws(string typeName, Action)` 通过 `e.GetType().__name` 精确
    // 比对，避免依赖未修好的 generic-E IsInstance。

    /// Assert that `body` throws an exception whose runtime type's short name
    /// equals `expectedTypeName`. Use `[ShouldThrow<E>]` for whole-test-level
    /// throw assertions where the type is statically known at attribute time.
    public static void Throws(string expectedTypeName, Action body) {
        try {
            body();
        } catch (Exception e) {
            var actual = e.GetType().__name;
            if (actual == expectedTypeName) {
                return;
            }
            throw new TestFailure(
                $"expected to throw {expectedTypeName} but got {actual}: {e.Message}",
                actual,
                expectedTypeName);
        }
        throw new TestFailure(
            $"expected to throw {expectedTypeName} but no exception was thrown",
            "<no throw>",
            expectedTypeName);
    }

    /// Assert any exception is thrown. Less type-safe than the typed overload;
    /// use when the test only cares "did this throw at all".
    public static void ThrowsAny(Action body) {
        try {
            body();
        } catch (Exception e) {
            return;
        }
        throw new TestFailure("expected to throw but no exception was thrown");
    }

    public static void DoesNotThrow(Action body) {
        try {
            body();
        } catch (Exception e) {
            var actual = e.GetType().__name;
            throw new TestFailure(
                $"expected no exception but got {actual}: {e.Message}",
                actual,
                "<no throw>");
        }
    }

    // ── 浮点容差 ──────────────────────────────────────────────────────────
    //
    // 绝对容差比较；NaN 永不命中（NaN != NaN by definition）。
    public static void EqualApprox(double actual, double expected, double eps) {
        var diff = actual - expected;
        if (diff < 0.0) { diff = -diff; }
        if (diff > eps) {
            throw new TestFailure(
                $"values differ beyond eps: |{actual} - {expected}| = {diff} > {eps}",
                actual.ToString(),
                expected.ToString());
        }
    }

    // ── 数值排序 / 范围（extend-assert-numeric-and-collection-helpers, 2026-05-30）─
    //
    // 直接表达"应当大于 / 小于 / 在范围内"的断言，替代过往
    // `Assert.True(x > N)` / `Assert.True(x > low && x < high)` 复合写法。
    // 参数顺序为 (actual, expected) 反映读法："port greater than 0"；
    // 这与 `Equal(expected, actual)` 的顺序*故意*不同 — equality 对称所以
    // 顺序无关，ordering 有方向所以顺序就是被断言的不等式。
    //
    // double overload 对 NaN 显式 guard：IEEE-754 下 NaN 与任何值的 <,>
    // 比较都是 false，朴素 `actual <= expected` 检查会让 `Greater(NaN, x)`
    // 静默通过（断言被绕过）。我们在 double 路径上先 reject NaN。
    //
    // 何时用 Greater vs EqualApprox：
    //   - strict ordering（端口号 > 0 / count > 0）→ Greater
    //   - "approximately equal" / 浮点容差 → EqualApprox
    // 不要把 ordering helper 偷塞容差语义。

    public static void Greater(long actual, long expected) {
        if (actual <= expected) {
            throw new TestFailure(
                $"expected {actual} > {expected}",
                actual.ToString(),
                $"> {expected}");
        }
    }

    public static void Greater(double actual, double expected) {
        if (actual != actual || expected != expected) {
            throw new TestFailure(
                $"Greater(double, double): NaN operand never satisfies ordering",
                actual.ToString(),
                $"> {expected}");
        }
        if (actual <= expected) {
            throw new TestFailure(
                $"expected {actual} > {expected}",
                actual.ToString(),
                $"> {expected}");
        }
    }

    public static void Less(long actual, long expected) {
        if (actual >= expected) {
            throw new TestFailure(
                $"expected {actual} < {expected}",
                actual.ToString(),
                $"< {expected}");
        }
    }

    public static void Less(double actual, double expected) {
        if (actual != actual || expected != expected) {
            throw new TestFailure(
                $"Less(double, double): NaN operand never satisfies ordering",
                actual.ToString(),
                $"< {expected}");
        }
        if (actual >= expected) {
            throw new TestFailure(
                $"expected {actual} < {expected}",
                actual.ToString(),
                $"< {expected}");
        }
    }

    public static void GreaterOrEqual(long actual, long expected) {
        if (actual < expected) {
            throw new TestFailure(
                $"expected {actual} >= {expected}",
                actual.ToString(),
                $">= {expected}");
        }
    }

    public static void GreaterOrEqual(double actual, double expected) {
        if (actual != actual || expected != expected) {
            throw new TestFailure(
                $"GreaterOrEqual(double, double): NaN operand never satisfies ordering",
                actual.ToString(),
                $">= {expected}");
        }
        if (actual < expected) {
            throw new TestFailure(
                $"expected {actual} >= {expected}",
                actual.ToString(),
                $">= {expected}");
        }
    }

    public static void LessOrEqual(long actual, long expected) {
        if (actual > expected) {
            throw new TestFailure(
                $"expected {actual} <= {expected}",
                actual.ToString(),
                $"<= {expected}");
        }
    }

    public static void LessOrEqual(double actual, double expected) {
        if (actual != actual || expected != expected) {
            throw new TestFailure(
                $"LessOrEqual(double, double): NaN operand never satisfies ordering",
                actual.ToString(),
                $"<= {expected}");
        }
        if (actual > expected) {
            throw new TestFailure(
                $"expected {actual} <= {expected}",
                actual.ToString(),
                $"<= {expected}");
        }
    }

    // InRange — inclusive bounds: `min <= actual <= max` passes.
    // Exclusive variant intentionally omitted — caller composes `Greater` +
    // `Less` if needed.
    public static void InRange(long actual, long min, long max) {
        if (actual < min || actual > max) {
            throw new TestFailure(
                $"expected {actual} in [{min}, {max}]",
                actual.ToString(),
                $"[{min}, {max}]");
        }
    }

    public static void InRange(double actual, double min, double max) {
        if (actual != actual || min != min || max != max) {
            throw new TestFailure(
                $"InRange(double, double, double): NaN operand never satisfies range",
                actual.ToString(),
                $"[{min}, {max}]");
        }
        if (actual < min || actual > max) {
            throw new TestFailure(
                $"expected {actual} in [{min}, {max}]",
                actual.ToString(),
                $"[{min}, {max}]");
        }
    }

    // ── 数组集合助手（extend-assert-numeric-and-collection-helpers, 2026-05-30）──
    //
    // 仅 `object[]` overload — z42 Phase 1 无泛型，无法表达
    // `Contains<T>(T, ICollection<T>)`。`object[]` 通过 boxing 覆盖
    // int[] / string[] / 对象引用数组等常见 stdlib 测试场景。
    // List / Set / Dictionary 的对应 helper 留待 L2 泛型落地后引入。
    //
    // 比对用默认 `==`：reference-equal for objects, value-equal for boxed
    // primitives — 与 List.Contains 等 stdlib 集合一致语义。
    //
    // **方法名前缀 `Array`**（不直接复用 Contains / IsEmpty）：z42 的
    // DependencyIndex first-wins 解析在跨 package 时不做 overload
    // resolution（见 .claude/rules/common-pitfalls.md §1）。z42.core 的
    // `Std.Assert.Contains(string, string)` 会先 win，bare `Assert.Contains`
    // 永远命中 z42.core 而看不到本文件的 `(object, object[])` overload。
    // 实施期 spec Decision 6 升级 — 为避免该 collision，array 系列方法
    // 加 `Array` 前缀，name space 在 z42.core 没人占。L2 加 generics 后
    // 可以引入真正的 `Contains<T>(T, IList<T>)` 并把这些 alias 弃用。

    public static void ArrayContains(object needle, object[] haystack) {
        for (int i = 0; i < haystack.Length; i++) {
            if (haystack[i] == needle) {
                return;
            }
        }
        throw new TestFailure(
            $"array does not contain expected element",
            $"<array of length {haystack.Length}>",
            needle.ToString());
    }

    public static void ArrayDoesNotContain(object needle, object[] haystack) {
        for (int i = 0; i < haystack.Length; i++) {
            if (haystack[i] == needle) {
                throw new TestFailure(
                    $"array unexpectedly contains element",
                    $"<contains {needle}>",
                    $"<does not contain {needle}>");
            }
        }
    }

    public static void ArrayIsEmpty(object[] coll) {
        if (coll.Length != 0) {
            throw new TestFailure(
                $"expected empty array but length = {coll.Length}",
                coll.Length.ToString(),
                "0");
        }
    }

    public static void ArrayIsNotEmpty(object[] coll) {
        if (coll.Length == 0) {
            throw new TestFailure(
                $"expected non-empty array but got empty",
                "0",
                "> 0");
        }
    }
}
