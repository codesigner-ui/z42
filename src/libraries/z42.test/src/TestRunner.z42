namespace Std.Test;

// `TestRunner` — 极简单元测试运行器 (z42.test v0)
//
// 当前 z42 缺 lambda / 通用 attribute / reflection，所以采用 imperative
// "Begin / try-catch-Fail / Summary" 模式。每个测试 case 用一对
// `Begin(name)` + `try { ... } catch (Exception e) { Fail(e); }` 组合：
//
//   var t = new TestRunner("MyTests");
//   t.Begin("Addition");
//   try { Assert.Equal(4, 2 + 2); } catch (Exception e) { t.Fail(e); }
//   t.Begin("Concat");
//   try { Assert.Equal("ab", "a" + "b"); } catch (Exception e) { t.Fail(e); }
//   return t.Summary();   // exit code = failed count
//
// 设计语义：
// - Begin(name) 隐式 finalize 上一个测试（如果上一次没被 Fail() 标记，
//   则视为 PASS）。第一次 Begin 跳过 finalize 步骤
// - Fail(exception) 标记当前测试失败 + 打印失败原因
// - Summary() finalize 最后一个测试（如果有），打印汇总，返回 failed 计数
//
// v1（lambda 就绪后）规划 API：
//   t.Run("Addition", () => Assert.Equal(4, 2 + 2));
//
// v2（reflection + attribute 就绪后）规划 API：
//   [Test] public void TestAddition() { ... }
//   t.RunAll<MyTests>();
public class TestRunner {
    string ContextName;
    string CurrentName;
    bool   CurrentActive;
    bool   CurrentFailed;
    int    Passed;
    int    Failed;

    public TestRunner(string contextName) {
        this.ContextName   = contextName;
        this.CurrentName   = "";
        this.CurrentActive = false;
        this.CurrentFailed = false;
        this.Passed        = 0;
        this.Failed        = 0;
        Console.WriteLine("══════════════════════════════════════");
        Console.WriteLine($" {contextName}");
        Console.WriteLine("══════════════════════════════════════");
    }

    // 开始一个测试 case。如果有进行中的 case，先 finalize 它。
    public void Begin(string name) {
        if (this.CurrentActive) {
            this.Finalize();
        }
        this.CurrentName   = name;
        this.CurrentActive = true;
        this.CurrentFailed = false;
    }

    // 标记当前 case 失败（用 try/catch 在异常处调用）。
    public void Fail(Exception e) {
        this.CurrentFailed = true;
        Console.WriteLine($"  ✗ FAIL: {this.CurrentName}");
        Console.WriteLine($"          {e.Message}");
    }

    // 收尾 + 打印汇总。返回 failed 计数（适合做 process exit code）。
    public int Summary() {
        if (this.CurrentActive) {
            this.Finalize();
        }
        Console.WriteLine("──────────────────────────────────────");
        Console.WriteLine($" Result: {this.Passed} passed, {this.Failed} failed");
        Console.WriteLine("══════════════════════════════════════");
        return this.Failed;
    }

    // 内部：把当前 case 计入 pass/fail 统计 + 打印 PASS 行。
    void Finalize() {
        if (this.CurrentFailed) {
            this.Failed = this.Failed + 1;
        } else {
            this.Passed = this.Passed + 1;
            Console.WriteLine($"  ✓ {this.CurrentName}");
        }
        this.CurrentActive = false;
    }
}
