// Reflective test runner v2 (retire-test-runner). Replaces the Rust z42-test-runner:
// loads a compiled test module, discovers its [Test]/[Setup]/[Teardown] via the
// TIDX returned by ModuleLoader, and runs each test by reflection
// (Type.GetType + Activator.CreateInstance + MethodInfo.Invoke), classifying
// pass / fail / skip — including [Skip] gating and [ShouldThrow<E>] matching.
//
// Lifecycle per [Test]: fresh instance → all [Setup] → the test → all [Teardown]
// (teardown always runs). Exit code: 0 = all passed (failures=0), 1 = any failure.
namespace Std.Test;

using Std;
using Std.IO;
using Std.Reflection;

public static class Runner {
    // Load + run every [Test] in the compiled module at `path`. Returns a process
    // exit code (0 = no failures, 1 = at least one failure).
    public static int RunModule(string path) {
        TestEntry[] entries = ModuleLoader.Load(path);
        int passed = 0; int failed = 0; int skipped = 0;
        int i = 0;
        while (i < entries.Length) {
            TestEntry e = entries[i];
            if (e.IsTest()) {
                int r = Runner._runOne(e, entries);
                if (r == 0)      { passed = passed + 1; }
                else if (r == 1) { failed = failed + 1; }
                else             { skipped = skipped + 1; }
            }
            i = i + 1;
        }
        Console.WriteLine("");
        Console.WriteLine("  Result: " + passed.ToString() + " passed, "
            + failed.ToString() + " failed, " + skipped.ToString() + " skipped");
        if (failed > 0) { return 1; }
        return 0;
    }

    // 0 = pass, 1 = fail, 2 = skip.
    static int _runOne(TestEntry e, TestEntry[] all) {
        if (e.IsIgnored()) {
            Console.WriteLine("  SKIP " + e.Qualified + " (ignored)");
            return 2;
        }
        if (e.IsSkipped() && Runner._skipApplies(e)) {
            string why = (e.SkipReason != null) ? (" (" + e.SkipReason + ")") : "";
            Console.WriteLine("  SKIP " + e.Qualified + why);
            return 2;
        }

        string typeName = e.DeclaringType();
        Type t = Type.GetType(typeName);
        if (t == null) {
            Console.WriteLine("  FAIL " + e.Qualified + " (type not found)");
            return 1;
        }
        object inst = Activator.CreateInstance(t);
        MethodInfo m = Runner._method(t, e.MethodName());
        if (m == null) {
            Console.WriteLine("  FAIL " + e.Qualified + " (method not found)");
            return 1;
        }

        Runner._runLifecycle(t, inst, all, typeName, 3);   // [Setup]

        bool threw = false;
        string errMsg = "";
        string errType = "";
        try {
            m.Invoke(inst, new object[0]);
        } catch (Exception ex) {
            threw = true;
            errMsg = ex.Message;
            errType = ex.GetType().FullName;
        }

        Runner._runLifecycle(t, inst, all, typeName, 4);   // [Teardown] (always)

        if (e.HasShouldThrow()) {
            if (threw && Runner._typeMatches(errType, e.ShouldThrow)) {
                Console.WriteLine("  PASS " + e.Qualified);
                return 0;
            }
            string got = threw ? errType : "no throw";
            Console.WriteLine("  FAIL " + e.Qualified + " (expected throw "
                + e.ShouldThrow + ", got " + got + ")");
            return 1;
        }
        if (threw) {
            Console.WriteLine("  FAIL " + e.Qualified + ": " + errType + ": " + errMsg);
            return 1;
        }
        Console.WriteLine("  PASS " + e.Qualified);
        return 0;
    }

    // Run all [Setup] (kind 3) or [Teardown] (kind 4) methods of `typeName` on `inst`.
    static void _runLifecycle(Type t, object inst, TestEntry[] all, string typeName, int kind) {
        int i = 0;
        while (i < all.Length) {
            TestEntry e = all[i];
            if (e.Kind == kind && e.DeclaringType() == typeName) {
                MethodInfo m = Runner._method(t, e.MethodName());
                if (m != null) {
                    try { m.Invoke(inst, new object[0]); } catch (Exception ex) { }
                }
            }
            i = i + 1;
        }
    }

    static MethodInfo _method(Type t, string name) {
        MethodInfo[] ms = t.GetMethods();
        int i = 0;
        while (i < ms.Length) {
            if (ms[i].Name == name) { return ms[i]; }
            i = i + 1;
        }
        return null;
    }

    // Does this [Skip] apply on the current host? Unconditional skip → yes.
    // Platform skip → yes iff host OS matches. Feature skip → conservatively yes
    // (skip feature-gated tests; precise feature detection is a follow-up).
    static bool _skipApplies(TestEntry e) {
        if (e.SkipPlatform != null) { return Platform.OS() == e.SkipPlatform; }
        if (e.SkipFeature != null) { return true; }
        return true;
    }

    // Exact FullName match for [ShouldThrow<E>] (simple matching, per spec).
    static bool _typeMatches(string actualFullName, string expected) {
        if (actualFullName == expected) { return true; }
        // tolerate unqualified expected (e.g. "InvalidOperationException")
        return Runner._simpleName(actualFullName) == Runner._simpleName(expected);
    }

    static string _simpleName(string fqn) {
        int i = fqn.Length - 1;
        while (i >= 0) {
            if (fqn.Substring(i, 1) == ".") { return fqn.Substring(i + 1, fqn.Length - (i + 1)); }
            i = i - 1;
        }
        return fqn;
    }
}
