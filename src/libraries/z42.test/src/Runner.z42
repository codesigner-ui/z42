// Reflective test runner v2 (retire-test-runner). Replaces the Rust z42-test-runner:
// loads a compiled test module and runs each [Test] / [Benchmark] it declares,
// classifying pass / fail / skip — including [Skip] gating and [ShouldThrow<E>]
// matching.
//
// z42 [Test]/[Benchmark]/[Setup]/[Teardown] are emitted as zero-arg FREE
// functions (`<Namespace>.<func>`), so the runner invokes them by their TIDX
// fully-qualified name (ModuleLoader.Invoke) — not via instance + MethodInfo.
//
// Lifecycle per [Test]: same-namespace [Setup] → the test → same-namespace
// [Teardown] (teardown always runs). Exit code: 0 = all passed (failures=0),
// 1 = any failure.
namespace Std.Test;

using Std;
using Std.IO;

public static class Runner {
    // Load + run every [Test] / [Benchmark] in the compiled module at `path`.
    // Returns a process exit code (0 = no failures, 1 = at least one failure).
    public static int RunModule(string path) {
        TestEntry[] entries = ModuleLoader.Load(path);
        int passed = 0; int failed = 0; int skipped = 0;
        int i = 0;
        while (i < entries.Length) {
            TestEntry e = entries[i];
            // [Test] and [Benchmark] are dispatched identically (zero-arg
            // invocation); the benchmark body constructs its own Bencher and
            // self-reports — mirrors the retired Rust runner, which ran both.
            if (e.IsTest() || e.IsBenchmark()) {
                int r = Runner._runOne(e, entries);
                if (r == 0)      { passed = passed + 1; }
                else if (r == 1) { failed = failed + 1; }
                else             { skipped = skipped + 1; }
            }
            i = i + 1;
        }
        Console.WriteLine("");
        Console.WriteLine("  Result: " + passed.ToString() + " passed, "
            + failed.ToString() + " failed, " + skipped.ToString() + " skipped");
        if (failed > 0) { return 1; }
        return 0;
    }

    // 0 = pass, 1 = fail, 2 = skip.
    static int _runOne(TestEntry e, TestEntry[] all) {
        if (e.IsIgnored()) {
            Console.WriteLine("  SKIP " + e.Qualified + " (ignored)");
            return 2;
        }
        if (e.IsSkipped() && Runner._skipApplies(e)) {
            string why = (e.SkipReason != null) ? (" (" + e.SkipReason + ")") : "";
            Console.WriteLine("  SKIP " + e.Qualified + why);
            return 2;
        }

        string ns = e.DeclaringType();
        Runner._runLifecycle(all, ns, 3);   // [Setup]

        bool threw = false;
        string errMsg = "";
        string errType = "";
        try {
            ModuleLoader.Invoke(e.Qualified);
        } catch (Exception ex) {
            threw = true;
            errMsg = ex.Message;
            errType = ex.GetType().FullName;
        }

        Runner._runLifecycle(all, ns, 4);   // [Teardown] (always)

        if (e.HasShouldThrow()) {
            if (threw && Runner._typeMatches(errType, e.ShouldThrow)) {
                Console.WriteLine("  PASS " + e.Qualified);
                return 0;
            }
            string got = threw ? errType : "no throw";
            Console.WriteLine("  FAIL " + e.Qualified + " (expected throw "
                + e.ShouldThrow + ", got " + got + ")");
            return 1;
        }
        if (threw) {
            Console.WriteLine("  FAIL " + e.Qualified + ": " + errType + ": " + errMsg);
            return 1;
        }
        Console.WriteLine("  PASS " + e.Qualified);
        return 0;
    }

    // Run all [Setup] (kind 3) or [Teardown] (kind 4) functions declared in the
    // same namespace `ns` as the test. (z42 free-function fixtures have no shared
    // instance; same-namespace grouping preserves locality.)
    static void _runLifecycle(TestEntry[] all, string ns, int kind) {
        int i = 0;
        while (i < all.Length) {
            TestEntry e = all[i];
            if (e.Kind == kind && e.DeclaringType() == ns) {
                try { ModuleLoader.Invoke(e.Qualified); } catch (Exception ex) { }
            }
            i = i + 1;
        }
    }

    // Does this [Skip] apply on the current host? Unconditional skip → yes.
    // Platform skip → yes iff host OS matches. Feature skip → conservatively yes
    // (skip feature-gated tests; precise feature detection is a follow-up).
    static bool _skipApplies(TestEntry e) {
        if (e.SkipPlatform != null) { return Platform.OS() == e.SkipPlatform; }
        if (e.SkipFeature != null) { return true; }
        return true;
    }

    // Match the thrown type against the [ShouldThrow<E>] expectation. `expected`
    // is z42c's chain "E;descendant…" (the declared type + every visible subtype
    // reaching it) — any segment matching the thrown type's FullName (exact or by
    // simple name) is a hit, mirroring the retired Rust runner. Null-safe: a
    // missing expected chain or thrown-type name → no match (reported as a fail).
    static bool _typeMatches(string actualFullName, string expected) {
        if (actualFullName == null || expected == null) { return false; }
        int start = 0;
        int i = 0;
        while (i <= expected.Length) {
            bool atEnd = (i == expected.Length);
            if (atEnd || expected.Substring(i, 1) == ";") {
                string seg = expected.Substring(start, i - start);
                if (seg.Length > 0) {
                    if (actualFullName == seg) { return true; }
                    if (Runner._simpleName(actualFullName) == Runner._simpleName(seg)) { return true; }
                }
                start = i + 1;
            }
            i = i + 1;
        }
        return false;
    }

    static string _simpleName(string fqn) {
        int i = fqn.Length - 1;
        while (i >= 0) {
            if (fqn.Substring(i, 1) == ".") { return fqn.Substring(i + 1, fqn.Length - (i + 1)); }
            i = i - 1;
        }
        return fqn;
    }
}
