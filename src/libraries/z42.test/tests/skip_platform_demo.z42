// add-test-skip-platform-feature-eval (2026-05-30) — in-tree e2e demo of
// conditional `[Skip(platform: …)] / [Skip(feature: …)]` evaluation.
//
// Verifies (via test-stdlib.sh wave) that the runner actually honors the
// platform/feature gate instead of unconditionally skipping every flagged
// test (pre-spec behavior). Each test below pairs an attribute with a body
// whose pass/fail outcome encodes the expected runner decision:
//
// - Per-platform `[Skip(platform: "<NAME>")]` tests use trivial pass bodies.
//   On host == NAME the runner skips; on other hosts the body runs and
//   passes. So **every host** gets {6 passed, 1 skipped} across the seven
//   per-platform tests.
//
// - `test_skip_on_atari` uses a fictional platform value that no host can
//   match. Always runs, always passes — proves the runner doesn't fall
//   back to "always skip when flag set".
//
// - `test_skip_unknown_feature` uses an unregistered feature name. The
//   deny-by-default policy in `skip_eval::is_feature_available` treats
//   unknown names as unavailable → always skipped. The body Asserts.Fail
//   to catch a regression where deny-by-default got flipped.
//
// Run a single platform's skip behavior manually:
//   ./z42-test-runner <dogfood.zbc> --platform ios
// to verify ios path matches without booting iOS.

namespace Z42TestSkipPlatformDemo;

using Std;
using Std.Test;

// ── Per-platform: skipped iff host == <NAME>; otherwise runs and passes ──

[Test]
[Skip(platform: "linux", reason: "linux-only demo: skipped on linux, runs elsewhere")]
void test_skip_on_linux() {
    // Body is a no-op pass — proves the runner *did* run us when host != linux.
    Assert.Equal(1, 1);
}

[Test]
[Skip(platform: "macos", reason: "macos-only demo: skipped on macos, runs elsewhere")]
void test_skip_on_macos() {
    Assert.Equal(1, 1);
}

[Test]
[Skip(platform: "windows", reason: "windows-only demo: skipped on windows, runs elsewhere")]
void test_skip_on_windows() {
    Assert.Equal(1, 1);
}

[Test]
[Skip(platform: "ios", reason: "ios-only demo: skipped on ios, runs elsewhere")]
void test_skip_on_ios() {
    Assert.Equal(1, 1);
}

[Test]
[Skip(platform: "android", reason: "android-only demo: skipped on android, runs elsewhere")]
void test_skip_on_android() {
    Assert.Equal(1, 1);
}

[Test]
[Skip(platform: "wasm", reason: "wasm-only demo: skipped on wasm, runs elsewhere")]
void test_skip_on_wasm() {
    Assert.Equal(1, 1);
}

[Test]
[Skip(platform: "freebsd", reason: "freebsd-only demo: skipped on freebsd, runs elsewhere")]
void test_skip_on_freebsd() {
    Assert.Equal(1, 1);
}

// ── Platform mismatch (never matches any real host) — always runs ────────

[Test]
[Skip(platform: "atari", reason: "fictional platform never matches host — must run")]
void test_skip_on_atari_never_matches() {
    // Reaching this body is the success condition — proves runner didn't
    // do a blanket skip on the SKIPPED flag.
    Assert.Equal(42, 42);
}

// ── Unknown feature: deny-by-default — always skipped ────────────────────

[Test]
[Skip(feature: "quantum_entanglement", reason: "unknown feature must skip via deny-by-default")]
void test_skip_unknown_feature_is_denied() {
    // Body should never execute. If it does, deny-by-default regressed.
    Assert.Fail("test_skip_unknown_feature_is_denied body ran — deny-by-default policy regressed");
}
