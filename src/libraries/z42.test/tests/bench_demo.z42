// add-benchmark-runner-dispatch (2026-05-31) — in-tree e2e demo of
// runner-dispatched `[Benchmark]` methods + regression test that the
// pre-spec "Bencher inside [Test]" workaround still works.
//
// Output (pretty): test wave shows `✓ bench:bench_addition_demo (Nms)`
// for the benchmark and `✓ test_bencher_inside_test_still_works (Mms)`
// for the regression test. Both also write a `bench[label] min=...`
// line to stdout from `printSummary`.

namespace Z42TestBenchDemo;

using Std;
using Std.Test;

// ── [Benchmark] runner-dispatched form ────────────────────────────────

[Benchmark]
void bench_addition_demo() {
    // Tiny Bencher run with low sample count so the demo finishes
    // quickly; real benchmarks use the defaults (warmup=10, samples=100).
    var b = new Bencher(2, 5);
    b.iter(() => {
        int x = 1 + 2 + 3;
        BenchHelpers.blackBox(x);
    });
    b.printSummary("addition_demo");
    // Sanity check on the Bencher itself — if iter didn't run at all
    // (e.g. runner skipped the body), Samples would be the default 100
    // but Min/Max/Median would be 0 (no measurement). We assert both
    // counters and stats moved to confirm the body actually executed.
    Assert.Equal(5, b.Samples);
    Assert.True(b.TotalNs > 0L);
}

// ── Regression: Bencher inside [Test] still works (pre-spec pattern) ──

[Test]
void test_bencher_inside_test_still_works() {
    var b = new Bencher(2, 5);
    b.iter(() => {
        int y = 4 + 5 + 6;
        BenchHelpers.blackBox(y);
    });
    b.printSummary("inside_test_regression");
    Assert.Equal(5, b.Samples);
    Assert.True(b.TotalNs > 0L);
}
