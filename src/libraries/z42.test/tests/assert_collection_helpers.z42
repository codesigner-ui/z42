// extend-assert-numeric-and-collection-helpers (2026-05-30) —
// array-collection assertion coverage.

namespace Z42TestAssertCollectionHelpers;

using Std;
using Std.Test;

// ── Contains(object, object[]) — int element ──────────────────────────

[Test]
void test_contains_object_array_pass_int() {
    object[] arr = new object[] { 1, 2, 3 };
    Assert.ArrayContains(2, arr);
}

[Test]
void test_contains_object_array_pass_string() {
    object[] arr = new object[] { "foo", "bar", "baz" };
    Assert.ArrayContains("bar", arr);
}

[Test]
void test_contains_object_array_fail() {
    object[] arr = new object[] { 1, 2, 3 };
    Assert.Throws("TestFailure", () => {
        Assert.ArrayContains(4, arr);
    });
}

[Test]
void test_contains_object_array_empty_haystack_always_fails() {
    object[] arr = new object[] { };
    Assert.Throws("TestFailure", () => {
        Assert.ArrayContains(1, arr);
    });
}

// ── DoesNotContain ────────────────────────────────────────────────────

[Test]
void test_does_not_contain_pass() {
    object[] arr = new object[] { 1, 2, 3 };
    Assert.ArrayDoesNotContain(4, arr);
}

[Test]
void test_does_not_contain_fail() {
    object[] arr = new object[] { 1, 2, 3 };
    Assert.Throws("TestFailure", () => {
        Assert.ArrayDoesNotContain(2, arr);
    });
}

[Test]
void test_does_not_contain_empty_haystack_always_passes() {
    object[] arr = new object[] { };
    Assert.ArrayDoesNotContain(1, arr);
}

// ── IsEmpty / IsNotEmpty ──────────────────────────────────────────────

[Test]
void test_is_empty_pass_zero_length() {
    object[] arr = new object[] { };
    Assert.ArrayIsEmpty(arr);
}

[Test]
void test_is_empty_fail_one_element() {
    object[] arr = new object[] { 1 };
    Assert.Throws("TestFailure", () => {
        Assert.ArrayIsEmpty(arr);
    });
}

[Test]
void test_is_not_empty_pass() {
    object[] arr = new object[] { 1, 2 };
    Assert.ArrayIsNotEmpty(arr);
}

[Test]
void test_is_not_empty_fail() {
    object[] arr = new object[] { };
    Assert.Throws("TestFailure", () => {
        Assert.ArrayIsNotEmpty(arr);
    });
}

// ── Regression: pre-spec string Contains overload unchanged ───────────

[Test]
void test_string_contains_still_works() {
    // Note: bare `Assert.Contains` resolves to z42.core's Std.Assert.Contains
    // (not z42.test's) due to DependencyIndex first-wins behavior across
    // packages (.claude/rules/common-pitfalls.md §1). z42.core's Contains
    // throws plain `Std.Exception` rather than `TestFailure`, so the fail-
    // path catches `Exception` not `TestFailure`. The test still verifies
    // the pre-spec string Contains overload remains reachable and throws
    // on missing-substring — that's the regression invariant.
    Assert.Contains("foo", "foobar");      // pass-path
    Assert.Throws("Exception", () => {
        Assert.Contains("baz", "foobar");  // fail-path
    });
}
