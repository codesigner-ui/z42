namespace Z42.Project;

/// `[profile.<name>]` 段。Name ∈ "debug" | "release"；Mode ∈ "interp" | "jit" | "aot"。
/// debug 默认：pack=false / strip=false / mode=interp。release：pack=true / strip=true。
public record Profile(
    string Name,
    bool   Pack,
    bool   Strip,
    string Mode,
    int    Optimize,    // 0–3
    bool   Debug
);
