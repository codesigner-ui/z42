// add-ipaddress-tryparse (2026-06-09): non-throwing IPAddress.TryParse →
// IPAddress? (null on malformed input). Same grammar as Parse.
namespace Z42NetIPAddressTryParseTests;

using Std;
using Std.Test;
using Std.Net.Sockets;

[Test]
void test_tryparse_valid_ipv4() {
    IPAddress? a = IPAddress.TryParse("192.168.1.1");
    Assert.True(a != null);
    Assert.True(a.IsIPv4());
    Assert.Equal("192.168.1.1", a.ToString());
}

[Test]
void test_tryparse_valid_ipv6() {
    IPAddress? a = IPAddress.TryParse("::1");
    Assert.True(a != null);
    Assert.True(a.IsIPv6());
}

[Test]
void test_tryparse_valid_v4mapped() {
    // Composes with the new IPv4-in-IPv6 dotted parsing.
    IPAddress? a = IPAddress.TryParse("::ffff:192.0.2.1");
    Assert.True(a != null);
    Assert.True(a.IsIPv6());
}

[Test]
void test_tryparse_invalid_returns_null() {
    Assert.True(IPAddress.TryParse("not.an.ip") == null);
    Assert.True(IPAddress.TryParse("999.0.0.1") == null);
    Assert.True(IPAddress.TryParse("1.2.3") == null);
    Assert.True(IPAddress.TryParse("") == null);
    Assert.True(IPAddress.TryParse(":::1") == null);
    Assert.True(IPAddress.TryParse("gg::1") == null);
}
