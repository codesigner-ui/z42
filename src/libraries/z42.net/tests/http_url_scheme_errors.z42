// add-z42-net-tls (2026-06-03): https:// is now accepted (TLS landed), so the
// old "https throws NotSupportedException" assertion is gone. What remains
// here are the scheme/format error paths that are still rejected: a missing
// scheme and an unsupported scheme (only http / https are allowed).
//
// Renamed from http_https_throws.z42.
namespace Z42NetHttpUrlSchemeErrorsTests;

using Std;
using Std.Test;
using Std.Net.Http;

[Test]
void test_malformed_url_throws_format() {
    var client = new HttpClient();
    bool threw = false;
    try {
        client.Get("not-a-url");
    } catch (FormatException e) {
        threw = true;
    }
    Assert.True(threw);
}

[Test]
void test_unknown_scheme_throws_format() {
    var client = new HttpClient();
    bool threw = false;
    try {
        client.Get("ftp://example.com");
    } catch (FormatException e) {
        threw = true;
    }
    Assert.True(threw);
}
