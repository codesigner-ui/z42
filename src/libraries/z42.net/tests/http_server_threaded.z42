// add-z42-net-http-server-threaded (2026-05-26): thread-per-accept variant.
namespace Z42NetHttpServerThreadedTests;

using Std;
using Std.Test;
using Std.Threading;
using Std.Net.Sockets;
using Std.Net.Http;

[Test]
void test_serve_threaded_handles_concurrent_clients() {
    var server = new HttpServer();
    server.Bind("127.0.0.1", 0);
    int port = server.LocalPort();
    string url = "http://127.0.0.1:" + Int32.ToString(port) + "/";

    // Start the threaded server in a background thread.
    Thread srv = Thread.Start(() => {
        server.ServeThreaded((HttpServerContext ctx) => {
            // Echo path back as body.
            ctx.SendText(200, "echo:" + ctx.Request.Url);
        });
    });

    // Spawn 4 client threads in parallel.
    int N = 4;
    Thread[] clients = new Thread[N];
    int i = 0;
    while (i < N) {
        int idx = i;
        clients[i] = Thread.Start(() => {
            var c = new HttpClient();
            HttpResponse r = c.Get(url + "client" + Int32.ToString(idx));
            Assert.Equal(200, r.StatusCode);
            Assert.Equal("echo:/client" + Int32.ToString(idx), r.BodyAsString());
        });
        i = i + 1;
    }
    // Join all clients.
    int j = 0;
    while (j < N) {
        clients[j].Join();
        j = j + 1;
    }

    // Shutdown — HttpServer.Stop() internally does the self-probe trick
    // to unblock its own AcceptTcpClient (since TcpListener::accept doesn't
    // reliably interrupt on listener fd close on macOS).
    server.Stop();
    srv.Join();
}

[Test]
void test_serve_threaded_handles_sequential_calls() {
    // Verify that ServeThreaded also handles requests one-after-the-other
    // correctly (not just concurrent).
    var server = new HttpServer();
    server.Bind("127.0.0.1", 0);
    int port = server.LocalPort();
    string url = "http://127.0.0.1:" + Int32.ToString(port) + "/";

    Thread srv = Thread.Start(() => {
        server.ServeThreaded((HttpServerContext ctx) => {
            ctx.SendText(200, "ok");
        });
    });

    var c1 = new HttpClient();
    Assert.Equal("ok", c1.Get(url).BodyAsString());
    var c2 = new HttpClient();
    Assert.Equal("ok", c2.Get(url).BodyAsString());
    var c3 = new HttpClient();
    Assert.Equal("ok", c3.Get(url).BodyAsString());

    server.Stop();
    srv.Join();
}
