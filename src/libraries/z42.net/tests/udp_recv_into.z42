// add-z42-net-udp-recv-into (2026-05-27): UdpClient.ReceiveInto.
namespace Z42NetUdpRecvIntoTests;

using Std;
using Std.Test;
using Std.Net.Sockets;
using Std.Encoding;

[Test]
void test_recv_into_round_trip_writes_into_buffer() {
    var server = new UdpClient();
    server.Bind("127.0.0.1", 0);
    int port = server.LocalPort();

    var client = new UdpClient();
    byte[] msg = Utf8.GetBytes("hello-recv-into");
    client.Send(msg, msg.Length, "127.0.0.1", port);

    byte[] buf = new byte[64];
    int n = server.ReceiveIntoFull(buf);
    Assert.Equal(msg.Length, n);

    // Decode the prefix; trailing bytes remain zero (untouched).
    byte[] view = new byte[n];
    int i = 0;
    while (i < n) { view[i] = buf[i]; i = i + 1; }
    Assert.Equal("hello-recv-into", Utf8.GetString(view));

    client.Dispose();
    server.Dispose();
}

[Test]
void test_recv_into_with_offset_preserves_prefix() {
    var server = new UdpClient();
    server.Bind("127.0.0.1", 0);
    int port = server.LocalPort();

    var client = new UdpClient();
    byte[] msg = Utf8.GetBytes("XYZ");
    client.Send(msg, msg.Length, "127.0.0.1", port);

    byte[] buf = new byte[16];
    buf[0] = (byte)'A';
    buf[1] = (byte)'B';
    int n = server.ReceiveInto(buf, 2, 14);
    Assert.Equal(3, n);
    // Bytes 0..2 untouched, 2..5 carry payload, rest zero.
    Assert.Equal((byte)'A', buf[0]);
    Assert.Equal((byte)'B', buf[1]);
    Assert.Equal((byte)'X', buf[2]);
    Assert.Equal((byte)'Y', buf[3]);
    Assert.Equal((byte)'Z', buf[4]);
    Assert.Equal((byte)0,   buf[5]);

    client.Dispose();
    server.Dispose();
}

[Test]
void test_recv_into_exposes_last_sender_address() {
    var server = new UdpClient();
    server.Bind("127.0.0.1", 0);
    int port = server.LocalPort();

    var client = new UdpClient();
    client.Bind("127.0.0.1", 0);
    int clientPort = client.LocalPort();
    byte[] msg = Utf8.GetBytes("ping");
    client.Send(msg, msg.Length, "127.0.0.1", port);

    byte[] buf = new byte[16];
    server.ReceiveIntoFull(buf);
    Assert.Equal("127.0.0.1", server.LastReceiveHost());
    Assert.Equal(clientPort, server.LastReceivePort());

    client.Dispose();
    server.Dispose();
}

[Test]
void test_recv_into_before_bind_throws() {
    var u = new UdpClient();
    bool caught = false;
    try {
        u.ReceiveIntoFull(new byte[16]);
    } catch (InvalidOperationException e) {
        caught = true;
    }
    Assert.True(caught);
    u.Dispose();
}

[Test]
void test_recv_into_truncates_oversize_datagram() {
    var server = new UdpClient();
    server.Bind("127.0.0.1", 0);
    int port = server.LocalPort();

    var client = new UdpClient();
    byte[] msg = new byte[20];
    int i = 0;
    while (i < 20) { msg[i] = (byte)(i + 1); i = i + 1; }
    client.Send(msg, msg.Length, "127.0.0.1", port);

    // Buffer smaller than datagram → silent truncation at the buffer edge.
    byte[] small = new byte[8];
    int n = server.ReceiveIntoFull(small);
    Assert.Equal(8, n);
    Assert.Equal((byte)1, small[0]);
    Assert.Equal((byte)8, small[7]);

    client.Dispose();
    server.Dispose();
}
