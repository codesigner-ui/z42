// add-z42-net-http-auth (2026-05-27): WithBasicAuth / WithBearerToken.
namespace Z42NetHttpAuthHelpersTests;

using Std;
using Std.Test;
using Std.Net.Http;

[Test]
void test_basic_auth_rfc7617_aladdin_open_sesame() {
    // RFC 7617 §2: the canonical example.
    //   "Aladdin:open sesame" → "QWxhZGRpbjpvcGVuIHNlc2FtZQ=="
    var req = new HttpRequest("GET", "http://example.com/");
    req.WithBasicAuth("Aladdin", "open sesame");
    string auth = req.Headers.Get("Authorization");
    Assert.Equal("Basic QWxhZGRpbjpvcGVuIHNlc2FtZQ==", auth);
}

[Test]
void test_basic_auth_overwrites_existing_header() {
    var req = new HttpRequest("GET", "http://example.com/");
    req.SetHeader("Authorization", "Bearer old-token");
    req.WithBasicAuth("u", "p");
    string auth = req.Headers.Get("Authorization");
    // Should be Basic now, not Bearer.
    Assert.True(auth.StartsWith("Basic "));
}

[Test]
void test_basic_auth_empty_password() {
    // Common pattern for token-as-user (e.g. GitHub API username + empty pwd).
    var req = new HttpRequest("GET", "http://example.com/");
    req.WithBasicAuth("token-as-user", "");
    string auth = req.Headers.Get("Authorization");
    // "token-as-user:" → "dG9rZW4tYXMtdXNlcjo="
    Assert.Equal("Basic dG9rZW4tYXMtdXNlcjo=", auth);
}

[Test]
void test_bearer_token_format() {
    var req = new HttpRequest("GET", "http://api.example.com/me");
    req.WithBearerToken("ghp_xxxxxxxxxxxxxxxxxxxx");
    string auth = req.Headers.Get("Authorization");
    Assert.Equal("Bearer ghp_xxxxxxxxxxxxxxxxxxxx", auth);
}

[Test]
void test_bearer_overwrites_existing_basic() {
    var req = new HttpRequest("GET", "http://example.com/");
    req.WithBasicAuth("u", "p");
    req.WithBearerToken("new-jwt-token");
    string auth = req.Headers.Get("Authorization");
    Assert.True(auth.StartsWith("Bearer "));
}

[Test]
void test_builder_chaining_with_other_setters() {
    var req = new HttpRequest("POST", "http://api.example.com/data")
        .WithBearerToken("tok123")
        .SetHeader("Content-Type", "application/json")
        .SetBody(new byte[]{ (byte)'{', (byte)'}' });
    Assert.Equal("Bearer tok123", req.Headers.Get("Authorization"));
    Assert.Equal("application/json", req.Headers.Get("Content-Type"));
    Assert.Equal(2, req.Body.Length);
}
