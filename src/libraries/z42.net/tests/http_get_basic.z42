// add-z42-net-http K3 (2026-05-25): basic GET against in-process server.
namespace Z42NetHttpGetBasicTests;

using Std;
using Std.Test;
using Std.Threading;
using Std.Net.Sockets;
using Std.Net.Http;

[Test]
void test_get_returns_200_ok_with_body() {
    // Spin up a tiny in-process server thread.
    var server = new TcpListener();
    server.Bind("127.0.0.1", 0);
    int port = server.LocalPort();
    string url = "http://127.0.0.1:" + Int32.ToString(port) + "/hello";

    Thread srv = Thread.Start(() => {
        var peer = server.AcceptTcpClient();
        var s = peer.GetStream();
        // Read request bytes — we don't parse, just drain until \r\n\r\n.
        byte[] buf = new byte[4096];
        int total = 0;
        while (true) {
            int got = s.Read(buf, total, buf.Length - total);
            if (got == 0) break;
            total = total + got;
            // Simple boundary check
            if (total >= 4) {
                if (buf[total - 4] == (byte)13 && buf[total - 3] == (byte)10
                    && buf[total - 2] == (byte)13 && buf[total - 1] == (byte)10) {
                    break;
                }
            }
        }
        // Send canned response
        string resp = "HTTP/1.1 200 OK\r\n"
            + "Content-Type: text/plain\r\n"
            + "Content-Length: 5\r\n"
            + "Connection: close\r\n"
            + "\r\n"
            + "Hello";
        byte[] respBytes = Utf8.GetBytes(resp);
        s.Write(respBytes, 0, respBytes.Length);
        peer.Dispose();
    });

    var client = new HttpClient();
    HttpResponse r = client.Get(url);

    Assert.Equal(200, r.StatusCode);
    Assert.Equal("OK", r.ReasonPhrase);
    Assert.True(r.IsSuccess());
    Assert.Equal("text/plain", r.Headers.Get("Content-Type"));
    Assert.Equal("Hello", r.BodyAsString());

    srv.Join();
    server.Stop();
}

[Test]
void test_404_not_found() {
    var server = new TcpListener();
    server.Bind("127.0.0.1", 0);
    int port = server.LocalPort();
    string url = "http://127.0.0.1:" + Int32.ToString(port) + "/missing";

    Thread srv = Thread.Start(() => {
        var peer = server.AcceptTcpClient();
        var s = peer.GetStream();
        byte[] buf = new byte[4096];
        int total = 0;
        while (total < 4 || !(buf[total - 4] == (byte)13 && buf[total - 3] == (byte)10
                              && buf[total - 2] == (byte)13 && buf[total - 1] == (byte)10)) {
            int got = s.Read(buf, total, buf.Length - total);
            if (got == 0) break;
            total = total + got;
        }
        string resp = "HTTP/1.1 404 Not Found\r\nContent-Length: 0\r\nConnection: close\r\n\r\n";
        byte[] rb = Utf8.GetBytes(resp);
        s.Write(rb, 0, rb.Length);
        peer.Dispose();
    });

    var client = new HttpClient();
    HttpResponse r = client.Get(url);
    Assert.Equal(404, r.StatusCode);
    Assert.Equal("Not Found", r.ReasonPhrase);
    Assert.False(r.IsSuccess());
    Assert.Equal(0, r.Body.Length);

    srv.Join();
    server.Stop();
}
