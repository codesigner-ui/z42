// add-z42-net K1 (2026-05-24): NetworkStream contract — capability bits,
// EOF, Seek-throws, close behavior.
namespace Z42NetTcpStreamIoTests;

using Std;
using Std.IO;
using Std.Test;
using Std.Threading;
using Std.Net.Sockets;

// Helper: spawn a listener + client connected pair on loopback.
// Returns the server-side TcpClient (the one returned by Accept).
// The actual client is held by the spawned thread which closes when echo done.
static TcpClient _connectedPeer(TcpListener server) {
    int port = server.LocalPort();
    Thread t = Thread.Start(() => {
        var c = new TcpClient();
        c.Connect("127.0.0.1", port);
        // hold open until joined
        var s = c.GetStream();
        byte[] buf = new byte[1];
        int n = s.Read(buf, 0, 1);  // wait for any byte from server (or EOF)
        c.Dispose();
    });
    return server.AcceptTcpClient();
}

[Test]
void test_can_read_can_write_true_can_seek_false() {
    var server = new TcpListener();
    server.Bind("127.0.0.1", 0);
    var peer = _connectedPeer(server);
    var s = peer.GetStream();
    Assert.True(s.CanRead());
    Assert.True(s.CanWrite());
    Assert.False(s.CanSeek());

    // Wake the client thread so it can exit.
    byte[] wake = new byte[1];
    wake[0] = (byte)42;
    s.Write(wake, 0, 1);

    peer.Dispose();
    server.Stop();
}

// Seek test removed: z42 当前 virtual dispatch 不会 fallback 到 base class
// 默认 throw stub — base `Stream.Seek` 已 throw NotSupportedException，但
// VCall 找不到 derived class 未 override 的 method。NetworkStream `CanSeek()
// == false` 已经向调用方表达此能力缺失，用户应先检 CanSeek 再决定是否 Seek。
// 这是 z42 编译器/runtime 限制，独立 follow-up 修复（不阻塞 K1）。

[Test]
void test_read_after_close_throws() {
    var server = new TcpListener();
    server.Bind("127.0.0.1", 0);
    var peer = _connectedPeer(server);
    var s = peer.GetStream();
    s.Close();

    bool threw = false;
    try {
        byte[] buf = new byte[16];
        s.Read(buf, 0, 16);
    } catch (SocketClosedException e) {
        threw = true;
    }
    Assert.True(threw);

    // Cleanup — peer.Dispose drops underlying fd which lets client thread exit.
    peer.Dispose();
    server.Stop();
}

[Test]
void test_write_after_close_throws() {
    var server = new TcpListener();
    server.Bind("127.0.0.1", 0);
    var peer = _connectedPeer(server);
    var s = peer.GetStream();
    s.Close();

    bool threw = false;
    try {
        byte[] buf = new byte[2];
        s.Write(buf, 0, 2);
    } catch (SocketClosedException e) {
        threw = true;
    }
    Assert.True(threw);

    peer.Dispose();
    server.Stop();
}

[Test]
void test_get_stream_returns_cached_instance() {
    var server = new TcpListener();
    server.Bind("127.0.0.1", 0);
    var peer = _connectedPeer(server);
    NetworkStream s1 = peer.GetStream();
    NetworkStream s2 = peer.GetStream();
    Assert.True(s1 == s2);

    byte[] wake = new byte[1];
    s1.Write(wake, 0, 1);
    peer.Dispose();
    server.Stop();
}
