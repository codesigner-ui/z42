// add-tcplistener-create-factory (2026-05-27): TcpListener.Create(host, port)
// static convenience that combines `new + Bind`.
namespace Z42NetTcpListenerFactoryTests;

using Std;
using Std.Test;
using Std.Net.Sockets;

[Test]
void test_create_returns_bound_listener() {
    var l = TcpListener.Create("127.0.0.1", 0);
    try {
        // OS picked a port, so LocalPort > 0 confirms Bind ran.
        Assert.True(l.LocalPort() > 0);
    } finally {
        l.Dispose();
    }
}

[Test]
void test_create_equivalent_to_manual_new_bind() {
    var manual = new TcpListener();
    manual.Bind("127.0.0.1", 0);
    var factory = TcpListener.Create("127.0.0.1", 0);
    try {
        // Both must have valid (distinct) ports.
        Assert.True(manual.LocalPort() > 0);
        Assert.True(factory.LocalPort() > 0);
        Assert.False(manual.LocalPort() == factory.LocalPort());
    } finally {
        manual.Dispose();
        factory.Dispose();
    }
}
