namespace Std;

// add-z42-net-websocket K4 (2026-05-25): base WebSocket exception. Subclassed
// by `WebSocketProtocolException` for RFC 6455 wire violations. Caller can
// catch this for catch-all WS error handling.
public class WebSocketException : NetException {
    public WebSocketException(string message) : base(message) {}

    override string ToString() {
        return "WebSocketException: " + this.Message;
    }
}
