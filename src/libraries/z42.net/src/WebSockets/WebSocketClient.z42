namespace Std.Net.WebSockets;

using Std;
using Std.Crypto;
using Std.Encoding;
using Std.Net.Sockets;

// add-z42-net-websocket K4 (2026-05-25): RFC 6455 WebSocket client over TCP.
//
// Pure-script over `Std.Net.Sockets.TcpClient` (K1). No new VM builtin.
// ws:// only — wss:// throws `NotSupportedException` pending
// `add-z42-net-tls`.
//
// Lifecycle:
//   var ws = new WebSocketClient();
//   ws.Connect("ws://example.com:8080/echo");
//   ws.SendText("hello");
//   WebSocketMessage rx = ws.Receive();   // blocks until message
//   ws.Close(1000, "bye");
//
// V0 limits:
//   - Outgoing always single-frame (FIN=1, no fragmentation send)
//   - Incoming fragmentation: assembled into one message
//   - Ping (server) → auto-Pong (client) inside `Receive`
//   - No Sec-WebSocket-Accept verification (status 101 + Upgrade header
//     sufficient v0; SHA-1 validation is `add-z42-net-websocket-accept-validate`
//     follow-up since z42.crypto lacks SHA-1)
//   - No per-message-deflate, no subprotocol negotiation
public class WebSocketClient {
    private TcpClient     _tcp;
    private NetworkStream _stream;
    private int           _state;
    private Random        _rng;

    public WebSocketClient() {
        this._tcp    = null;
        this._stream = null;
        this._state  = WebSocketState.Closed;
        this._rng    = new Random();
    }

    public int State() {
        return this._state;
    }

    /// Establish a WebSocket connection. URL must be `ws://host[:port][/path]`.
    /// `wss://` throws `NotSupportedException` pending TLS support.
    public void Connect(string url) {
        if (this._state != WebSocketState.Closed) {
            throw new InvalidOperationException("WebSocketClient already connected");
        }
        this._state = WebSocketState.Connecting;

        // ── Parse URL (ws:// minimal subset; HttpUrl is http-only)
        _WsUrl parsed = WebSocketClient._parseWsUrl(url);
        string host = parsed.Host;
        int    port = parsed.Port;
        string pathQuery = parsed.PathQuery;

        // ── TCP connect
        var tcp = new TcpClient();
        tcp.Connect(host, port);
        var stream = tcp.GetStream();
        this._tcp    = tcp;
        this._stream = stream;

        // ── Send Upgrade request
        string key = WebSocketClient._randomKey(this._rng);
        string hostHeader = host;
        if (port != 80) hostHeader = host + ":" + Int32.ToString(port);
        string req = "GET " + pathQuery + " HTTP/1.1\r\n"
            + "Host: " + hostHeader + "\r\n"
            + "Upgrade: websocket\r\n"
            + "Connection: Upgrade\r\n"
            + "Sec-WebSocket-Key: " + key + "\r\n"
            + "Sec-WebSocket-Version: 13\r\n"
            + "User-Agent: z42-ws/0.1\r\n"
            + "\r\n";
        byte[] reqBytes = Utf8.GetBytes(req);
        stream.Write(reqBytes, 0, reqBytes.Length);

        // ── Read response. Must be 101 Switching Protocols + Upgrade: websocket.
        //    Sec-WebSocket-Accept also verified against base64(SHA-1(key + magic))
        //    per RFC 6455 §4.2.2 (add-sha1-to-crypto 2026-05-25 unblock).
        WebSocketClient._verifyHandshakeResponse(stream, key);

        this._state = WebSocketState.Open;
    }

    /// Send a text message (UTF-8 encoded). Single frame, FIN=1.
    public void SendText(string text) {
        this._ensureOpen();
        byte[] payload = Utf8.GetBytes(text);
        this._sendFrame(_FrameCodec.OpText, payload, payload.Length);
    }

    /// Send a binary message. `length` allows passing a slice (uses `data[0..length]`).
    public void SendBinary(byte[] data, int length) {
        this._ensureOpen();
        this._sendFrame(_FrameCodec.OpBinary, data, length);
    }

    /// Send an unsolicited ping. Server should reply with pong (auto-handled
    /// in this client's Receive).
    public void SendPing(byte[] payload, int length) {
        this._ensureOpen();
        this._sendFrame(_FrameCodec.OpPing, payload, length);
    }

    /// Block until a text / binary / close message arrives. Ping frames
    /// from the server are auto-acknowledged with Pong frames and the
    /// receive loop continues. Pong frames are silently dropped.
    ///
    /// Returns a `WebSocketMessage`; for close frames, the message type is
    /// `Close` and the caller should `Close()` the client (or accept the
    /// connection has ended).
    public WebSocketMessage Receive() {
        if (this._state == WebSocketState.Closed) {
            throw new InvalidOperationException("WebSocketClient is closed");
        }
        // Accumulate fragmented frames (RFC §5.4). v0: single message at a
        // time; multi-frame messages get assembled here.
        byte[] body = new byte[0];
        int messageOpcode = -1;
        while (true) {
            _DecodedFrame frame = _FrameCodec.ReadFrame(this._stream);
            if (frame.Opcode == _FrameCodec.OpPing) {
                // Auto-Pong the same payload back. Control frames cannot be
                // fragmented (RFC §5.4) — frame.Fin must be true here.
                this._sendFrame(_FrameCodec.OpPong, frame.Payload, frame.Payload.Length);
                continue;
            }
            if (frame.Opcode == _FrameCodec.OpPong) {
                // Drop — application doesn't care about pong (heartbeat path).
                continue;
            }
            if (frame.Opcode == _FrameCodec.OpClose) {
                // Server-initiated close. Reply with close (echo or empty)
                // if we haven't already, then transition to Closed.
                if (this._state == WebSocketState.Open) {
                    this._sendFrame(_FrameCodec.OpClose, frame.Payload, frame.Payload.Length);
                }
                this._state = WebSocketState.Closed;
                return new WebSocketMessage(WebSocketMessageType.Close, frame.Payload);
            }
            // Data frame (text / binary / continuation).
            if (frame.Opcode == _FrameCodec.OpText || frame.Opcode == _FrameCodec.OpBinary) {
                if (messageOpcode != -1) {
                    throw new WebSocketProtocolException(
                        "new data frame mid-fragmented-message (expected continuation, got opcode "
                        + Int32.ToString(frame.Opcode) + ")");
                }
                messageOpcode = frame.Opcode;
            } else if (frame.Opcode == _FrameCodec.OpContinuation) {
                if (messageOpcode == -1) {
                    throw new WebSocketProtocolException(
                        "continuation frame without initial data frame");
                }
            } else {
                throw new WebSocketProtocolException(
                    "unknown opcode: " + Int32.ToString(frame.Opcode));
            }
            // Append frame payload to body.
            body = WebSocketClient._concatBytes(body, frame.Payload);
            if (frame.Fin) {
                int messageType;
                if (messageOpcode == _FrameCodec.OpText) {
                    messageType = WebSocketMessageType.Text;
                } else {
                    messageType = WebSocketMessageType.Binary;
                }
                return new WebSocketMessage(messageType, body);
            }
        }
        // Unreachable.
        throw new WebSocketProtocolException("receive loop terminated unexpectedly");
    }

    /// Close the connection with a status code and optional reason text.
    /// Status code 1000 = normal closure (RFC 6455 §7.4).
    public void Close(int statusCode, string reason) {
        if (this._state == WebSocketState.Closed) return;
        // Close payload: 2-byte BE status + UTF-8 reason
        byte[] reasonBytes = Utf8.GetBytes(reason);
        byte[] payload = new byte[2 + reasonBytes.Length];
        payload[0] = (byte)((statusCode >> 8) & 0xFF);
        payload[1] = (byte)(statusCode & 0xFF);
        int i = 0;
        while (i < reasonBytes.Length) {
            payload[2 + i] = reasonBytes[i];
            i = i + 1;
        }
        try {
            this._sendFrame(_FrameCodec.OpClose, payload, payload.Length);
        } catch (Exception e) {
            // Swallow — connection may already be torn down.
        }
        this._state = WebSocketState.CloseSent;
        // Don't wait for server's close ack — caller can drive `Receive` if
        // they want the close-ack message. Drop the TCP socket either way.
        this.Dispose();
    }

    /// Immediately tear down the TCP connection without a graceful close.
    /// Idempotent.
    public void Dispose() {
        if (this._tcp != null) {
            this._tcp.Dispose();
            this._tcp = null;
            this._stream = null;
        }
        this._state = WebSocketState.Closed;
    }

    // ── Internals ────────────────────────────────────────────────────────

    private void _ensureOpen() {
        if (this._state != WebSocketState.Open) {
            throw new InvalidOperationException("WebSocketClient is not open (state=" + Int32.ToString(this._state) + ")");
        }
    }

    private void _sendFrame(int opcode, byte[] payload, int length) {
        byte[] mask = WebSocketClient._randomMask(this._rng);
        byte[] frame = _FrameCodec.EncodeFrame(opcode, payload, length, mask);
        this._stream.Write(frame, 0, frame.Length);
    }

    // ── URL parsing ──────────────────────────────────────────────────────

    static _WsUrl _parseWsUrl(string url) {
        int sep = WebSocketClient._indexOf(url, "://", 0);
        if (sep < 0) {
            throw new FormatException("WebSocketClient: missing '://' in URL '" + url + "'");
        }
        string sch = WebSocketClient._substring(url, 0, sep).ToLower();
        if (sch == "wss") {
            throw new NotSupportedException(
                "wss:// not supported in z42.net v0; needs add-z42-net-tls follow-up");
        }
        if (sch != "ws") {
            throw new FormatException("WebSocketClient: only ws:// supported, got '" + sch + "'");
        }
        int authStart = sep + 3;
        int pathStart = WebSocketClient._indexOfAnyAfter(url, '/', '?', authStart);
        int authEnd;
        if (pathStart < 0) { authEnd = url.Length; } else { authEnd = pathStart; }
        string auth = WebSocketClient._substring(url, authStart, authEnd);
        if (auth.Length == 0) {
            throw new FormatException("WebSocketClient: empty authority");
        }
        string host;
        int    port;
        int colonAt = WebSocketClient._indexOf(auth, ":", 0);
        if (colonAt < 0) {
            host = auth;
            port = 80;
        } else {
            host = WebSocketClient._substring(auth, 0, colonAt);
            string portStr = WebSocketClient._substring(auth, colonAt + 1, auth.Length);
            try {
                port = Int32.Parse(portStr);
            } catch (Exception e) {
                throw new FormatException("WebSocketClient: invalid port '" + portStr + "'");
            }
            if (port < 0 || port > 65535) {
                throw new FormatException("WebSocketClient: port out of range: " + Int32.ToString(port));
            }
        }
        string pathQuery;
        if (pathStart < 0) {
            pathQuery = "/";
        } else {
            pathQuery = WebSocketClient._substring(url, pathStart, url.Length);
            if (pathQuery.Length == 0) pathQuery = "/";
        }
        return new _WsUrl(host, port, pathQuery);
    }

    // ── Handshake response verification ──────────────────────────────────

    static void _verifyHandshakeResponse(Stream stream, string clientKey) {
        // Read status line + headers via a simple line reader. Reusing the
        // HTTP module's reader would create a cross-module dependency; we
        // re-implement minimal line reader inline (`_WsLineReader` below).
        var lr = new _WsLineReader(stream);
        string statusLine = lr.ReadLine();
        if (statusLine == null) {
            throw new WebSocketProtocolException("handshake: EOF reading status line");
        }
        if (!WebSocketClient._startsWith(statusLine, "HTTP/1.1 101")
            && !WebSocketClient._startsWith(statusLine, "HTTP/1.0 101")) {
            throw new WebSocketProtocolException(
                "handshake: expected 101 Switching Protocols, got '" + statusLine + "'");
        }
        bool seenUpgrade  = false;
        string acceptHdr  = null;
        while (true) {
            string line = lr.ReadLine();
            if (line == null) {
                throw new WebSocketProtocolException("handshake: EOF in headers");
            }
            if (line.Length == 0) break;
            int colon = WebSocketClient._indexOfChar(line, ':', 0);
            if (colon < 0) continue;
            string name      = WebSocketClient._substring(line, 0, colon).ToLower();
            string rawValue  = WebSocketClient._trim(WebSocketClient._substring(line, colon + 1, line.Length));
            string lowValue  = rawValue.ToLower();
            if (name == "upgrade" && lowValue == "websocket") {
                seenUpgrade = true;
            }
            if (name == "sec-websocket-accept") {
                acceptHdr = rawValue;
            }
        }
        if (!seenUpgrade) {
            throw new WebSocketProtocolException(
                "handshake: missing 'Upgrade: websocket' response header");
        }
        // Sec-WebSocket-Accept validation per RFC 6455 §4.2.2.
        // base64(SHA-1(clientKey + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11")).
        if (acceptHdr == null) {
            throw new WebSocketProtocolException(
                "handshake: missing 'Sec-WebSocket-Accept' response header");
        }
        string expected = WebSocketClient._computeExpectedAccept(clientKey);
        if (acceptHdr != expected) {
            throw new WebSocketProtocolException(
                "handshake: invalid Sec-WebSocket-Accept '" + acceptHdr
                + "', expected '" + expected + "'");
        }
    }

    /// Compute the expected `Sec-WebSocket-Accept` value for a given client
    /// `Sec-WebSocket-Key` per RFC 6455 §4.2.2.
    static string _computeExpectedAccept(string clientKey) {
        string magic = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11";
        string combined = clientKey + magic;
        byte[] digest = Sha1.HashString(combined);
        return Base64.Encode(digest);
    }

    static string _randomKey(Random rng) {
        // 16 random bytes → base64. Generates a fresh value per Connect call.
        byte[] keyBytes = new byte[16];
        int i = 0;
        while (i < 16) {
            keyBytes[i] = (byte)(rng.NextIntRange(0, 256));
            i = i + 1;
        }
        return Base64.Encode(keyBytes);
    }

    static byte[] _randomMask(Random rng) {
        byte[] mask = new byte[4];
        mask[0] = (byte)(rng.NextIntRange(0, 256));
        mask[1] = (byte)(rng.NextIntRange(0, 256));
        mask[2] = (byte)(rng.NextIntRange(0, 256));
        mask[3] = (byte)(rng.NextIntRange(0, 256));
        return mask;
    }

    // ── Byte / string helpers ────────────────────────────────────────────

    static byte[] _concatBytes(byte[] a, byte[] b) {
        byte[] r = new byte[a.Length + b.Length];
        int i = 0;
        while (i < a.Length) { r[i] = a[i]; i = i + 1; }
        int j = 0;
        while (j < b.Length) { r[a.Length + j] = b[j]; j = j + 1; }
        return r;
    }

    static int _indexOf(string s, string needle, int start) {
        int n = s.Length;
        int m = needle.Length;
        if (m == 0) return start;
        int i = start;
        while (i + m <= n) {
            int j = 0;
            while (j < m && s.CharAt(i + j) == needle.CharAt(j)) {
                j = j + 1;
            }
            if (j == m) return i;
            i = i + 1;
        }
        return -1;
    }

    static int _indexOfChar(string s, char c, int start) {
        int i = start;
        while (i < s.Length) {
            if (s.CharAt(i) == c) return i;
            i = i + 1;
        }
        return -1;
    }

    static int _indexOfAnyAfter(string s, char c1, char c2, int start) {
        int i = start;
        while (i < s.Length) {
            char ch = s.CharAt(i);
            if (ch == c1 || ch == c2) return i;
            i = i + 1;
        }
        return -1;
    }

    static string _substring(string s, int start, int end) {
        if (start >= end) return "";
        char[] buf = new char[end - start];
        int i = 0;
        while (i < end - start) {
            buf[i] = s.CharAt(start + i);
            i = i + 1;
        }
        return String.FromChars(buf);
    }

    static bool _startsWith(string s, string prefix) {
        if (s.Length < prefix.Length) return false;
        int i = 0;
        while (i < prefix.Length) {
            if (s.CharAt(i) != prefix.CharAt(i)) return false;
            i = i + 1;
        }
        return true;
    }

    static string _trim(string s) {
        int start = 0;
        while (start < s.Length && (s.CharAt(start) == ' ' || s.CharAt(start) == '\t')) {
            start = start + 1;
        }
        int end = s.Length;
        while (end > start && (s.CharAt(end - 1) == ' ' || s.CharAt(end - 1) == '\t')) {
            end = end - 1;
        }
        return WebSocketClient._substring(s, start, end);
    }
}

// Internal value carrier — z42 has no out params / tuples, so the URL parser
// returns this 3-field record.
public class _WsUrl {
    public string Host;
    public int    Port;
    public string PathQuery;

    public _WsUrl(string host, int port, string pathQuery) {
        this.Host      = host;
        this.Port      = port;
        this.PathQuery = pathQuery;
    }
}

// Internal line reader for handshake response (minimal copy of HttpClient's
// `_LineReader` — kept inline to avoid Http ↔ WebSockets cross-coupling).
public class _WsLineReader {
    private Stream _stream;
    private byte[] _buf;
    private int    _bufStart;
    private int    _bufEnd;
    private char[] _line;
    private int    _lineLen;

    public _WsLineReader(Stream stream) {
        this._stream   = stream;
        this._buf      = new byte[1024];
        this._bufStart = 0;
        this._bufEnd   = 0;
        this._line     = new char[256];
        this._lineLen  = 0;
    }

    public string ReadLine() {
        this._lineLen = 0;
        bool any = false;
        while (true) {
            if (this._bufStart >= this._bufEnd) {
                if (!this._refill()) {
                    if (!any) return null;
                    return this._finish();
                }
            }
            int b = (int)this._buf[this._bufStart];
            this._bufStart = this._bufStart + 1;
            any = true;
            if (b == 10) {
                return this._finish();
            }
            if (b == 13) {
                if (this._bufStart >= this._bufEnd) {
                    this._refill();
                }
                if (this._bufStart < this._bufEnd && (int)this._buf[this._bufStart] == 10) {
                    this._bufStart = this._bufStart + 1;
                }
                return this._finish();
            }
            if (this._lineLen == this._line.Length) {
                char[] grown = new char[this._line.Length * 2];
                int i = 0;
                while (i < this._lineLen) { grown[i] = this._line[i]; i = i + 1; }
                this._line = grown;
            }
            this._line[this._lineLen] = (char)b;
            this._lineLen = this._lineLen + 1;
        }
        return this._finish();
    }

    private bool _refill() {
        this._bufStart = 0;
        int got = this._stream.Read(this._buf, 0, this._buf.Length);
        this._bufEnd = got;
        return got > 0;
    }

    private string _finish() {
        char[] chars = new char[this._lineLen];
        int i = 0;
        while (i < this._lineLen) {
            chars[i] = this._line[i];
            i = i + 1;
        }
        return String.FromChars(chars);
    }
}
