namespace Std.Net.Sockets;

using Std;

// add-z42-net K1 (2026-05-24): sync blocking TCP client.
//
// Lifecycle:
//   var c = new TcpClient();
//   c.Connect("example.com", 80);     // blocks until TCP handshake complete
//   var s = c.GetStream();            // returns cached NetworkStream
//   s.Write(req, 0, req.Length);
//   var n = s.Read(buf, 0, buf.Length);
//   c.Dispose();                      // closes fd
//
// Connect can be deferred (default constructor creates an unconnected client)
// or eager via `new TcpClient(host, port)`. Mirrors .NET BCL.
//
// IDisposable: z42 没有正式的 IDisposable protocol，但 stdlib 约定带
// `Dispose()` 方法 + GC finalizer drop。这里 explicit Dispose 必须在
// 用户 main path 上调用以及时释放 fd；GC fallback 只是保险。
public class TcpClient {
    private long _slotId;
    private bool _connected;
    private bool _disposed;
    private NetworkStream _stream;
    private string _remoteHost;
    private int _remotePort;
    // add-net-socket-options-extended (2026-05-30): value > 0 routes the
    // next Connect() through __net_tcp_connect_with_timeout. 0 = no preset.
    private int _connectTimeoutMs;

    public TcpClient() {
        this._slotId    = -1;
        this._connected = false;
        this._disposed  = false;
        this._stream    = null;
        this._remoteHost = "";
        this._remotePort = 0;
        this._connectTimeoutMs = 0;
    }

    /// Static factory equivalent to `new TcpClient()` + `.Connect(host, port)`.
    /// Static method rather than 2-param ctor because z42 当前 constructor
    /// 重载解析对多个 2-param ctor 冲突 — accept-side wrapper 用 `_fromAcceptedSlot`
    /// (long, bool) 占用了 $2 slot。
    public static TcpClient ConnectTo(string host, int port) {
        var c = new TcpClient();
        c.Connect(host, port);
        return c;
    }

    /// Establish TCP connection to `host:port`. Blocks until handshake
    /// completes or fails. Throws `SocketException` on connection refused
    /// / DNS failure / network unreachable.
    public void Connect(string host, int port) {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (this._connected) {
            throw new InvalidOperationException("TcpClient already connected");
        }
        // add-net-socket-options-extended (2026-05-30): route through the
        // timeout-aware builtin when SetConnectTimeout(>0) was called.
        object[] raw;
        if (this._connectTimeoutMs > 0) {
            raw = NetTcpNative.ConnectWithTimeout(host, port, this._connectTimeoutMs);
        } else {
            raw = NetTcpNative.Connect(host, port);
        }
        long slotId = NetTcpDecode.ToSlot(raw);
        this._slotId     = slotId;
        this._connected  = true;
        this._remoteHost = host;
        this._remotePort = port;
    }

    /// add-net-socket-options-extended (2026-05-30): cap how long the next
    /// `Connect()` will wait for the TCP handshake before throwing
    /// `SocketException`. `millis <= 0` clears the preset (= blocking).
    /// Call before `Connect` — applies to the NEXT Connect call only; the
    /// value persists across re-connects on the same TcpClient instance.
    public void SetConnectTimeout(int millis) {
        this._connectTimeoutMs = millis;
    }

    /// Get the byte-oriented NetworkStream over this socket. Lazy + cached:
    /// repeat calls return the same instance, so callers can `==`-compare and
    /// closing one closes all.
    public NetworkStream GetStream() {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (!this._connected) {
            throw new InvalidOperationException("TcpClient not connected — call Connect first");
        }
        if (this._stream == null) {
            this._stream = new NetworkStream(this._slotId);
        }
        return this._stream;
    }

    /// Host this client was Connected to (or constructed with). Useful for
    /// error messages and logging.
    public string RemoteHost() {
        return this._remoteHost;
    }

    public int RemotePort() {
        return this._remotePort;
    }

    // add-httpclient-timeout (2026-05-27): per-socket read/write deadlines.
    // `millis <= 0` clears the deadline (back to blocking). Throws
    // `SocketException` if the OS rejects (rare; e.g. bad ms value).

    public void SetReadTimeout(int millis) {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (!this._connected) {
            throw new InvalidOperationException("TcpClient not connected — call Connect first");
        }
        object[] raw = NetTcpNative.SocketSetReadTimeout(this._slotId, millis);
        long kind = (long)raw[0];
        if (kind != 0) {
            NetTcpDecode.Throw(raw, kind);
        }
    }

    public void SetWriteTimeout(int millis) {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (!this._connected) {
            throw new InvalidOperationException("TcpClient not connected — call Connect first");
        }
        object[] raw = NetTcpNative.SocketSetWriteTimeout(this._slotId, millis);
        long kind = (long)raw[0];
        if (kind != 0) {
            NetTcpDecode.Throw(raw, kind);
        }
    }

    /// add-z42-net-socket-options (2026-05-27): TCP_NODELAY (Nagle off).
    /// Default off batches small writes for throughput; on sends
    /// immediately for latency-sensitive protocols (HTTP/2, gaming, RPC).
    public void SetNoDelay(bool enable) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._connected) {
            throw new InvalidOperationException("TcpClient not connected — call Connect first");
        }
        object[] raw = NetTcpNative.SocketSetNoDelay(this._slotId, enable);
        long kind = (long)raw[0];
        if (kind != 0) { NetTcpDecode.Throw(raw, kind); }
    }

    /// add-z42-net-socket-options (2026-05-27): IP_TTL (hop limit) on the
    /// connected socket. `ttl` ∈ [1, 255] typical (255 = unrestricted,
    /// 1 = link-local only).
    public void SetTtl(int ttl) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._connected) {
            throw new InvalidOperationException("TcpClient not connected — call Connect first");
        }
        object[] raw = NetTcpNative.SocketSetTtl(this._slotId, ttl);
        long kind = (long)raw[0];
        if (kind != 0) { NetTcpDecode.Throw(raw, kind); }
    }

    /// add-net-socket-options-extended (2026-05-30): SO_KEEPALIVE on the
    /// connected socket. Uses OS default idle / interval / probe-count.
    /// Use the 4-arg overload for fine-grained tuning.
    /// Must be called AFTER `Connect()` — pre-connect there's no socket.
    public void SetKeepAlive(bool enable) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._connected) {
            throw new InvalidOperationException("TcpClient not connected — call Connect first");
        }
        object[] raw = NetTcpNative.SocketSetKeepalive(this._slotId, enable);
        long kind = (long)raw[0];
        if (kind != 0) { NetTcpDecode.Throw(raw, kind); }
    }

    /// add-net-keepalive-tuning (2026-06-03): SO_KEEPALIVE with per-OS
    /// idle / interval / probe tuning. Same socket / lifecycle rules
    /// as the 1-arg overload. All three tuning values must be `>= 1`
    /// when `enable == true`; `enable == false` ignores them and just
    /// disables keepalive.
    ///
    /// Per-OS field support (silently ignored when unsupported):
    ///   - `idleSecs`     — Unix + Windows
    ///   - `intervalSecs` — Unix + Windows (via WSAIoctl on Windows)
    ///   - `probes`       — Linux / Android / FreeBSD only
    public void SetKeepAlive(bool enable, int idleSecs, int intervalSecs, int probes) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._connected) {
            throw new InvalidOperationException("TcpClient not connected — call Connect first");
        }
        object[] raw = NetTcpNative.SocketSetKeepaliveTuned(this._slotId, enable,
            (long)idleSecs, (long)intervalSecs, (long)probes);
        long kind = (long)raw[0];
        if (kind != 0) { NetTcpDecode.Throw(raw, kind); }
    }

    /// Close the socket and release the underlying fd. Idempotent.
    /// Subsequent operations throw `SocketClosedException`.
    public void Dispose() {
        if (this._disposed) return;
        this._disposed = true;
        if (this._stream != null) {
            this._stream.MarkClosed();
        }
        if (this._connected) {
            NetTcpNative.SocketDrop(this._slotId);
            this._connected = false;
        }
    }

    /// Alias for `Dispose()` matching .NET BCL `TcpClient.Close()`.
    public void Close() {
        this.Dispose();
    }

    // ── Internal constructor for `TcpListener.AcceptTcpClient` ───────────
    //
    // The listener has the slot id from `__net_tcp_accept`; we just need
    // to wrap it in a TcpClient with `_connected = true` straight away.
    // No public-API access path — z42 has no `internal`, see NetworkStream.
    public TcpClient(long slotId, bool fromAccept) {
        this._slotId    = slotId;
        this._connected = true;
        this._disposed  = false;
        this._stream    = null;
        this._remoteHost = "<accepted>";
        this._remotePort = 0;
    }
}
