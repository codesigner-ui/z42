namespace Std.Net.Sockets;

using Std;

// add-net-ipaddress (2026-05-27): strong-typed IP address with parsing,
// family detection, and byte access. v0 supports:
//   * IPv4 dotted-quad: "1.2.3.4"
//   * IPv6 full-form:   "2001:0db8:0000:0000:0000:0000:0000:0001"
//   * IPv6 `::` shorthand for one zero-run: "::1", "::", "2001:db8::1"
//
// Not in scope for v0 (deferred to follow-up):
//   * IPv4-in-IPv6 dotted (e.g. "::ffff:192.0.2.1")
//   * IPv6 zone identifier suffix ("fe80::1%en0")
//   * `Try*` non-throwing variants — caller can `try { Parse }
//     catch (FormatException) {}` (matches BCL `IPAddress.Parse` shape)
public sealed class IPAddress {
    /// AddressFamily-style constant — 4 for IPv4, 6 for IPv6. (No enum
    /// yet — z42 enums are L1 named ints which would collide with
    /// `Ipv4` / `Ipv6` constants in the global namespace.)
    public static int FamilyIPv4 = 4;
    public static int FamilyIPv6 = 6;

    private int    _family;   // 4 or 6
    private byte[] _bytes;    // 4 or 16 bytes, network byte order

    public IPAddress(int family, byte[] bytes) {
        if (family == 4) {
            if (bytes.Length != 4) {
                throw new ArgumentException("IPv4 address requires 4 bytes, got " + bytes.Length.ToString());
            }
        } else if (family == 6) {
            if (bytes.Length != 16) {
                throw new ArgumentException("IPv6 address requires 16 bytes, got " + bytes.Length.ToString());
            }
        } else {
            throw new ArgumentException("unsupported family " + family.ToString() + " (use 4 or 6)");
        }
        this._family = family;
        this._bytes  = bytes;
    }

    // ── Factories ──────────────────────────────────────────────────────

    /// IPv4 loopback (127.0.0.1).
    public static IPAddress Loopback() {
        byte[] b = new byte[4];
        b[0] = (byte)127; b[1] = (byte)0; b[2] = (byte)0; b[3] = (byte)1;
        return new IPAddress(4, b);
    }

    /// IPv4 any (0.0.0.0).
    public static IPAddress Any() {
        return new IPAddress(4, new byte[4]);
    }

    /// IPv6 loopback (::1).
    public static IPAddress IPv6Loopback() {
        byte[] b = new byte[16];
        b[15] = (byte)1;
        return new IPAddress(6, b);
    }

    /// IPv6 any (::).
    public static IPAddress IPv6Any() {
        return new IPAddress(6, new byte[16]);
    }

    // ── Parsing ────────────────────────────────────────────────────────

    /// Parse a string into an IPAddress. Try IPv4 first (`.` separator),
    /// fall back to IPv6 (`:` separator). Throws `FormatException` on
    /// malformed input.
    public static IPAddress Parse(string s) {
        if (s == null || s.Length == 0) {
            throw new FormatException("IPAddress.Parse: empty input");
        }
        if (IPAddress._containsChar(s, '.') && !IPAddress._containsChar(s, ':')) {
            return IPAddress._parseIPv4(s);
        }
        if (IPAddress._containsChar(s, ':')) {
            return IPAddress._parseIPv6(s);
        }
        throw new FormatException("IPAddress.Parse: no '.' or ':' in '" + s + "'");
    }

    // ── Inspect ────────────────────────────────────────────────────────

    public int Family() { return this._family; }

    public bool IsIPv4() { return this._family == 4; }
    public bool IsIPv6() { return this._family == 6; }

    /// Return a copy of the raw bytes (4 for IPv4, 16 for IPv6).
    public byte[] GetAddressBytes() {
        byte[] copy = new byte[this._bytes.Length];
        int i = 0;
        while (i < this._bytes.Length) { copy[i] = this._bytes[i]; i = i + 1; }
        return copy;
    }

    /// True for 127.0.0.0/8 (IPv4) or ::1 (IPv6).
    public bool IsLoopback() {
        if (this._family == 4) {
            return (int)this._bytes[0] == 127;
        }
        // IPv6: ::1 → bytes[0..14] all 0, bytes[15] == 1.
        int i = 0;
        while (i < 15) {
            if ((int)this._bytes[i] != 0) return false;
            i = i + 1;
        }
        return (int)this._bytes[15] == 1;
    }

    /// True for 0.0.0.0 (IPv4) or :: (IPv6).
    public bool IsAny() {
        int i = 0;
        while (i < this._bytes.Length) {
            if ((int)this._bytes[i] != 0) return false;
            i = i + 1;
        }
        return true;
    }

    /// True for 224.0.0.0/4 (IPv4) or ff00::/8 (IPv6).
    public bool IsMulticast() {
        if (this._family == 4) {
            int b0 = (int)this._bytes[0] & 0xF0;
            return b0 == 0xE0;
        }
        return (int)this._bytes[0] == 0xFF;
    }

    // ── Display ────────────────────────────────────────────────────────

    /// Canonical string. IPv4 uses dotted-quad; IPv6 uses the longest
    /// zero-run elision (`::`), lower-case hex, no leading zeros within
    /// a group. Round-trips with `Parse`.
    public override string ToString() {
        if (this._family == 4) {
            return ((int)this._bytes[0]).ToString() + "."
                 + ((int)this._bytes[1]).ToString() + "."
                 + ((int)this._bytes[2]).ToString() + "."
                 + ((int)this._bytes[3]).ToString();
        }
        return IPAddress._formatIPv6(this._bytes);
    }

    public bool Equals(IPAddress other) {
        if (other == null) return false;
        if (this._family != other._family) return false;
        if (this._bytes.Length != other._bytes.Length) return false;
        int i = 0;
        while (i < this._bytes.Length) {
            if ((int)this._bytes[i] != (int)other._bytes[i]) return false;
            i = i + 1;
        }
        return true;
    }

    // ── Internal: IPv4 parse ───────────────────────────────────────────

    static IPAddress _parseIPv4(string s) {
        byte[] bytes = new byte[4];
        int octet = 0;
        int value = 0;
        bool sawDigit = false;
        int i = 0;
        while (i < s.Length) {
            char c = s.CharAt(i);
            if (c == '.') {
                if (!sawDigit) {
                    throw new FormatException("IPv4: empty octet in '" + s + "'");
                }
                if (octet >= 3) {
                    throw new FormatException("IPv4: too many dots in '" + s + "'");
                }
                bytes[octet] = (byte)value;
                octet = octet + 1;
                value = 0;
                sawDigit = false;
            } else if (c >= '0' && c <= '9') {
                value = value * 10 + ((int)c - (int)'0');
                if (value > 255) {
                    throw new FormatException("IPv4: octet > 255 in '" + s + "'");
                }
                sawDigit = true;
            } else {
                throw new FormatException("IPv4: invalid char '" + IPAddress._charStr(c) + "' in '" + s + "'");
            }
            i = i + 1;
        }
        if (octet != 3 || !sawDigit) {
            throw new FormatException("IPv4: need 4 octets in '" + s + "'");
        }
        bytes[3] = (byte)value;
        return new IPAddress(4, bytes);
    }

    // ── Internal: IPv6 parse ───────────────────────────────────────────

    /// IPv6 parse — handles `::` shorthand (at most one). Each group is
    /// 1-4 hex digits. Total 8 groups when expanded; `::` fills the gap.
    static IPAddress _parseIPv6(string s) {
        // Split into pre / post halves around `::` if present.
        int dcPos = IPAddress._findDoubleColon(s);
        string preStr;
        string postStr;
        if (dcPos < 0) {
            preStr = s;
            postStr = "";
        } else {
            preStr  = IPAddress._slice(s, 0, dcPos);
            postStr = IPAddress._slice(s, dcPos + 2, s.Length);
        }
        // Parse each half into a list of u16 groups.
        int[] pre  = IPAddress._splitColonGroups(preStr, s);
        int[] post = IPAddress._splitColonGroups(postStr, s);
        int total = pre.Length + post.Length;
        if (dcPos < 0) {
            if (total != 8) {
                throw new FormatException("IPv6: need exactly 8 groups in '" + s + "'");
            }
        } else {
            if (total > 7) {
                throw new FormatException("IPv6: `::` would elide zero groups in '" + s + "'");
            }
        }
        // Assemble 16 bytes.
        byte[] bytes = new byte[16];
        int idx = 0;
        int i = 0;
        while (i < pre.Length) {
            bytes[idx]     = (byte)((pre[i] >> 8) & 0xFF);
            bytes[idx + 1] = (byte)(pre[i] & 0xFF);
            idx = idx + 2;
            i = i + 1;
        }
        // Skip the zero-run (already zero-initialised).
        if (dcPos >= 0) {
            int zeroGroups = 8 - total;
            idx = idx + zeroGroups * 2;
        }
        i = 0;
        while (i < post.Length) {
            bytes[idx]     = (byte)((post[i] >> 8) & 0xFF);
            bytes[idx + 1] = (byte)(post[i] & 0xFF);
            idx = idx + 2;
            i = i + 1;
        }
        return new IPAddress(6, bytes);
    }

    static int _findDoubleColon(string s) {
        int i = 0;
        while (i + 1 < s.Length) {
            if (s.CharAt(i) == ':' && s.CharAt(i + 1) == ':') {
                // Verify only one `::` in the whole string.
                int j = i + 2;
                while (j + 1 < s.Length) {
                    if (s.CharAt(j) == ':' && s.CharAt(j + 1) == ':') {
                        throw new FormatException("IPv6: more than one `::` in '" + s + "'");
                    }
                    j = j + 1;
                }
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

    /// Parse a colon-separated list of hex groups. Empty input → empty array.
    /// Each group must be 1-4 hex digits.
    static int[] _splitColonGroups(string s, string original) {
        if (s.Length == 0) { return new int[0]; }
        // Count groups (= colons + 1).
        int n = 1;
        int i = 0;
        while (i < s.Length) {
            if (s.CharAt(i) == ':') { n = n + 1; }
            i = i + 1;
        }
        int[] result = new int[n];
        int idx = 0;
        int start = 0;
        i = 0;
        while (i <= s.Length) {
            if (i == s.Length || s.CharAt(i) == ':') {
                if (i == start) {
                    throw new FormatException("IPv6: empty group in '" + original + "'");
                }
                int group = IPAddress._parseHexGroup(s, start, i, original);
                result[idx] = group;
                idx = idx + 1;
                start = i + 1;
            }
            i = i + 1;
        }
        return result;
    }

    static int _parseHexGroup(string s, int start, int end, string original) {
        int len = end - start;
        if (len < 1 || len > 4) {
            throw new FormatException("IPv6: group must be 1-4 hex digits in '" + original + "'");
        }
        int v = 0;
        int i = start;
        while (i < end) {
            char c = s.CharAt(i);
            int d;
            if (c >= '0' && c <= '9')      { d = (int)c - (int)'0'; }
            else if (c >= 'a' && c <= 'f') { d = (int)c - (int)'a' + 10; }
            else if (c >= 'A' && c <= 'F') { d = (int)c - (int)'A' + 10; }
            else {
                throw new FormatException("IPv6: non-hex '" + IPAddress._charStr(c) + "' in '" + original + "'");
            }
            v = (v << 4) | d;
            i = i + 1;
        }
        return v;
    }

    // ── Internal: IPv6 format ──────────────────────────────────────────

    /// Format 16-byte IPv6 to canonical string with longest-zero-run elision.
    static string _formatIPv6(byte[] bytes) {
        // Decompose into 8 u16 groups.
        int[] groups = new int[8];
        int i = 0;
        while (i < 8) {
            groups[i] = ((int)bytes[i * 2] << 8) | (int)bytes[i * 2 + 1];
            i = i + 1;
        }
        // Find longest run of zeros (>= 2) to compress.
        int bestStart = -1;
        int bestLen = 0;
        int curStart = -1;
        int curLen = 0;
        i = 0;
        while (i < 8) {
            if (groups[i] == 0) {
                if (curLen == 0) { curStart = i; }
                curLen = curLen + 1;
                if (curLen > bestLen) { bestStart = curStart; bestLen = curLen; }
            } else {
                curLen = 0;
            }
            i = i + 1;
        }
        if (bestLen < 2) { bestStart = -1; }  // Don't compress single-zero runs.

        string result = "";
        i = 0;
        while (i < 8) {
            if (i == bestStart) {
                // At the zero-run gap, emit `::` regardless of position so
                // the result has two colons here (one is the trailing
                // separator of the previous group, one is the leading
                // separator of the next group). The next-group branch
                // skips its leading separator via `justAfterEllipsis`.
                if (i == 0) { result = "::"; }
                else { result = result + "::"; }
                i = i + bestLen;
                continue;
            }
            if (i > 0 && (bestStart < 0 || i != bestStart + bestLen || true)) {
                // Separator before each non-leading group, unless we just
                // emitted `::` which already includes the trailing `:`.
                bool justAfterEllipsis = (bestStart >= 0 && i == bestStart + bestLen);
                if (!justAfterEllipsis) {
                    result = result + ":";
                }
            }
            result = result + IPAddress._hexGroupStr(groups[i]);
            i = i + 1;
        }
        return result;
    }

    /// 1-4 lowercase hex digits, no leading zeros.
    static string _hexGroupStr(int v) {
        if (v == 0) { return "0"; }
        string s = "";
        bool sawNonzero = false;
        int shift = 12;
        while (shift >= 0) {
            int nibble = (v >> shift) & 0xF;
            if (sawNonzero || nibble != 0) {
                sawNonzero = true;
                if (nibble < 10) {
                    s = s + IPAddress._charStr((char)((int)'0' + nibble));
                } else {
                    s = s + IPAddress._charStr((char)((int)'a' + nibble - 10));
                }
            }
            shift = shift - 4;
        }
        return s;
    }

    // ── Internal helpers ───────────────────────────────────────────────

    static bool _containsChar(string s, char c) {
        int i = 0;
        while (i < s.Length) {
            if (s.CharAt(i) == c) return true;
            i = i + 1;
        }
        return false;
    }

    static string _slice(string s, int start, int end) {
        if (start >= end) return "";
        char[] buf = new char[end - start];
        int i = 0;
        while (i < end - start) { buf[i] = s.CharAt(start + i); i = i + 1; }
        return String.FromChars(buf);
    }

    static string _charStr(char c) {
        char[] buf = new char[1];
        buf[0] = c;
        return String.FromChars(buf);
    }
}
