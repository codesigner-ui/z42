namespace Std;

// add-z42-net-http K3 (2026-05-25): HTTP wire format violation — malformed
// status line, missing CRLF, invalid header line, unexpected EOF mid-body,
// invalid chunked size hex, etc. Distinct from `SocketException` (lower
// network layer) so callers can route protocol bugs separately.
public class HttpProtocolException : HttpException {
    public HttpProtocolException(string message) : base(message) {}

    override string ToString() {
        return "HttpProtocolException: " + this.Message;
    }
}
