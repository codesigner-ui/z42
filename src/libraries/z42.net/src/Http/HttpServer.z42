namespace Std.Net.Http;

using Std;
using Std.IO;
using Std.Threading;
using Std.Net.Sockets;

// add-z42-net-http-server (2026-05-25): single-threaded HTTP/1.1 server.
//
// Pure-script over K1 `TcpListener`. Pattern:
//   var server = new HttpServer();
//   server.Bind("127.0.0.1", 0);
//   int port = server.LocalPort();
//   server.Serve((ctx) => {
//       ctx.SendText(200, "Hello, world!");
//   });
//
// V0 limits:
// - Single-connection serial: one request fully processed before next accept
// - Connection: close after each response (no keep-alive)
// - No streaming request body (parser reads full body upfront)
// - No WebSocket upgrade handling (would need handler to bypass response emit)
// - HTTP only (https:// via `add-z42-net-tls`)
//
// Multi-threaded variant is `add-z42-net-http-server-threaded` follow-up:
// dispatch each `AcceptTcpClient` to a `Std.Threading.Thread` worker.
public class HttpServer {
    private TcpListener _listener;
    private bool        _stopped;
    private int         _localPort;
    private string      _bindHost;

    public HttpServer() {
        this._listener  = null;
        this._stopped   = false;
        this._localPort = 0;
        this._bindHost  = "";
    }

    /// Bind to `host:port` (port 0 → OS-assigned ephemeral). Discover the
    /// chosen port via `LocalPort()` after bind.
    public void Bind(string host, int port) {
        if (this._stopped) {
            throw new SocketClosedException();
        }
        if (this._listener != null) {
            throw new InvalidOperationException("HttpServer already bound");
        }
        var lis = new TcpListener();
        lis.Bind(host, port);
        this._listener  = lis;
        this._localPort = lis.LocalPort();
        this._bindHost  = host;
    }

    public int LocalPort() {
        if (this._listener == null) {
            throw new InvalidOperationException("HttpServer not bound");
        }
        return this._localPort;
    }

    public string BindHost() {
        return this._bindHost;
    }

    /// Handle exactly one incoming request — blocks until a client connects,
    /// then dispatches to the handler. Useful for tests + careful control flow.
    /// Returns after the response is sent and the connection closed.
    public void HandleNext(Action<HttpServerContext> handler) {
        if (this._listener == null) {
            throw new InvalidOperationException("HttpServer not bound");
        }
        if (this._stopped) {
            throw new SocketClosedException();
        }
        TcpClient peer = this._listener.AcceptTcpClient();
        // If Stop() ran concurrently, the accept might have returned a probe
        // connection the Stop helper made to unblock us. Drop it and return.
        if (this._stopped) {
            try { peer.Dispose(); } catch (Exception e) { }
            throw new SocketClosedException();
        }
        try {
            NetworkStream stream = peer.GetStream();
            this._dispatchOne(stream, handler);
            peer.Dispose();
        } catch (Exception e) {
            try { peer.Dispose(); } catch (Exception e2) { }
            throw e;
        }
    }

    // Parse one request and invoke the handler. Uses `var` inference on the
    // ReadRequest return to avoid E0402 cross-class type-object mismatch.
    private void _dispatchOne(NetworkStream stream, Action<HttpServerContext> handler) {
        HttpServerContext ctx = null;
        bool parsed = false;
        try {
            var req = _HttpRequestParser.ReadRequest(stream);
            parsed = true;
            ctx = new HttpServerContext(req, stream);
            handler(ctx);
            if (!ctx.ResponseSent) {
                this._tryEmitErrorResponse(stream, 500, "Internal Server Error",
                    "Handler did not call ctx.Send*");
            }
        } catch (Exception e) {
            if (!parsed) {
                this._tryEmitErrorResponse(stream, 400, "Bad Request",
                    "Malformed request: " + e.Message);
            } else if (ctx != null && !ctx.ResponseSent) {
                this._tryEmitErrorResponse(stream, 500, "Internal Server Error",
                    "Handler threw: " + e.Message);
            }
        }
    }

    /// Loop forever (until `Stop()` called from another thread) handling
    /// one request at a time. V0 single-connection serial.
    public void Serve(Action<HttpServerContext> handler) {
        while (!this._stopped) {
            try {
                this.HandleNext(handler);
            } catch (SocketClosedException e) {
                // Stop() called — listener closed mid-accept. Normal exit path.
                return;
            } catch (Exception e) {
                // Per-iteration error — log and continue.
                ConsoleError.WriteLine("HttpServer.Serve: error: " + e.Message);
            }
        }
    }

    /// Accept-loop with thread-per-connection. Each accepted TcpClient is
    /// handed to a fresh `Std.Threading.Thread` running the handler; the
    /// main accept loop continues immediately without waiting.
    ///
    /// Worker threads are fire-and-forget (no Join) — they drain when their
    /// request completes. Handler MUST be thread-safe (avoid shared mutable
    /// state or guard it).
    ///
    /// `Stop()` closes the listener which causes the next AcceptTcpClient
    /// to throw; in-flight workers continue but are not joined on Stop. For
    /// graceful shutdown, application should drain via cooperation.
    ///
    /// Trade-off: unbounded thread spawn. A request spike spawns a thread
    /// per concurrent connection. Workload-bounded variant is
    /// `add-z42-net-http-server-pool` follow-up.
    public void ServeThreaded(Action<HttpServerContext> handler) {
        while (!this._stopped) {
            if (this._listener == null) return;
            TcpClient peer;
            try {
                peer = this._listener.AcceptTcpClient();
            } catch (SocketClosedException e) {
                return;
            } catch (Exception e) {
                ConsoleError.WriteLine("HttpServer.ServeThreaded: accept error: " + e.Message);
                continue;
            }
            // Stop()-probe wake-up check: if the accept returned because
            // Stop() did a self-connect to unblock us, drop the peer + exit.
            if (this._stopped) {
                try { peer.Dispose(); } catch (Exception e) { }
                return;
            }
            // Dispatch this peer to a worker thread; main loop continues.
            // Capture `peer` and `handler` (handler is the outer parameter,
            // shared by all workers — must be thread-safe per docstring).
            TcpClient workerPeer = peer;
            Thread.Start(() => {
                this._workerHandle(workerPeer, handler);
            });
        }
    }

    /// add-z42-net-http-server-pool (2026-05-28): accept-loop with
    /// bounded worker pool. Pre-spawns `workerCount` worker threads
    /// reading from a bounded `Channel<TcpClient>` of capacity
    /// `queueSize`. When the queue is full, the accept loop drops the
    /// connection (immediately Disposes the TcpClient — caller sees a
    /// connection-reset rather than a delayed processing).
    ///
    /// Trade-off vs ServeThreaded:
    ///   - ServeThreaded: unbounded thread spawn. Spikes can OOM the
    ///     process (each Thread carries a stack — easy to spawn 10k+
    ///     during a flood).
    ///   - ServeWithPool: bounded concurrency, predictable resource
    ///     footprint. Excess connections are dropped early instead of
    ///     queuing → backpressure-friendly + DoS-resistant.
    ///
    /// `workerCount`: typically 2-4× CPU cores. Each worker is a
    /// `Std.Threading.Thread` consuming from the channel.
    /// `queueSize`: how many accepted connections can wait for a free
    /// worker. Larger absorbs spikes; smaller drops earlier under load.
    ///
    /// `Stop()` closes the channel; workers drain pending work then
    /// exit on the next `Recv` (which throws `ChannelDisconnectedException`).
    public void ServeWithPool(Action<HttpServerContext> handler, int workerCount, int queueSize) {
        if (workerCount < 1) {
            throw new ArgumentException(
                "HttpServer.ServeWithPool: workerCount must be ≥ 1, got " + workerCount.ToString());
        }
        if (queueSize < 1) {
            throw new ArgumentException(
                "HttpServer.ServeWithPool: queueSize must be ≥ 1, got " + queueSize.ToString());
        }
        var queue = new Channel<TcpClient>(queueSize);
        // Spawn worker pool. Each worker loops Recv → handle until the
        // channel is closed (Stop() path).
        int w = 0;
        while (w < workerCount) {
            Thread.Start(() => {
                while (true) {
                    TcpClient peer;
                    try {
                        peer = queue.Recv();
                    } catch (ChannelDisconnectedException e) {
                        return;
                    } catch (Exception e) {
                        ConsoleError.WriteLine("HttpServer.ServeWithPool: worker recv error: " + e.Message);
                        return;
                    }
                    if (peer != null) {
                        this._workerHandle(peer, handler);
                    }
                }
            });
            w = w + 1;
        }
        // Accept loop on the calling thread. Enqueues peers; drops if
        // the pool is saturated.
        while (!this._stopped) {
            if (this._listener == null) {
                queue.Close();
                return;
            }
            TcpClient peer;
            try {
                peer = this._listener.AcceptTcpClient();
            } catch (SocketClosedException e) {
                queue.Close();
                return;
            } catch (Exception e) {
                ConsoleError.WriteLine("HttpServer.ServeWithPool: accept error: " + e.Message);
                continue;
            }
            if (this._stopped) {
                try { peer.Dispose(); } catch (Exception e) { }
                queue.Close();
                return;
            }
            // TrySend instead of Send so the accept loop doesn't block
            // when the pool is saturated — drops the connection instead.
            // The DoS-resistance trade-off rationale lives in the
            // docstring above.
            bool enqueued = queue.TrySend(peer);
            if (!enqueued) {
                try { peer.Dispose(); } catch (Exception e) { }
            }
        }
        queue.Close();
    }

    /// Signal the serve loop to exit + close the listener. Idempotent.
    /// If `Serve` / `ServeThreaded` is running in another thread, this also
    /// connects a one-shot probe to the listener port so the in-flight
    /// `AcceptTcpClient` returns immediately (the OS doesn't reliably
    /// interrupt blocking `accept()` on listener fd close — macOS notably).
    /// The accept loop checks `_stopped` after each accept and treats
    /// `true` as exit signal, discarding the probe peer.
    public void Stop() {
        if (this._stopped) return;
        this._stopped = true;
        // Wake the accept loop: connect a probe to ourselves so the next
        // accept returns. Must happen BEFORE we drop the listener.
        int port = this._localPort;
        if (this._listener != null && port > 0) {
            try {
                var probe = new TcpClient();
                probe.Connect("127.0.0.1", port);
                probe.Dispose();
            } catch (Exception e) {
                // Probe might fail if listener already gone or host unreachable
                // (loopback only). Best-effort.
            }
        }
        if (this._listener != null) {
            this._listener.Stop();
            this._listener = null;
        }
    }

    public void Dispose() {
        this.Stop();
    }

    // ── Internal helpers ─────────────────────────────────────────────────

    /// Worker body for `ServeThreaded` — handles one accepted connection
    /// then drops it. Pulled out of the spawning lambda because the IR
    /// verifier doesn't accept nested try/catch with no-op handlers in
    /// thread-spawn closures (register-flow check tripped on empty catch
    /// blocks).
    private void _workerHandle(TcpClient workerPeer, Action<HttpServerContext> handler) {
        NetworkStream stream = null;
        try {
            stream = workerPeer.GetStream();
            this._dispatchOne(stream, handler);
        } catch (Exception e) {
            // Per-worker error — swallow; logging would race other workers.
        }
        try {
            workerPeer.Dispose();
        } catch (Exception e2) {
            // Best-effort cleanup.
        }
    }

    private void _tryEmitErrorResponse(NetworkStream stream, int code, string reason, string body) {
        try {
            string head = "HTTP/1.1 " + Int32.ToString(code) + " " + reason + "\r\n"
                + "Content-Type: text/plain; charset=utf-8\r\n"
                + "Content-Length: " + Int32.ToString(body.Length) + "\r\n"
                + "Connection: close\r\n"
                + "\r\n";
            byte[] hb = Utf8.GetBytes(head);
            stream.Write(hb, 0, hb.Length);
            byte[] bb = Utf8.GetBytes(body);
            stream.Write(bb, 0, bb.Length);
        } catch (Exception e) {
            // Best-effort — connection may already be broken.
        }
    }
}
