namespace Std.Net.Http;

using Std;
using Std.IO;

// add-z42-net-http-cookies (2026-05-26): cookie storage + Set-Cookie parsing.
//
// Subset of RFC 6265 §5.2 (parsing) + §5.3 (storage) + §5.4 (matching).
// Storage: parallel `Cookie[]` array (no field generic types in z42).
//
// V0 limits: no auto-jar on HttpClient (user calls IngestFromResponse +
// CookieHeaderFor manually); no SameSite enforcement; no Public Suffix List.
public class CookieJar {
    private Cookie[] _cookies;
    private int      _count;
    private int      _cap;

    public CookieJar() {
        this._cap     = 8;
        this._cookies = new Cookie[8];
        this._count   = 0;
    }

    /// Number of stored cookies (excluding ones that would be removed by
    /// expiry cleanup at `nowUnixSec`). Pass `0` to count all incl expired.
    public int LiveCount(long nowUnixSec) {
        if (nowUnixSec == 0L) return this._count;
        int alive = 0;
        int i = 0;
        while (i < this._count) {
            if (!this._cookies[i].IsExpired(nowUnixSec)) alive = alive + 1;
            i = i + 1;
        }
        return alive;
    }

    /// Add or replace a cookie matching (Name, Domain, Path) tuple.
    public void Add(Cookie cookie) {
        // Replace existing matching tuple
        int i = 0;
        while (i < this._count) {
            Cookie c = this._cookies[i];
            if (c.Name == cookie.Name
                && c.Domain == cookie.Domain
                && c.Path == cookie.Path) {
                this._cookies[i] = cookie;
                return;
            }
            i = i + 1;
        }
        // Grow if needed
        if (this._count == this._cap) {
            int newCap = this._cap * 2;
            Cookie[] grown = new Cookie[newCap];
            int j = 0;
            while (j < this._count) {
                grown[j] = this._cookies[j];
                j = j + 1;
            }
            this._cookies = grown;
            this._cap     = newCap;
        }
        this._cookies[this._count] = cookie;
        this._count = this._count + 1;
    }

    /// Parse all `Set-Cookie:` headers in a response and add to jar. Uses
    /// `responseHost`/`responsePath` as defaults for cookies missing
    /// Domain/Path. Cookies with `Max-Age` or `Expires` set their absolute
    /// expiry from `nowUnixSec`.
    public void IngestFromResponse(HttpResponse response, string responseHost, string responsePath, long nowUnixSec) {
        this.IngestSetCookieHeaders(response.Headers, responseHost, responsePath, nowUnixSec);
    }

    /// Variant taking `HttpHeaders` directly — used by `HttpClient` to avoid
    /// z42 cross-file class-token mismatch on `HttpResponse` (the same class
    /// referenced from CookieJar.z42 vs HttpClient.z42 produces two type
    /// tokens; `HttpHeaders` is referenced from a single file (HttpHeaders.z42)
    /// and threads correctly).
    public void IngestSetCookieHeaders(HttpHeaders headers, string responseHost, string responsePath, long nowUnixSec) {
        int n = headers.Count();
        int i = 0;
        while (i < n) {
            string name = headers.GetNameAt(i);
            if (name.ToLower() == "set-cookie") {
                string raw = headers.GetValueAt(i);
                Cookie c = CookieJar._parseSetCookie(raw, responseHost, responsePath, nowUnixSec);
                if (c != null) {
                    this.Add(c);
                }
            }
            i = i + 1;
        }
    }

    /// add-cookie-jar-persist (2026-05-27): save jar to Netscape "cookies.txt"
    /// format — the de-facto interchange shared with curl / wget / browsers.
    /// Each line is tab-separated:
    ///   domain<TAB>HostOnly<TAB>path<TAB>Secure<TAB>ExpiresUnixSec<TAB>Name<TAB>Value
    /// HttpOnly cookies prefix domain with `#HttpOnly_` (curl convention).
    /// Header comments retained for tool compatibility.
    public void SaveToFile(string path) {
        StringBuilder sb = new StringBuilder();
        sb.Append("# Netscape HTTP Cookie File\n");
        sb.Append("# https://curl.se/docs/http-cookies.html\n");
        sb.Append("# Saved by z42 Std.Net.Http.CookieJar — edits preserved on re-save.\n\n");
        int i = 0;
        while (i < this._count) {
            Cookie c = this._cookies[i];
            string dom = c.Domain;
            if (c.HttpOnly) { dom = "#HttpOnly_" + dom; }
            // HostOnly: leading "." in domain = subdomain match (FALSE); no
            // leading "." = exact host match (TRUE). v0 stored domains
            // already stripped of leading ".", so default to FALSE (subdomain-OK)
            // which matches the input we were originally fed.
            string hostOnly = "FALSE";
            string secure = c.Secure ? "TRUE" : "FALSE";
            sb.Append(dom);          sb.Append("\t");
            sb.Append(hostOnly);     sb.Append("\t");
            sb.Append(c.Path);       sb.Append("\t");
            sb.Append(secure);       sb.Append("\t");
            sb.Append(c.ExpiresUnixSec.ToString()); sb.Append("\t");
            sb.Append(c.Name);       sb.Append("\t");
            sb.Append(c.Value);      sb.Append("\n");
            i = i + 1;
        }
        File.WriteAllTextAtomic(path, sb.ToString());
    }

    /// add-cookie-jar-persist (2026-05-27): hydrate jar from a previously
    /// saved Netscape-format file. Returns the count of cookies loaded.
    /// Skips comment lines (`#`) and `#HttpOnly_` prefix is decoded to set
    /// `HttpOnly = true`. Malformed lines are silently skipped (best-effort
    /// matches curl / wget behaviour).
    public int LoadFromFile(string path) {
        string content = File.ReadAllText(path);
        int loaded = 0;
        int pos = 0;
        while (pos < content.Length) {
            int eol = pos;
            while (eol < content.Length && content.CharAt(eol) != '\n') { eol = eol + 1; }
            string line = CookieJar._substring(content, pos, eol);
            pos = eol + 1;
            if (line.Length == 0) continue;
            // Trim trailing '\r' for CRLF files.
            if (line.CharAt(line.Length - 1) == '\r') {
                line = CookieJar._substring(line, 0, line.Length - 1);
            }
            if (line.Length == 0) continue;
            // Skip comments, EXCEPT the #HttpOnly_ marker.
            bool httpOnly = false;
            if (line.CharAt(0) == '#') {
                if (CookieJar._startsWith(line, "#HttpOnly_")) {
                    httpOnly = true;
                    line = CookieJar._substring(line, 10, line.Length);
                } else {
                    continue;
                }
            }
            // 7 tab-separated fields.
            string[] fields = CookieJar._splitTab(line);
            if (fields.Length < 7) continue;
            string domain    = fields[0];
            // fields[1] = HostOnly (ignored — v0 doesn't model it)
            string p         = fields[2];
            bool   secure    = fields[3] == "TRUE";
            long   expiresUS = CookieJar._tryParseLong(fields[4]);
            string name      = fields[5];
            string val       = fields[6];
            if (name.Length == 0) continue;
            var c = new Cookie(name, val);
            c.Domain         = domain;
            c.Path           = p;
            c.Secure         = secure;
            c.HttpOnly       = httpOnly;
            c.ExpiresUnixSec = expiresUS;
            this.Add(c);
            loaded = loaded + 1;
        }
        return loaded;
    }

    /// Returns wire-format `Cookie:` header value (`name1=value1; name2=value2`)
    /// for cookies matching (host, path, isSecure). Empty string if none match.
    public string CookieHeaderFor(string host, string path, bool isSecure, long nowUnixSec) {
        string result = "";
        int matched = 0;
        int i = 0;
        while (i < this._count) {
            Cookie c = this._cookies[i];
            if (!c.IsExpired(nowUnixSec) && c.Matches(host, path, isSecure)) {
                if (matched > 0) result = result + "; ";
                result = result + c.Name + "=" + c.Value;
                matched = matched + 1;
            }
            i = i + 1;
        }
        return result;
    }

    // ── Set-Cookie parser ────────────────────────────────────────────────

    /// Parse a single Set-Cookie header value. Returns null on malformed
    /// input (no "name=value" prefix). Best-effort: unrecognised attributes
    /// are silently ignored; Expires that fails to parse falls back to
    /// session cookie.
    public static Cookie _parseSetCookie(string raw, string responseHost, string responsePath, long nowUnixSec) {
        // First segment: NAME=VALUE
        int semi = CookieJar._indexOfChar(raw, ';', 0);
        string firstSeg;
        if (semi < 0) {
            firstSeg = raw;
        } else {
            firstSeg = CookieJar._substring(raw, 0, semi);
        }
        int eq = CookieJar._indexOfChar(firstSeg, '=', 0);
        if (eq < 0) return null;
        string name  = CookieJar._trim(CookieJar._substring(firstSeg, 0, eq));
        string value = CookieJar._trim(CookieJar._substring(firstSeg, eq + 1, firstSeg.Length));
        if (name.Length == 0) return null;

        var c = new Cookie(name, value);
        c.Domain = responseHost.ToLower();
        c.Path   = CookieJar._defaultPath(responsePath);

        // Parse remaining attributes
        if (semi < 0) return c;
        int pos = semi + 1;
        while (pos < raw.Length) {
            int nextSemi = CookieJar._indexOfChar(raw, ';', pos);
            int end;
            if (nextSemi < 0) { end = raw.Length; } else { end = nextSemi; }
            string attr = CookieJar._trim(CookieJar._substring(raw, pos, end));
            CookieJar._applyAttr(c, attr, nowUnixSec);
            if (nextSemi < 0) break;
            pos = nextSemi + 1;
        }
        return c;
    }

    static void _applyAttr(Cookie c, string attr, long nowUnixSec) {
        if (attr.Length == 0) return;
        int eq = CookieJar._indexOfChar(attr, '=', 0);
        string name;
        string val;
        if (eq < 0) {
            name = attr.ToLower();
            val  = "";
        } else {
            name = CookieJar._substring(attr, 0, eq).ToLower();
            val  = CookieJar._trim(CookieJar._substring(attr, eq + 1, attr.Length));
        }
        if (name == "domain") {
            if (val.Length > 0) c.Domain = val.ToLower();
        } else if (name == "path") {
            if (val.Length > 0) c.Path = val;
        } else if (name == "secure") {
            c.Secure = true;
        } else if (name == "httponly") {
            c.HttpOnly = true;
        } else if (name == "max-age") {
            int delta = CookieJar._tryParseInt(val);
            if (delta >= 0) {
                c.ExpiresUnixSec = nowUnixSec + (long)delta;
            } else if (delta == -2) {
                // negative — expire immediately per RFC §5.2.2
                c.ExpiresUnixSec = 1L;
            }
        } else if (name == "expires") {
            // V0: not parsing HTTP-date format. If Max-Age was set first or
            // gets set later, that takes precedence. If only Expires present,
            // treat as session cookie (won't expire on time). Real Expires
            // date parsing is `add-z42-net-http-cookies-expires-date` follow-up.
        }
        // SameSite, Comment, Version etc. silently ignored (v0).
    }

    /// Default-path derivation per RFC 6265 §5.1.4.
    /// "/foo/bar" → "/foo"; "/foo" → "/"; "/" → "/"
    static string _defaultPath(string requestPath) {
        if (requestPath.Length == 0 || requestPath.CharAt(0) != '/') return "/";
        int lastSlash = -1;
        int i = 0;
        while (i < requestPath.Length) {
            char ch = requestPath.CharAt(i);
            if (ch == '?' || ch == '#') break;
            if (ch == '/') lastSlash = i;
            i = i + 1;
        }
        if (lastSlash <= 0) return "/";
        return CookieJar._substring(requestPath, 0, lastSlash);
    }

    // ── String helpers ───────────────────────────────────────────────────

    static int _indexOfChar(string s, char c, int start) {
        int i = start;
        while (i < s.Length) {
            if (s.CharAt(i) == c) return i;
            i = i + 1;
        }
        return -1;
    }

    static string _substring(string s, int start, int end) {
        if (start >= end) return "";
        char[] buf = new char[end - start];
        int i = 0;
        while (i < end - start) {
            buf[i] = s.CharAt(start + i);
            i = i + 1;
        }
        return String.FromChars(buf);
    }

    static string _trim(string s) {
        int start = 0;
        while (start < s.Length && (s.CharAt(start) == ' ' || s.CharAt(start) == '\t')) {
            start = start + 1;
        }
        int end = s.Length;
        while (end > start && (s.CharAt(end - 1) == ' ' || s.CharAt(end - 1) == '\t')) {
            end = end - 1;
        }
        return CookieJar._substring(s, start, end);
    }

    /// add-cookie-jar-persist (2026-05-27): split on TAB. No empty-field
    /// elision (matches Netscape format columns); returns string[] sized
    /// to actual delimiter count + 1.
    static string[] _splitTab(string s) {
        int count = 1;
        int i = 0;
        while (i < s.Length) {
            if (s.CharAt(i) == '\t') count = count + 1;
            i = i + 1;
        }
        string[] result = new string[count];
        int field = 0;
        int start = 0;
        i = 0;
        while (i <= s.Length) {
            if (i == s.Length || s.CharAt(i) == '\t') {
                result[field] = CookieJar._substring(s, start, i);
                field = field + 1;
                start = i + 1;
            }
            i = i + 1;
        }
        return result;
    }

    static bool _startsWith(string s, string prefix) {
        if (s.Length < prefix.Length) return false;
        int i = 0;
        while (i < prefix.Length) {
            if (s.CharAt(i) != prefix.CharAt(i)) return false;
            i = i + 1;
        }
        return true;
    }

    /// Parse a long (signed). Returns 0 on parse error — caller decides if
    /// 0 is meaningful (for ExpiresUnixSec it means session cookie, which
    /// is the right fallback for malformed timestamps).
    static long _tryParseLong(string s) {
        if (s.Length == 0) return 0L;
        long sign = 1L;
        int i = 0;
        if (s.CharAt(0) == '-') { sign = -1L; i = 1; }
        else if (s.CharAt(0) == '+') { i = 1; }
        if (i >= s.Length) return 0L;
        long n = 0L;
        while (i < s.Length) {
            int ch = (int)s.CharAt(i);
            if (ch < 48 || ch > 57) return 0L;
            n = n * 10L + (long)(ch - 48);
            i = i + 1;
        }
        return n * sign;
    }

    /// Returns parsed value, -2 if string parses but is negative, -1 if
    /// non-numeric. (Distinguished because RFC has special semantics for
    /// negative Max-Age.)
    static int _tryParseInt(string s) {
        if (s.Length == 0) return -1;
        int sign = 1;
        int i = 0;
        if (s.CharAt(0) == '-') { sign = -1; i = 1; }
        else if (s.CharAt(0) == '+') { i = 1; }
        if (i >= s.Length) return -1;
        int n = 0;
        while (i < s.Length) {
            int ch = (int)s.CharAt(i);
            if (ch < 48 || ch > 57) return -1;
            n = n * 10 + (ch - 48);
            i = i + 1;
        }
        int signed = n * sign;
        if (signed < 0) return -2;
        return signed;
    }
}
