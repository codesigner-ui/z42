namespace Std.Net.Sockets;

using Std;

// add-z42-net-udp K2 (2026-05-25): result carrier for `UdpClient.Receive()`.
//
// z42 has no out-params / tuple return; `UdpClient.Receive()` must surface
// THREE things atomically: datagram bytes + sender IP + sender port. Wrap
// in a small read-after-construct class with public fields (no setters —
// stdlib convention for immutable-by-discipline value carriers).
//
// Mirror .NET BCL `System.Net.Sockets.UdpReceiveResult`.
public class UdpReceiveResult {
    public byte[] Buffer;
    public string RemoteHost;
    public int    RemotePort;

    public UdpReceiveResult(byte[] buffer, string remoteHost, int remotePort) {
        this.Buffer     = buffer;
        this.RemoteHost = remoteHost;
        this.RemotePort = remotePort;
    }
}
