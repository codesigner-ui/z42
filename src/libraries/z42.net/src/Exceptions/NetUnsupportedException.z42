namespace Std;

// add-z42-net K1 (2026-05-24): 网络 API 在当前 target 不支持时抛出。
// 主要场景：wasm32 — std::net 不可用，所有 `__net_tcp_*` builtin 直接返回
// KIND_UNSUPPORTED tuple，z42 端 translate 为本异常。允许 wasm host
// 用 try/catch 探测能力 + 退路到 JS interop fallback。
public class NetUnsupportedException : NetException {
    public NetUnsupportedException()
        : base("network sockets are not supported on this target (e.g. wasm32)") {
    }

    override string ToString() {
        return "NetUnsupportedException: " + this.Message;
    }
}
