namespace Std;

// add-z42-net K1 (2026-05-24): z42.net 异常体系基类。
// 镜像 .NET BCL `System.Net.Sockets.SocketException : NetworkException : Exception`。
// 用户 try/catch 时通常捕获具体子类（`SocketException` / `SocketClosedException` /
// `NetUnsupportedException`），但 `NetException` 提供一个 catch-all。
public class NetException : Exception {
    public NetException(string message) : base(message) {
    }

    override string ToString() {
        return "NetException: " + this.Message;
    }
}
