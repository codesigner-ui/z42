namespace Std;

// add-z42-net K1 (2026-05-24): 在已 `Dispose` / `Close` / `Stop` 的 socket
// 或 listener 上调用操作时抛出。也包括 slot id 在 VM 侧找不到的边界情况
// （通常意味着 user-after-free 误用）。镜像 `ProcessHandleInvalidException`
// 的角色。
public class SocketClosedException : NetException {
    public SocketClosedException()
        : base("socket has been closed or disposed") {
    }

    override string ToString() {
        return "SocketClosedException: " + this.Message;
    }
}
