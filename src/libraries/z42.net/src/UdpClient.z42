namespace Std.Net.Sockets;

using Std;

// add-z42-net-udp K2 (2026-05-25): sync blocking UDP (datagram) socket.
//
// Lifecycle:
//   var u = new UdpClient();
//   u.Bind("0.0.0.0", 0);                          // bind for receive (port 0 = OS-assigned)
//   int port = u.LocalPort();
//   u.Send(data, data.Length, "127.0.0.1", 9000);  // send to remote
//   var rx = u.Receive();                           // blocks; rx.Buffer / RemoteHost / RemotePort
//   u.Dispose();
//
// Each Send/Receive is a discrete datagram (vs TCP's stream). Receive
// blocks until a datagram arrives. No connection state in v0; remote
// address always explicit per Send (Connect+default-remote is follow-up
// `add-z42-net-udp-connected`).
//
// **Auto-bind**: if `Send` is called before `Bind`, we auto-bind to
// `("0.0.0.0", 0)` (OS-assigned ephemeral port). This matches BCL
// `UdpClient.Send` behavior. Caller can then `LocalPort()` to discover
// the assigned port.
public class UdpClient {
    private long   _slotId;
    private bool   _bound;
    private bool   _disposed;
    private int    _localPort;
    private string _bindHost;
    // add-z42-net-udp-connected (2026-05-27): default remote for the bare
    // SendConnected / SendConnectedString helpers. Kept independent of the
    // OS-level UDP connect() — z42 still uses bare `sendto`/`recvfrom`
    // under the hood (no kernel-level connected state), the "connection"
    // is purely a stored default address in this object.
    private bool   _connected;
    private string _remoteHost;
    private int    _remotePort;
    // add-z42-net-udp-recv-into (2026-05-27): sender address of the most
    // recent ReceiveInto call (Receive() returns its own tuple so no
    // shared state needed; ReceiveInto returns just bytesWritten).
    private string _lastRxHost;
    private int    _lastRxPort;

    public UdpClient() {
        this._slotId     = -1;
        this._bound      = false;
        this._disposed   = false;
        this._localPort  = 0;
        this._bindHost   = "";
        this._connected  = false;
        this._remoteHost = "";
        this._remotePort = 0;
        this._lastRxHost = "";
        this._lastRxPort = 0;
    }

    /// Bind to `host:port`. Use port 0 to let the OS pick an available
    /// ephemeral port; query `LocalPort()` afterwards to discover.
    public void Bind(string host, int port) {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (this._bound) {
            throw new InvalidOperationException("UdpClient already bound");
        }
        object[] raw = UdpNative.Bind(host, port);
        long[] slotAndPort = UdpDecode.ToBindResult(raw);
        this._slotId    = slotAndPort[0];
        this._localPort = (int)slotAndPort[1];
        this._bindHost  = host;
        this._bound     = true;
    }

    /// Send a datagram of `length` bytes (from `data[0..length]`) to
    /// `remoteHost:remotePort`. Returns the number of bytes sent (always
    /// `length` for normal-sized datagrams; OS may fragment larger).
    ///
    /// If the client hasn't `Bind`ed yet, auto-binds to `("0.0.0.0", 0)`
    /// (ephemeral port). Discover the chosen port with `LocalPort()`.
    public int Send(byte[] data, int length, string remoteHost, int remotePort) {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (!this._bound) {
            // Auto-bind to ephemeral on first Send.
            this.Bind("0.0.0.0", 0);
        }
        object[] raw = UdpNative.Send(this._slotId, data, 0, length, remoteHost, remotePort);
        return UdpDecode.ToInt(raw);
    }

    /// Block until a datagram arrives; return it plus the sender's address.
    public UdpReceiveResult Receive() {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (!this._bound) {
            throw new InvalidOperationException("UdpClient.Receive() called before Bind()");
        }
        object[] raw = UdpNative.Recv(this._slotId);
        long kind = (long)raw[0];
        if (kind != 0) {
            UdpDecode.Throw(raw, kind);
        }
        // Note: `new UdpReceiveResult(...)` must be invoked in the same file as
        // the declared return type or z42's cross-file type resolver produces
        // two different type tokens for the same class (manifests as
        // "expected UdpReceiveResult, got UdpReceiveResult"). Filed as
        // a follow-up of `compiler-future-typed-overload-resolution`.
        byte[] buf  = (byte[])raw[1];
        string host = (string)raw[2];
        int    port = (int)(long)raw[3];
        return new UdpReceiveResult(buf, host, port);
    }

    /// add-z42-net-udp-connected (2026-05-27): set a default remote
    /// address so subsequent `SendConnected` / `SendConnectedString` calls
    /// don't need to repeat it. Does not actually call OS `connect(2)` on
    /// the socket — under the hood we still use `sendto` with the stored
    /// address, matching BCL `UdpClient.Connect` semantics (informational
    /// default, not a kernel filter). Connect may be called multiple times
    /// to retarget; reusing the same UdpClient across remotes is fine.
    public void Connect(string remoteHost, int remotePort) {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        this._remoteHost = remoteHost;
        this._remotePort = remotePort;
        this._connected  = true;
    }

    /// Clear the connected default. Subsequent `SendConnected` will throw.
    /// `Connect` again to retarget. Idempotent.
    public void Disconnect() {
        this._connected  = false;
        this._remoteHost = "";
        this._remotePort = 0;
    }

    /// True if `Connect` has been called and not subsequently `Disconnect`-ed.
    public bool IsConnected() {
        return this._connected;
    }

    /// Send `length` bytes of `data` to the address previously set via
    /// `Connect`. Throws `InvalidOperationException` if not connected.
    /// Auto-binds to ephemeral `("0.0.0.0", 0)` on first send (same as
    /// the addressed `Send` variant).
    public int SendConnected(byte[] data, int length) {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (!this._connected) {
            throw new InvalidOperationException(
                "UdpClient.SendConnected called before Connect()");
        }
        return this.Send(data, length, this._remoteHost, this._remotePort);
    }

    /// Convenience: send the entire `data` array to the connected remote.
    public int SendConnected(byte[] data) {
        return this.SendConnected(data, data.Length);
    }

    /// add-z42-net-udp-recv-into (2026-05-27): receive a datagram into the
    /// caller's pre-allocated buffer at `[offset, offset + count)`. Avoids
    /// the per-call allocation of `Receive()`. Returns the number of bytes
    /// written (clamped to `count` — over-large datagrams are truncated to
    /// fit; caller can pre-size the buffer to MTU-style limits if needed).
    /// Remote sender address is exposed via `LastReceiveHost` / `LastReceivePort`
    /// helpers since z42's overload resolver can't disambiguate two `Receive`
    /// shapes by arg-type alone — the array overload chose a different
    /// disposition for the address pair.
    public int ReceiveInto(byte[] buf, int offset, int count) {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (!this._bound) {
            throw new InvalidOperationException("UdpClient.ReceiveInto() called before Bind()");
        }
        object[] raw = UdpNative.RecvInto(this._slotId, buf, offset, count);
        long kind = (long)raw[0];
        if (kind != 0) {
            UdpDecode.Throw(raw, kind);
            return -1;
        }
        int n = (int)(long)raw[1];
        this._lastRxHost = (string)raw[2];
        this._lastRxPort = (int)(long)raw[3];
        return n;
    }

    /// Convenience: fill the entire `buf` (offset 0, count buf.Length).
    /// Named distinctly (not an overload of `ReceiveInto`) because z42's
    /// arity-based overload resolution proved fragile under cross-file
    /// method tables here — keep an explicit name until
    /// `compiler-future-typed-overload-resolution` lands.
    public int ReceiveIntoFull(byte[] buf) {
        return this.ReceiveInto(buf, 0, buf.Length);
    }

    /// Sender address of the most recent `ReceiveInto` call (empty / 0 before
    /// any successful receive).
    public string LastReceiveHost() { return this._lastRxHost; }
    public int    LastReceivePort() { return this._lastRxPort; }

    // ── Multicast (add-z42-net-udp-multicast 2026-05-27) ────────────────

    /// Join an IPv4 multicast group. `groupIp` must be in the multicast
    /// range (224.0.0.0/4); call after `Bind` (typically `Bind("0.0.0.0",
    /// port)` so the kernel can deliver group traffic to your port).
    /// `ifaceIp` of `"0.0.0.0"` defers interface selection to the OS.
    /// Calling multiple times with different groups subscribes to all of
    /// them on the same socket.
    public void JoinMulticastGroup(string groupIp, string ifaceIp) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._bound) {
            throw new InvalidOperationException("JoinMulticastGroup before Bind");
        }
        object[] raw = UdpNative.JoinMulticast(this._slotId, groupIp, ifaceIp);
        long kind = (long)raw[0];
        if (kind != 0) { UdpDecode.Throw(raw, kind); }
    }

    /// Convenience: defer interface to the OS (`0.0.0.0`).
    public void JoinMulticastGroup(string groupIp) {
        this.JoinMulticastGroup(groupIp, "0.0.0.0");
    }

    /// Leave a previously joined IPv4 multicast group. Idempotent at the
    /// kernel level — re-leaving a group not currently joined errors as
    /// `SocketException`. Caller responsible for symmetric Join/Leave.
    public void LeaveMulticastGroup(string groupIp, string ifaceIp) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._bound) {
            throw new InvalidOperationException("LeaveMulticastGroup before Bind");
        }
        object[] raw = UdpNative.LeaveMulticast(this._slotId, groupIp, ifaceIp);
        long kind = (long)raw[0];
        if (kind != 0) { UdpDecode.Throw(raw, kind); }
    }

    public void LeaveMulticastGroup(string groupIp) {
        this.LeaveMulticastGroup(groupIp, "0.0.0.0");
    }

    /// IP_MULTICAST_LOOP — controls whether multicasts sent on this socket
    /// loop back to the local host. Default = true (matches BSD socket
    /// default). Disabling can save a recv per send for senders that
    /// don't need to consume their own output.
    /// add-z42-net-socket-options (2026-05-27): IP_TTL for unicast sends.
    /// (Multicast TTL is `set_multicast_ttl_v4` — separate follow-up if
    /// a caller needs it.)
    public void SetTtl(int ttl) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._bound) {
            throw new InvalidOperationException("SetTtl before Bind");
        }
        object[] raw = UdpNative.SetTtl(this._slotId, ttl);
        long kind = (long)raw[0];
        if (kind != 0) { UdpDecode.Throw(raw, kind); }
    }

    public void SetMulticastLoop(bool enable) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._bound) {
            throw new InvalidOperationException("SetMulticastLoop before Bind");
        }
        object[] raw = UdpNative.SetMulticastLoop(this._slotId, enable);
        long kind = (long)raw[0];
        if (kind != 0) { UdpDecode.Throw(raw, kind); }
    }

    /// add-net-socket-options-extended (2026-05-30): UDP recv timeout.
    /// `millis <= 0` clears the timeout (blocking forever). Throws
    /// `InvalidOperationException` if called before Bind — the socket
    /// option is per-fd, so there's no socket to set the option on yet.
    public void SetReadTimeout(int millis) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._bound) {
            throw new InvalidOperationException("SetReadTimeout before Bind");
        }
        object[] raw = UdpNative.SetReadTimeout(this._slotId, millis);
        long kind = (long)raw[0];
        if (kind != 0) { UdpDecode.Throw(raw, kind); }
    }

    public void SetWriteTimeout(int millis) {
        if (this._disposed) { throw new SocketClosedException(); }
        if (!this._bound) {
            throw new InvalidOperationException("SetWriteTimeout before Bind");
        }
        object[] raw = UdpNative.SetWriteTimeout(this._slotId, millis);
        long kind = (long)raw[0];
        if (kind != 0) { UdpDecode.Throw(raw, kind); }
    }

    /// Local bound port — useful after `Bind(host, 0)` to discover the
    /// OS-assigned port. Throws `InvalidOperationException` if not bound.
    public int LocalPort() {
        if (this._disposed) {
            throw new SocketClosedException();
        }
        if (!this._bound) {
            throw new InvalidOperationException("UdpClient.LocalPort() called before Bind()");
        }
        return this._localPort;
    }

    public string BindHost() {
        return this._bindHost;
    }

    /// Close the socket. Idempotent. Subsequent ops throw `SocketClosedException`.
    public void Dispose() {
        if (this._disposed) return;
        this._disposed = true;
        if (this._bound) {
            UdpNative.Drop(this._slotId);
            this._bound = false;
        }
    }

    /// Alias for `Dispose()` matching .NET BCL `UdpClient.Close()`.
    public void Close() {
        this.Dispose();
    }
}
