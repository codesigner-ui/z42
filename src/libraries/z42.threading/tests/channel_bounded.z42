// add-sync-primitives-bounded-channel (2026-05-20): Channel<T>.WithCapacity
// + bounded-channel back-pressure semantics.
namespace Z42ThreadingChannelBoundedTests;

using Std;
using Std.Test;
using Std.Threading;

[Test]
void test_bounded_basic_send_recv() {
    // capacity=2; send 2 + recv 2 + close + recv throws disconnected.
    var c = new Channel<long>(2);
    c.Send(10);
    c.Send(20);
    Assert.Equal((long)10, c.Recv());
    Assert.Equal((long)20, c.Recv());
    c.Close();
    bool caught = false;
    try {
        c.Recv();
    } catch (ChannelDisconnectedException e) {
        caught = true;
    }
    Assert.True(caught);
}

public static class Pipe {
    public static Channel<long> Q;
}

[Test]
void test_bounded_back_pressure_with_slow_consumer() {
    // capacity=2, 1 producer thread sends 5 values, main thread is the
    // slow consumer. Without back-pressure the queue would grow to 5;
    // with back-pressure the producer blocks at Send #3 until main
    // recvs #1, then again at Send #5 until main recvs #3, etc.
    //
    // Success criterion: all 5 values arrive in FIFO order; test
    // completes within reasonable time (no deadlock, no OOM).
    Pipe.Q = new Channel<long>(2);

    Thread producer = Thread.Start(() => {
        int i = 0;
        while (i < 5) {
            Pipe.Q.Send((long)i);
            i = i + 1;
        }
    });

    // Slow consumer — pull each value, yield between pulls so producer
    // gets a chance to block (the test still passes without the yield;
    // it's there to ensure we exercise the blocking path).
    long sum = 0;
    int j = 0;
    while (j < 5) {
        long v = Pipe.Q.Recv();
        sum = sum + v;
        j = j + 1;
    }
    producer.Join();
    Assert.Equal((long)(0 + 1 + 2 + 3 + 4), sum);
}
