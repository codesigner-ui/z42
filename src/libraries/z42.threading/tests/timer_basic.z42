// add-z42-threading-timer (2026-05-30): Std.Threading.Timer
// — periodic + one-shot background callback over Thread + Sleep.
namespace Z42ThreadingTimerTests;

using Std;
using Std.Test;
using Std.Threading;
using Std.Time;

[Test]
void test_periodic_fires_multiple_times() {
    int[] fires = new int[1];
    fires[0] = 0;
    Timer t = Timer.StartPeriodic(50, () => {
        fires[0] = fires[0] + 1;
    });
    // poll-timer-fires (2026-06-21): a Thread.Sleep-based timer has unbounded
    // wakeup jitter under load — even the prior fixed 500ms window (ideal ~10
    // fires) still dropped below 3 fires on contended macOS CI runners. Poll up
    // to ~5s for the >= 3 target instead of a fixed sleep: a working 50ms timer
    // reaches 3 fires in ~150ms and exits early, while a starved runner gets the
    // slack it needs. Only a genuinely dead periodic thread (never reaching 3
    // fires in 5s) trips the assertion — which is exactly what the test guards.
    int waitedMs = 0;
    while (fires[0] < 3 && waitedMs < 5000) {
        Thread.Sleep(50);
        waitedMs = waitedMs + 50;
    }
    t.StopAndJoin();
    Assert.True(fires[0] >= 3);
}

[Test]
void test_start_once_fires_exactly_once() {
    int[] fires = new int[1];
    fires[0] = 0;
    Timer t = Timer.StartOnce(50, () => {
        fires[0] = fires[0] + 1;
    });
    // harden-timer-test-jitter (2026-06-01): widened 150ms→500ms so the
    // single fire reliably lands even when a contended CI runner delays the
    // worker thread's first wakeup. StartOnce self-stops, so it can never
    // fire twice — the count stays exactly 1.
    Thread.Sleep(500);
    Assert.Equal(1, fires[0]);
    Assert.False(t.IsRunning());
}

[Test]
void test_start_once_cancelled_before_fire() {
    int[] fires = new int[1];
    fires[0] = 0;
    Timer t = Timer.StartOnce(500, () => {
        fires[0] = 1;
    });
    // Immediate stop — callback should not fire.
    t.StopAndJoin();
    Thread.Sleep(600);
    Assert.Equal(0, fires[0]);
}

[Test]
void test_stop_responsive_for_large_interval() {
    Timer t = Timer.StartPeriodic(10000, () => {
        // never expected to fire within the test window
    });
    Thread.Sleep(50);
    // StopAndJoin returns after the current 100ms chunk completes, NOT after
    // the full 10s interval. harden-timer-test-jitter (2026-06-01): raised the
    // cap 250ms→1000ms so a contended CI runner's Thread.Sleep(100) overshoot
    // + Join scheduling slack can't trip it, while still being 10x below the
    // 10s interval — i.e. still proving the chunked-sleep responsiveness.
    Stopwatch sw = Stopwatch.StartNew();
    t.StopAndJoin();
    sw.Stop();
    long elapsedMs = sw.Elapsed().TotalMilliseconds();
    Assert.True(elapsedMs < 1000);
}

[Test]
void test_stop_idempotent() {
    Timer t = Timer.StartPeriodic(50, () => { });
    Thread.Sleep(80);
    t.Stop();
    t.Stop();
    t.Stop();
    t.StopAndJoin();
    Assert.False(t.IsRunning());
}

[Test]
void test_callback_exception_does_not_kill_timer() {
    int[] fires = new int[1];
    fires[0] = 0;
    Timer t = Timer.StartPeriodic(50, () => {
        fires[0] = fires[0] + 1;
        if (fires[0] == 1) {
            throw new Exception("first fire intentionally fails");
        }
    });
    // harden-timer-test-jitter (2026-06-01): same Thread.Sleep jitter concern
    // as test_periodic_fires_multiple_times. Widen to a 500ms window (ideal
    // ~10 fires) so `>= 2` (first fire throws, ≥1 more must land) holds under
    // contended CI scheduling. Verifies an exception in one fire doesn't kill
    // the periodic Timer thread.
    Thread.Sleep(500);
    t.StopAndJoin();
    Assert.True(fires[0] >= 2);
}

[Test]
void test_stop_and_join_waits_for_in_flight_callback() {
    bool[] started = new bool[1];
    bool[] done = new bool[1];
    started[0] = false;
    done[0] = false;
    Timer t = Timer.StartPeriodic(10, () => {
        started[0] = true;
        Thread.Sleep(200);
        done[0] = true;
    });
    // harden-timer-test-jitter (2026-06-01): the old fixed Thread.Sleep(50)
    // "give the callback a chance to start" raced — on a contended CI runner
    // the worker thread may not be scheduled within 50ms, so StopAndJoin would
    // exit before the callback ever ran and `done` stayed false. Instead poll
    // a `started` flag (set at callback entry) until the callback is provably
    // in-flight, then StopAndJoin must block until it finishes.
    int waited = 0;
    while (!started[0] && waited < 5000) {
        Thread.Sleep(5);
        waited = waited + 5;
    }
    Assert.True(started[0]);   // callback actually entered (not a scheduling miss)
    t.StopAndJoin();
    // Once StopAndJoin returns, the in-flight callback must have finished.
    Assert.True(done[0]);
}

[Test]
void test_is_running_reflects_state() {
    Timer t = Timer.StartPeriodic(100, () => { });
    Assert.True(t.IsRunning());
    t.StopAndJoin();
    Assert.False(t.IsRunning());
}

[Test]
void test_zero_interval_throws_argument_exception() {
    bool threw = false;
    try {
        Timer.StartPeriodic(0, () => { });
    } catch (ArgumentException e) {
        threw = true;
    }
    Assert.True(threw);
}

[Test]
void test_negative_delay_once_throws() {
    bool threw = false;
    try {
        Timer.StartOnce(-1, () => { });
    } catch (ArgumentException e) {
        threw = true;
    }
    Assert.True(threw);
}
