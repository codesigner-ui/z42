namespace Std;

// add-z42-json (2026-05-14)：JSON 解析 / 序列化错误。
//
// Placed in `Std` (not `Std.Json`) so the `: Exception` base reference
// resolves via same-namespace lookup. Same pattern as TomlException /
// ProcessStartException.
//
// 携带 1-based 行 / 列号（0 = 不可用，e.g. stringify-time errors）。
public class JsonException : Exception {
    public int Line;
    public int Column;

    public JsonException(string message) : base(message) {
        this.Line = 0;
        this.Column = 0;
    }

    public JsonException(string message, int line, int column) : base(message) {
        this.Line = line;
        this.Column = column;
    }

    override string ToString() {
        if (this.Line > 0) {
            return "JsonException at " + this.Line.ToString() + ":" + this.Column.ToString() + ": " + this.Message;
        }
        return "JsonException: " + this.Message;
    }
}
