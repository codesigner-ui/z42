// add-z42-io-binary (2026-05-15)：int16/32/64 LE+BE round-trip + cursor 行为。
namespace Z42IoBinaryBasicTests;

using Std.Test;
using Std.Binary;

[Test]
void test_byte_round_trip() {
    var w = new BinaryWriter();
    w.WriteByte(0);
    w.WriteByte(127);
    w.WriteByte(255);
    byte[] buf = w.ToArray();
    Assert.Equal(3, buf.Length);

    var r = new BinaryReader(buf);
    Assert.Equal(0,   r.ReadByte());
    Assert.Equal(127, r.ReadByte());
    Assert.Equal(255, r.ReadByte());
    Assert.True(r.EndOfStream());
}

[Test]
void test_int16_le_round_trip() {
    var w = new BinaryWriter();
    w.WriteInt16LE(0);
    w.WriteInt16LE(1);
    w.WriteInt16LE(32767);
    w.WriteInt16LE(-1);
    w.WriteInt16LE(-32768);

    var r = new BinaryReader(w.ToArray());
    Assert.Equal(0,      r.ReadInt16LE());
    Assert.Equal(1,      r.ReadInt16LE());
    Assert.Equal(32767,  r.ReadInt16LE());
    Assert.Equal(-1,     r.ReadInt16LE());
    Assert.Equal(-32768, r.ReadInt16LE());
}

[Test]
void test_int16_be_byte_order() {
    var w = new BinaryWriter();
    w.WriteInt16BE(0x1234);     // BE → bytes [0x12, 0x34]
    byte[] buf = w.ToArray();
    Assert.Equal(2,    buf.Length);
    Assert.Equal(0x12, (int)buf[0]);
    Assert.Equal(0x34, (int)buf[1]);

    var r = new BinaryReader(buf);
    Assert.Equal(0x1234, r.ReadInt16BE());
}

[Test]
void test_int16_le_byte_order() {
    var w = new BinaryWriter();
    w.WriteInt16LE(0x1234);     // LE → bytes [0x34, 0x12]
    byte[] buf = w.ToArray();
    Assert.Equal(0x34, (int)buf[0]);
    Assert.Equal(0x12, (int)buf[1]);
}

[Test]
void test_int32_round_trip() {
    var w = new BinaryWriter();
    w.WriteInt32LE(0);
    w.WriteInt32LE(2147483647);     // i32::MAX
    w.WriteInt32LE(-2147483647);    // i32::MIN+1 (parser limit on bare -2^31 lit)
    w.WriteInt32BE(2147483647);
    w.WriteInt32BE(-2147483647);

    var r = new BinaryReader(w.ToArray());
    Assert.Equal(0,           r.ReadInt32LE());
    Assert.Equal(2147483647,  r.ReadInt32LE());
    Assert.Equal(-2147483647, r.ReadInt32LE());
    Assert.Equal(2147483647,  r.ReadInt32BE());
    Assert.Equal(-2147483647, r.ReadInt32BE());
}

[Test]
void test_int32_byte_order() {
    var w = new BinaryWriter();
    w.WriteInt32BE(0x01020304);     // BE → [01, 02, 03, 04]
    w.WriteInt32LE(0x01020304);     // LE → [04, 03, 02, 01]
    byte[] buf = w.ToArray();
    Assert.Equal(0x01, (int)buf[0]);
    Assert.Equal(0x02, (int)buf[1]);
    Assert.Equal(0x03, (int)buf[2]);
    Assert.Equal(0x04, (int)buf[3]);
    Assert.Equal(0x04, (int)buf[4]);
    Assert.Equal(0x03, (int)buf[5]);
    Assert.Equal(0x02, (int)buf[6]);
    Assert.Equal(0x01, (int)buf[7]);
}

[Test]
void test_int64_round_trip() {
    var w = new BinaryWriter();
    w.WriteInt64LE(0L);
    w.WriteInt64LE(9223372036854775807L);     // i64::MAX
    w.WriteInt64LE(-9223372036854775807L);    // i64::MIN
    w.WriteInt64BE(9223372036854775807L);
    w.WriteInt64BE(-9223372036854775807L);

    var r = new BinaryReader(w.ToArray());
    Assert.Equal(0L,                    r.ReadInt64LE());
    Assert.Equal(9223372036854775807L,  r.ReadInt64LE());
    Assert.Equal(-9223372036854775807L, r.ReadInt64LE());
    Assert.Equal(9223372036854775807L,  r.ReadInt64BE());
    Assert.Equal(-9223372036854775807L, r.ReadInt64BE());
}

[Test]
void test_int64_byte_order() {
    var w = new BinaryWriter();
    w.WriteInt64BE(0x0102030405060708L);
    byte[] buf = w.ToArray();
    Assert.Equal(0x01, (int)buf[0]);
    Assert.Equal(0x02, (int)buf[1]);
    Assert.Equal(0x03, (int)buf[2]);
    Assert.Equal(0x04, (int)buf[3]);
    Assert.Equal(0x05, (int)buf[4]);
    Assert.Equal(0x06, (int)buf[5]);
    Assert.Equal(0x07, (int)buf[6]);
    Assert.Equal(0x08, (int)buf[7]);
}

[Test]
void test_cursor_position_and_seek() {
    byte[] data = new byte[10];
    int i = 0;
    while (i < 10) { data[i] = (byte)i; i = i + 1; }

    var r = new BinaryReader(data);
    Assert.Equal(0,  r.GetPosition());
    Assert.Equal(10, r.GetLength());

    r.Skip(3);
    Assert.Equal(3, r.GetPosition());
    Assert.Equal(3, r.ReadByte());
    Assert.Equal(4, r.GetPosition());

    r.Seek(8);
    Assert.Equal(8, r.ReadByte());
    Assert.Equal(9, r.ReadByte());
    Assert.True(r.EndOfStream());
}

[Test]
void test_mixed_types_stream() {
    var w = new BinaryWriter();
    w.WriteInt32LE(42);
    w.WriteByte(7);
    w.WriteInt16BE(-1000);
    w.WriteInt64LE(123456789012345L);

    var r = new BinaryReader(w.ToArray());
    Assert.Equal(42,                r.ReadInt32LE());
    Assert.Equal(7,                 r.ReadByte());
    Assert.Equal(-1000,             r.ReadInt16BE());
    Assert.Equal(123456789012345L,  r.ReadInt64LE());
    Assert.True(r.EndOfStream());
}
