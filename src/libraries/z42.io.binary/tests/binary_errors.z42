// add-z42-io-binary (2026-05-15)：越界 read / 非法 seek / writer grow 行为。
namespace Z42IoBinaryErrorsTests;

using Std;
using Std.Test;
using Std.IO.Binary;

[Test]
void test_read_past_end_throws() {
    byte[] data = new byte[2];
    data[0] = (byte)1;
    data[1] = (byte)2;
    var r = new BinaryReader(data);
    r.ReadByte();
    r.ReadByte();
    bool caught = false;
    try { r.ReadByte(); }
    catch (BinaryException e) { caught = true; }
    Assert.True(caught);
}

[Test]
void test_read_int32_short_buffer_throws() {
    byte[] data = new byte[3];
    var r = new BinaryReader(data);
    bool caught = false;
    try { r.ReadInt32LE(); }
    catch (BinaryException e) { caught = true; }
    Assert.True(caught);
}

[Test]
void test_seek_negative_throws() {
    var r = new BinaryReader(new byte[5]);
    bool caught = false;
    try { r.Seek(-1); }
    catch (BinaryException e) { caught = true; }
    Assert.True(caught);
}

[Test]
void test_seek_past_end_throws() {
    var r = new BinaryReader(new byte[5]);
    bool caught = false;
    try { r.Seek(100); }
    catch (BinaryException e) { caught = true; }
    Assert.True(caught);
}

[Test]
void test_read_bytes_negative_count_throws() {
    var r = new BinaryReader(new byte[5]);
    bool caught = false;
    try { r.ReadBytes(-1); }
    catch (BinaryException e) { caught = true; }
    Assert.True(caught);
}

[Test]
void test_writer_grows_past_initial_capacity() {
    var w = new BinaryWriter(2);
    int i = 0;
    while (i < 100) {
        w.WriteByte((i & 0xFF));
        i = i + 1;
    }
    Assert.Equal(100, w.GetLength());
    byte[] buf = w.ToArray();
    Assert.Equal(100, buf.Length);

    var r = new BinaryReader(buf);
    int j = 0;
    while (j < 100) {
        Assert.Equal(j & 0xFF, r.ReadByte());
        j = j + 1;
    }
}

[Test]
void test_writer_clear_resets_position() {
    var w = new BinaryWriter();
    w.WriteInt32LE(42);
    Assert.Equal(4, w.GetLength());
    w.Clear();
    Assert.Equal(0, w.GetLength());
    w.WriteByte(9);
    byte[] buf = w.ToArray();
    Assert.Equal(1,  buf.Length);
    Assert.Equal(9, (int)buf[0]);
}

[Test]
void test_to_array_is_snapshot() {
    var w = new BinaryWriter();
    w.WriteByte(1);
    byte[] snap = w.ToArray();
    w.WriteByte(2);
    // 第一次 snapshot 不被后续 write 影响
    Assert.Equal(1, snap.Length);
    Assert.Equal(1, (int)snap[0]);
}
