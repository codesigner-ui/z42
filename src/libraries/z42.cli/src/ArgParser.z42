namespace Std.Cli;
using Std;
using Std.Text;
using Std.IO;

// add-z42-cli (2026-05-16)：CLI argv 解析器。最小子集 — flag + option + positional。
//
// 用法：
//   var p = new ArgParser("build-stdlib", "Compile z42 stdlib workspace");
//   p.AddFlag("verbose", "v", "verbose output");
//   p.AddOption("profile", "p", "build profile", "release");
//   p.AddPositional("target", "build target directory");
//
//   ParseResult r = p.Parse(Environment.GetCommandLineArgs());
//   if (r.ShowHelp()) { Console.WriteLine(p.HelpText()); Environment.Exit(0); }
//   bool verbose = r.GetFlag("verbose");
//   string prof  = r.GetOption("profile");
//   string tgt   = r.GetPositional(0);
//
// 不支持（v0）：subcommand、required option、type-converted parse（int/float）、
// `-nvalue`（紧贴形式）。详 design doc Deferred。
public class ArgParser {
    private string _programName;
    private string _description;

    // Declared flags (parallel arrays)
    private string[] _flagLongs;
    private string[] _flagShorts;       // "" if none
    private string[] _flagHelps;
    private int      _flagCount;

    // Declared options
    private string[] _optionLongs;
    private string[] _optionShorts;
    private string[] _optionHelps;
    private string[] _optionDefaults;
    // add-cli-required-option (2026-05-26): parallel `_optionRequired` array.
    // When true, Parse throws if the option wasn't seen on the command line.
    private bool[]   _optionRequired;
    // add-cli-repeated-option (2026-05-26): when true, the option may be
    // passed multiple times; values are collected into a list.
    private bool[]   _optionRepeated;
    // add-cli-env-fallback (2026-05-26): per-option fallback env-var name.
    // Empty string when no env fallback. Lookup precedence: argv > env > default.
    private string[] _optionEnvVars;
    private int      _optionCount;

    // add-cli-strict-vs-extras (2026-05-26): when true, unknown flags /
    // options go into `ParseResult.Extras()` instead of throwing.
    private bool _allowExtras;

    // add-cli-mutually-exclusive (2026-05-26): each entry is a group of
    // option long-names where at most one may be set on the command line.
    // Stored as parallel arrays: per-group flat-string list + per-group
    // count. Internal `_MutexGroup` wrapper avoids string[][] which z42
    // doesn't natively support.
    private _MutexGroup[] _mutexGroups;
    private int           _mutexGroupCount;

    // Declared positionals (in order)
    private string[] _positionalNames;
    private string[] _positionalHelps;
    // add-cli-optional-positional (2026-06-10): per-positional optional flag.
    // Optional positionals must follow all required ones (enforced in
    // AddPositional). Missing optional → GetPositional returns "".
    private bool[]   _positionalOptional;
    private int      _positionalCount;

    public ArgParser(string programName, string description) {
        this._programName     = programName;
        this._description     = description;
        this._flagLongs       = new string[8];
        this._flagShorts      = new string[8];
        this._flagHelps       = new string[8];
        this._flagCount       = 0;
        this._optionLongs     = new string[8];
        this._optionShorts    = new string[8];
        this._optionHelps     = new string[8];
        this._optionDefaults  = new string[8];
        this._optionRequired  = new bool[8];
        this._optionRepeated  = new bool[8];
        this._optionEnvVars   = new string[8];
        this._optionCount     = 0;
        this._allowExtras     = false;
        this._mutexGroups     = new _MutexGroup[4];
        this._mutexGroupCount = 0;
        this._positionalNames = new string[8];
        this._positionalHelps = new string[8];
        this._positionalOptional = new bool[8];
        this._positionalCount = 0;
    }

    // ── Declaration API ──────────────────────────────────────────────────

    /// 注册 boolean flag。shortName 可为 ""（无短名）。
    /// `-h` / `--help` 是 auto-registered，无需手加。
    public void AddFlag(string longName, string shortName, string help) {
        this.EnsureFlagCap();
        this._flagLongs[this._flagCount]  = longName;
        this._flagShorts[this._flagCount] = shortName;
        this._flagHelps[this._flagCount]  = help;
        this._flagCount = this._flagCount + 1;
    }

    /// 注册带值的 option（`--name value` / `--name=value`）。
    public void AddOption(string longName, string shortName, string help, string defaultValue) {
        this.EnsureOptionCap();
        this._optionLongs[this._optionCount]    = longName;
        this._optionShorts[this._optionCount]   = shortName;
        this._optionHelps[this._optionCount]    = help;
        this._optionDefaults[this._optionCount] = defaultValue;
        this._optionRequired[this._optionCount] = false;
        this._optionRepeated[this._optionCount] = false;
        this._optionEnvVars[this._optionCount]  = "";
        this._optionCount = this._optionCount + 1;
    }

    /// 注册带 env 后备 default 的 option — 解析优先级为 argv > envVar > defaultValue.
    /// Empty/missing env var falls through to defaultValue. Typical use:
    /// `AddOptionWithEnv("api-key", "k", "API token", "", "API_TOKEN")`.
    /// add-cli-env-fallback (2026-05-26).
    public void AddOptionWithEnv(string longName, string shortName, string help,
                                  string defaultValue, string envVarName) {
        this.EnsureOptionCap();
        this._optionLongs[this._optionCount]    = longName;
        this._optionShorts[this._optionCount]   = shortName;
        this._optionHelps[this._optionCount]    = help + " (env: $" + envVarName + ")";
        this._optionDefaults[this._optionCount] = defaultValue;
        this._optionRequired[this._optionCount] = false;
        this._optionRepeated[this._optionCount] = false;
        this._optionEnvVars[this._optionCount]  = envVarName;
        this._optionCount = this._optionCount + 1;
    }

    /// Declare that AT MOST ONE of `names` may be set on the command line.
    /// Validated at the end of Parse — multiple set → CliException listing
    /// the conflict. Each name must already be a registered option (long
    /// name). add-cli-mutually-exclusive (2026-05-26).
    public void AddMutuallyExclusive(string[] names) {
        // Validate every name is registered up-front so the user gets a
        // declaration-time error rather than a confusing Parse-time one.
        int i = 0;
        while (i < names.Length) {
            int oi = this.FindOptionLongIndex(names[i]);
            if (oi < 0) {
                throw new CliException("AddMutuallyExclusive: option '" + names[i] + "' not registered");
            }
            i = i + 1;
        }
        if (this._mutexGroupCount >= this._mutexGroups.Length) {
            int n = this._mutexGroups.Length * 2;
            _MutexGroup[] g = new _MutexGroup[n];
            int j = 0;
            while (j < this._mutexGroupCount) { g[j] = this._mutexGroups[j]; j = j + 1; }
            this._mutexGroups = g;
        }
        this._mutexGroups[this._mutexGroupCount] = new _MutexGroup(names);
        this._mutexGroupCount = this._mutexGroupCount + 1;
    }

    /// Find an option by long name; returns -1 if not registered.
    private int FindOptionLongIndex(string longName) {
        int i = 0;
        while (i < this._optionCount) {
            if (this._optionLongs[i] == longName) { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// 注册可重复 option — argv 中每次出现都 append 而非覆盖。Retrieved via
    /// `ParseResult.GetRepeatedOption(name) → string[]`. Typical use:
    /// `-D NAME=VALUE -D OTHER=VALUE`. `GetOption(name)` returns the LAST
    /// value (matches the implicit repeated-option semantics).
    /// add-cli-repeated-option (2026-05-26).
    public void AddRepeatedOption(string longName, string shortName, string help) {
        this.EnsureOptionCap();
        this._optionLongs[this._optionCount]    = longName;
        this._optionShorts[this._optionCount]   = shortName;
        this._optionHelps[this._optionCount]    = help + " (repeatable)";
        this._optionDefaults[this._optionCount] = "";
        this._optionRequired[this._optionCount] = false;
        this._optionRepeated[this._optionCount] = true;
        this._optionEnvVars[this._optionCount]  = "";
        this._optionCount = this._optionCount + 1;
    }

    /// Enable pass-through mode: unknown flags / options go into
    /// `ParseResult.Extras()` instead of throwing `CliException`.
    /// Useful for wrapper / pass-through tools. add-cli-strict-vs-extras
    /// (2026-05-26).
    public void AllowExtras() {
        this._allowExtras = true;
    }

    /// 注册必填 option — Parse 在 argv 中没看到该 option 时抛 CliException
    /// (`required option '--name' missing`). `defaultValue` is unused but
    /// kept in the parallel array for storage uniformity. The presence-tracking
    /// uses a sentinel: the option's slot stays at `_optionDefaults[i]` (i.e.,
    /// `""` for required options) until argv writes a value; Parse then checks
    /// each required slot still equals `""`. add-cli-required-option (2026-05-26).
    public void AddRequiredOption(string longName, string shortName, string help) {
        this.EnsureOptionCap();
        this._optionLongs[this._optionCount]    = longName;
        this._optionShorts[this._optionCount]   = shortName;
        this._optionHelps[this._optionCount]    = help + " (required)";
        this._optionDefaults[this._optionCount] = "";       // sentinel "missing"
        this._optionRequired[this._optionCount] = true;
        this._optionRepeated[this._optionCount] = false;
        this._optionEnvVars[this._optionCount]  = "";
        this._optionCount = this._optionCount + 1;
    }

    /// 注册 positional 参数（按声明顺序匹配 argv 中非 flag/option 的部分）。
    public void AddPositional(string name, string help) {
        // add-cli-optional-positional: required positionals must precede all
        // optional ones (so the missing-required check is a simple count).
        if (this._positionalCount > 0 && this._positionalOptional[this._positionalCount - 1]) {
            throw new CliException("required positional '" + name +
                "' cannot follow an optional positional");
        }
        this.EnsurePositionalCap();
        this._positionalNames[this._positionalCount] = name;
        this._positionalHelps[this._positionalCount] = help;
        this._positionalOptional[this._positionalCount] = false;
        this._positionalCount = this._positionalCount + 1;
    }

    /// 注册可选 positional —— 未提供时 `GetPositional(i)` 返回 ""，且不触发
    /// "缺 positional" 报错。必须在所有必填 positional 之后声明（否则报错）。
    /// help 中渲染为 `[name]`。add-cli-optional-positional (2026-06-10).
    public void AddOptionalPositional(string name, string help) {
        this.EnsurePositionalCap();
        this._positionalNames[this._positionalCount] = name;
        this._positionalHelps[this._positionalCount] = help;
        this._positionalOptional[this._positionalCount] = true;
        this._positionalCount = this._positionalCount + 1;
    }

    // ── Parse ────────────────────────────────────────────────────────────

    /// 解析 argv（不含 program name）。返回 ParseResult。
    public ParseResult Parse(string[] argv) {
        var r = new ParseResult();
        // 初始化 flag results = 全部 false
        r._flagLongs  = new string[this._flagCount];
        r._flagValues = new bool[this._flagCount];
        r._flagCount  = this._flagCount;
        int i = 0;
        while (i < this._flagCount) {
            r._flagLongs[i]  = this._flagLongs[i];
            r._flagValues[i] = false;
            i = i + 1;
        }
        // 初始化 option results = defaults
        r._optionLongs    = new string[this._optionCount];
        r._optionValues   = new string[this._optionCount];
        r._optionWasSet   = new bool[this._optionCount];
        r._optionRepeated = new bool[this._optionCount];
        r._optionLists    = new _RepeatedList[this._optionCount];
        r._optionCount    = this._optionCount;
        int j = 0;
        while (j < this._optionCount) {
            r._optionLongs[j]      = this._optionLongs[j];
            // Resolution precedence: env-var fallback applied at init time
            // (so default → env-var value if set); argv parse later
            // overwrites with `_optionWasSet = true`. add-cli-env-fallback
            // (2026-05-26).
            string initVal = this._optionDefaults[j];
            string envName = this._optionEnvVars[j];
            if (envName.Length > 0) {
                string? envVal = Environment.GetEnvironmentVariable(envName);
                if (envVal != null) {
                    string nonNull = envVal ?? "";
                    if (nonNull.Length > 0) {
                        initVal = nonNull;
                    }
                }
            }
            r._optionValues[j]     = initVal;
            r._optionWasSet[j]     = false;
            r._optionRepeated[j]   = this._optionRepeated[j];
            if (this._optionRepeated[j]) {
                r._optionLists[j] = new _RepeatedList();
            } else {
                r._optionLists[j] = null;
            }
            j = j + 1;
        }
        // Extras list (only populated when AllowExtras was called).
        // add-cli-strict-vs-extras (2026-05-26).
        r._extras = new string[4];
        r._extrasCount = 0;
        r._allowExtras = this._allowExtras;
        // positionals
        r._positionalNames  = new string[this._positionalCount];
        r._positionalValues = new string[this._positionalCount];
        int k = 0;
        while (k < this._positionalCount) {
            r._positionalNames[k]  = this._positionalNames[k];
            r._positionalValues[k] = "";
            k = k + 1;
        }
        r._positionalCount = 0;

        // 扫描 argv
        int idx = 0;
        while (idx < argv.Length) {
            string a = argv[idx];
            if (a == "-h" || a == "--help") {
                r._showHelp = true;
                idx = idx + 1;
                continue;
            }
            if (a.Length >= 2 && a.CharAt(0) == '-' && a.CharAt(1) == '-') {
                // long flag/option
                idx = this.ParseLong(a, argv, idx, r);
            } else if (a.Length >= 2 && a.CharAt(0) == '-') {
                // short flag/option
                idx = this.ParseShort(a, argv, idx, r);
            } else {
                // positional
                if (r._positionalCount >= this._positionalCount) {
                    throw new CliException("unexpected positional argument '" + a +
                        "' (expected " + this._positionalCount.ToString() + ")");
                }
                r._positionalValues[r._positionalCount] = a;
                r._positionalCount = r._positionalCount + 1;
                idx = idx + 1;
            }
        }

        // positional 数量校验（ShowHelp 时跳过）—— 只对必填 positional。
        // 必填全在前（AddPositional 排序约束），requiredCount = leading 必填数。
        // add-cli-optional-positional: 缺可选不报错。
        int requiredCount = 0;
        while (requiredCount < this._positionalCount && !this._positionalOptional[requiredCount]) {
            requiredCount = requiredCount + 1;
        }
        if (!r._showHelp && r._positionalCount < requiredCount) {
            throw new CliException("missing positional argument: '" +
                this._positionalNames[r._positionalCount] + "'");
        }

        // Required-option validation — add-cli-required-option (2026-05-26).
        // Skip when --help requested (so callers can print help with no args).
        if (!r._showHelp) {
            int m = 0;
            while (m < this._optionCount) {
                if (this._optionRequired[m] && !r._optionWasSet[m]) {
                    throw new CliException("required option '--" +
                        this._optionLongs[m] + "' missing");
                }
                m = m + 1;
            }
        }
        // Mutually-exclusive group validation — add-cli-mutually-exclusive
        // (2026-05-26). Skip when --help requested.
        if (!r._showHelp) {
            int g = 0;
            while (g < this._mutexGroupCount) {
                _MutexGroup grp = this._mutexGroups[g];
                int seenCount = 0;
                string firstSeen = "";
                string secondSeen = "";
                int k = 0;
                while (k < grp._count) {
                    int oi = this.FindOptionLongIndex(grp._names[k]);
                    if (oi >= 0 && r._optionWasSet[oi]) {
                        if (seenCount == 0) { firstSeen  = grp._names[k]; }
                        else if (seenCount == 1) { secondSeen = grp._names[k]; }
                        seenCount = seenCount + 1;
                    }
                    k = k + 1;
                }
                if (seenCount > 1) {
                    throw new CliException("options '--" + firstSeen +
                        "' and '--" + secondSeen + "' are mutually exclusive");
                }
                g = g + 1;
            }
        }

        return r;
    }

    // 解析 --long 或 --long=value 或 --long value
    private int ParseLong(string a, string[] argv, int idx, ParseResult r) {
        // 切割 = 形式
        string name = "";
        string value = "";
        bool hasValue = false;
        int eq = this.IndexOf(a, '=');
        if (eq >= 0) {
            name  = a.Substring(2, eq - 2);
            value = a.Substring(eq + 1, a.Length - eq - 1);
            hasValue = true;
        } else {
            name = a.Substring(2, a.Length - 2);
        }
        // 找 flag
        int fi = this.FindFlagByLong(name);
        if (fi >= 0) {
            if (hasValue) {
                throw new CliException("flag '--" + name + "' does not take a value");
            }
            r._flagValues[fi] = true;
            return idx + 1;
        }
        // 找 option
        int oi = this.FindOptionByLong(name);
        if (oi >= 0) {
            string val;
            int  nextIdx;
            if (hasValue) {
                val     = value;
                nextIdx = idx + 1;
            } else {
                if (idx + 1 >= argv.Length) {
                    throw new CliException("option '--" + name + "' requires a value");
                }
                val     = argv[idx + 1];
                nextIdx = idx + 2;
            }
            r._optionValues[oi] = val;
            r._optionWasSet[oi] = true;
            if (this._optionRepeated[oi]) {
                r._optionLists[oi].Append(val);
            }
            return nextIdx;
        }
        // Pass-through unknown options if extras allowed.
        if (this._allowExtras) {
            ArgParser._AppendExtra(r, a);
            return idx + 1;
        }
        throw new CliException("unknown option '--" + name + "'");
    }

    /// Push a token into ParseResult._extras (grow on demand).
    /// add-cli-strict-vs-extras (2026-05-26).
    static void _AppendExtra(ParseResult r, string token) {
        if (r._extrasCount >= r._extras.Length) {
            int n = r._extras.Length * 2;
            string[] g = new string[n];
            int i = 0;
            while (i < r._extrasCount) { g[i] = r._extras[i]; i = i + 1; }
            r._extras = g;
        }
        r._extras[r._extrasCount] = token;
        r._extrasCount = r._extrasCount + 1;
    }

    private int ParseShort(string a, string[] argv, int idx, ParseResult r) {
        string name = a.Substring(1, a.Length - 1);
        int fi = this.FindFlagByShort(name);
        if (fi >= 0) {
            r._flagValues[fi] = true;
            return idx + 1;
        }
        int oi = this.FindOptionByShort(name);
        if (oi >= 0) {
            if (idx + 1 >= argv.Length) {
                throw new CliException("option '-" + name + "' requires a value");
            }
            string val = argv[idx + 1];
            r._optionValues[oi] = val;
            r._optionWasSet[oi] = true;
            if (this._optionRepeated[oi]) {
                r._optionLists[oi].Append(val);
            }
            return idx + 2;
        }
        // GNU-style short-flag cluster `-abc` = `-a -b -c` (boolean flags only).
        // Only entered when the token isn't a registered single short. Each
        // char must be a registered flag's short name; if ANY char is an
        // option-short, throws because clustering doesn't compose with values.
        // add-cli-short-flag-cluster (2026-05-26).
        // Skip cluster path entirely when `_allowExtras` is on — the whole
        // token goes to extras instead.
        if (name.Length > 1 && !this._allowExtras) {
            // First pass: validate every char is a known flag short.
            int p = 0;
            while (p < name.Length) {
                string ch = name.Substring(p, 1);
                int cfi = this.FindFlagByShort(ch);
                if (cfi < 0) {
                    int coi = this.FindOptionByShort(ch);
                    if (coi >= 0) {
                        throw new CliException("short-flag cluster '-" + name +
                            "' contains option '-" + ch +
                            "' that requires a value (clusters are flags only)");
                    }
                    throw new CliException("unknown option '-" + name + "'");
                }
                p = p + 1;
            }
            // Second pass: set each flag.
            int q = 0;
            while (q < name.Length) {
                string ch = name.Substring(q, 1);
                int cfi = this.FindFlagByShort(ch);
                r._flagValues[cfi] = true;
                q = q + 1;
            }
            return idx + 1;
        }
        if (this._allowExtras) {
            ArgParser._AppendExtra(r, a);
            return idx + 1;
        }
        throw new CliException("unknown option '-" + name + "'");
    }

    // ── HelpText ─────────────────────────────────────────────────────────

    /// 自动生成的 help 文本（Usage + 选项列表）。
    public string HelpText() {
        StringBuilder sb = new StringBuilder();
        sb.Append(this._programName);
        if (this._description.Length > 0) {
            sb.Append(" — ");
            sb.Append(this._description);
        }
        sb.Append("\n\n");

        // Usage line
        sb.Append("USAGE:\n    ");
        sb.Append(this._programName);
        sb.Append(" [OPTIONS]");
        int p = 0;
        while (p < this._positionalCount) {
            if (this._positionalOptional[p]) {
                sb.Append(" [");
                sb.Append(this._positionalNames[p]);
                sb.Append("]");
            } else {
                sb.Append(" <");
                sb.Append(this._positionalNames[p]);
                sb.Append(">");
            }
            p = p + 1;
        }
        sb.Append("\n\n");

        // Flags
        if (this._flagCount > 0) {
            sb.Append("FLAGS:\n");
            int i = 0;
            while (i < this._flagCount) {
                sb.Append("    ");
                if (this._flagShorts[i].Length > 0) {
                    sb.Append("-");
                    sb.Append(this._flagShorts[i]);
                    sb.Append(", ");
                }
                sb.Append("--");
                sb.Append(this._flagLongs[i]);
                sb.Append("    ");
                sb.Append(this._flagHelps[i]);
                sb.Append("\n");
                i = i + 1;
            }
            sb.Append("    -h, --help    Print this help and exit\n\n");
        } else {
            sb.Append("FLAGS:\n    -h, --help    Print this help and exit\n\n");
        }

        // Options
        if (this._optionCount > 0) {
            sb.Append("OPTIONS:\n");
            int i = 0;
            while (i < this._optionCount) {
                sb.Append("    ");
                if (this._optionShorts[i].Length > 0) {
                    sb.Append("-");
                    sb.Append(this._optionShorts[i]);
                    sb.Append(", ");
                }
                sb.Append("--");
                sb.Append(this._optionLongs[i]);
                sb.Append(" <");
                sb.Append(this._optionLongs[i]);
                sb.Append(">    ");
                sb.Append(this._optionHelps[i]);
                sb.Append("  [default: ");
                sb.Append(this._optionDefaults[i]);
                sb.Append("]\n");
                i = i + 1;
            }
            sb.Append("\n");
        }

        // Positionals
        if (this._positionalCount > 0) {
            sb.Append("ARGS:\n");
            int i = 0;
            while (i < this._positionalCount) {
                if (this._positionalOptional[i]) {
                    sb.Append("    [");
                    sb.Append(this._positionalNames[i]);
                    sb.Append("]    ");
                } else {
                    sb.Append("    <");
                    sb.Append(this._positionalNames[i]);
                    sb.Append(">    ");
                }
                sb.Append(this._positionalHelps[i]);
                sb.Append("\n");
                i = i + 1;
            }
        }

        return sb.ToString();
    }

    // ── Internals ────────────────────────────────────────────────────────

    private int FindFlagByLong(string name) {
        int i = 0;
        while (i < this._flagCount) {
            if (this._flagLongs[i] == name) { return i; }
            i = i + 1;
        }
        return -1;
    }

    private int FindFlagByShort(string name) {
        int i = 0;
        while (i < this._flagCount) {
            if (this._flagShorts[i] == name) { return i; }
            i = i + 1;
        }
        return -1;
    }

    private int FindOptionByLong(string name) {
        int i = 0;
        while (i < this._optionCount) {
            if (this._optionLongs[i] == name) { return i; }
            i = i + 1;
        }
        return -1;
    }

    private int FindOptionByShort(string name) {
        int i = 0;
        while (i < this._optionCount) {
            if (this._optionShorts[i] == name) { return i; }
            i = i + 1;
        }
        return -1;
    }

    private int IndexOf(string s, char c) {
        int i = 0;
        while (i < s.Length) {
            if (s.CharAt(i) == c) { return i; }
            i = i + 1;
        }
        return -1;
    }

    private void EnsureFlagCap() {
        if (this._flagCount < this._flagLongs.Length) { return; }
        int n = this._flagLongs.Length * 2;
        string[] gl = new string[n];
        string[] gs = new string[n];
        string[] gh = new string[n];
        int i = 0;
        while (i < this._flagCount) {
            gl[i] = this._flagLongs[i];
            gs[i] = this._flagShorts[i];
            gh[i] = this._flagHelps[i];
            i = i + 1;
        }
        this._flagLongs  = gl;
        this._flagShorts = gs;
        this._flagHelps  = gh;
    }

    private void EnsureOptionCap() {
        if (this._optionCount < this._optionLongs.Length) { return; }
        int n = this._optionLongs.Length * 2;
        string[] gl = new string[n];
        string[] gs = new string[n];
        string[] gh = new string[n];
        string[] gd = new string[n];
        bool[]   gr = new bool[n];
        bool[]   gp = new bool[n];
        string[] ge = new string[n];
        int i = 0;
        while (i < this._optionCount) {
            gl[i] = this._optionLongs[i];
            gs[i] = this._optionShorts[i];
            gh[i] = this._optionHelps[i];
            gd[i] = this._optionDefaults[i];
            gr[i] = this._optionRequired[i];
            gp[i] = this._optionRepeated[i];
            ge[i] = this._optionEnvVars[i];
            i = i + 1;
        }
        this._optionLongs    = gl;
        this._optionShorts   = gs;
        this._optionHelps    = gh;
        this._optionDefaults = gd;
        this._optionRequired = gr;
        this._optionRepeated = gp;
        this._optionEnvVars  = ge;
    }

    private void EnsurePositionalCap() {
        if (this._positionalCount < this._positionalNames.Length) { return; }
        int n = this._positionalNames.Length * 2;
        string[] gn = new string[n];
        string[] gh = new string[n];
        bool[]   go = new bool[n];
        int i = 0;
        while (i < this._positionalCount) {
            gn[i] = this._positionalNames[i];
            gh[i] = this._positionalHelps[i];
            go[i] = this._positionalOptional[i];
            i = i + 1;
        }
        this._positionalNames = gn;
        this._positionalHelps = gh;
        this._positionalOptional = go;
    }
}
