namespace Std;

// add-z42-cli (2026-05-16)：ArgParser.Parse 失败时抛出。
// 覆盖：未知 long flag、缺 option value、positional 数量不足。
public class CliException : Exception {
    public CliException(string message) : base(message) {}

    override string ToString() {
        return "CliException: " + this.Message;
    }
}
