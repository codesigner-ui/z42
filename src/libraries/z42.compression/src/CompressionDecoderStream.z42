namespace Std.Compression;

using Std;
using Std.IO;

// refactor-compression-stream-on-iostream (2026-05-24): pull-mode
// decoder Stream — caller reads decompressed bytes; the decoder
// pulls compressed bytes from the wrapped source Stream as needed.
//
// add-compression-streaming-decode (2026-06-09): **true per-chunk streaming**.
//   * Each `Read` serves out of an internal decompressed-output buffer.
//   * When that buffer drains (and not yet at end): pull one CHUNK of
//     compressed bytes from `_src`, feed it to the cdylib decoder slot via
//     `_CompressorFeed` (which returns the *incremental* decompressed output
//     produced so far), and buffer that. The decoder slot is held across
//     `Read` calls — begun lazily on first `Read`, finished at `_src` EOF.
//   * `_src` EOF → `_CompressorFinish` flushes the codec footer / tail output.
//
// Memory is bounded by one compressed CHUNK + the decompressed output a single
// chunk produces — multi-GB / network payloads no longer materialise in full
// before the first `Read` returns. The public Stream API is unchanged
// (replaces the former v0 "lazy bulk decode" which `ReadAllBytes()` + one-shot
// fed the whole payload). The cdylib (`z42_compression`) was already streaming
// (`flate2::write::*Decoder` + per-feed `std::mem::take`); v0 simply didn't
// consume `_CompressorFeed`'s incremental return.
//
// Neither this stream closes `_src` — caller owns its lifecycle (matches the
// `leaveOpen=true` convention of the other compression stream wrappers).

public sealed class CompressionDecoderStream : Stream {
    private Stream _src;
    private int    _algo;
    private long   _slotId;     // cdylib decoder slot; -1 = not begun
    private byte[] _outBuf;     // decompressed output not yet served
    private int    _outPos;
    private bool   _srcEof;     // _src drained
    private bool   _finished;   // _CompressorFinish already called (slot freed)
    private bool   _closed;

    public CompressionDecoderStream(Stream src, int algo) {
        if (!src.CanRead()) {
            throw new ArgumentException("CompressionDecoderStream: src Stream is not readable");
        }
        this._src      = src;
        this._algo     = algo;
        this._slotId   = -1;
        this._outBuf   = new byte[0];
        this._outPos   = 0;
        this._srcEof   = false;
        this._finished = false;
        this._closed   = false;
    }

    // ── Capability ───────────────────────────────────────────────────────

    override bool CanRead()  { return true; }
    override bool CanWrite() { return false; }
    override bool CanSeek()  { return false; }

    // ── Read ─────────────────────────────────────────────────────────────

    override int Read(byte[] buffer, int offset, int count) {
        if (this._closed) {
            throw new InvalidOperationException("CompressionDecoderStream: stream is closed");
        }
        if (offset < 0 || count < 0 || offset + count > buffer.Length) {
            throw new ArgumentException("Read: buffer / offset / count out of range");
        }
        if (count == 0) { return 0; }

        // Pull/decode until the output buffer has bytes, or we hit true EOF.
        int chunkSize = 65536;
        while (this._outPos >= this._outBuf.Length && !this._finished) {
            if (this._slotId < 0) {
                this._slotId = CompressionDecoderStream._CompressorBegin(this._algo, 0, true);
            }
            if (this._srcEof) {
                // No more compressed input → flush decoder tail and stop.
                this._outBuf   = CompressionDecoderStream._CompressorFinish(this._slotId);
                this._outPos   = 0;
                this._finished = true;
            } else {
                byte[] chunk = new byte[chunkSize];
                int nRead = this._src.Read(chunk, 0, chunkSize);
                if (nRead <= 0) {
                    this._srcEof = true;   // next loop iteration finishes
                } else {
                    // Feed exactly nRead bytes (Stream.Read may underfill the chunk).
                    byte[] fed = chunk;
                    if (nRead < chunkSize) {
                        fed = new byte[nRead];
                        int j = 0;
                        while (j < nRead) { fed[j] = chunk[j]; j = j + 1; }
                    }
                    this._outBuf = CompressionDecoderStream._CompressorFeed(this._slotId, fed);
                    this._outPos = 0;
                    // feed may yield 0 bytes (input buffered, no full block yet) →
                    // loop continues pulling the next chunk.
                }
            }
        }

        int available = this._outBuf.Length - this._outPos;
        if (available <= 0) { return 0; }   // EOF: finished and buffer drained
        int n = count;
        if (n > available) { n = available; }
        int i = 0;
        while (i < n) {
            buffer[offset + i] = this._outBuf[this._outPos + i];
            i = i + 1;
        }
        this._outPos = this._outPos + n;
        return n;
    }

    override void Close() {
        // Free the cdylib slot if still held. If we never reached `_src` EOF
        // (partial read then early Close), `_CompressorFinish` both flushes and
        // frees the slot; we discard its output and swallow any tail error
        // (an incomplete stream finish is expected on early abort).
        if (this._slotId >= 0 && !this._finished) {
            try {
                CompressionDecoderStream._CompressorFinish(this._slotId);
            } catch (Exception e) {
                // intentionally ignored — early-abort cleanup
            }
            this._finished = true;
        }
        this._outBuf = new byte[0];
        this._outPos = 0;
        this._closed = true;
    }

    // ── Native bindings ──────────────────────────────────────────────────

    [Native(lib = "z42_compression", entry = "__compressor_begin")]
    private static extern long _CompressorBegin(int algo, int level, bool isDecompress);

    [Native(lib = "z42_compression", entry = "__compressor_feed")]
    private static extern byte[] _CompressorFeed(long slotId, byte[] chunk);

    [Native(lib = "z42_compression", entry = "__compressor_finish")]
    private static extern byte[] _CompressorFinish(long slotId);
}
