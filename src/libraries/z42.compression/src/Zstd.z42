namespace Std.Compression;

using Std;

// add-z42-compression (2026-05-22): Zstandard (RFC 8478 / RFC 8878).
// Better compression ratio than gzip at similar speed; the modern
// default for cargo, NPM, Arch, Debian etc.
//
// refactor-compression-stream-on-iostream (2026-05-24): see Gzip.z42
// for the API shape rationale.

public static class Zstd {
    [Native(lib = "z42_compression", entry = "__zstd_compress")]
    private static extern byte[] _CompressRaw(byte[] data, int level);

    [Native(lib = "z42_compression", entry = "__zstd_decompress")]
    private static extern byte[] _DecompressRaw(byte[] data);

    public static byte[] Compress(byte[] data) {
        return _CompressRaw(data, Compression.ZstdDefault);
    }

    public static byte[] Compress(byte[] data, int level) {
        return _CompressRaw(data, level);
    }

    public static byte[] Decompress(byte[] data) {
        return _DecompressRaw(data);
    }

    public static Stream WrapWrite(Stream dest) {
        return new CompressionEncoderStream(dest, AlgoId.Zstd, Compression.ZstdDefault);
    }

    public static Stream WrapWrite(Stream dest, int level) {
        return new CompressionEncoderStream(dest, AlgoId.Zstd, level);
    }

    public static Stream WrapRead(Stream src) {
        return new CompressionDecoderStream(src, AlgoId.Zstd);
    }
}
