namespace Std.Compression;

using Std;

// add-z42-compression-brotli (2026-05-27): Brotli (RFC 7932) — the
// HTTP `Content-Encoding: br` algorithm; typically 15-25% better ratio
// than gzip on web text at similar speed (better at high levels).
//
// Backed by pure-Rust `brotli` crate (no C deps), so the same code
// path works on every target including wasm32 — unlike Zstd which
// excludes wasm.
//
// v0 scope: one-shot Compress / Decompress only. Streaming (slot-based
// like Gzip / Zstd) deferred to follow-up; current users (HTTP response
// decoding) consume whole payloads at once.
public static class Brotli {
    [Native(lib = "z42_compression", entry = "__brotli_compress")]
    private static extern byte[] _CompressRaw(byte[] data, int level);

    [Native(lib = "z42_compression", entry = "__brotli_decompress")]
    private static extern byte[] _DecompressRaw(byte[] data);

    /// Compress at level 11 (best ratio — brotli reference default).
    public static byte[] Compress(byte[] data) {
        return _CompressRaw(data, Compression.BrotliDefault);
    }

    /// Compress at the given level (0 fastest .. 11 best).
    public static byte[] Compress(byte[] data, int level) {
        return _CompressRaw(data, level);
    }

    /// Decompress a brotli-encoded byte stream.
    /// Throws `CompressionException` on malformed input.
    public static byte[] Decompress(byte[] data) {
        return _DecompressRaw(data);
    }
}
