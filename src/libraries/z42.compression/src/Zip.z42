namespace Std.Archive;

using Std;
using Std.IO;
using Std.Compression;

// add-z42-compression (2026-05-22): Zip archive reader (PKWARE
// APPNOTE.TXT v6.3.x). Pure z42 parsing of the local file header /
// central directory / EOCD; per-entry payload decompression goes
// through `Std.Compression.Deflate` for method=8 (DEFLATE) entries.
// method=0 (STORE) is also supported.
//
// v0 scope:
//   - Read-side only (Write deferred to `add-z42-compression-zip-write`
//     follow-up — needs `byte[][]` array-of-array support in z42 to
//     express the natural implementation; v0 ships the high-impact
//     extraction use case for the former `setup-tools.sh` NDK/SDK unzipping)
//   - methods 0 (STORE) and 8 (DEFLATE) only
//   - no encryption (method 99 / strong encryption)
//   - no ZIP64 extra fields (archives < 4 GB, fewer than 65 535 entries)
//   - filenames assumed UTF-8 (general purpose bit 11 set; older
//     CP437/GBK archives produce mojibake names — pax exception left
//     to v1)
//   - no central directory comments

public class ZipEntry {
    public string Name;
    public byte[] Content;
    public int    CompressionMethod;  // 0 = STORE, 8 = DEFLATE

    public ZipEntry(string name, byte[] content, int compressionMethod) {
        this.Name              = name;
        this.Content           = content;
        this.CompressionMethod = compressionMethod;
    }
}

public static class Zip {
    // PKWARE signatures
    private static int _sigLocalFileHeader  = 0x04034b50;  // "PK\x03\x04"
    private static int _sigCentralDirHeader = 0x02014b50;  // "PK\x01\x02"
    private static int _sigEocd               = 0x06054b50;  // "PK\x05\x06"
    private static int _methodStore   = 0;
    private static int _methodDeflate = 8;

    // ── Read ────────────────────────────────────────────────────────

    public static ZipEntry[] Read(byte[] zipBytes) {
        if (zipBytes.Length < 22) {
            throw new ArchiveException("zip archive too small (< 22 bytes EOCD)");
        }
        int eocdOff = _LocateEocd(zipBytes);
        if (eocdOff < 0) {
            throw new ArchiveException("zip archive: no EOCD signature");
        }
        int entryCount = _ReadU16LE(zipBytes, eocdOff + 10);
        int cdOff      = _ReadU32LE(zipBytes, eocdOff + 16);

        ZipEntry[] result = new ZipEntry[entryCount];
        int cdCursor = cdOff;
        int i = 0;
        while (i < entryCount) {
            int sig = _ReadU32LE(zipBytes, cdCursor);
            if (sig != Zip._sigCentralDirHeader) {
                throw new ArchiveException("zip: bad central directory entry signature at " + cdCursor.ToString());
            }
            int method      = _ReadU16LE(zipBytes, cdCursor + 10);
            int compressed  = _ReadU32LE(zipBytes, cdCursor + 20);
            int uncompressed = _ReadU32LE(zipBytes, cdCursor + 24);
            int nameLen     = _ReadU16LE(zipBytes, cdCursor + 28);
            int extraLen    = _ReadU16LE(zipBytes, cdCursor + 30);
            int commentLen  = _ReadU16LE(zipBytes, cdCursor + 32);
            int localOff    = _ReadU32LE(zipBytes, cdCursor + 42);
            string name = _ReadStr(zipBytes, cdCursor + 46, nameLen);

            int localSig = _ReadU32LE(zipBytes, localOff);
            if (localSig != Zip._sigLocalFileHeader) {
                throw new ArchiveException("zip: bad local file header for entry '" + name + "'");
            }
            int localNameLen  = _ReadU16LE(zipBytes, localOff + 26);
            int localExtraLen = _ReadU16LE(zipBytes, localOff + 28);
            int payloadOff = localOff + 30 + localNameLen + localExtraLen;

            byte[] rawPayload = new byte[compressed];
            int j = 0;
            while (j < compressed) {
                rawPayload[j] = zipBytes[payloadOff + j];
                j = j + 1;
            }

            byte[] content;
            if (method == Zip._methodStore) {
                content = rawPayload;
            } else if (method == Zip._methodDeflate) {
                content = Deflate.Decompress(rawPayload);
                if (content.Length != uncompressed) {
                    throw new ArchiveException("zip: decompressed size mismatch for '" + name + "'");
                }
            } else {
                throw new ArchiveException("zip: unsupported compression method " + method.ToString() + " for entry '" + name + "' (only 0=STORE / 8=DEFLATE)");
            }

            result[i] = new ZipEntry(name, content, method);
            cdCursor = cdCursor + 46 + nameLen + extraLen + commentLen;
            i = i + 1;
        }
        return result;
    }

    // ── Write (add-zip-write 2026-05-27) ────────────────────────────────
    //
    // Build a `.zip` archive byte[] from in-memory entries. Each entry's
    // `CompressionMethod` field selects STORE (0, no compression) or
    // DEFLATE (8, via `Std.Compression.Deflate.Compress`).
    //
    // Single-buffer layout (the "2-pass workaround" alternative to
    // `byte[][]`): one growable buffer accumulates LFH+name+data per
    // entry while we record offsets; then we append the central
    // directory entries; then the EOCD. The "2-pass" name is historical
    // — actually it's a one-pass write with parallel arrays tracking
    // per-entry offsets / sizes / CRCs.
    //
    // v0 scope:
    //   - Methods 0 (STORE) and 8 (DEFLATE) only — matches Read
    //   - General-purpose-bit-flag UTF-8 marker (bit 11) always set —
    //     names assumed UTF-8 to match Read
    //   - DOS modification time = 1980-01-01 00:00:00 (Zip's epoch);
    //     mtime preservation is a follow-up
    //   - No ZIP64 (< 4 GB archive, < 65 535 entries)
    //   - No encryption / extra fields / comments
    //
    // CRC-32: polynomial 0xEDB88320 (reflected), table-driven.
    public static byte[] Write(ZipEntry[] entries) {
        // Pass 1: precompute per-entry compressed data + CRC + offsets.
        // Aggregate written-so-far counter is the LFH offset.
        // Use grow-on-append byte[] pattern.
        int n = entries.Length;
        long[] crc32s         = new long[n];
        int[]  compressedLens = new int[n];
        int[]  localOffsets   = new int[n];
        // Compressed data for each entry — we don't have byte[][], so
        // we keep them as separate byte[] in a parallel array (works
        // because byte[] IS a value the array can hold; only `byte[][]`
        // syntactic forms aren't supported).
        // Wait — z42 supports `Type[]` for any Type. Use ZipEntry[] as
        // precedent. byte[][] should work via the same mechanism: array
        // of `byte[]` references. If it doesn't lex, fall back to
        // concatenating into one big buffer + offset-tracking.

        // Single aggregate buffer: LFH+name+data per entry. Grows on
        // append. Each entry's LFH offset is recorded before appending.
        _GrowBuf agg = new _GrowBuf();
        int i = 0;
        while (i < n) {
            ZipEntry e = entries[i];
            byte[] rawContent = e.Content;
            int method = e.CompressionMethod;
            byte[] data;
            if (method == Zip._methodStore) {
                data = rawContent;
            } else if (method == Zip._methodDeflate) {
                data = Deflate.Compress(rawContent);
            } else {
                throw new ArchiveException(
                    "Zip.Write: unsupported method " + method.ToString()
                    + " for entry '" + e.Name + "' (only 0=STORE / 8=DEFLATE)");
            }
            long crc = Zip._crc32(rawContent);
            crc32s[i] = crc;
            compressedLens[i] = data.Length;
            localOffsets[i] = agg.Count();

            // Local file header: 30 fixed bytes.
            agg.AppendU32LE((long)Zip._sigLocalFileHeader);
            agg.AppendU16LE(20);                 // version-needed (2.0 — DEFLATE)
            agg.AppendU16LE(0x0800);             // GPBF: bit 11 = UTF-8 names
            agg.AppendU16LE(method);
            agg.AppendU16LE(0);                  // last-mod time (1980-01-01)
            agg.AppendU16LE(0x0021);             // last-mod date (1980-01-01)
            agg.AppendU32LE(crc);
            agg.AppendU32LE((long)data.Length);  // compressed size
            agg.AppendU32LE((long)rawContent.Length);  // uncompressed size
            byte[] nameBytes = Zip._utf8Bytes(e.Name);
            agg.AppendU16LE(nameBytes.Length);
            agg.AppendU16LE(0);                  // extra-field length
            agg.AppendBytes(nameBytes);
            agg.AppendBytes(data);

            i = i + 1;
        }

        int cdOffset = agg.Count();
        // Central directory entries — 46 fixed bytes each.
        i = 0;
        while (i < n) {
            ZipEntry e = entries[i];
            byte[] nameBytes = Zip._utf8Bytes(e.Name);
            agg.AppendU32LE((long)Zip._sigCentralDirHeader);
            agg.AppendU16LE(0x031E);             // version-made-by: 3 (Unix) << 8 | 30 (4.5)
            agg.AppendU16LE(20);                 // version-needed
            agg.AppendU16LE(0x0800);             // GPBF
            agg.AppendU16LE(e.CompressionMethod);
            agg.AppendU16LE(0);                  // mtime
            agg.AppendU16LE(0x0021);             // mdate
            agg.AppendU32LE(crc32s[i]);
            agg.AppendU32LE((long)compressedLens[i]);
            agg.AppendU32LE((long)e.Content.Length);
            agg.AppendU16LE(nameBytes.Length);
            agg.AppendU16LE(0);                  // extra
            agg.AppendU16LE(0);                  // comment
            agg.AppendU16LE(0);                  // disk number start
            agg.AppendU16LE(0);                  // internal attrs
            agg.AppendU32LE(0L);                 // external attrs (0644 << 16 typical; 0 = no-op)
            agg.AppendU32LE((long)localOffsets[i]);
            agg.AppendBytes(nameBytes);
            i = i + 1;
        }
        int cdSize = agg.Count() - cdOffset;

        // EOCD — 22 fixed bytes.
        agg.AppendU32LE((long)Zip._sigEocd);
        agg.AppendU16LE(0);                      // disk number
        agg.AppendU16LE(0);                      // start-of-CD disk
        agg.AppendU16LE(n);                      // total entries on this disk
        agg.AppendU16LE(n);                      // total entries
        agg.AppendU32LE((long)cdSize);
        agg.AppendU32LE((long)cdOffset);
        agg.AppendU16LE(0);                      // comment length

        return agg.Finish();
    }

    // ── CRC-32 (poly 0xEDB88320, IEEE 802.3) ────────────────────────────

    private static long[] _crc32Table() {
        long[] t = new long[256];
        int i = 0;
        while (i < 256) {
            long c = (long)i;
            int k = 0;
            while (k < 8) {
                if ((c & 1L) != 0L) {
                    c = (c >> 1) ^ 0xEDB88320L;
                } else {
                    c = c >> 1;
                }
                // Mask off sign-extended bits (long is i64; right-shift
                // on a positive value <= 0xFFFFFFFF stays positive but
                // we keep the explicit mask for clarity).
                c = c & 0xFFFFFFFFL;
                k = k + 1;
            }
            t[i] = c;
            i = i + 1;
        }
        return t;
    }

    private static long _crc32(byte[] data) {
        long[] t = Zip._crc32Table();
        long crc = 0xFFFFFFFFL;
        int i = 0;
        while (i < data.Length) {
            int b = (int)data[i] & 0xFF;
            int idx = (int)((crc ^ (long)b) & 0xFFL);
            crc = (crc >> 8) ^ t[idx];
            crc = crc & 0xFFFFFFFFL;
            i = i + 1;
        }
        return crc ^ 0xFFFFFFFFL;
    }

    // UTF-8 encode (z42.encoding's Utf8 lives in another package — keep
    // Zip self-contained by inlining a minimal UTF-8 encoder for
    // ASCII / BMP / supplementary code points).
    private static byte[] _utf8Bytes(string s) {
        // Count bytes first.
        int count = 0;
        int i = 0;
        while (i < s.Length) {
            int c = (int)s.CharAt(i);
            if (c < 0x80)        { count = count + 1; }
            else if (c < 0x800)  { count = count + 2; }
            else                  { count = count + 3; }
            i = i + 1;
        }
        byte[] r = new byte[count];
        int pos = 0;
        i = 0;
        while (i < s.Length) {
            int c = (int)s.CharAt(i);
            if (c < 0x80) {
                r[pos] = (byte)c;
                pos = pos + 1;
            } else if (c < 0x800) {
                r[pos]     = (byte)(0xC0 | (c >> 6));
                r[pos + 1] = (byte)(0x80 | (c & 0x3F));
                pos = pos + 2;
            } else {
                r[pos]     = (byte)(0xE0 | (c >> 12));
                r[pos + 1] = (byte)(0x80 | ((c >> 6) & 0x3F));
                r[pos + 2] = (byte)(0x80 | (c & 0x3F));
                pos = pos + 3;
            }
            i = i + 1;
        }
        return r;
    }

    public static byte[] ExtractFile(byte[] zipBytes, string name) {
        ZipEntry[] entries = Read(zipBytes);
        int i = 0;
        while (i < entries.Length) {
            if (entries[i].Name == name) {
                return entries[i].Content;
            }
            i = i + 1;
        }
        throw new ArchiveException("zip: entry '" + name + "' not found");
    }

    // add-zip-extractall (2026-05-27): extract every entry to destDir.
    // Mirrors `Tar.ExtractTo`. Entry names ending in `/` are directories
    // (created but no file written). Zip-Slip prevention identical:
    // reject names with absolute paths or `..` segments. Returns number
    // of files written (directory entries don't count).
    //
    // Companion `CreateFromDirectory` is deferred — requires `Zip.Write`
    // which is itself deferred (`compression-future-zip-write`).
    public static int ExtractAllTo(byte[] zipBytes, string destDir) {
        Directory.Create(destDir);
        ZipEntry[] entries = Zip.Read(zipBytes);
        int written = 0;
        int i = 0;
        while (i < entries.Length) {
            ZipEntry e = entries[i];
            _EnsureSafeZipEntryName(e.Name);
            string targetPath = Path.Join(destDir, e.Name);
            // Names ending in `/` are pure directories (PKWARE convention).
            if (e.Name.Length > 0 && e.Name.CharAt(e.Name.Length - 1) == '/') {
                Directory.Create(targetPath);
            } else {
                string parent = Path.GetDirectoryName(targetPath);
                if (parent.Length > 0) {
                    Directory.Create(parent);
                }
                File.WriteAllBytes(targetPath, e.Content);
                written = written + 1;
            }
            i = i + 1;
        }
        return written;
    }

    // Zip-Slip CVE defence — symmetric to `Tar._EnsureSafeEntryName`.
    // Reject absolute paths (`/...`) and any `..` path segment.
    private static void _EnsureSafeZipEntryName(string name) {
        if (name.Length == 0) {
            throw new ArchiveException("zip entry has empty name");
        }
        if (name.CharAt(0) == '/') {
            throw new ArchiveException("zip entry name is absolute path: " + name);
        }
        string[] segs = name.Split("/");
        int i = 0;
        while (i < segs.Length) {
            if (segs[i] == "..") {
                throw new ArchiveException("zip entry name contains '..' segment: " + name);
            }
            i = i + 1;
        }
    }

    // ── Helpers ─────────────────────────────────────────────────────

    private static int _LocateEocd(byte[] bytes) {
        int max = bytes.Length - 22;
        int min = 0;
        if (bytes.Length > 65557) {
            min = bytes.Length - 65557;
        }
        int i = max;
        while (i >= min) {
            if (_ReadU32LE(bytes, i) == Zip._sigEocd) {
                return i;
            }
            i = i - 1;
        }
        return -1;
    }

    private static int _ReadU16LE(byte[] bytes, int off) {
        return ((int)bytes[off]) | (((int)bytes[off + 1]) << 8);
    }

    private static int _ReadU32LE(byte[] bytes, int off) {
        return ((int)bytes[off])
             | (((int)bytes[off + 1]) << 8)
             | (((int)bytes[off + 2]) << 16)
             | (((int)bytes[off + 3]) << 24);
    }

    private static string _ReadStr(byte[] bytes, int offset, int len) {
        // add-zip-extractall (2026-05-27): `new string(chars)` returns a
        // GcRef-wrapped namespace-local "Std.Archive.string" type rather
        // than the primitive `Std.String`, breaking downstream CharAt /
        // Length / Split calls. Switch to documented `String.FromChars`
        // intrinsic. (Same latent bug Tar._ReadStr had until 2026-05-26.)
        char[] chars = new char[len];
        int i = 0;
        while (i < len) {
            chars[i] = (char)bytes[offset + i];
            i = i + 1;
        }
        return String.FromChars(chars);
    }
}

// add-zip-write (2026-05-27): grow-on-append byte buffer used by
// `Zip.Write` to assemble the archive in a single pass. Keeps the
// implementation self-contained (no dependency on z42.io's
// MemoryStream or any other List-style abstraction); doubles capacity
// on overflow.
public class _GrowBuf {
    private byte[] _buf;
    private int    _count;

    public _GrowBuf() {
        this._buf = new byte[256];
        this._count = 0;
    }

    public int Count() { return this._count; }

    public void AppendU8(int v) {
        this._ensure(1);
        this._buf[this._count] = (byte)(v & 0xFF);
        this._count = this._count + 1;
    }

    public void AppendU16LE(int v) {
        this._ensure(2);
        this._buf[this._count]     = (byte)(v & 0xFF);
        this._buf[this._count + 1] = (byte)((v >> 8) & 0xFF);
        this._count = this._count + 2;
    }

    /// `long` argument keeps the high-bit semantics clean for full u32
    /// range (CRC-32 of 0xFFFF_FFFF etc.). Caller passes the value as
    /// long; low 32 bits get emitted little-endian.
    public void AppendU32LE(long v) {
        this._ensure(4);
        this._buf[this._count]     = (byte)(v & 0xFFL);
        this._buf[this._count + 1] = (byte)((v >> 8)  & 0xFFL);
        this._buf[this._count + 2] = (byte)((v >> 16) & 0xFFL);
        this._buf[this._count + 3] = (byte)((v >> 24) & 0xFFL);
        this._count = this._count + 4;
    }

    public void AppendBytes(byte[] data) {
        this._ensure(data.Length);
        int i = 0;
        while (i < data.Length) {
            this._buf[this._count + i] = data[i];
            i = i + 1;
        }
        this._count = this._count + data.Length;
    }

    /// Return a tightly-sized copy of the accumulated bytes.
    public byte[] Finish() {
        byte[] r = new byte[this._count];
        int i = 0;
        while (i < this._count) { r[i] = this._buf[i]; i = i + 1; }
        return r;
    }

    private void _ensure(int extra) {
        int needed = this._count + extra;
        if (needed <= this._buf.Length) return;
        int newCap = this._buf.Length * 2;
        while (newCap < needed) { newCap = newCap * 2; }
        byte[] bigger = new byte[newCap];
        int i = 0;
        while (i < this._count) { bigger[i] = this._buf[i]; i = i + 1; }
        this._buf = bigger;
    }
}
