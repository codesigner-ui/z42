namespace Std.Archive;

using Std;
using Std.IO;

// add-z42-compression (2026-05-22): ustar archive (POSIX 1003.1-1988).
// Pure z42 — no FFI dependency. Tar is an archive format only (no
// compression); pair with `Std.Compression.Gzip` / `Zstd` etc. when
// you want `.tar.gz` / `.tar.zst`.
//
// v0 scope: ustar format (the modern GNU tar / bsdtar default).
//   - regular files (typeflag '0' or '\0')
//   - 100-byte name + 155-byte prefix (long-name handling via prefix
//     concatenation; pax extended headers are deferred)
//   - octal sizes / modes
//   - 512-byte blocks with NUL padding
//   - 2 × 512 NUL trailer marks EOF
//
// Out of scope (deferred): pax extended headers, sparse files, symlinks
// with content, hard links, device files. Bytes of an unsupported entry
// type produce an `ArchiveException`.

public class TarEntry {
    public string Name;
    public byte[] Content;
    public int    Mode;

    public TarEntry(string name, byte[] content, int mode) {
        this.Name    = name;
        this.Content = content;
        this.Mode    = mode;
    }
}

public static class Tar {
    // ── Read ────────────────────────────────────────────────────────

    public static TarEntry[] Read(byte[] tarBytes) {
        if (tarBytes.Length == 0) {
            return new TarEntry[0];
        }
        if (tarBytes.Length % 512 != 0) {
            throw new ArchiveException("tar archive length must be a multiple of 512 bytes");
        }

        // Build result into a List-like growable buffer. Use byte[]+count
        // pattern; entries grow on demand.
        TarEntry[] buf = new TarEntry[16];
        int count = 0;
        int offset = 0;

        while (offset + 512 <= tarBytes.Length) {
            // EOF marker: two consecutive zero blocks → stop.
            if (_IsZeroBlock(tarBytes, offset)) {
                break;
            }

            // Parse header fields.
            string name = _ReadStr(tarBytes, offset, 100);
            int mode    = _ReadOctal(tarBytes, offset + 100, 8);
            long size   = _ReadOctalLong(tarBytes, offset + 124, 12);
            byte typeflag = tarBytes[offset + 156];
            string prefix = _ReadStr(tarBytes, offset + 345, 155);

            // ustar magic check is informational; we accept any header.

            // Glue prefix + "/" + name (ustar spec) when prefix non-empty.
            string fullName;
            if (prefix.Length > 0) {
                fullName = prefix + "/" + name;
            } else {
                fullName = name;
            }

            offset = offset + 512;

            // Only regular files supported in v0.
            byte zero = 48;  // ASCII '0'
            byte nul  = 0;
            if (typeflag != zero && typeflag != nul) {
                // Skip non-regular entries' payload; throw on archive
                // close if any were present? v0: throw immediately so
                // callers know the archive has unsupported content.
                throw new ArchiveException("unsupported tar entry typeflag at offset " + offset.ToString());
            }

            // Read payload + skip padding to next 512-byte boundary.
            byte[] content = new byte[(int)size];
            int i = 0;
            while (i < (int)size) {
                content[i] = tarBytes[offset + i];
                i = i + 1;
            }
            long padded = ((size + 511) / 512) * 512;
            offset = offset + (int)padded;

            // Grow buf if needed
            if (count >= buf.Length) {
                TarEntry[] bigger = new TarEntry[buf.Length * 2];
                int j = 0;
                while (j < count) {
                    bigger[j] = buf[j];
                    j = j + 1;
                }
                buf = bigger;
            }
            buf[count] = new TarEntry(fullName, content, mode);
            count = count + 1;
        }

        TarEntry[] result = new TarEntry[count];
        int k = 0;
        while (k < count) {
            result[k] = buf[k];
            k = k + 1;
        }
        return result;
    }

    // ── Write ───────────────────────────────────────────────────────

    public static byte[] Write(TarEntry[] entries) {
        // Compute total output size: 512 header + padded payload per
        // entry + 2*512 zero trailer.
        long total = 0;
        int idx = 0;
        while (idx < entries.Length) {
            long size = (long)entries[idx].Content.Length;
            long padded = ((size + 511) / 512) * 512;
            total = total + 512 + padded;
            idx = idx + 1;
        }
        total = total + 1024;  // 2 × 512 zero trailer

        byte[] result = new byte[(int)total];
        int off = 0;
        idx = 0;
        while (idx < entries.Length) {
            TarEntry e = entries[idx];
            _WriteHeader(result, off, e);
            off = off + 512;
            int i = 0;
            while (i < e.Content.Length) {
                result[off + i] = e.Content[i];
                i = i + 1;
            }
            long padded = (((long)e.Content.Length + 511) / 512) * 512;
            off = off + (int)padded;
            idx = idx + 1;
        }
        // 1024 zero bytes are already 0 from new byte[].
        return result;
    }

    // ── WriteStream (add-tar-write-stream 2026-05-27) ───────────────
    //
    // Streaming variant of `Write`: serialise entries directly to a
    // Stream instead of returning a byte[]. Symmetric with
    // `ExtractStream` on the read side. Working set is one 512-byte
    // header buffer + the current entry's content; the dest Stream
    // can forward to a Gzip/Zstd encoder for `.tar.gz` / `.tar.zst`
    // pipelines without ever materialising the whole archive:
    //
    //   var outFs = new FileStream(tgzPath, FileMode.Write);
    //   try {
    //       Stream gz = Gzip.WrapWrite(outFs);
    //       try { Tar.WriteStream(entries, gz); }
    //       finally { gz.Close(); }  // flushes gzip footer
    //   } finally { outFs.Close(); }
    //
    // Does NOT close `dest` — caller owns its lifecycle (matches
    // CompressionEncoderStream / StreamWriter convention).
    public static void WriteStream(TarEntry[] entries, Stream dest) {
        byte[] header = new byte[512];
        byte[] pad    = new byte[512];  // reusable scratch for tail-padding
        int idx = 0;
        while (idx < entries.Length) {
            TarEntry e = entries[idx];
            // Zero the header buffer (reused across entries).
            int z = 0;
            while (z < 512) { header[z] = (byte)0; z = z + 1; }
            _WriteHeader(header, 0, e);
            dest.Write(header, 0, 512);
            if (e.Content.Length > 0) {
                dest.Write(e.Content, 0, e.Content.Length);
            }
            // Pad to next 512-byte boundary.
            int padBytes = (int)(((long)e.Content.Length + 511L) / 512L * 512L
                                  - (long)e.Content.Length);
            if (padBytes > 0) {
                // pad[] is zero-initialised from `new byte[512]` and we
                // never write into it, so it stays all-zero.
                dest.Write(pad, 0, padBytes);
            }
            idx = idx + 1;
        }
        // Two 512-byte zero blocks mark end-of-archive (POSIX convention).
        dest.Write(pad, 0, 512);
        dest.Write(pad, 0, 512);
    }

    // ── Extract (add-tar-extract-to 2026-05-26) ─────────────────────
    //
    // Decode `tarBytes`, write every regular-file entry to `destDir`
    // (creating intermediate directories as needed), and set the
    // executable bit when any of u/g/o exec bits are set in the entry
    // mode. Returns the number of entries extracted.
    //
    // 用于把 bash `tar -xzf foo.tar.gz -C dest` 移植成 z42：
    //   byte[] tarBytes = Gzip.Decompress(File.ReadAllBytes(tgzPath));
    //   int n = Tar.ExtractTo(tarBytes, destDir);
    //
    // 安全：拒绝 entry name 含 `..` segment 或绝对路径（Zip Slip CVE
    // 防御）。不安全模式留 backlog；当前所有调用都走严格路径。

    public static int ExtractTo(byte[] tarBytes, string destDir) {
        Directory.Create(destDir);
        TarEntry[] entries = Tar.Read(tarBytes);
        int written = 0;
        int i = 0;
        while (i < entries.Length) {
            TarEntry e = entries[i];
            _EnsureSafeEntryName(e.Name);
            string targetPath = Path.Join(destDir, e.Name);
            string parent     = Path.GetDirectoryName(targetPath);
            if (parent.Length > 0) {
                Directory.Create(parent);
            }
            _WriteBytesToFile(targetPath, e.Content);
            if ((e.Mode & 0x49) != 0) {  // 0o111 = 0x49 — any of u/g/o exec bit
                File.MakeExecutable(targetPath);
            }
            written = written + 1;
            i = i + 1;
        }
        return written;
    }

    private static void _WriteBytesToFile(string path, byte[] content) {
        FileStream fs = new FileStream(path, FileMode.Write);
        try {
            fs.WriteAllBytes(content);
        } finally {
            fs.Close();
        }
    }

    // ── ExtractStream (add-tar-extract-stream 2026-05-27) ───────────────
    //
    // Streaming variant of ExtractTo: reads tar blocks from `src` 512
    // bytes at a time instead of requiring the entire archive in memory.
    // Pairs naturally with the now-streaming `Gzip.WrapRead` for
    // `.tar.gz` extraction:
    //
    //   FileStream tgz = new FileStream(path, FileMode.Read);
    //   try { Tar.ExtractStream(Gzip.WrapRead(tgz), destDir); }
    //   finally { tgz.Close(); }
    //
    // Avoids the ~250 MB peak working set that `ExtractTo` produces on
    // 30 MB tarballs (whole archive + per-entry Content byte[] all live
    // at once).
    //
    // Same Zip-Slip protection as `ExtractTo`. Returns number of entries
    // extracted. Throws `ArchiveException` on truncated input / unsupported
    // typeflag, `IOException` on stream read failure.
    public static int ExtractStream(Stream src, string destDir) {
        Directory.Create(destDir);
        byte[] header = new byte[512];
        byte[] dataBuf = new byte[512];
        int written = 0;
        while (true) {
            int n = _ReadFull(src, header, 0, 512);
            if (n == 0) {
                // Premature EOF (no zero-trailer). Some tarballs omit
                // the explicit end marker; treat as clean stop.
                break;
            }
            if (n < 512) {
                throw new ArchiveException("tar: truncated header (got "
                    + n.ToString() + " of 512 bytes)");
            }
            // EOF marker: zero block. Don't strictly require a second
            // zero block since some writers (busybox) emit only one.
            if (_IsZeroBlock(header, 0)) {
                break;
            }

            string name    = _ReadStr(header, 0, 100);
            int    mode    = _ReadOctal(header, 100, 8);
            long   size    = _ReadOctalLong(header, 124, 12);
            byte   typeflag = header[156];
            string prefix  = _ReadStr(header, 345, 155);

            string fullName;
            if (prefix.Length > 0) { fullName = prefix + "/" + name; }
            else { fullName = name; }

            byte zero = 48;  // '0'
            byte nul  = 0;
            if (typeflag != zero && typeflag != nul) {
                throw new ArchiveException(
                    "tar: unsupported entry typeflag for " + fullName);
            }
            _EnsureSafeEntryName(fullName);

            string targetPath = Path.Join(destDir, fullName);
            string parent     = Path.GetDirectoryName(targetPath);
            if (parent.Length > 0) {
                Directory.Create(parent);
            }

            // Stream the file contents in 512-byte chunks. Skip trailing
            // padding bytes (tar pads to the next 512 boundary).
            FileStream outFs = new FileStream(targetPath, FileMode.Write);
            try {
                long remaining = size;
                while (remaining > 0L) {
                    int chunk = remaining > 512L ? 512 : (int)remaining;
                    int got = _ReadFull(src, dataBuf, 0, chunk);
                    if (got < chunk) {
                        throw new ArchiveException(
                            "tar: truncated entry '" + fullName + "' (wanted "
                            + chunk.ToString() + " more bytes, got "
                            + got.ToString() + ")");
                    }
                    outFs.Write(dataBuf, 0, chunk);
                    remaining = remaining - (long)chunk;
                }
                // Consume padding to next 512 boundary.
                long padded = ((size + 511L) / 512L) * 512L;
                long padBytes = padded - size;
                if (padBytes > 0L) {
                    _ReadFull(src, dataBuf, 0, (int)padBytes);
                }
            } finally {
                outFs.Close();
            }
            if ((mode & 0x49) != 0) {  // any exec bit
                File.MakeExecutable(targetPath);
            }
            written = written + 1;
        }
        return written;
    }

    /// Read exactly `count` bytes from `s` into `buf[offset..]`, looping
    /// over short reads. Returns the number actually read (less than
    /// count only at EOF). Mirrors `Stream.ReadExactly` semantics but
    /// returns the count instead of throwing on EOF — caller decides if
    /// short = error or clean stop.
    private static int _ReadFull(Stream s, byte[] buf, int offset, int count) {
        int total = 0;
        while (total < count) {
            int n = s.Read(buf, offset + total, count - total);
            if (n <= 0) break;
            total = total + n;
        }
        return total;
    }

    // Zip-Slip 防御：entry name 不允许绝对路径 / `..` segment。
    // 通过把 path 按 `/` 拆开逐段检查，避免 `..` 偷出 destDir。
    private static void _EnsureSafeEntryName(string name) {
        if (name.Length == 0) {
            throw new ArchiveException("tar entry has empty name");
        }
        if (name.CharAt(0) == '/') {
            throw new ArchiveException("tar entry name is absolute path: " + name);
        }
        string[] segs = name.Split("/");
        int i = 0;
        while (i < segs.Length) {
            if (segs[i] == "..") {
                throw new ArchiveException("tar entry name contains '..' segment: " + name);
            }
            i = i + 1;
        }
    }

    // ── Helpers ─────────────────────────────────────────────────────

    private static bool _IsZeroBlock(byte[] bytes, int offset) {
        int i = 0;
        while (i < 512) {
            if (bytes[offset + i] != 0) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }

    private static string _ReadStr(byte[] bytes, int offset, int maxLen) {
        // Read until NUL or end of field.
        int end = 0;
        while (end < maxLen) {
            if (bytes[offset + end] == 0) {
                break;
            }
            end = end + 1;
        }
        // add-tar-extract-to (2026-05-26): `new string(chars)` returned Null
        // for empty char arrays in z42; switch to documented `String.FromChars`
        // intrinsic. Affected all-NUL prefix fields (typical ustar headers).
        char[] chars = new char[end];
        int i = 0;
        while (i < end) {
            chars[i] = (char)bytes[offset + i];
            i = i + 1;
        }
        return String.FromChars(chars);
    }

    private static int _ReadOctal(byte[] bytes, int offset, int len) {
        // Octal ASCII digits in a fixed-width field, possibly NUL- or
        // space-terminated.
        int result = 0;
        int i = 0;
        while (i < len) {
            byte b = bytes[offset + i];
            // ASCII '0' = 48, '7' = 55
            if (b >= 48 && b <= 55) {
                result = result * 8 + (int)(b - 48);
            } else {
                break;
            }
            i = i + 1;
        }
        return result;
    }

    private static long _ReadOctalLong(byte[] bytes, int offset, int len) {
        long result = 0L;
        int i = 0;
        while (i < len) {
            byte b = bytes[offset + i];
            if (b >= 48 && b <= 55) {
                result = result * 8L + (long)(b - 48);
            } else {
                break;
            }
            i = i + 1;
        }
        return result;
    }

    private static void _WriteOctal(byte[] bytes, int offset, int len, long value) {
        // Write value as left-zero-padded octal digits + trailing NUL.
        int writePos = offset + len - 1;
        bytes[writePos] = 0;
        writePos = writePos - 1;
        long v = value;
        while (writePos >= offset) {
            int digit = (int)(v & 7L);
            bytes[writePos] = (byte)(48 + digit);
            v = v >> 3;
            writePos = writePos - 1;
        }
    }

    private static void _WriteStr(byte[] bytes, int offset, int maxLen, string s) {
        int n = s.Length;
        if (n > maxLen) {
            n = maxLen;
        }
        int i = 0;
        while (i < n) {
            bytes[offset + i] = (byte)s.CharAt(i);
            i = i + 1;
        }
    }

    private static void _WriteHeader(byte[] bytes, int offset, TarEntry e) {
        _WriteStr(bytes, offset, 100, e.Name);
        _WriteOctal(bytes, offset + 100, 8, (long)e.Mode);
        _WriteOctal(bytes, offset + 108, 8, 0L);    // uid
        _WriteOctal(bytes, offset + 116, 8, 0L);    // gid
        _WriteOctal(bytes, offset + 124, 12, (long)e.Content.Length);
        _WriteOctal(bytes, offset + 136, 12, 0L);   // mtime
        // checksum field (offset 148, 8 bytes): fill with spaces during
        // checksum computation, write the actual checksum afterward.
        int i = 0;
        while (i < 8) {
            bytes[offset + 148 + i] = 32;  // ASCII space
            i = i + 1;
        }
        bytes[offset + 156] = 48;  // typeflag '0' = regular file
        // ustar magic + version (offset 257..264)
        _WriteStr(bytes, offset + 257, 6, "ustar");
        bytes[offset + 263] = 48;  // version '0'
        bytes[offset + 264] = 48;  // version '0'
        // Compute header checksum: sum of all 512 bytes (with checksum
        // field filled with spaces) as a 6-digit octal + NUL + space.
        long sum = 0L;
        int k = 0;
        while (k < 512) {
            sum = sum + (long)bytes[offset + k];
            k = k + 1;
        }
        // Write checksum field: 6 octal digits + NUL + space.
        _WriteOctal(bytes, offset + 148, 7, sum);
        bytes[offset + 154] = 0;   // NUL between digits and space
        bytes[offset + 155] = 32;  // trailing space (POSIX convention)
    }
}
