namespace Std.Compression;

using Std;
using Std.IO;

// add-z42-compression (2026-05-22): raw DEFLATE (RFC 1951) — no
// framing, no checksum. Used by Zip entry payloads and by callers who
// need the raw stream (e.g. embedding in custom binary formats).
//
// refactor-compression-stream-on-iostream (2026-05-24): see Gzip.z42
// for the API shape rationale.

public static class Deflate {
    [Native(lib = "z42_compression", entry = "__deflate_compress")]
    private static extern byte[] _CompressRaw(byte[] data, int level, int mode);

    [Native(lib = "z42_compression", entry = "__deflate_decompress")]
    private static extern byte[] _DecompressRaw(byte[] data, int mode);

    public static byte[] Compress(byte[] data) {
        return _CompressRaw(data, Compression.Default, AlgoId.DeflateRaw);
    }

    public static byte[] Compress(byte[] data, int level) {
        return _CompressRaw(data, level, AlgoId.DeflateRaw);
    }

    public static byte[] Decompress(byte[] data) {
        return _DecompressRaw(data, AlgoId.DeflateRaw);
    }

    public static Stream WrapWrite(Stream dest) {
        return new CompressionEncoderStream(dest, AlgoId.DeflateRaw, Compression.Default);
    }

    public static Stream WrapWrite(Stream dest, int level) {
        return new CompressionEncoderStream(dest, AlgoId.DeflateRaw, level);
    }

    public static Stream WrapRead(Stream src) {
        return new CompressionDecoderStream(src, AlgoId.DeflateRaw);
    }
}
