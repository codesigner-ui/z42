// add-stream-overloads-to-format-parsers (2026-05-24): Stream-based
// YAML parse / write overloads on YamlValue. Tests held back from
// the original spec landing pending the char-comparison VM fix
// (fix-char-comparison-bail, 2026-05-24); now active.
namespace Z42YamlStreamTests;

using Std;
using Std.Test;
using Std.IO;
using Std.Encoding;
using Std.Yaml;

byte[] _utf8(string s) { return Encoding.GetUtf8().GetBytes(s); }
string _decode(byte[] b) { return Encoding.GetUtf8().GetString(b); }

[Test]
void test_parse_from_memory_stream() {
    MemoryStream ms = new MemoryStream(_utf8("name: z42\nversion: 42\n"));
    YamlValue v = YamlValue.ParseStream(ms);
    Assert.True(v.IsMapping());
    Assert.Equal("z42", v.Get("name").AsString());
    Assert.Equal(42L,   v.Get("version").AsInt());
}

[Test]
void test_parse_from_file_stream() {
    string path = File.CreateTempFile("z42_yaml_stream_", ".yaml");
    try {
        File.WriteAllText(path, "list:\n  - one\n  - two\n  - three\n");
        FileStream fs = new FileStream(path);
        try {
            YamlValue v = YamlValue.ParseStream(fs);
            YamlValue list = v.Get("list");
            Assert.True(list.IsSequence());
            Assert.Equal(3, list.Count());
            Assert.Equal("two", list.At(1).AsString());
        } finally {
            fs.Close();
        }
    } finally {
        File.Delete(path);
    }
}

[Test]
void test_write_to_memory_stream() {
    YamlValue root = YamlValue.OfMapping();
    root.Set("k", YamlValue.OfString("v"));
    root.Set("n", YamlValue.OfInt(7L));
    MemoryStream ms = new MemoryStream();
    YamlValue.WriteTo(ms, root);
    string out_ = _decode(ms.ToArray());
    Assert.True(out_.Length > 0);
    YamlValue back = YamlValue.Parse(out_);
    Assert.Equal("v", back.Get("k").AsString());
    Assert.Equal(7L,  back.Get("n").AsInt());
}

[Test]
void test_round_trip_filestream() {
    string path = File.CreateTempFile("z42_yaml_rt_", ".yaml");
    try {
        YamlValue original = YamlValue.OfMapping();
        original.Set("name",  YamlValue.OfString("project"));
        original.Set("count", YamlValue.OfInt(3L));

        FileStream wfs = new FileStream(path, FileMode.Write);
        try {
            YamlValue.WriteTo(wfs, original);
        } finally {
            wfs.Close();
        }
        FileStream rfs = new FileStream(path);
        try {
            YamlValue back = YamlValue.ParseStream(rfs);
            Assert.Equal("project", back.Get("name").AsString());
            Assert.Equal(3L,        back.Get("count").AsInt());
        } finally {
            rfs.Close();
        }
    } finally {
        File.Delete(path);
    }
}
