// add-z42-yaml (2026-05-24): malformed input → YamlException.
namespace Z42YamlParseErrorsTests;

using Std;
using Std.Test;
using Std.Yaml;

[Test]
void test_tab_in_indentation_throws() {
    bool caught = false;
    try {
        // 1 tab + content
        Yaml.Parse("a:\n\tb: 1\n");
    } catch (YamlException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_unterminated_double_quote_throws() {
    bool caught = false;
    try {
        Yaml.Parse("\"no end");
    } catch (YamlException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_unterminated_single_quote_throws() {
    bool caught = false;
    try {
        Yaml.Parse("'no end");
    } catch (YamlException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_unterminated_flow_sequence_throws() {
    bool caught = false;
    try {
        Yaml.Parse("[1, 2, 3");
    } catch (YamlException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_unterminated_flow_mapping_throws() {
    bool caught = false;
    try {
        Yaml.Parse("{a: 1");
    } catch (YamlException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_duplicate_mapping_key_throws() {
    bool caught = false;
    try {
        Yaml.Parse("name: alice\nname: bob\n");
    } catch (YamlException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_unknown_escape_in_double_quote_throws() {
    bool caught = false;
    try {
        Yaml.Parse("\"\\q\"");
    } catch (YamlException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_accessor_type_mismatch_throws() {
    YamlValue v = Yaml.Parse("42");
    bool caught = false;
    try {
        v.AsString();  // it's an int, not a string
    } catch (YamlException e) {
        caught = true;
    }
    Assert.True(caught);
}

[Test]
void test_missing_key_throws() {
    YamlValue v = Yaml.Parse("name: alice\n");
    bool caught = false;
    try {
        v.Get("nonexistent");
    } catch (YamlException e) {
        caught = true;
    }
    Assert.True(caught);
}
