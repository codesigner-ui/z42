namespace Std.Yaml;

using Std;
using Std.Text;

// add-z42-yaml (2026-05-24): YAML 1.2 subset parser.
//
// Algorithm: single-pass recursive descent. Each block recursion tracks
// the required parent-indent; child lines must indent strictly more.
// Lines are processed in order; comments and blank lines are skipped at
// the line boundary so they never appear mid-token.
//
// Supported:
//   * Block mapping        key: value
//   * Block sequence       - item
//   * Flow mapping         { key: value, ... }
//   * Flow sequence        [ value, ... ]
//   * Scalars              plain / 'single' / "double" with \n \t \" \\ \uXXXX escapes
//   * null token           ~ or empty value
//   * bool tokens          true / false (YAML 1.2 — no yes/on/off Norway-problem)
//   * int / float          decimal (signed, exponent); hex 0xFF / octal 0o755
//   * Comments             # …  (line-end and standalone)
//   * Document markers     --- (start) / ... (end); multi-doc via ParseAll
//   * Anchors / aliases    &name / *name with per-doc scope + DeepClone
//   * Tags                 !!str / !!int / !!float / !!bool / !!null
//   * Block scalars        | literal / > folded with -/+ chomping
//   * Timestamps           ISO 8601 prefix → YamlValue kind 7
//   * Merge keys           <<: *anchor  (YAML 1.1 extension)
//
// Not supported (raise YamlException → see yaml.md Deferred):
//   complex keys (`? key` syntax) / YAML 1.1 yes-no-on-off bool quirks.

public sealed class YamlParser {
    private string _src;
    private int    _pos;
    private int    _line;
    private int    _col;

    // Anchor table (per document — reset between docs in ParseAllDocuments).
    // Parallel arrays: anchor name → value. add-yaml-anchors-aliases (2026-05-25).
    private string[]    _anchorNames;
    private YamlValue[] _anchorValues;
    private int         _anchorCount;

    // add-yaml-merge-keys (2026-06-01): the most recent mapping/flow key was
    // produced from a quoted string literal (`"<<"` / `'<<'`). The merge-key
    // dispatcher only fires on an unquoted plain `<<`, so quoted keys remain
    // literal — the documented escape hatch for users who genuinely need
    // `<<` as data. Set by _ParseMappingKey / _ParseFlowKey on every call.
    private bool _lastKeyQuoted;

    // add-yaml-merge-keys (2026-06-01): per-mapping table of keys that were
    // inserted via a `<<:` merge rather than an explicit entry. Used by the
    // mapping parsers so an explicit key can overwrite a merged value,
    // while explicit-vs-explicit collisions still throw. Saved + restored
    // around any recursive descent into a nested mapping. z42's `ref`
    // modifier is compile-time only at runtime (parameter-modifiers.md),
    // so a per-parser field with save/restore is cleaner than tuple
    // returns or array re-assignment across helpers.
    private string[] _mergedKeys;
    private int      _mergedCount;

    public YamlParser(string src) {
        this._src  = src;
        this._pos  = 0;
        this._line = 1;
        this._col  = 1;
        this._anchorNames  = new string[4];
        this._anchorValues = new YamlValue[4];
        this._anchorCount  = 0;
        this._lastKeyQuoted = false;
        this._mergedKeys   = new string[8];
        this._mergedCount  = 0;
    }

    // ── Public entry ─────────────────────────────────────────────────────

    public YamlValue ParseDocument() {
        YamlValue root = this._ParseOneDocBody();
        // Anything left over (other than trailing `...` + blanks) is either a
        // second document or trailing junk — strict single-doc mode rejects
        // both with a hint to use `ParseAllDocuments` for multi-doc input.
        this._SkipBlankLines();
        if (this._pos < this._src.Length && this._PeekLineIs("...")) {
            this._ConsumeRestOfLine();
            this._SkipBlankLines();
        }
        if (this._pos < this._src.Length) {
            throw this._Err("unexpected trailing content after document (use ParseAllDocuments for multi-doc YAML)");
        }
        return root;
    }

    /// Multi-document entry: returns every `---`-separated document in
    /// order. Empty / blank input → empty array. add-yaml-multi-doc (2026-05-25).
    public YamlValue[] ParseAllDocuments() {
        YamlValue[] docs = new YamlValue[8];
        int count = 0;
        while (true) {
            this._SkipBlankLines();
            if (this._pos >= this._src.Length) { break; }
            YamlValue doc = this._ParseOneDocBody();
            // Grow if needed.
            if (count == docs.Length) {
                YamlValue[] bigger = new YamlValue[docs.Length * 2];
                int i = 0;
                while (i < count) {
                    bigger[i] = docs[i];
                    i = i + 1;
                }
                docs = bigger;
            }
            docs[count] = doc;
            count = count + 1;
            // Allow optional `...` end-of-document marker between docs.
            this._SkipBlankLines();
            if (this._pos < this._src.Length && this._PeekLineIs("...")) {
                this._ConsumeRestOfLine();
            }
        }
        // Trim to actual count.
        YamlValue[] result = new YamlValue[count];
        int j = 0;
        while (j < count) {
            result[j] = docs[j];
            j = j + 1;
        }
        return result;
    }

    /// Parse exactly one document body (no strict trailing-content check).
    /// Stops at EOF or a `---` / `...` document boundary, leaving the marker
    /// unconsumed so the caller can decide what to do with it.
    private YamlValue _ParseOneDocBody() {
        // Reset anchor table — anchors are scoped per-document.
        this._anchorCount = 0;
        this._SkipBlankLines();
        if (this._pos >= this._src.Length) {
            return YamlValue.OfNull();
        }
        // Optional document-start marker — consumed here, opens this doc.
        if (this._PeekLineIs("---")) {
            this._ConsumeRestOfLine();
            this._SkipBlankLines();
            // Empty doc (immediately another boundary or EOF).
            if (this._pos >= this._src.Length || this._IsDocBoundary()) {
                return YamlValue.OfNull();
            }
        }
        return this._ParseBlockValue(0);
    }

    /// True if the current line is a document-boundary marker (`---` or `...`).
    /// Used by block parsers to break out cleanly so root-level markers don't
    /// get mis-parsed as plain scalars / sequence dashes.
    private bool _IsDocBoundary() {
        return this._PeekLineIs("---") || this._PeekLineIs("...");
    }

    // ── Block value: dispatch on first non-WS char ──────────────────────
    //
    // `requiredIndent` is the indent the next non-blank line must have to
    // belong to this block. Returns the parsed YamlValue; on return,
    // `_pos` sits at the start of the line *after* the block (or EOF).

    private YamlValue _ParseBlockValue(int requiredIndent) {
        this._SkipBlankLines();
        if (this._pos >= this._src.Length) {
            return YamlValue.OfNull();
        }
        // Doc boundary `---` / `...` at root-indent terminates the block —
        // returning null lets the multi-doc loop pick up the boundary cleanly.
        if (this._IsDocBoundary()) {
            return YamlValue.OfNull();
        }
        int actualIndent = this._CurrentLineIndent();
        if (actualIndent < requiredIndent) {
            // Block is empty.
            return YamlValue.OfNull();
        }
        // Inspect first non-WS char to decide block flavour.
        int lineStart = this._pos;
        int contentPos = lineStart + actualIndent;
        if (contentPos >= this._src.Length) {
            return YamlValue.OfNull();
        }
        char first = this._src.CharAt(contentPos);

        // Block sequence: line starts with `- ` (or just `-` at EOL).
        if (first == '-') {
            // Peek to confirm it's a real sequence dash, not start of a
            // negative number scalar (e.g. `-42`). It's a sequence dash
            // iff the next char is whitespace or EOL.
            if (contentPos + 1 >= this._src.Length
                || this._src.CharAt(contentPos + 1) == ' '
                || this._src.CharAt(contentPos + 1) == '\n'
                || this._src.CharAt(contentPos + 1) == '\r') {
                return this._ParseBlockSequence(actualIndent);
            }
        }

        // Flow style — single-line `[…]` or `{…}` value at this indent.
        if (first == '[' || first == '{') {
            this._pos = contentPos;
            this._col = actualIndent + 1;
            YamlValue v = this._ParseFlow();
            this._SkipInlineSpacesAndOptionalComment();
            this._ConsumeRestOfLine();
            return v;
        }

        // Otherwise it's either a block mapping (`key: …`) or a plain
        // scalar that takes up the line. Distinguish by scanning the
        // current line for an unquoted `:` followed by space / EOL.
        if (this._LineHasMappingColon(contentPos)) {
            return this._ParseBlockMapping(actualIndent);
        }

        // Plain scalar (or quoted string) on a single line.
        this._pos = contentPos;
        this._col = actualIndent + 1;
        YamlValue v = this._ParseBlockScalarValue();
        this._ConsumeRestOfLine();
        return v;
    }

    // ── Block mapping ────────────────────────────────────────────────────

    private YamlValue _ParseBlockMapping(int indent) {
        YamlValue m = YamlValue.OfMapping();
        // add-yaml-merge-keys (2026-06-01): save outer mapping's merged-key
        // table so nested mappings don't clobber it; reset for this
        // mapping; restore on every return path.
        string[] savedMergedKeys = this._mergedKeys;
        int      savedMergedCount = this._mergedCount;
        this._mergedKeys  = new string[8];
        this._mergedCount = 0;
        YamlValue result = this._ParseBlockMappingBody(m, indent);
        this._mergedKeys  = savedMergedKeys;
        this._mergedCount = savedMergedCount;
        return result;
    }

    private YamlValue _ParseBlockMappingBody(YamlValue m, int indent) {
        while (true) {
            this._SkipBlankLines();
            if (this._pos >= this._src.Length) { break; }
            // Doc boundary terminates the mapping (multi-doc support).
            if (this._IsDocBoundary()) { break; }
            int lineIndent = this._CurrentLineIndent();
            if (lineIndent < indent) { break; }
            if (lineIndent > indent) {
                // Over-indented child line at the mapping level is an error
                // — it should have been absorbed by the previous value's
                // recursive descent.
                throw this._Err("unexpected indent at mapping level (expected "
                    + indent.ToString() + ", got " + lineIndent.ToString() + ")");
            }
            int contentPos = this._pos + indent;
            // Refuse to parse a `- ` sequence entry inline with a mapping.
            char first = this._src.CharAt(contentPos);
            if (first == '-' && (contentPos + 1 >= this._src.Length
                || this._src.CharAt(contentPos + 1) == ' '
                || this._src.CharAt(contentPos + 1) == '\n'
                || this._src.CharAt(contentPos + 1) == '\r')) {
                break;  // sibling block sequence shouldn't happen at exact mapping indent
            }
            this._pos = contentPos;
            this._col = indent + 1;

            // Parse key (plain or quoted scalar before unquoted `:`).
            string key = this._ParseMappingKey();
            bool keyQuoted = this._lastKeyQuoted;
            this._SkipInlineSpaces();
            if (this._pos >= this._src.Length || this._src.CharAt(this._pos) != ':') {
                throw this._Err("expected ':' after mapping key '" + key + "'");
            }
            this._pos = this._pos + 1;  // consume ':'
            this._col = this._col + 1;
            this._SkipInlineSpaces();

            // What follows: inline value on this line, or block value on next.
            YamlValue val;
            if (this._pos >= this._src.Length
                || this._src.CharAt(this._pos) == '\n'
                || this._src.CharAt(this._pos) == '\r'
                || (this._src.CharAt(this._pos) == '#' && this._IsCommentStart())) {
                // Empty inline value → check next line.
                this._ConsumeRestOfLine();
                this._SkipBlankLines();
                if (this._pos >= this._src.Length) {
                    val = YamlValue.OfNull();
                } else {
                    int nextIndent = this._CurrentLineIndent();
                    if (nextIndent > indent) {
                        val = this._ParseBlockValue(nextIndent);
                    } else if (nextIndent == indent
                            && nextIndent < this._src.Length - this._pos
                            && this._src.CharAt(this._pos + nextIndent) == '-') {
                        // fix-yaml-quoted-strings (2026-05-24): YAML allows a
                        // mapping value to be a block sequence at the SAME
                        // indent as the mapping key — `key:\n- item`. The
                        // YamlWriter emits sequences this way (see writer
                        // line 110 "sequence keeps mapping's indent for -").
                        // Pre-fix, we treated it as `key: null` then bailed
                        // on the unexpected `-` as trailing content.
                        // Confirm it's a real sequence dash (followed by WS
                        // or EOL) before committing.
                        int dashNext = this._pos + nextIndent + 1;
                        bool isDash = dashNext >= this._src.Length
                            || this._src.CharAt(dashNext) == ' '
                            || this._src.CharAt(dashNext) == '\n'
                            || this._src.CharAt(dashNext) == '\r';
                        if (isDash) {
                            val = this._ParseBlockSequence(nextIndent);
                        } else {
                            val = YamlValue.OfNull();
                        }
                    } else {
                        val = YamlValue.OfNull();
                    }
                }
            } else if (this._src.CharAt(this._pos) == '[' || this._src.CharAt(this._pos) == '{') {
                val = this._ParseFlow();
                this._SkipInlineSpacesAndOptionalComment();
                this._ConsumeRestOfLine();
            } else {
                // Dispatch precedence: tag → anchor/alias → block scalar → plain.
                YamlValue tagged = this._TryParseTag(indent);
                if (tagged != null) {
                    val = tagged;
                } else {
                    YamlValue anchored = this._TryParseAnchorOrAlias(indent);
                    if (anchored != null) {
                        val = anchored;
                    } else {
                        YamlValue block = this._TryParseBlockScalar(indent);
                        if (block != null) {
                            val = block;
                        } else {
                            val = this._ParseBlockScalarValue();
                            this._ConsumeRestOfLine();
                        }
                    }
                }
            }

            // add-yaml-merge-keys (2026-06-01): unquoted plain `<<` is a
            // merge directive; quoted `"<<"` / `'<<'` keeps its literal
            // string-key meaning (escape hatch).
            if (key == "<<" && !keyQuoted) {
                this._ApplyMerge(m, val);
            } else if (m.ContainsKey(key)) {
                int mi = this._IndexOfMergedKey(key);
                if (mi >= 0) {
                    m.Set(key, val);
                    this._RemoveMergedKeyAt(mi);
                } else {
                    throw this._Err("duplicate mapping key '" + key + "'");
                }
            } else {
                m.Set(key, val);
            }
        }
        return m;
    }

    private string _ParseMappingKey() {
        if (this._pos >= this._src.Length) {
            throw this._Err("expected mapping key, got EOF");
        }
        char c = this._src.CharAt(this._pos);
        if (c == '"') {
            this._lastKeyQuoted = true;
            return this._ParseDoubleQuotedString();
        }
        if (c == '\'') {
            this._lastKeyQuoted = true;
            return this._ParseSingleQuotedString();
        }
        this._lastKeyQuoted = false;
        // Plain key: read until ':' (followed by space or EOL) or EOL.
        int start = this._pos;
        while (this._pos < this._src.Length) {
            char ch = this._src.CharAt(this._pos);
            if (ch == ':') {
                // Mapping key terminator iff next is WS/EOL/EOF.
                if (this._pos + 1 >= this._src.Length
                    || this._src.CharAt(this._pos + 1) == ' '
                    || this._src.CharAt(this._pos + 1) == '\n'
                    || this._src.CharAt(this._pos + 1) == '\r'
                    || this._src.CharAt(this._pos + 1) == '\t') {
                    break;
                }
            }
            if (ch == '\n' || ch == '\r') { break; }
            this._pos = this._pos + 1;
            this._col = this._col + 1;
        }
        if (start == this._pos) {
            throw this._Err("expected mapping key, got empty");
        }
        string raw = this._src.Substring(start, this._pos - start);
        return raw.TrimEnd();
    }

    // ── Block sequence ──────────────────────────────────────────────────

    private YamlValue _ParseBlockSequence(int indent) {
        YamlValue seq = YamlValue.OfSequence();
        while (true) {
            this._SkipBlankLines();
            if (this._pos >= this._src.Length) { break; }
            // Doc boundary terminates the sequence (multi-doc support).
            if (this._IsDocBoundary()) { break; }
            int lineIndent = this._CurrentLineIndent();
            if (lineIndent < indent) { break; }
            if (lineIndent > indent) {
                throw this._Err("unexpected indent at sequence level (expected "
                    + indent.ToString() + ", got " + lineIndent.ToString() + ")");
            }
            int contentPos = this._pos + indent;
            if (contentPos >= this._src.Length || this._src.CharAt(contentPos) != '-') {
                break;
            }
            // Must be a dash followed by WS / EOL.
            if (contentPos + 1 < this._src.Length) {
                char nx = this._src.CharAt(contentPos + 1);
                if (nx != ' ' && nx != '\n' && nx != '\r' && nx != '\t') {
                    break;
                }
            }
            // Consume `- ` (or just `-` at EOL).
            this._pos = contentPos + 1;
            this._col = indent + 2;
            this._SkipInlineSpaces();

            // The "value" starts at this column. It may be:
            //   - inline scalar / flow
            //   - empty (newline immediately) → child block on next line
            //   - inline `key: …` indicating a single-line mapping entry,
            //     where the rest of the mapping continues at deeper indent
            //     under the same `-` (rare — v0 supports inline single
            //     k:v form only, multi-line nested mapping under `- ` is
            //     out of v0 scope; raise an error)
            YamlValue item;
            if (this._pos >= this._src.Length
                || this._src.CharAt(this._pos) == '\n'
                || this._src.CharAt(this._pos) == '\r'
                || (this._src.CharAt(this._pos) == '#' && this._IsCommentStart())) {
                this._ConsumeRestOfLine();
                this._SkipBlankLines();
                if (this._pos >= this._src.Length) {
                    item = YamlValue.OfNull();
                } else {
                    int nextIndent = this._CurrentLineIndent();
                    if (nextIndent > indent) {
                        item = this._ParseBlockValue(nextIndent);
                    } else {
                        item = YamlValue.OfNull();
                    }
                }
            } else if (this._src.CharAt(this._pos) == '[' || this._src.CharAt(this._pos) == '{') {
                item = this._ParseFlow();
                this._SkipInlineSpacesAndOptionalComment();
                this._ConsumeRestOfLine();
            } else {
                // Could be a plain scalar OR an inline `key: value` mapping
                // entry. If the line contains an unquoted `:` followed by
                // WS/EOL, treat as a single-pair inline mapping.
                int probePos = this._pos;
                if (this._LineHasMappingColon(probePos)) {
                    // Inline mapping under `- `. v0: support exactly one
                    // k:v on the same line; deeper nested mapping under
                    // the dash is a v1 case.
                    string key = this._ParseMappingKey();
                    this._SkipInlineSpaces();
                    if (this._pos >= this._src.Length || this._src.CharAt(this._pos) != ':') {
                        throw this._Err("expected ':' in inline mapping under '- '");
                    }
                    this._pos = this._pos + 1;
                    this._col = this._col + 1;
                    this._SkipInlineSpaces();
                    YamlValue val;
                    if (this._pos >= this._src.Length
                        || this._src.CharAt(this._pos) == '\n'
                        || this._src.CharAt(this._pos) == '\r') {
                        val = YamlValue.OfNull();
                    } else if (this._src.CharAt(this._pos) == '[' || this._src.CharAt(this._pos) == '{') {
                        val = this._ParseFlow();
                    } else {
                        val = this._ParseBlockScalarValue();
                    }
                    item = YamlValue.OfMapping();
                    item.Set(key, val);
                    this._ConsumeRestOfLine();
                } else {
                    // Dispatch precedence: tag → anchor/alias → block scalar → plain.
                    YamlValue tagged = this._TryParseTag(indent);
                    if (tagged != null) {
                        item = tagged;
                    } else {
                        YamlValue anchored = this._TryParseAnchorOrAlias(indent);
                        if (anchored != null) {
                            item = anchored;
                        } else {
                            YamlValue block = this._TryParseBlockScalar(indent);
                            if (block != null) {
                                item = block;
                            } else {
                                item = this._ParseBlockScalarValue();
                                this._ConsumeRestOfLine();
                            }
                        }
                    }
                }
            }
            seq.Add(item);
        }
        return seq;
    }

    // ── Flow style ───────────────────────────────────────────────────────

    private YamlValue _ParseFlow() {
        char c = this._src.CharAt(this._pos);
        if (c == '[') { return this._ParseFlowSequence(); }
        if (c == '{') { return this._ParseFlowMapping(); }
        throw this._Err("expected '[' or '{', got '" + c.ToString() + "'");
    }

    private YamlValue _ParseFlowSequence() {
        this._Advance();  // consume '['
        YamlValue seq = YamlValue.OfSequence();
        this._SkipFlowWS();
        if (this._pos < this._src.Length && this._src.CharAt(this._pos) == ']') {
            this._Advance();
            return seq;
        }
        while (true) {
            YamlValue v = this._ParseFlowValue();
            seq.Add(v);
            this._SkipFlowWS();
            if (this._pos >= this._src.Length) {
                throw this._Err("unterminated flow sequence (missing ']')");
            }
            char ch = this._src.CharAt(this._pos);
            if (ch == ',') {
                this._Advance();
                this._SkipFlowWS();
                continue;
            }
            if (ch == ']') {
                this._Advance();
                return seq;
            }
            throw this._Err("expected ',' or ']' in flow sequence, got '" + ch.ToString() + "'");
        }
        return seq;  // unreachable
    }

    private YamlValue _ParseFlowMapping() {
        this._Advance();  // consume '{'
        YamlValue m = YamlValue.OfMapping();
        this._SkipFlowWS();
        if (this._pos < this._src.Length && this._src.CharAt(this._pos) == '}') {
            this._Advance();
            return m;
        }
        // add-yaml-merge-keys (2026-06-01): save outer merged-key table;
        // restore on every return path (mirrors _ParseBlockMapping).
        string[] savedMergedKeys = this._mergedKeys;
        int      savedMergedCount = this._mergedCount;
        this._mergedKeys  = new string[8];
        this._mergedCount = 0;
        YamlValue result = this._ParseFlowMappingBody(m);
        this._mergedKeys  = savedMergedKeys;
        this._mergedCount = savedMergedCount;
        return result;
    }

    private YamlValue _ParseFlowMappingBody(YamlValue m) {
        while (true) {
            string key = this._ParseFlowKey();
            bool keyQuoted = this._lastKeyQuoted;
            this._SkipFlowWS();
            if (this._pos >= this._src.Length || this._src.CharAt(this._pos) != ':') {
                throw this._Err("expected ':' after flow mapping key '" + key + "'");
            }
            this._Advance();
            this._SkipFlowWS();
            YamlValue v = this._ParseFlowValue();
            if (key == "<<" && !keyQuoted) {
                this._ApplyMerge(m, v);
            } else if (m.ContainsKey(key)) {
                int mi = this._IndexOfMergedKey(key);
                if (mi >= 0) {
                    m.Set(key, v);
                    this._RemoveMergedKeyAt(mi);
                } else {
                    throw this._Err("duplicate flow mapping key '" + key + "'");
                }
            } else {
                m.Set(key, v);
            }
            this._SkipFlowWS();
            if (this._pos >= this._src.Length) {
                throw this._Err("unterminated flow mapping (missing '}')");
            }
            char ch = this._src.CharAt(this._pos);
            if (ch == ',') {
                this._Advance();
                this._SkipFlowWS();
                continue;
            }
            if (ch == '}') {
                this._Advance();
                return m;
            }
            throw this._Err("expected ',' or '}' in flow mapping, got '" + ch.ToString() + "'");
        }
        return m;  // unreachable
    }

    private string _ParseFlowKey() {
        if (this._pos >= this._src.Length) {
            throw this._Err("expected flow mapping key, got EOF");
        }
        char c = this._src.CharAt(this._pos);
        if (c == '"') {
            this._lastKeyQuoted = true;
            return this._ParseDoubleQuotedString();
        }
        if (c == '\'') {
            this._lastKeyQuoted = true;
            return this._ParseSingleQuotedString();
        }
        this._lastKeyQuoted = false;
        // Plain flow key: until ':' or ',' or '}' or whitespace
        int start = this._pos;
        while (this._pos < this._src.Length) {
            char ch = this._src.CharAt(this._pos);
            if (ch == ':' || ch == ',' || ch == '}' || ch == ']'
                || ch == '\n' || ch == '\r' || ch == ' ' || ch == '\t') { break; }
            this._Advance();
        }
        if (start == this._pos) {
            throw this._Err("expected flow mapping key, got empty");
        }
        return this._src.Substring(start, this._pos - start);
    }

    private YamlValue _ParseFlowValue() {
        if (this._pos >= this._src.Length) {
            throw this._Err("expected flow value, got EOF");
        }
        char c = this._src.CharAt(this._pos);
        if (c == '[' || c == '{') { return this._ParseFlow(); }
        if (c == '"') { return YamlValue.OfString(this._ParseDoubleQuotedString()); }
        if (c == '\'') { return YamlValue.OfString(this._ParseSingleQuotedString()); }
        // add-yaml-merge-keys (2026-06-01): inline `*alias` inside a flow
        // value. Block contexts already resolve aliases via
        // _TryParseAnchorOrAlias, which also consumes the rest of the line —
        // wrong for flow contexts where the alias is bounded by `,` / `]` /
        // `}`. Here we parse the alias by hand and let the surrounding flow
        // parser handle trailing whitespace via _SkipFlowWS. (`&anchor`
        // declarations in flow context remain a pre-existing gap; add when
        // there's demand.)
        if (c == '*') {
            this._Advance();
            string name = this._ParseAnchorName();
            if (name.Length == 0) {
                throw this._Err("expected anchor name after '*'");
            }
            YamlValue target = this._LookupAnchor(name);
            if (target == null) {
                throw this._Err("undefined anchor: *" + name);
            }
            return target.DeepClone();
        }
        // Plain scalar: until ',' or ']' or '}' or EOL
        int start = this._pos;
        while (this._pos < this._src.Length) {
            char ch = this._src.CharAt(this._pos);
            if (ch == ',' || ch == ']' || ch == '}' || ch == '\n' || ch == '\r') { break; }
            this._Advance();
        }
        string raw = this._src.Substring(start, this._pos - start);
        return this._ParseScalarLiteral(raw.Trim());
    }

    // ── Scalars (quoted strings + plain literal type detection) ─────────

    private string _ParseDoubleQuotedString() {
        this._Advance();  // consume opening "
        StringBuilder sb = new StringBuilder();
        while (this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            if (c == '"') {
                this._Advance();
                return sb.ToString();
            }
            if (c == '\\') {
                this._Advance();
                if (this._pos >= this._src.Length) {
                    throw this._Err("unterminated string escape");
                }
                char esc = this._src.CharAt(this._pos);
                this._Advance();
                if (esc == 'n')  { sb.Append('\n'); }
                else if (esc == 't')  { sb.Append('\t'); }
                else if (esc == 'r')  { sb.Append('\r'); }
                else if (esc == '\\') { sb.Append('\\'); }
                else if (esc == '"')  { sb.Append('"'); }
                else if (esc == '/')  { sb.Append('/'); }
                else if (esc == '0')  { sb.Append((char)0); }
                else if (esc == 'u') {
                    if (this._pos + 4 > this._src.Length) {
                        throw this._Err("incomplete \\uXXXX escape");
                    }
                    string hex = this._src.Substring(this._pos, 4);
                    int code = 0;
                    int hi = 0;
                    while (hi < 4) {
                        char hc = hex.CharAt(hi);
                        int hv;
                        if (hc >= '0' && hc <= '9')      { hv = (int)hc - (int)'0'; }
                        else if (hc >= 'a' && hc <= 'f') { hv = (int)hc - (int)'a' + 10; }
                        else if (hc >= 'A' && hc <= 'F') { hv = (int)hc - (int)'A' + 10; }
                        else { throw this._Err("bad hex in \\uXXXX escape: '" + hc.ToString() + "'"); }
                        code = code * 16 + hv;
                        hi = hi + 1;
                    }
                    this._pos = this._pos + 4;
                    this._col = this._col + 4;
                    sb.Append((char)code);
                } else {
                    throw this._Err("unknown string escape: \\" + esc.ToString());
                }
                continue;
            }
            if (c == '\n') {
                throw this._Err("newline in double-quoted string");
            }
            sb.Append(c);
            this._Advance();
        }
        throw this._Err("unterminated double-quoted string");
    }

    private string _ParseSingleQuotedString() {
        this._Advance();  // consume opening '
        StringBuilder sb = new StringBuilder();
        while (this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            if (c == '\'') {
                // YAML 1.2: '' inside a single-quoted string is a literal '.
                if (this._pos + 1 < this._src.Length && this._src.CharAt(this._pos + 1) == '\'') {
                    sb.Append('\'');
                    this._Advance();
                    this._Advance();
                    continue;
                }
                this._Advance();
                return sb.ToString();
            }
            if (c == '\n') {
                throw this._Err("newline in single-quoted string");
            }
            sb.Append(c);
            this._Advance();
        }
        throw this._Err("unterminated single-quoted string");
    }

    /// fix-yaml-quoted-strings (2026-05-24): single entry point for
    /// "scalar value at the current cursor in block context" — handles
    /// `"..."` / `'...'` quoted strings before falling back to plain
    /// scalar reading + type detection. Pre-fix, block-context scalar
    /// paths (top-level value, mapping value, sequence item) called
    /// `_ConsumeLinePlainScalar` directly which slurped the quotes as
    /// literal characters, then `_ParseScalarLiteral` returned the
    /// raw `"hello"` as a string (with the quotes).
    ///
    /// Caller is responsible for `_ConsumeRestOfLine()` after — this
    /// helper only consumes up to the end of the scalar token.
    private YamlValue _ParseBlockScalarValue() {
        if (this._pos < this._src.Length) {
            char first = this._src.CharAt(this._pos);
            if (first == '"') {
                return YamlValue.OfString(this._ParseDoubleQuotedString());
            }
            if (first == '\'') {
                return YamlValue.OfString(this._ParseSingleQuotedString());
            }
        }
        string raw = this._ConsumeLinePlainScalar();
        return this._ParseScalarLiteral(raw);
    }

    /// Try to parse a YAML tag (`!!str`, `!!int`, etc.) at current position.
    /// Returns the type-coerced YamlValue if a tag was found; null otherwise.
    /// Supports the YAML 1.2 universal type tags `!!str` / `!!int` / `!!float`
    /// / `!!bool` / `!!null`. Unknown / local tags (e.g. `!myTag`) silently
    /// fall back to plain-scalar type inference (z42 v0 has no user tag
    /// registry). add-yaml-tags (2026-05-25).
    private YamlValue _TryParseTag(int parentIndent) {
        if (this._pos >= this._src.Length) { return null; }
        if (this._src.CharAt(this._pos) != '!') { return null; }
        string tag = this._ParseTagName();
        this._SkipInlineSpaces();
        // Parse the following scalar value verbatim (raw text), then coerce.
        YamlValue raw;
        if (this._pos < this._src.Length && this._src.CharAt(this._pos) == '"') {
            raw = YamlValue.OfString(this._ParseDoubleQuotedString());
            this._ConsumeRestOfLine();
        } else if (this._pos < this._src.Length && this._src.CharAt(this._pos) == '\'') {
            raw = YamlValue.OfString(this._ParseSingleQuotedString());
            this._ConsumeRestOfLine();
        } else if (this._pos >= this._src.Length
                || this._src.CharAt(this._pos) == '\n'
                || this._src.CharAt(this._pos) == '\r'
                || (this._src.CharAt(this._pos) == '#' && this._IsCommentStart())) {
            // No inline value after the tag — tag applies to an empty value.
            this._ConsumeRestOfLine();
            raw = YamlValue.OfNull();
        } else if (this._src.CharAt(this._pos) == '[' || this._src.CharAt(this._pos) == '{') {
            // Flow-style value after a tag — coerce only meaningful for
            // collection tags (!!seq/!!map) which are not in v0 scope.
            // Treat as the underlying flow value; tag ignored.
            YamlValue flow = this._ParseFlow();
            this._SkipInlineSpacesAndOptionalComment();
            this._ConsumeRestOfLine();
            return flow;
        } else {
            string lit = this._ConsumeLinePlainScalar();
            raw = YamlValue.OfString(lit);
        }
        return this._ApplyTagCoercion(tag, raw);
    }

    /// Parse a tag handle starting with `!`. Accepts `!`, `!!`, and
    /// `!`/`!!` followed by an identifier (alphanumerics + `_` `-` `.`).
    /// Returns the full handle string including leading `!`(s).
    private string _ParseTagName() {
        int start = this._pos;
        this._Advance();                          // first `!`
        if (this._pos < this._src.Length && this._src.CharAt(this._pos) == '!') {
            this._Advance();                      // optional second `!`
        }
        while (this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            bool ok = (c >= 'a' && c <= 'z')
                || (c >= 'A' && c <= 'Z')
                || (c >= '0' && c <= '9')
                || c == '_' || c == '-' || c == '.';
            if (!ok) { break; }
            this._Advance();
        }
        return this._src.Substring(start, this._pos - start);
    }

    /// Apply a YAML 1.2 universal tag's type coercion to a raw scalar.
    /// Unknown tags fall through to plain-scalar type inference.
    private YamlValue _ApplyTagCoercion(string tag, YamlValue raw) {
        if (tag == "!!str") {
            if (raw.IsNull()) { return YamlValue.OfString(""); }
            return raw;
        }
        if (tag == "!!int") {
            if (raw.IsNull()) { throw this._Err("!!int tag requires a value"); }
            string text = raw.AsString().Trim();
            try { return YamlValue.OfInt(Int64.Parse(text)); }
            catch (Exception e) {
                throw this._Err("!!int: value '" + text + "' is not an integer");
            }
        }
        if (tag == "!!float") {
            if (raw.IsNull()) { throw this._Err("!!float tag requires a value"); }
            string text = raw.AsString().Trim();
            try { return YamlValue.OfFloat(Double.Parse(text)); }
            catch (Exception e) {
                throw this._Err("!!float: value '" + text + "' is not a float");
            }
        }
        if (tag == "!!bool") {
            if (raw.IsNull()) { throw this._Err("!!bool tag requires a value"); }
            string text = raw.AsString().Trim();
            if (text == "true"  || text == "True"  || text == "TRUE")  { return YamlValue.OfBool(true); }
            if (text == "false" || text == "False" || text == "FALSE") { return YamlValue.OfBool(false); }
            throw this._Err("!!bool: value '" + text + "' is not true/false");
        }
        if (tag == "!!null") {
            if (raw.IsNull()) { return raw; }
            string text = raw.AsString().Trim();
            if (text == "" || text == "~" || text == "null") { return YamlValue.OfNull(); }
            throw this._Err("!!null: value '" + text + "' is not empty/~/null");
        }
        // Unknown / local tag — silently ignore, re-run scalar inference on
        // the raw text. z42 v0 doesn't ship a tag registry for user types.
        if (raw.IsNull()) { return raw; }
        string s = raw.AsString();
        return this._ParseScalarLiteral(s.Trim());
    }

    /// Try to parse an anchor declaration (`&name`) or alias reference
    /// (`*name`) at the current position. Returns the resulting YamlValue
    /// if either was found, `null` otherwise. `parentIndent` is the indent
    /// of the line containing the indicator; needed when the anchored value
    /// is a block at deeper indent. add-yaml-anchors-aliases (2026-05-25).
    private YamlValue _TryParseAnchorOrAlias(int parentIndent) {
        if (this._pos >= this._src.Length) { return null; }
        char c = this._src.CharAt(this._pos);
        if (c != '&' && c != '*') { return null; }
        bool isAnchor = (c == '&');
        this._Advance();
        string name = this._ParseAnchorName();
        if (name.Length == 0) {
            throw this._Err(isAnchor
                ? "expected anchor name after '&'"
                : "expected anchor name after '*'");
        }
        if (!isAnchor) {
            // Alias: look up and return a deep clone.
            YamlValue target = this._LookupAnchor(name);
            if (target == null) {
                throw this._Err("undefined anchor: *" + name);
            }
            // Consume trailing whitespace + comment + EOL for the alias line.
            this._SkipInlineSpacesAndOptionalComment();
            this._ConsumeRestOfLine();
            return target.DeepClone();
        }
        // Anchor declaration: parse the value that follows.
        this._SkipInlineSpaces();
        YamlValue val;
        if (this._pos >= this._src.Length
                || this._src.CharAt(this._pos) == '\n'
                || this._src.CharAt(this._pos) == '\r'
                || (this._src.CharAt(this._pos) == '#' && this._IsCommentStart())) {
            // Block value: anchored content is on subsequent indented lines.
            this._ConsumeRestOfLine();
            this._SkipBlankLines();
            if (this._pos >= this._src.Length) {
                val = YamlValue.OfNull();
            } else {
                int nextIndent = this._CurrentLineIndent();
                if (nextIndent > parentIndent) {
                    val = this._ParseBlockValue(nextIndent);
                } else {
                    val = YamlValue.OfNull();
                }
            }
        } else if (this._src.CharAt(this._pos) == '|' || this._src.CharAt(this._pos) == '>') {
            // Block scalar follows the anchor on the same line.
            YamlValue block = this._TryParseBlockScalar(parentIndent);
            val = block != null ? block : YamlValue.OfNull();
        } else if (this._src.CharAt(this._pos) == '[' || this._src.CharAt(this._pos) == '{') {
            val = this._ParseFlow();
            this._SkipInlineSpacesAndOptionalComment();
            this._ConsumeRestOfLine();
        } else {
            val = this._ParseBlockScalarValue();
            this._ConsumeRestOfLine();
        }
        this._RegisterAnchor(name, val);
        return val;
    }

    /// Parse an anchor name starting at `_pos` (after the `&` or `*` sigil).
    /// Accepts alphanumerics + `_` `-` `.` (YAML 1.2 is more permissive but
    /// this covers all common use cases). Stops at whitespace / EOL / flow
    /// indicators.
    private string _ParseAnchorName() {
        int start = this._pos;
        while (this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            bool ok = (c >= 'a' && c <= 'z')
                || (c >= 'A' && c <= 'Z')
                || (c >= '0' && c <= '9')
                || c == '_' || c == '-' || c == '.';
            if (!ok) { break; }
            this._Advance();
        }
        return this._src.Substring(start, this._pos - start);
    }

    private void _RegisterAnchor(string name, YamlValue v) {
        // Overwrite policy: YAML 1.2 allows re-declaring an anchor (later
        // wins for subsequent aliases). Match that behaviour.
        int i = 0;
        while (i < this._anchorCount) {
            if (this._anchorNames[i] == name) {
                this._anchorValues[i] = v;
                return;
            }
            i = i + 1;
        }
        if (this._anchorCount == this._anchorNames.Length) {
            int newCap = this._anchorNames.Length * 2;
            string[]    nk = new string[newCap];
            YamlValue[] nv = new YamlValue[newCap];
            int j = 0;
            while (j < this._anchorCount) {
                nk[j] = this._anchorNames[j];
                nv[j] = this._anchorValues[j];
                j = j + 1;
            }
            this._anchorNames  = nk;
            this._anchorValues = nv;
        }
        this._anchorNames[this._anchorCount]  = name;
        this._anchorValues[this._anchorCount] = v;
        this._anchorCount = this._anchorCount + 1;
    }

    private YamlValue _LookupAnchor(string name) {
        int i = 0;
        while (i < this._anchorCount) {
            if (this._anchorNames[i] == name) {
                return this._anchorValues[i];
            }
            i = i + 1;
        }
        return null;
    }

    // ── Merge keys (`<<: *anchor`) ───────────────────────────────────────
    //
    // add-yaml-merge-keys (2026-06-01): YAML 1.1 merge-key extension
    // (`tag:yaml.org,2002:merge`). Dispatched by _ParseBlockMapping /
    // _ParseFlowMapping when an unquoted plain `<<` key is parsed. The
    // value must resolve to a mapping or a sequence of mappings; each
    // source mapping contributes (k, v.DeepClone()) entries except for
    // keys already present in the destination. Earlier sources override
    // later ones (spec). Explicit keys override merged keys regardless of
    // source position — the parser tracks "this key came from a merge" in
    // `_mergedKeys` and lets an explicit Set() overwrite.
    //
    // _mergedKeys is per-mapping state. Each mapping parser saves the
    // outer state to locals, resets, runs, then restores before return.
    // Recursion via _ParseBlockValue → _ParseBlockMapping / _ParseFlow
    // is safe because the nested parser does its own save/restore.

    /// Merge `mergeVal` into `dst`. `mergeVal` must be a mapping or a
    /// sequence whose every item is a mapping; anything else throws.
    /// For each source mapping (in order), insert every (k, v) for which
    /// `dst` does not already contain `k`, recording `k` in `_mergedKeys`.
    private void _ApplyMerge(YamlValue dst, YamlValue mergeVal) {
        if (mergeVal.IsMapping()) {
            this._MergeOneSource(dst, mergeVal);
            return;
        }
        if (mergeVal.IsSequence()) {
            int n = mergeVal.Length();
            int i = 0;
            while (i < n) {
                YamlValue item = mergeVal.At(i);
                if (!item.IsMapping()) {
                    throw this._Err("merge key '<<' sequence item must be a mapping, got " + item.KindName());
                }
                this._MergeOneSource(dst, item);
                i = i + 1;
            }
            return;
        }
        throw this._Err("merge key '<<' value must be a mapping or sequence of mappings, got " + mergeVal.KindName());
    }

    private void _MergeOneSource(YamlValue dst, YamlValue source) {
        string[] keys = source.Keys();
        int i = 0;
        while (i < keys.Length) {
            string k = keys[i];
            if (!dst.ContainsKey(k)) {
                dst.Set(k, source.Get(k).DeepClone());
                this._AppendMergedKey(k);
            }
            i = i + 1;
        }
    }

    private void _AppendMergedKey(string key) {
        if (this._mergedCount == this._mergedKeys.Length) {
            int newCap = this._mergedKeys.Length * 2;
            string[] bigger = new string[newCap];
            int j = 0;
            while (j < this._mergedCount) {
                bigger[j] = this._mergedKeys[j];
                j = j + 1;
            }
            this._mergedKeys = bigger;
        }
        this._mergedKeys[this._mergedCount] = key;
        this._mergedCount = this._mergedCount + 1;
    }

    /// Linear scan — merge counts are typically <10. Returns the index of
    /// `key` in the current merged-key table, or -1.
    private int _IndexOfMergedKey(string key) {
        int i = 0;
        while (i < this._mergedCount) {
            if (this._mergedKeys[i] == key) { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// Drop entry at `index` from `_mergedKeys`, shifting tail down by 1.
    private void _RemoveMergedKeyAt(int index) {
        int i = index;
        while (i + 1 < this._mergedCount) {
            this._mergedKeys[i] = this._mergedKeys[i + 1];
            i = i + 1;
        }
        this._mergedCount = this._mergedCount - 1;
        this._mergedKeys[this._mergedCount] = "";
    }

    /// Try to parse a block-scalar indicator (`|` literal or `>` folded)
    /// at the current position. Returns the resulting string YamlValue if
    /// a block scalar starts here; `null` otherwise (caller falls through
    /// to the inline-scalar path). `parentIndent` is the indent of the
    /// line containing the indicator; content lines must indent strictly
    /// more than this. add-yaml-multiline-strings (2026-05-25).
    private YamlValue _TryParseBlockScalar(int parentIndent) {
        if (this._pos >= this._src.Length) { return null; }
        char first = this._src.CharAt(this._pos);
        if (first != '|' && first != '>') { return null; }
        bool literal = (first == '|');
        this._Advance();
        // Optional chomping (`-` strip, `+` keep, default clip) and indent
        // indicator (digit 1-9). Either order; at most one of each.
        // chomp: 0 = clip, 1 = strip, 2 = keep.
        int chomp = 0;
        int explicitIndent = -1;
        int passes = 0;
        while (passes < 2 && this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            if ((c == '-' || c == '+') && chomp == 0) {
                if (c == '-') { chomp = 1; }
                else          { chomp = 2; }
                this._Advance();
            } else if (c >= '1' && c <= '9' && explicitIndent < 0) {
                explicitIndent = (int)c - (int)'0';
                this._Advance();
            } else {
                passes = 2;     // exit inner loop
            }
            passes = passes + 1;
        }
        // Indicator line ends with optional spaces + optional comment + EOL.
        this._SkipInlineSpacesAndOptionalComment();
        this._ConsumeRestOfLine();
        // Collect content lines.
        StringBuilder content = new StringBuilder();
        int contentIndent = -1;
        int pendingBlanks = 0;
        bool sawContent = false;
        bool prevWasBlank = false;
        while (this._pos < this._src.Length) {
            int lineStart = this._pos;
            int lineIndent = 0;
            while (lineStart + lineIndent < this._src.Length
                    && this._src.CharAt(lineStart + lineIndent) == ' ') {
                lineIndent = lineIndent + 1;
            }
            int probe = lineStart + lineIndent;
            bool blank = false;
            if (probe >= this._src.Length) {
                blank = true;
            } else {
                char pc = this._src.CharAt(probe);
                if (pc == '\n' || pc == '\r') { blank = true; }
            }
            if (blank) {
                if (sawContent) {
                    pendingBlanks = pendingBlanks + 1;
                    prevWasBlank = true;
                }
                // Consume the blank line and continue.
                this._pos = probe;
                this._ConsumeRestOfLine();
                continue;
            }
            // First non-blank line decides content indent (unless explicit).
            if (contentIndent < 0) {
                if (explicitIndent > 0) {
                    contentIndent = parentIndent + explicitIndent;
                } else {
                    contentIndent = lineIndent;
                }
                // Content indent must be strictly greater than parent;
                // otherwise the block scalar is empty and this line belongs
                // to the surrounding context.
                if (contentIndent <= parentIndent) {
                    this._pos = lineStart;
                    contentIndent = -1;          // signal "empty body"
                    pendingBlanks = 0;            // discard tracked blanks
                    break;
                }
            }
            if (lineIndent < contentIndent) {
                // Reached a dedented line → block scalar ends; leave the
                // line for the surrounding parser to handle.
                this._pos = lineStart;
                break;
            }
            // Capture the line text starting at contentIndent.
            int textStart = lineStart + contentIndent;
            int textEnd = textStart;
            while (textEnd < this._src.Length
                    && this._src.CharAt(textEnd) != '\n'
                    && this._src.CharAt(textEnd) != '\r') {
                textEnd = textEnd + 1;
            }
            string lineText = this._src.Substring(textStart, textEnd - textStart);
            // Emit separator between previous content and this line.
            if (sawContent) {
                if (literal) {
                    // Always one `\n` for the previous line's break, plus
                    // one extra `\n` per intervening blank.
                    content.Append("\n");
                    int k = 0;
                    while (k < pendingBlanks) {
                        content.Append("\n");
                        k = k + 1;
                    }
                } else {
                    // Folded: blank lines fold to `\n`; consecutive non-blank
                    // lines fold to a single space.
                    if (prevWasBlank) {
                        int k = 0;
                        while (k < pendingBlanks) {
                            content.Append("\n");
                            k = k + 1;
                        }
                    } else {
                        content.Append(" ");
                    }
                }
            }
            content.Append(lineText);
            sawContent = true;
            prevWasBlank = false;
            pendingBlanks = 0;
            this._pos = textEnd;
            this._ConsumeRestOfLine();
        }
        // Apply chomping.
        string body = content.ToString();
        if (!sawContent) {
            return YamlValue.OfString("");
        }
        if (chomp == 1) {
            // strip: no trailing newlines.
            return YamlValue.OfString(body);
        }
        if (chomp == 0) {
            // clip: exactly one trailing newline.
            return YamlValue.OfString(body + "\n");
        }
        // keep: one trailing newline + one per trailing blank line.
        int trailing = 1 + pendingBlanks;
        int t = 0;
        while (t < trailing) {
            body = body + "\n";
            t = t + 1;
        }
        return YamlValue.OfString(body);
    }

    /// Consume from current pos through the rest of the line; return the
    /// trimmed content, stripped of any end-of-line `#…` comment.
    private string _ConsumeLinePlainScalar() {
        int start = this._pos;
        int commentStart = -1;
        while (this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            if (c == '\n' || c == '\r') { break; }
            // YAML allows `#` inside a plain scalar only when not preceded
            // by whitespace; an inline comment requires `␣#`.
            if (c == '#' && this._pos > start) {
                char prev = this._src.CharAt(this._pos - 1);
                if (prev == ' ' || prev == '\t') {
                    commentStart = this._pos;
                    break;
                }
            }
            this._Advance();
        }
        int end = commentStart >= 0 ? commentStart : this._pos;
        string raw = this._src.Substring(start, end - start);
        return raw.Trim();
    }

    /// Type-detect a plain (unquoted, untrimmed) scalar:
    ///   "" / "~" / "null"  → null
    ///   "true" / "false"   → bool
    ///   integer literal    → int   (sign, decimal only — v0)
    ///   float literal      → float (sign, decimal point or exponent — v0)
    ///   otherwise          → string
    private YamlValue _ParseScalarLiteral(string raw) {
        if (raw.Length == 0)      { return YamlValue.OfNull(); }
        if (raw == "~")           { return YamlValue.OfNull(); }
        if (raw == "null")        { return YamlValue.OfNull(); }
        if (raw == "Null")        { return YamlValue.OfNull(); }
        if (raw == "NULL")        { return YamlValue.OfNull(); }
        if (raw == "true")        { return YamlValue.OfBool(true); }
        if (raw == "True")        { return YamlValue.OfBool(true); }
        if (raw == "TRUE")        { return YamlValue.OfBool(true); }
        if (raw == "false")       { return YamlValue.OfBool(false); }
        if (raw == "False")       { return YamlValue.OfBool(false); }
        if (raw == "FALSE")       { return YamlValue.OfBool(false); }
        // YAML 1.2 hex / octal literals (add-yaml-numeric-bases, 2026-05-25).
        // Checked before decimal so `0xFF` / `0o755` aren't matched as string.
        if (this._LooksLikeHex(raw)) {
            return YamlValue.OfInt(this._ParseHex(raw));
        }
        if (this._LooksLikeOctal(raw)) {
            return YamlValue.OfInt(this._ParseOctal(raw));
        }
        // add-yaml-timestamps (2026-05-27): ISO 8601 timestamp before
        // numeric inference. `YYYY-...` shape doesn't overlap int/float
        // lexical patterns so there's no false positive on numeric input.
        // Parse failure falls through to numeric / string for graceful
        // degradation of "almost-but-not-quite" date-shaped strings.
        if (this._LooksLikeTimestamp(raw)) {
            try { return YamlValue.OfTimestampString(raw); }
            catch (Exception e) { /* fall through */ }
        }
        // Try int → float → string.
        if (this._LooksLikeInt(raw)) {
            try { return YamlValue.OfInt(Int64.Parse(raw)); }
            catch (Exception e) { /* fall through to float / string */ }
        }
        if (this._LooksLikeFloat(raw)) {
            try { return YamlValue.OfFloat(Double.Parse(raw)); }
            catch (Exception e) { /* fall through to string */ }
        }
        return YamlValue.OfString(raw);
    }

    /// Cheap prefix-check for ISO 8601 — `YYYY-MM-DD` exactly, or that
    /// followed by `T`/`t`/space + at least `HH`. ParseIso8601 does the
    /// real validation; this just gates whether to attempt it.
    private bool _LooksLikeTimestamp(string s) {
        if (s.Length < 10) { return false; }
        int i = 0;
        while (i < 4) {
            char c = s.CharAt(i);
            if (c < '0' || c > '9') { return false; }
            i = i + 1;
        }
        if (s.CharAt(4) != '-') { return false; }
        if (s.CharAt(5) < '0' || s.CharAt(5) > '9') { return false; }
        if (s.CharAt(6) < '0' || s.CharAt(6) > '9') { return false; }
        if (s.CharAt(7) != '-') { return false; }
        if (s.CharAt(8) < '0' || s.CharAt(8) > '9') { return false; }
        if (s.CharAt(9) < '0' || s.CharAt(9) > '9') { return false; }
        if (s.Length == 10) { return true; }
        char sep = s.CharAt(10);
        if (sep != 'T' && sep != 't' && sep != ' ') { return false; }
        if (s.Length < 13) { return false; }
        return (s.CharAt(11) >= '0' && s.CharAt(11) <= '9')
            && (s.CharAt(12) >= '0' && s.CharAt(12) <= '9');
    }

    /// YAML 1.2 hex literal: `0x` prefix (lowercase), at least one hex digit.
    /// No sign allowed (matches YAML 1.2 spec §10.2 schema).
    private bool _LooksLikeHex(string s) {
        if (s.Length < 3) { return false; }
        if (s.CharAt(0) != '0' || s.CharAt(1) != 'x') { return false; }
        int i = 2;
        while (i < s.Length) {
            char c = s.CharAt(i);
            bool isHexDigit = (c >= '0' && c <= '9')
                || (c >= 'a' && c <= 'f')
                || (c >= 'A' && c <= 'F');
            if (!isHexDigit) { return false; }
            i = i + 1;
        }
        return true;
    }

    private long _ParseHex(string s) {
        long n = 0;
        int i = 2;
        while (i < s.Length) {
            char c = s.CharAt(i);
            long d = 0;
            if (c >= '0' && c <= '9')      { d = (long)((int)c - (int)'0'); }
            else if (c >= 'a' && c <= 'f') { d = (long)((int)c - (int)'a' + 10); }
            else                            { d = (long)((int)c - (int)'A' + 10); }
            n = (n << 4) | d;
            i = i + 1;
        }
        return n;
    }

    /// YAML 1.2 octal literal: `0o` prefix, at least one octal digit.
    /// No sign allowed.
    private bool _LooksLikeOctal(string s) {
        if (s.Length < 3) { return false; }
        if (s.CharAt(0) != '0' || s.CharAt(1) != 'o') { return false; }
        int i = 2;
        while (i < s.Length) {
            char c = s.CharAt(i);
            if (c < '0' || c > '7') { return false; }
            i = i + 1;
        }
        return true;
    }

    private long _ParseOctal(string s) {
        long n = 0;
        int i = 2;
        while (i < s.Length) {
            long d = (long)((int)s.CharAt(i) - (int)'0');
            n = (n << 3) | d;
            i = i + 1;
        }
        return n;
    }

    private bool _LooksLikeInt(string s) {
        int i = 0;
        if (s.Length == 0) { return false; }
        if (s.CharAt(0) == '+' || s.CharAt(0) == '-') { i = 1; }
        if (i >= s.Length) { return false; }
        while (i < s.Length) {
            char c = s.CharAt(i);
            if (c < '0' || c > '9') { return false; }
            i = i + 1;
        }
        return true;
    }

    private bool _LooksLikeFloat(string s) {
        int i = 0;
        if (s.Length == 0) { return false; }
        if (s.CharAt(0) == '+' || s.CharAt(0) == '-') { i = 1; }
        bool sawDigit = false;
        bool sawDot = false;
        bool sawExp = false;
        while (i < s.Length) {
            char c = s.CharAt(i);
            if (c >= '0' && c <= '9') {
                sawDigit = true;
            } else if (c == '.' && !sawDot && !sawExp) {
                sawDot = true;
            } else if ((c == 'e' || c == 'E') && sawDigit && !sawExp) {
                sawExp = true;
                if (i + 1 < s.Length && (s.CharAt(i + 1) == '+' || s.CharAt(i + 1) == '-')) {
                    i = i + 1;
                }
            } else {
                return false;
            }
            i = i + 1;
        }
        return sawDigit && (sawDot || sawExp);
    }

    // ── Whitespace + line handling ──────────────────────────────────────

    /// Number of leading space characters on the line starting at _pos.
    /// Throws if a tab appears in the indentation (YAML forbids).
    private int _CurrentLineIndent() {
        int i = this._pos;
        int n = 0;
        while (i < this._src.Length) {
            char c = this._src.CharAt(i);
            if (c == ' ') { n = n + 1; i = i + 1; continue; }
            if (c == '\t') {
                throw this._Err("tab character not allowed in indentation");
            }
            break;
        }
        return n;
    }

    private void _SkipBlankLines() {
        while (this._pos < this._src.Length) {
            int save = this._pos;
            int indent = 0;
            // Skip leading spaces.
            while (save < this._src.Length && this._src.CharAt(save) == ' ') {
                save = save + 1;
                indent = indent + 1;
            }
            if (save >= this._src.Length) { this._pos = save; return; }
            char c = this._src.CharAt(save);
            if (c == '\n' || c == '\r' || c == '#') {
                this._pos = save;
                this._col = indent + 1;
                this._ConsumeRestOfLine();
                continue;
            }
            return;
        }
    }

    private void _SkipInlineSpaces() {
        while (this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            if (c == ' ' || c == '\t') { this._Advance(); } else { break; }
        }
    }

    private void _SkipInlineSpacesAndOptionalComment() {
        this._SkipInlineSpaces();
        if (this._pos < this._src.Length && this._src.CharAt(this._pos) == '#') {
            // Skip until EOL.
            while (this._pos < this._src.Length) {
                char c = this._src.CharAt(this._pos);
                if (c == '\n' || c == '\r') { break; }
                this._Advance();
            }
        }
    }

    private void _SkipFlowWS() {
        while (this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            if (c == ' ' || c == '\t' || c == '\n' || c == '\r') {
                this._Advance();
                continue;
            }
            if (c == '#') {
                while (this._pos < this._src.Length && this._src.CharAt(this._pos) != '\n') {
                    this._Advance();
                }
                continue;
            }
            break;
        }
    }

    private void _ConsumeRestOfLine() {
        while (this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            if (c == '\n') {
                this._pos = this._pos + 1;
                this._line = this._line + 1;
                this._col = 1;
                return;
            }
            if (c == '\r') {
                this._pos = this._pos + 1;
                if (this._pos < this._src.Length && this._src.CharAt(this._pos) == '\n') {
                    this._pos = this._pos + 1;
                }
                this._line = this._line + 1;
                this._col = 1;
                return;
            }
            this._pos = this._pos + 1;
        }
    }

    private bool _PeekLineIs(string marker) {
        int i = this._pos;
        int m = 0;
        while (i < this._src.Length && m < marker.Length) {
            if (this._src.CharAt(i) != marker.CharAt(m)) { return false; }
            i = i + 1;
            m = m + 1;
        }
        if (m < marker.Length) { return false; }
        if (i >= this._src.Length) { return true; }
        char nx = this._src.CharAt(i);
        return nx == '\n' || nx == '\r' || nx == ' ' || nx == '\t';
    }

    private bool _IsCommentStart() {
        // Caller ensures this._pos points at '#'. A comment requires `␣#` —
        // i.e. the char before must be whitespace OR this must be the first
        // non-WS char of the line. We approximate: if prev char is space or
        // we're at line start, it's a comment.
        if (this._pos == 0) { return true; }
        char prev = this._src.CharAt(this._pos - 1);
        return prev == ' ' || prev == '\t' || prev == '\n' || prev == '\r';
    }

    /// Scan from `start` to end-of-line looking for an unquoted `:` followed
    /// by WS / EOL — that means the line is a block-mapping key:value.
    /// Returns false for lines that are plain scalars.
    private bool _LineHasMappingColon(int start) {
        int i = start;
        bool inSingleQuote = false;
        bool inDoubleQuote = false;
        while (i < this._src.Length) {
            char c = this._src.CharAt(i);
            if (c == '\n' || c == '\r') { return false; }
            if (inDoubleQuote) {
                if (c == '\\' && i + 1 < this._src.Length) { i = i + 2; continue; }
                if (c == '"') { inDoubleQuote = false; }
                i = i + 1;
                continue;
            }
            if (inSingleQuote) {
                if (c == '\'') {
                    if (i + 1 < this._src.Length && this._src.CharAt(i + 1) == '\'') {
                        i = i + 2; continue;
                    }
                    inSingleQuote = false;
                }
                i = i + 1;
                continue;
            }
            if (c == '"')  { inDoubleQuote = true;  i = i + 1; continue; }
            if (c == '\'') { inSingleQuote = true;  i = i + 1; continue; }
            // Inline comment ends search.
            if (c == '#' && i > start) {
                char prev = this._src.CharAt(i - 1);
                if (prev == ' ' || prev == '\t') { return false; }
            }
            if (c == ':') {
                if (i + 1 >= this._src.Length) { return true; }
                char nx = this._src.CharAt(i + 1);
                if (nx == ' ' || nx == '\t' || nx == '\n' || nx == '\r') {
                    return true;
                }
            }
            i = i + 1;
        }
        return false;
    }

    private void _Advance() {
        if (this._pos < this._src.Length) {
            char c = this._src.CharAt(this._pos);
            this._pos = this._pos + 1;
            if (c == '\n') {
                this._line = this._line + 1;
                this._col = 1;
            } else {
                this._col = this._col + 1;
            }
        }
    }

    private YamlException _Err(string msg) {
        return new YamlException(msg + " at " + this._line.ToString() + ":" + this._col.ToString());
    }
}
