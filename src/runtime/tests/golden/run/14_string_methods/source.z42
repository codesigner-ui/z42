void Main() {
    var s = "  Hello, World!  ";

    Assert.Equal("  hello, world!  ", s.ToLower());
    Assert.Equal("  HELLO, WORLD!  ", s.ToUpper());
    Assert.Equal("Hello, World!", s.Trim());
    Assert.Equal("Hello, World!  ", s.TrimStart());
    Assert.Equal("  Hello, World!", s.TrimEnd());

    var t = "Hello, World!";
    Assert.Equal(7, t.IndexOf("World"));
    Assert.Equal(-1, t.IndexOf("xyz"));
    Assert.Equal("Hello, Rust!", t.Replace("World", "Rust"));

    // Split
    var csv = "a,b,c,d";
    var parts = csv.Split(",");
    Assert.Equal(4, parts.Length);
    Assert.Equal("a", parts[0]);
    Assert.Equal("d", parts[3]);
}
