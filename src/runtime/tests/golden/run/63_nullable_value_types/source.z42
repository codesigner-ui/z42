using Std.IO;
// Test: nullable value types (int?, double?, bool?)

void Main() {
    // Nullable int with value
    int? a = 42;
    Assert.Equal(42, a ?? 0);

    // Nullable int with null
    int? b = null;
    Assert.Equal(0, b ?? 0);

    // Nullable double
    double? d = 3.14;
    Assert.Equal(3.14, d ?? 0.0);

    double? dn = null;
    Assert.Equal(0.0, dn ?? 0.0);

    // Nullable bool
    bool? flag = true;
    Assert.Equal(true, flag ?? false);

    bool? noFlag = null;
    Assert.Equal(false, noFlag ?? false);

    // Nullable in if condition via ??
    int? val = 10;
    int result = val ?? -1;
    Assert.Equal(10, result);

    int? noVal = null;
    int result2 = noVal ?? -1;
    Assert.Equal(-1, result2);

    // Reassign nullable from value to null
    int? x = 100;
    Assert.Equal(100, x ?? 0);
    x = null;
    Assert.Equal(0, x ?? 0);

    Console.WriteLine("nullable value types ok");
}
