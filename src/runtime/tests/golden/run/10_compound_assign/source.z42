void Main() {
    var x = 10;
    x += 5;
    Console.WriteLine(x);   // 15

    x -= 3;
    Console.WriteLine(x);   // 12

    x *= 2;
    Console.WriteLine(x);   // 24

    x /= 4;
    Console.WriteLine(x);   // 6

    x %= 4;
    Console.WriteLine(x);   // 2

    // post-increment / decrement
    var i = 0;
    i++;
    i++;
    i--;
    Console.WriteLine(i);   // 1
}
