namespace Test;

string maybeNull(bool returnNull) {
    if (returnNull) {
        return null;
    }
    return "hello";
}

void main() {
    // Basic ?? — non-null value returned as-is
    var s = maybeNull(false) ?? "default";
    Assert.Equal("hello", s);

    // ?? — null triggers right-hand side
    var t = maybeNull(true) ?? "default";
    Assert.Equal("default", t);

    // Chaining: a ?? b ?? c
    var a = null ?? null ?? "found";
    Assert.Equal("found", a);

    // Right-side is only evaluated when left is null
    var x = "value" ?? "other";
    Assert.Equal("value", x);
}
