namespace Demo;
using Std.IO;

void Main() {
    // for with break
    int sum = 0;
    for (int i = 0; i < 100; i++) {
        if (i == 5) break;
        sum += i;
    }
    Assert.Equal(10, sum);   // 0+1+2+3+4

    // for with continue (skip even numbers)
    int oddSum = 0;
    for (int i = 0; i < 10; i++) {
        if (i % 2 == 0) continue;
        oddSum += i;
    }
    Assert.Equal(25, oddSum);  // 1+3+5+7+9

    // while loop
    int count = 0;
    int n = 1;
    while (n < 100) {
        n = n * 2;
        count++;
    }
    Assert.Equal(7, count);    // 2,4,8,16,32,64,128 → 7 iterations
    Assert.Equal(128, n);

    // while with break
    int found = -1;
    int j = 0;
    while (true) {
        if (j * j > 50) {
            found = j;
            break;
        }
        j++;
    }
    Assert.Equal(8, found);    // 8*8=64 > 50

    // Nested loop: break only inner
    int total = 0;
    for (int outer = 0; outer < 3; outer++) {
        for (int inner = 0; inner < 10; inner++) {
            if (inner == 2) break;
            total++;
        }
    }
    Assert.Equal(6, total);    // 3 outer × 2 inner

    Console.WriteLine("loop control ok");
}
