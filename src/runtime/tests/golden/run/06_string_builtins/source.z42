void Main() {
    string s = "Hello, World!";

    Assert.Equal(13, s.Length);

    Assert.True(s.Contains("World"));
    Assert.False(s.Contains("world"));

    Assert.True(s.StartsWith("Hello"));
    Assert.True(s.EndsWith("!"));

    Assert.Equal("World!", s.Substring(7));
    Assert.Equal("World", s.Substring(7, 5));
}
