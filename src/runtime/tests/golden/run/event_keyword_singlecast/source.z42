// 2026-05-04 add-event-keyword-singlecast (D-7) regression golden.
// 端到端验证单播 event：
//  - 首次 += 设置成功
//  - 二次 += 抛 InvalidOperationException
//  - -= 引用相等清空，相等性可重复绑定
namespace Demo;
using Std;
using Std.IO;

public class Cocoa {
    public event Action<int> OnKey;
}

void Main() {
    var c = new Cocoa();

    // ── 首次 += 成功 ──
    c.OnKey += (int x) => Console.WriteLine($"a:{x}");
    Console.WriteLine("first bind ok");

    // ── 双绑定抛 InvalidOperationException ──
    try {
        c.OnKey += (int x) => Console.WriteLine($"b:{x}");
        Console.WriteLine("no exception (should not reach)");
    } catch (InvalidOperationException e) {
        Console.WriteLine("double bind caught");
    }

    // ── 同 handler 重复绑定 ──
    var d = new Cocoa();
    Action<int> handler = (int x) => Console.WriteLine($"c:{x}");
    d.OnKey += handler;
    Console.WriteLine("d bound");
    d.OnKey -= handler;
    Console.WriteLine("d cleared");
    // 清空后可重新绑定
    d.OnKey += handler;
    Console.WriteLine("d rebound");
}
