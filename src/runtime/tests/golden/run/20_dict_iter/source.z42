// Test: Dictionary.Keys() / Values() / Entries() iteration + KeyValuePair
// (add-keyvaluepair-and-dict-entries, 2026-04-27;
//  Entries() 添加于 fix-generic-array-type-parsing)。

void Main() {
    var dict = new Dictionary<string, int>();
    dict["alpha"] = 1;
    dict["beta"]  = 2;
    dict["gamma"] = 3;

    Console.WriteLine($"count={dict.Count}");

    // Sum values via Keys() + indexer
    var keys = dict.Keys();
    int total = 0;
    int i = 0;
    while (i < keys.Length) {
        total = total + dict[keys[i]];
        i = i + 1;
    }
    Console.WriteLine($"sum={total}");  // 1+2+3=6

    // Sum values via Values() directly
    var vals = dict.Values();
    int total2 = 0;
    int j = 0;
    while (j < vals.Length) {
        total2 = total2 + vals[j];
        j = j + 1;
    }
    Console.WriteLine($"sum2={total2}");  // 6

    // KeyValuePair 类型作为独立类型可用
    var kv = new KeyValuePair<string, int>("hello", 42);
    Console.WriteLine($"kv={kv.Key}/{kv.Value}");  // hello/42

    // dict.Entries() 返回 KeyValuePair<K,V>[]，访问 .Value 应拿到具体类型 int
    // (fix-generic-type-roundtrip 修复后)。
    var entries = dict.Entries();
    Console.WriteLine($"entries_len={entries.Length}");  // 3
    int total3 = 0;
    int m = 0;
    while (m < entries.Length) {
        total3 = total3 + entries[m].Value;
        m = m + 1;
    }
    Console.WriteLine($"sum3={total3}");  // 6 (1+2+3)
}
