using Std.IO;
// Test: generic class — code sharing, type param in fields and methods

class Box<T> {
    T value;
    Box(T v) {
        this.value = v;
    }
    T Get() {
        return this.value;
    }
}

class Pair<A, B> {
    A first;
    B second;
    Pair(A a, B b) {
        this.first = a;
        this.second = b;
    }
}

void Main() {
    // Box with int (type inference)
    var b1 = new Box(42);
    Assert.Equal(42, b1.Get());

    // Box with string (type inference)
    var b2 = new Box("hello");
    Assert.Equal("hello", b2.Get());

    // Explicit type args: new Box<int>(...)
    var b3 = new Box<int>(99);
    Assert.Equal(99, b3.Get());

    // Pair with mixed types (type inference)
    var p = new Pair(1, "one");
    Assert.Equal(1, p.first);
    Assert.Equal("one", p.second);

    // Explicit type args: new Pair<int, string>(...)
    var p2 = new Pair<int, string>(2, "two");
    Assert.Equal(2, p2.first);
    Assert.Equal("two", p2.second);

    Console.WriteLine("generic class ok");
}
