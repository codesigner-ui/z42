void Main() {
    int[] nums = new int[] { 1, 2, 3, 4, 5 };

    // Basic foreach
    int sum = 0;
    foreach (var n in nums) {
        sum += n;
    }
    Console.WriteLine(sum);

    // Foreach with break
    int first = 0;
    foreach (var n in nums) {
        first = n;
        break;
    }
    Console.WriteLine(first);

    // Foreach with continue (skip even numbers, sum odds)
    int odds = 0;
    foreach (var n in nums) {
        if (n % 2 == 0) continue;
        odds += n;
    }
    Console.WriteLine(odds);
}
