.module "ControlFlow"

.func @ControlFlow.Main  params:0  ret:void  mode:Interp
  .block entry
    %0 = const.i64  0
    %1 = copy  %0
    br  cond_0

  .block cond_0
    %2 = const.i64  3
    %3 = lt  %1, %2
    br.cond  %3  body_1  end_3

  .block body_1
    %4 = call  @Std.IO.Console.WriteLine  %1
    br  incr_2

  .block incr_2
    %5 = const.i64  1
    %6 = add  %1, %5
    %1 = copy  %6
    br  cond_0

  .block end_3
    ret
