.module "ControlFlow"

.strings
  s0  "positive"
  s1  "negative"
  s2  "zero"

.func @ControlFlow.Sign  params:1  ret:string  mode:Interp  ; %0=this
  .linetable
    block:0  instr:0  line:4
    block:1  instr:0  line:5
    block:2  instr:0  line:6
    block:3  instr:0  line:7
    block:4  instr:0  line:8
    block:4  instr:0  line:9
  .block entry
    %1:i32 = const.i64  0
    %2:bool = gt  %0:i32, %1:i32
    br.cond  %2:bool  then_0  else_1

  .block then_0
    %3:str = const.str  s0          ; "positive"
    ret  %3:str

  .block else_1
    %4:i32 = const.i64  0
    %5:bool = lt  %0:i32, %4:i32
    br.cond  %5:bool  then_3  else_4

  .block then_3
    %6:str = const.str  s1          ; "negative"
    ret  %6:str

  .block else_4
    %7:str = const.str  s2          ; "zero"
    ret  %7:str

  .block end_5
    br  end_2

  .block end_2
    ret

.func @ControlFlow.Main  params:0  ret:void  mode:Interp
  .linetable
    block:0  instr:0  line:14
    block:0  instr:3  line:15
    block:0  instr:7  line:16
  .block entry
    %0:i32 = const.i64  1
    %1:str = call  @ControlFlow.Sign  %0:i32
    %2:void = call  @Std.IO.Console.WriteLine  %1:str
    %3:i32 = const.i64  3
    %4:i32 = neg  %3:i32
    %5:str = call  @ControlFlow.Sign  %4:i32
    %6:void = call  @Std.IO.Console.WriteLine  %5:str
    %7:i32 = const.i64  0
    %8:str = call  @ControlFlow.Sign  %7:i32
    %9:void = call  @Std.IO.Console.WriteLine  %8:str
    ret
