.module "ControlFlow"

.func @ControlFlow.Sum  params:1  ret:int  mode:Interp  ; %0=this
  .block entry
    %1 = const.i64  0
    %2 = copy  %1
    %3 = const.i64  1
    %4 = copy  %3
    br  cond_0

  .block cond_0
    %5 = le  %4, %0
    br.cond  %5  body_1  end_2

  .block body_1
    %6 = add  %2, %4
    %2 = copy  %6
    %7 = const.i64  1
    %8 = add  %4, %7
    %4 = copy  %8
    br  cond_0

  .block end_2
    ret  %2

.func @ControlFlow.Main  params:0  ret:void  mode:Interp
  .block entry
    %0 = const.i64  5
    %1 = call  @ControlFlow.Sum  %0
    %2 = call  @Std.IO.Console.WriteLine  %1
    ret
