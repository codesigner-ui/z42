.module "Hello"

.strings
  s0  "Hello, "
  s1  "!"
  s2  "world"
  s3  "z42 version 0.1, the answer is "

.func @Hello.Greet  params:1  ret:string  mode:Interp  ; %0=this
  .block entry
    %1 = const.str  s0          ; "Hello, "
    %2 = to_str  %0
    %3 = const.str  s1          ; "!"
    %4 = str.concat  %1, %2
    %5 = str.concat  %4, %3
    ret  %5

.func @Hello.Main  params:0  ret:void  mode:Interp
  .block entry
    %0 = const.str  s2          ; "world"
    %1 = call  @Hello.Greet  %0
    store  @msg  %1
    %2 = load  @msg
    %3 = call  @Std.IO.Console.WriteLine  %2
    %4 = const.str  s3          ; "z42 version 0.1, the answer is "
    %5 = const.i64  42
    %6 = to_str  %5
    %7 = str.concat  %4, %6
    %8 = call  @Std.IO.Console.WriteLine  %7
    ret
