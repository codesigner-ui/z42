// Embedding API hello-world fixture.
//
// Spec: docs/spec/archive/2026-05-10-add-embedding-api/ (H2 / H3)
//       docs/design/runtime/embedding.md §9.1, §10
//
// Loaded by `host::host_tests::*` and the external `examples/hello_*`.
// Each entry exercises a distinct host-API path:
//
//   Main       — H2 happy path (single line, void return)
//   MultiLine  — H3 sink ordering (3 lines must arrive in order)
//   Boom       — H3 VmException (z42 throw escapes the entry)
//
// Output goes through Console.WriteLine, which routes through corelib
// io and lands in the host's stdout sink.

namespace Embedding.Hello;

using Std.IO;

void Main() {
    Console.WriteLine("Hello, World!");
}

void MultiLine() {
    Console.WriteLine("first");
    Console.WriteLine("second");
    Console.WriteLine("third");
}

void Boom() {
    throw new Exception("intentional embedding-test failure");
}
