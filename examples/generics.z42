// 泛型、Lambda、委托与 LINQ 风格 — z42 Phase 1 (C# syntax)
namespace Demo.Generics;

using System;
using System.Collections.Generic;
using System.Linq;

// ── 泛型类 ─────────────────────────────────────────────────────────────────

public class Option<T> {
    private readonly T? _value;
    private readonly bool _hasValue;

    private Option() { _hasValue = false; }
    private Option(T value) { _value = value; _hasValue = true; }

    public static Option<T> Some(T value) => new Option<T>(value);
    public static Option<T> None()        => new Option<T>();

    public bool HasValue => _hasValue;

    public T Unwrap() {
        if (!_hasValue) throw new InvalidOperationException("Option is None");
        return _value!;
    }

    public T UnwrapOr(T defaultValue) => _hasValue ? _value! : defaultValue;

    public Option<U> Map<U>(Func<T, U> f) =>
        _hasValue ? Option<U>.Some(f(_value!)) : Option<U>.None();

    public Option<U> FlatMap<U>(Func<T, Option<U>> f) =>
        _hasValue ? f(_value!) : Option<U>.None();

    public override string ToString() =>
        _hasValue ? $"Some({_value})" : "None";
}

// ── 泛型方法与约束 ─────────────────────────────────────────────────────────

T Min<T>(T a, T b) where T : IComparable<T> =>
    a.CompareTo(b) <= 0 ? a : b;

T Max<T>(T a, T b) where T : IComparable<T> =>
    a.CompareTo(b) >= 0 ? a : b;

List<T> Filter<T>(IEnumerable<T> source, Predicate<T> predicate) {
    var result = new List<T>();
    foreach (var item in source)
        if (predicate(item)) result.Add(item);
    return result;
}

List<U> Map<T, U>(IEnumerable<T> source, Func<T, U> selector) {
    var result = new List<U>();
    foreach (var item in source) result.Add(selector(item));
    return result;
}

U Reduce<T, U>(IEnumerable<T> source, U seed, Func<U, T, U> accumulator) {
    var acc = seed;
    foreach (var item in source) acc = accumulator(acc, item);
    return acc;
}

// ── 委托与 Lambda ──────────────────────────────────────────────────────────

// 函数式管道
Func<T, T> Compose<T>(Func<T, T> f, Func<T, T> g) =>
    x => f(g(x));

Func<T, T> Repeat<T>(Func<T, T> f, int times) {
    return x => {
        var result = x;
        for (int i = 0; i < times; i++) result = f(result);
        return result;
    };
}

// 部分应用
Func<int, int> Adder(int n) => x => x + n;
Func<int, int> Multiplier(int n) => x => x * n;

// ── 内置集合的 LINQ 风格操作 ─────────────────────────────────────────────

void LinqDemo() {
    var numbers = Enumerable.Range(1, 20).ToList();

    // 筛选偶数
    var evens = numbers.Where(n => n % 2 == 0).ToList();

    // 映射
    var squares = numbers.Select(n => n * n).ToList();

    // 聚合
    int sum  = numbers.Sum();
    int max  = numbers.Max();
    double avg = numbers.Average();

    // 分组
    var groups = numbers.GroupBy(n => n % 3)
                        .ToDictionary(g => g.Key, g => g.ToList());

    // 链式操作
    var result = numbers
        .Where(n => n % 2 == 0)
        .Select(n => n * n)
        .Where(n => n > 50)
        .OrderByDescending(n => n)
        .Take(3)
        .ToList();

    Console.WriteLine($"Evens: [{string.Join(", ", evens)}]");
    Console.WriteLine($"Top 3 even squares > 50: [{string.Join(", ", result)}]");
    Console.WriteLine($"Sum={sum}, Max={max}, Avg={avg:F1}");
}

// ── 入口 ───────────────────────────────────────────────────────────────────

void Main() {
    // Option<T>
    var some = Option<int>.Some(42);
    var none = Option<int>.None();

    Console.WriteLine(some);                           // Some(42)
    Console.WriteLine(none);                           // None
    Console.WriteLine(some.Map(x => x * 2));          // Some(84)
    Console.WriteLine(none.UnwrapOr(-1));              // -1

    // 泛型方法
    Console.WriteLine(Min(3, 7));                      // 3
    Console.WriteLine(Min("apple", "banana"));         // apple

    var nums = new[] { 5, 2, 8, 1, 9, 3 };
    var filtered = Filter(nums, n => n > 4);
    var mapped   = Map(nums, n => n * n);
    var total    = Reduce(nums, 0, (acc, n) => acc + n);

    Console.WriteLine($"Filtered: [{string.Join(", ", filtered)}]");   // [5, 8, 9]
    Console.WriteLine($"Squared:  [{string.Join(", ", mapped)}]");     // [25, 4, 64, ...]
    Console.WriteLine($"Sum: {total}");                                 // 28

    // 函数组合
    var add3    = Adder(3);
    var times2  = Multiplier(2);
    var add3ThenDouble = Compose(times2, add3);

    Console.WriteLine(add3ThenDouble(5));              // (5+3)*2 = 16
    Console.WriteLine(Repeat(add3, 4)(0));             // 0+3+3+3+3 = 12

    // LINQ
    LinqDemo();
}
