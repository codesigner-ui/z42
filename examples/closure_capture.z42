// L3 完整闭包（核心子集）示例 — 捕获 + 档 C 堆擦除。
// 设计见 docs/design/closure.md，实施见
// spec/archive/2026-05-01-impl-closure-l3-core/。
//
// 覆盖：
//   • 值类型捕获 — 快照语义（外层修改不影响闭包）
//   • 引用类型捕获 — 按身份共享（闭包内修改对象 → 外层可见）
//   • 高阶函数 + 闭包参数（CallIndirect on Closure）
//   • 嵌套 lambda 中的传递性捕获（内层 lambda 通过外层 env 访问）
//   • Local function 捕获（一层嵌套的 helper）

namespace Demo.ClosureCapture;

using Std.IO;

class Counter {
    public int n;
    Counter() { this.n = 0; }
}

int Apply((int) -> int f, int x) => f(x);

int OuterLocal() {
    var prefix = 1000;
    int Helper(int x) => x + prefix;     // local fn 捕获 prefix
    return Helper(23);
}

void Main() {
    // 1. 值类型快照
    var k = 10;
    (int) -> bool gt_k = (int x) => x > k;
    Console.WriteLine(gt_k(15));         // true
    k = 100;
    Console.WriteLine(gt_k(15));         // 仍然 true：闭包持有 k=10 的快照

    // 2. 引用类型按身份
    var c = new Counter();
    var inc = () => c.n = c.n + 1;
    inc(); inc(); inc();
    Console.WriteLine(c.n);              // 3

    // 3. 闭包作为高阶函数参数
    var bias = 100;
    Console.WriteLine(Apply((int x) => x + bias, 5));   // 105

    // 4. 嵌套传递性捕获
    var k2 = 7;
    var f = () => {
        var g = () => k2 * 2;            // 内层 lambda 通过 f 的 env 间接捕获 k2
        return g();
    };
    Console.WriteLine(f());              // 14

    // 5. Local function 捕获
    Console.WriteLine(OuterLocal());     // 1023
}
