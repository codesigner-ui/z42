// 枚举、判别联合与模式匹配 — z42 Phase 1 (C# syntax)
namespace Demo.Patterns;

using System;

// ── 枚举 ───────────────────────────────────────────────────────────────────

public enum Direction { North, South, East, West }

public enum HttpStatus : int {
    Ok          = 200,
    Created     = 201,
    BadRequest  = 400,
    NotFound    = 404,
    ServerError = 500,
}

// ── 判别联合（abstract record 模式） ───────────────────────────────────────

public abstract record Expr;
public sealed record Num(double Value)                 : Expr;
public sealed record Add(Expr Left, Expr Right)        : Expr;
public sealed record Mul(Expr Left, Expr Right)        : Expr;
public sealed record Neg(Expr Operand)                 : Expr;

// 递归求值
double Eval(Expr e) => e switch {
    Num(var v)       => v,
    Add(var l, var r) => Eval(l) + Eval(r),
    Mul(var l, var r) => Eval(l) * Eval(r),
    Neg(var inner)   => -Eval(inner),
    _                => throw new ArgumentException($"Unknown: {e}")
};

// 打印表达式
string Pretty(Expr e) => e switch {
    Num(var v)       => v.ToString(),
    Add(var l, var r) => $"({Pretty(l)} + {Pretty(r)})",
    Mul(var l, var r) => $"({Pretty(l)} * {Pretty(r)})",
    Neg(var inner)   => $"-{Pretty(inner)}",
    _                => "?"
};

// ── 类型模式、属性模式 ─────────────────────────────────────────────────────

public abstract record Shape2;
public sealed record Circle2(double Radius)             : Shape2;
public sealed record Rect2(double Width, double Height) : Shape2;

string Describe(Shape2 s) => s switch {
    Circle2 { Radius: 0 }             => "degenerate circle",
    Circle2 { Radius: > 100 }         => "huge circle",
    Circle2 c                         => $"circle r={c.Radius:F1}",
    Rect2 { Width: var w, Height: var h } when w == h
                                      => $"square side={w:F1}",
    Rect2 r                           => $"rect {r.Width:F1}x{r.Height:F1}",
    _                                 => "unknown shape"
};

// ── switch 语句模式 ────────────────────────────────────────────────────────

string HttpLabel(HttpStatus s) {
    return s switch {
        HttpStatus.Ok or HttpStatus.Created => "success",
        >= HttpStatus.BadRequest and < HttpStatus.ServerError => "client error",
        HttpStatus.ServerError => "server error",
        _ => "unknown"
    };
}

// ── 元组模式 ───────────────────────────────────────────────────────────────

string ClassifyPoint(double x, double y) => (x, y) switch {
    (0, 0)         => "origin",
    (> 0, > 0)     => "Q1",
    (< 0, > 0)     => "Q2",
    (< 0, < 0)     => "Q3",
    (> 0, < 0)     => "Q4",
    (0, _)         => "Y axis",
    (_, 0)         => "X axis",
    _              => "?"
};

// ── 列表模式（C# 11+） ─────────────────────────────────────────────────────

string DescribeList(int[] arr) => arr switch {
    []          => "empty",
    [var x]     => $"single: {x}",
    [var f, var l] => $"pair: {f}..{l}",
    [var h, .. var rest] => $"starts with {h}, {rest.Length} more"
};

// ── 入口 ───────────────────────────────────────────────────────────────────

void Main() {
    // 表达式树求值
    // (2 + 3) * -(4)  =>  -20
    var expr = new Mul(
        new Add(new Num(2), new Num(3)),
        new Neg(new Num(4))
    );
    Console.WriteLine($"{Pretty(expr)} = {Eval(expr)}");    // ((2 + 3) * -4) = -20

    // 形状描述
    Console.WriteLine(Describe(new Circle2(0)));             // degenerate circle
    Console.WriteLine(Describe(new Circle2(5)));             // circle r=5.0
    Console.WriteLine(Describe(new Rect2(3, 3)));            // square side=3.0
    Console.WriteLine(Describe(new Rect2(4, 6)));            // rect 4.0x6.0

    // HTTP status
    Console.WriteLine(HttpLabel(HttpStatus.Ok));             // success
    Console.WriteLine(HttpLabel(HttpStatus.NotFound));       // client error

    // 坐标象限
    Console.WriteLine(ClassifyPoint(1, 2));                  // Q1
    Console.WriteLine(ClassifyPoint(0, 0));                  // origin

    // 列表模式
    Console.WriteLine(DescribeList(new[] { 1, 2, 3, 4 }));  // starts with 1, 3 more

    // 方向枚举
    var dir = Direction.North;
    string arrow = dir switch {
        Direction.North => "↑",
        Direction.South => "↓",
        Direction.East  => "→",
        Direction.West  => "←",
    };
    Console.WriteLine(arrow);                                // ↑
}
