// 异常处理 — z42 Phase 1 (C# syntax)
// [Phase 2] 将替换为 Result<T, E> + ? 运算符（Rust 风格）
namespace Demo.Exceptions;

using System;
using System.IO;

// ── 自定义异常 ─────────────────────────────────────────────────────────────

public class Z42Exception(string message, int errorCode)
    : Exception(message) {
    public int ErrorCode { get; } = errorCode;
}

public class ValidationException(string field, string reason)
    : Z42Exception($"Validation failed on '{field}': {reason}", 400) {
    public string Field  { get; } = field;
    public string Reason { get; } = reason;
}

public class ParseError(string input, int position, string expected)
    : Z42Exception($"Parse error at pos {position}: expected {expected}, got '{input[position..]}'", 422) {
    public string Input    { get; } = input;
    public int    Position { get; } = position;
    public string Expected { get; } = expected;
}

// ── 异常抛出 ───────────────────────────────────────────────────────────────

int ParsePositive(string s) {
    if (!int.TryParse(s, out var n))
        throw new ParseError(s, 0, "integer");
    if (n <= 0)
        throw new ValidationException("value", $"must be positive, got {n}");
    return n;
}

double Divide(double a, double b) {
    if (b == 0) throw new DivideByZeroException($"Cannot divide {a} by zero");
    return a / b;
}

// ── try / catch / finally ──────────────────────────────────────────────────

void TryCatchDemo() {
    // 多个 catch，从最具体到最通用
    try {
        var n = ParsePositive("-5");
        Console.WriteLine(n);
    } catch (ValidationException ex) {
        Console.WriteLine($"[Validation] {ex.Field}: {ex.Reason}");
    } catch (ParseError ex) {
        Console.WriteLine($"[Parse] pos={ex.Position}: {ex.Message}");
    } catch (Z42Exception ex) {
        Console.WriteLine($"[Z42 error {ex.ErrorCode}] {ex.Message}");
    } catch (Exception ex) {
        Console.WriteLine($"[Unexpected] {ex.GetType().Name}: {ex.Message}");
    } finally {
        Console.WriteLine("--- finally block always runs ---");
    }
}

// ── when 过滤器 ────────────────────────────────────────────────────────────

void WhenFilterDemo(string input) {
    try {
        var n = ParsePositive(input);
        Console.WriteLine($"Parsed: {n}");
    } catch (Exception ex) when (ex.Message.Contains("zero")) {
        Console.WriteLine($"Zero-related error: {ex.Message}");
    } catch (Exception ex) when (input.Length > 10) {
        Console.WriteLine($"Long input caused error: {ex.Message}");
    } catch (Exception ex) {
        Console.WriteLine($"Other error: {ex.Message}");
    }
}

// ── 异常传播与包装 ─────────────────────────────────────────────────────────

double SafeDivide(string a, string b) {
    try {
        double x = double.Parse(a);
        double y = double.Parse(b);
        return Divide(x, y);
    } catch (FormatException ex) {
        throw new ValidationException("input", "must be a number") { };
    } catch (DivideByZeroException ex) {
        throw new Z42Exception($"Division by zero: {ex.Message}", 500);
    }
}

// ── using / IDisposable ────────────────────────────────────────────────────

public class ManagedResource(string name) : IDisposable {
    private bool _disposed = false;

    public void Use() {
        if (_disposed) throw new ObjectDisposedException(name);
        Console.WriteLine($"Using {name}");
    }

    public void Dispose() {
        if (!_disposed) {
            Console.WriteLine($"Disposing {name}");
            _disposed = true;
        }
    }
}

void UsingDemo() {
    // using — 离开作用域自动调用 Dispose
    using var resource = new ManagedResource("FileHandle");
    resource.Use();
}   // <- Dispose() 在此调用

