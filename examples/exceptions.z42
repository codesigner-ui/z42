// ── 入口 ───────────────────────────────────────────────────────────────────

void Main() {
    TryCatchDemo();
    WhenFilterDemo("abc");
    WhenFilterDemo("0");

    try {
        Console.WriteLine(SafeDivide("10", "2"));
        Console.WriteLine(SafeDivide("10", "0"));
    } catch (Z42Exception ex) {
        Console.WriteLine($"Caught Z42Exception [{ex.ErrorCode}]: {ex.Message}");
    }

    UsingDemo();
}
