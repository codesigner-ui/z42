// 面向对象 — 类、接口、记录、继承 — z42 Phase 1 (C# syntax)
namespace Demo.Oop;

using System;
using System.Collections.Generic;

// ── 接口 ───────────────────────────────────────────────────────────────────

public interface IShape {
    double Area();
    double Perimeter();
    string Name { get; }
}

public interface IDrawable {
    void Draw(string color = "black");
}

// ── 抽象基类 ────────────────────────────────────────────────────────────────

public abstract class Shape : IShape, IDrawable {
    public abstract double Area();
    public abstract double Perimeter();
    public abstract string Name { get; }

    public virtual void Draw(string color = "black") {
        Console.WriteLine($"[{color}] {Name}: area={Area():F2}, perimeter={Perimeter():F2}");
    }

    public override string ToString() => $"{Name}(area={Area():F2})";
}

// ── 具体类 ─────────────────────────────────────────────────────────────────

public class Circle(double radius) : Shape {
    public double Radius { get; } = radius;

    public override double Area()      => Math.PI * Radius * Radius;
    public override double Perimeter() => 2 * Math.PI * Radius;
    public override string Name        => "Circle";
}

public class Rectangle : Shape {
    public double Width  { get; }
    public double Height { get; }

    public Rectangle(double width, double height) {
        Width  = width;
        Height = height;
    }

    public override double Area()      => Width * Height;
    public override double Perimeter() => 2 * (Width + Height);
    public override string Name        => "Rectangle";

    // 方法重载
    public static Rectangle Square(double side) => new Rectangle(side, side);
}

// ── Record — 不可变值对象 ───────────────────────────────────────────────────

public record Point(double X, double Y) {
    public double DistanceTo(Point other) {
        double dx = X - other.X;
        double dy = Y - other.Y;
        return Math.Sqrt(dx * dx + dy * dy);
    }

    public static readonly Point Origin = new(0, 0);
}

public record struct Vector2(double X, double Y) {
    public static Vector2 operator +(Vector2 a, Vector2 b) =>
        new(a.X + b.X, a.Y + b.Y);

    public double Length => Math.Sqrt(X * X + Y * Y);

    public Vector2 Normalized() {
        var len = Length;
        return len == 0 ? this : new(X / len, Y / len);
    }
}

// ── 泛型类 ─────────────────────────────────────────────────────────────────

public class ShapeCollection<T> where T : IShape {
    private readonly List<T> _shapes = new();

    public void Add(T shape)     => _shapes.Add(shape);
    public int  Count            => _shapes.Count;

    public double TotalArea() {
        double total = 0;
        foreach (var s in _shapes) total += s.Area();
        return total;
    }

    public T? Largest() {
        if (_shapes.Count == 0) return default;
        var max = _shapes[0];
        foreach (var s in _shapes)
            if (s.Area() > max.Area()) max = s;
        return max;
    }
}

// ── 入口 ───────────────────────────────────────────────────────────────────

void Main() {
    var shapes = new ShapeCollection<Shape>();
    shapes.Add(new Circle(5));
    shapes.Add(new Rectangle(4, 6));
    shapes.Add(Rectangle.Square(3));

    foreach (var s in new Shape[] { new Circle(5), new Rectangle(4, 6) }) {
        s.Draw("blue");
    }

    Console.WriteLine($"Total area: {shapes.TotalArea():F2}");
    Console.WriteLine($"Largest: {shapes.Largest()}");

    // Record 不可变更新
    var origin = Point.Origin;
    var shifted = origin with { X = 3.0, Y = 4.0 };
    Console.WriteLine($"Distance: {origin.DistanceTo(shifted):F2}");   // 5.00

    // Vector
    var v1 = new Vector2(3, 0);
    var v2 = new Vector2(0, 4);
    var sum = v1 + v2;
    Console.WriteLine($"Vector sum length: {sum.Length:F2}");           // 5.00
}
