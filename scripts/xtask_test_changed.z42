// xtask — `test changed` body (unify-scripts-into-xtask; folded from the former
// standalone scripts/test-changed.z42). Same Z42Xtask namespace.
//
// Inspect uncommitted git changes, map each file to a coarse test command,
// dedupe, and run the union in order. Mirrors docs/design/testing/testing.md
// "增量测试" mapping. Driven in-process by `_testChanged` (xtask.z42), which
// parses the legacy CLI (base ref positional + --dry-run) and calls
// `_testChangedRun(base_, dryRun)` directly.
//
// Each mapped plan command is a logical `xtask test …` (run by re-entering the
// in-process test router `_test`, NOT by shelling out) or a raw `cargo …`
// (run via `_exec(new Process("cargo")…)`). First failing command
// short-circuits the remainder.
//
// Shared helpers (_root / _exec / _at / _splitWords / _append / _sortStrings)
// live in xtask.z42 / xtask_golden.z42 (same namespace) and are not redefined
// here. The file-classification / git-output helpers below are module-private.
namespace Z42Xtask;

using Std;
using Std.IO;

// `test changed` body — run in-process. Returns the overall exit code:
// 0 on success, 2 when not a git repo / spawn failure, or the first failing
// command's exit code. `base_` is the diff base (default "HEAD" resolved by
// the caller); `dryRun` prints the plan without executing.
int _testChangedRun(string base_, bool dryRun) {
    if (!_isInGitRepo()) {
        ConsoleError.WriteLine("[test-changed] error: not a git repository");
        return 2;
    }

    Console.WriteLine("[test-changed] base = " + base_);

    // ── Collect changed files ────────────────────────────────────────────
    string tracked   = _gitOutput(new string[]{ "diff", "--name-only", base_, "--" });
    string untracked = _gitOutput(new string[]{ "ls-files", "--others", "--exclude-standard" });
    string[] changed = _dedupeNonEmpty(_splitLines(tracked + "\n" + untracked));

    if (changed.Length == 0) {
        Console.WriteLine("[test-changed] no changed files; nothing to run");
        return 0;
    }

    Console.WriteLine("[test-changed] changed files (" + changed.Length.ToString() + "):");
    int li = 0;
    while (li < changed.Length) {
        Console.WriteLine("  " + changed[li]);
        li = li + 1;
    }

    // ── Map each file → test command ─────────────────────────────────────
    string[] plan = new string[8];
    int      planCount = 0;
    bool needsFull = false;
    bool touchedAny = false;
    int i = 0;
    while (i < changed.Length) {
        string f = changed[i];
        _MapResult m = _mapFile(f);
        if (m.needsFull) {
            needsFull = true;
            touchedAny = true;
        } else if (m.touchedAny) {
            touchedAny = true;
            int ci = 0;
            while (ci < m.commands.Length) {
                if (m.commands[ci].Length > 0
                    && !_contains(plan, planCount, m.commands[ci])) {
                    plan = _append(plan, planCount, m.commands[ci]);
                    planCount = planCount + 1;
                }
                ci = ci + 1;
            }
        }
        i = i + 1;
    }

    if (needsFull) {
        plan = new string[1];
        plan[0] = "xtask test all";
        planCount = 1;
    }

    if (planCount == 0) {
        if (!touchedAny) {
            Console.WriteLine(
                "[test-changed] only documentation / spec / config touched; no tests to run");
        } else {
            Console.WriteLine(
                "[test-changed] no test commands mapped (changes don't affect any test scope)");
        }
        return 0;
    }

    // ── Plan output ──────────────────────────────────────────────────────
    Console.WriteLine("[test-changed] plan:");
    int pi = 0;
    while (pi < planCount) {
        Console.WriteLine("  → " + plan[pi]);
        pi = pi + 1;
    }

    if (dryRun) {
        Console.WriteLine("[test-changed] --dry-run: not executing");
        return 0;
    }

    // ── Execution ────────────────────────────────────────────────────────
    Console.WriteLine("[test-changed] running...");
    Console.WriteLine("");

    int exitCode = 0;
    pi = 0;
    while (pi < planCount) {
        string cmd = plan[pi];
        Console.WriteLine("──── " + cmd + " ────");
        int rc = _runPlanCmd(cmd);
        if (rc != 0) {
            exitCode = rc;
            Console.WriteLine("[test-changed] command failed: " + cmd
                + "  (exit " + exitCode.ToString() + ")");
            break;
        }
        Console.WriteLine("");
        pi = pi + 1;
    }

    if (exitCode == 0) {
        Console.WriteLine("[test-changed] result: ok");
    }
    return exitCode;
}

// Run one plan command in-process. Logical `xtask test …` re-enters the test
// router `_test` (argv[0] == "test"); raw `cargo …` runs via _exec. Returns the
// command's exit code (2 on an unrecognized prefix, which shouldn't occur given
// the mapping only ever emits these two shapes).
int _runPlanCmd(string cmd) {
    string[] toks = _splitWords(cmd);
    if (toks.Length == 0) { return 0; }
    if (toks[0] == "xtask") {
        // Drop the leading "xtask"; the remainder ("test", "vm", …) is the
        // _test argv (sub = argv[1]).
        string[] argv = new string[toks.Length - 1];
        int i = 1;
        while (i < toks.Length) { argv[i - 1] = toks[i]; i = i + 1; }
        return _test(argv);
    }
    if (toks[0] == "cargo") {
        Process p = new Process("cargo");
        int i = 1;
        while (i < toks.Length) { p = p.Arg(toks[i]); i = i + 1; }
        return _exec(p);
    }
    ConsoleError.WriteLine("[test-changed] internal error: unrecognized plan command: " + cmd);
    return 2;
}

// ── Mapping ──────────────────────────────────────────────────────────────

class _MapResult {
    public string[] commands;
    public bool needsFull;
    public bool touchedAny;

    public _MapResult() {
        this.commands = new string[0];
        this.needsFull = false;
        this.touchedAny = false;
    }
}

_MapResult _mapFile(string f) {
    var r = new _MapResult();

    // Docs / spec / claude state — no tests.
    if (_endsWith(f, ".md")
        || _startsWith(f, "docs/")
        || _startsWith(f, ".claude/")
        || f == ".gitignore"
        || f == ".gitattributes"
        || _startsWithPrefix(f, "LICENSE")
        || _startsWithPrefix(f, "README")) {
        return r;
    }

    // Stdlib library.
    if (_startsWith(f, "src/libraries/")) {
        string lib = _segment(f, 2);
        if (_containsSlash(f, "/src/")) {
            r.commands = new string[2];
            r.commands[0] = "xtask test lib " + lib;
            r.commands[1] = "xtask test vm";
            r.touchedAny = true;
            return r;
        }
        if (_containsSlash(f, "/tests/")) {
            r.commands = new string[1];
            r.commands[0] = "xtask test lib " + lib;
            r.touchedAny = true;
            return r;
        }
        if (_endsWith(f, ".toml")) {
            r.commands = new string[1];
            r.commands[0] = "xtask test lib " + lib;
            r.touchedAny = true;
            return r;
        }
        // Catch-all (workspace.toml at root, README inside lib root, etc.)
        return r;
    }

    // Runtime (Rust VM).
    if (_startsWith(f, "src/runtime/src/")
        || f == "src/runtime/Cargo.toml"
        || f == "src/runtime/Cargo.lock"
        || f == "src/runtime/build.rs") {
        r.commands = new string[2];
        r.commands[0] = "cargo test --manifest-path src/runtime/Cargo.toml";
        r.commands[1] = "xtask test vm";
        r.touchedAny = true;
        return r;
    }
    if (_startsWith(f, "src/runtime/tests/")) {
        r.commands = new string[1];
        r.commands[0] = "cargo test --manifest-path src/runtime/Cargo.toml";
        r.touchedAny = true;
        return r;
    }
    if (_startsWith(f, "src/tests/cross-zpkg/")) {
        r.commands = new string[1];
        r.commands[0] = "xtask test cross-zpkg";
        r.touchedAny = true;
        return r;
    }
    if (_startsWith(f, "src/tests/")) {
        r.commands = new string[1];
        r.commands[0] = "xtask test vm";
        r.touchedAny = true;
        return r;
    }

    // C# compiler.
    if (_startsWith(f, "src/compiler/")) {
        r.commands = new string[2];
        r.commands[0] = "xtask test compiler";
        r.commands[1] = "xtask test vm";
        r.touchedAny = true;
        return r;
    }

    // Toolchain.
    if (_startsWith(f, "src/toolchain/")) {
        r.commands = new string[2];
        r.commands[0] = "cargo test --manifest-path src/toolchain/test-runner/Cargo.toml";
        r.commands[1] = "xtask test lib";
        r.touchedAny = true;
        return r;
    }

    // All xtask CLI source is now ONE compiled xtask.zpkg (the test-vm / regen /
    // cross / dist / stdlib logic all folded in), so any scripts/xtask* change
    // rebuilds the whole CLI → full sweep. A change to the stdlib-build module
    // (xtask_stdlib.z42) also affects every downstream test. Workspace config too.
    if (_startsWith(f, "scripts/xtask")
        || _endsWith(f, ".workspace.toml")) {
        r.needsFull = true;
        r.touchedAny = true;
        return r;
    }

    // Anything else under src/ → full sweep (defensive).
    if (_startsWith(f, "src/")) {
        r.needsFull = true;
        r.touchedAny = true;
        return r;
    }

    // Examples / artifacts / bench — no test impact.
    if (_startsWith(f, "examples/")
        || _startsWith(f, "artifacts/")
        || _startsWith(f, "bench/")) {
        return r;
    }

    // Unknown root-level file → full sweep (safe default).
    r.needsFull = true;
    r.touchedAny = true;
    return r;
}

// ── Git helpers ──────────────────────────────────────────────────────────

bool _isInGitRepo() {
    try {
        ProcessResult r = new Process("git")
            .Arg("rev-parse").Arg("--is-inside-work-tree")
            .Stdout(Stdio.Null()).Stderr(Stdio.Null())
            .Run();
        return r.ExitCode == 0;
    } catch (Exception e) {
        return false;
    }
}

string _gitOutput(string[] args) {
    try {
        ProcessResult r = new Process("git")
            .Args(args)
            .Stderr(Stdio.Null())
            .Run();
        if (r.ExitCode != 0) return "";
        return r.Stdout;
    } catch (Exception e) {
        return "";
    }
}

// ── String / array helpers (module-private) ──────────────────────────────

bool _startsWith(string s, string prefix) {
    if (s.Length < prefix.Length) return false;
    int i = 0;
    while (i < prefix.Length) {
        if (s.CharAt(i) != prefix.CharAt(i)) return false;
        i = i + 1;
    }
    return true;
}

// Allow either exact "LICENSE" or "LICENSE.md" / "LICENSE-MIT" style.
bool _startsWithPrefix(string s, string prefix) {
    return _startsWith(s, prefix);
}

bool _endsWith(string s, string suffix) {
    if (s.Length < suffix.Length) return false;
    int off = s.Length - suffix.Length;
    int i = 0;
    while (i < suffix.Length) {
        if (s.CharAt(off + i) != suffix.CharAt(i)) return false;
        i = i + 1;
    }
    return true;
}

bool _containsSlash(string s, string needle) {
    int i = 0;
    int limit = s.Length - needle.Length;
    while (i <= limit) {
        bool match = true;
        int j = 0;
        while (j < needle.Length) {
            if (s.CharAt(i + j) != needle.CharAt(j)) { match = false; break; }
            j = j + 1;
        }
        if (match) return true;
        i = i + 1;
    }
    return false;
}

// Return the n-th path segment (0-based; '/'-split).
string _segment(string path, int n) {
    int idx = 0;
    int start = 0;
    int i = 0;
    while (i <= path.Length) {
        if (i == path.Length || path.CharAt(i) == '/') {
            if (idx == n) {
                return path.Substring(start, i - start);
            }
            idx = idx + 1;
            start = i + 1;
        }
        i = i + 1;
    }
    return "";
}

string[] _splitLines(string s) {
    string[] result = new string[8];
    int n = 0;
    int start = 0;
    int i = 0;
    while (i <= s.Length) {
        if (i == s.Length || s.CharAt(i) == '\n') {
            if (i > start) {
                result = _append(result, n, s.Substring(start, i - start));
                n = n + 1;
            }
            start = i + 1;
        }
        i = i + 1;
    }
    string[] tight = new string[n];
    int t = 0;
    while (t < n) { tight[t] = result[t]; t = t + 1; }
    return tight;
}

string[] _dedupeNonEmpty(string[] xs) {
    string[] result = new string[xs.Length];
    int n = 0;
    int i = 0;
    while (i < xs.Length) {
        if (xs[i].Length > 0 && !_contains(result, n, xs[i])) {
            result[n] = xs[i];
            n = n + 1;
        }
        i = i + 1;
    }
    // Tighten to exactly the deduped elements, then sort with the shared
    // arity-1 _sortStrings (xtask_golden.z42) which sorts the whole array.
    string[] tight = new string[n];
    int t = 0;
    while (t < n) { tight[t] = result[t]; t = t + 1; }
    _sortStrings(tight);
    return tight;
}

bool _contains(string[] arr, int count, string v) {
    int i = 0;
    while (i < count) {
        if (arr[i] == v) return true;
        i = i + 1;
    }
    return false;
}
