// xtask — `test changed` body (unify-scripts-into-xtask; folded from the former
// standalone scripts/test-changed.z42). Same Z42Xtask namespace.
//
// Inspect uncommitted git changes, map each file to a coarse test command,
// dedupe, and run the union in order. Mirrors docs/design/testing/testing.md
// "增量测试" mapping. Driven in-process by `_testChanged` (xtask.z42), which
// parses the legacy CLI (base ref positional + --dry-run) and calls
// `_testChangedRun(base_, dryRun)` directly.
//
// Each mapped plan command is a logical `xtask test …` (run by re-entering the
// in-process test router `_test`, NOT by shelling out) or a raw `cargo …`
// (run via `_exec(new Process("cargo")…)`). First failing command
// short-circuits the remainder.
//
// Shared helpers (_root / _exec / _at / _splitWords / _append / _sortStrings)
// live in xtask.z42 / xtask_golden.z42 (same namespace) and are not redefined
// here. The file-classification / git-output helpers below are module-private.
namespace Z42Xtask;

using Std;
using Std.IO;

// `test changed` body — run in-process. Returns the overall exit code:
// 0 on success, 2 when not a git repo / spawn failure, or the first failing
// command's exit code. `base_` is the diff base (default "HEAD" resolved by
// the caller); `dryRun` prints the plan without executing.
int _testChangedRun(string base_, bool dryRun) {
    if (!_isInGitRepo()) {
        ConsoleError.WriteLine("[test-changed] error: not a git repository");
        return 2;
    }
    Console.WriteLine("[test-changed] base = " + base_);

    // ── Collect changed files ────────────────────────────────────────────
    string tracked   = _gitOutput(new string[]{ "diff", "--name-only", base_, "--" });
    string untracked = _gitOutput(new string[]{ "ls-files", "--others", "--exclude-standard" });
    string[] changed = _dedupeNonEmpty(_splitLines(tracked + "\n" + untracked));

    if (changed.Length == 0) {
        Console.WriteLine("[test-changed] no changed files; nothing to run");
        return 0;
    }

    Console.WriteLine("[test-changed] changed files (" + changed.Length.ToString() + "):");
    int li = 0;
    while (li < changed.Length) {
        Console.WriteLine("  " + changed[li]);
        li = li + 1;
    }

    // ── Map → de-duped plan ──────────────────────────────────────────────
    _ChangedPlan plan = _buildChangedPlan(changed);
    if (plan.cmds.Length == 0) {
        if (!plan.touchedAny) {
            Console.WriteLine(
                "[test-changed] only documentation / spec / config touched; no tests to run");
        } else {
            Console.WriteLine(
                "[test-changed] no test commands mapped (changes don't affect any test scope)");
        }
        return 0;
    }

    // ── Plan output ──────────────────────────────────────────────────────
    Console.WriteLine("[test-changed] plan:");
    int pi = 0;
    while (pi < plan.cmds.Length) {
        Console.WriteLine("  → " + plan.cmds[pi]);
        pi = pi + 1;
    }

    if (dryRun) {
        Console.WriteLine("[test-changed] --dry-run: not executing");
        return 0;
    }

    return _executeChangedPlan(plan.cmds);
}

// Plan derived from the changed-file set: the de-duped command list to run
// (right-sized), plus whether any file was classified at all — which drives the
// "only docs touched" vs "nothing mapped" message when cmds is empty.
class _ChangedPlan {
    public string[] cmds;
    public bool touchedAny;
    public _ChangedPlan() { this.cmds = new string[0]; this.touchedAny = false; }
}

// Map every changed file (_mapFile) into a de-duped plan. needsFull on any file
// collapses the whole plan to the full gate ("xtask test all").
_ChangedPlan _buildChangedPlan(string[] changed) {
    var p = new _ChangedPlan();
    string[] plan = new string[8];
    int planCount = 0;
    bool needsFull = false;
    int i = 0;
    while (i < changed.Length) {
        _MapResult m = _mapFile(changed[i]);
        if (m.needsFull) {
            needsFull = true;
            p.touchedAny = true;
        } else if (m.touchedAny) {
            p.touchedAny = true;
            int ci = 0;
            while (ci < m.commands.Length) {
                if (m.commands[ci].Length > 0
                    && !_contains(plan, planCount, m.commands[ci])) {
                    plan = _append(plan, planCount, m.commands[ci]);
                    planCount = planCount + 1;
                }
                ci = ci + 1;
            }
        }
        i = i + 1;
    }
    if (needsFull) {
        p.cmds = new string[1];
        p.cmds[0] = "xtask test all";
        return p;
    }
    string[] sized = new string[planCount];
    int k = 0;
    while (k < planCount) { sized[k] = plan[k]; k = k + 1; }
    p.cmds = sized;
    return p;
}

// Run each plan command in order; first failure short-circuits. Returns the
// overall exit code (first failing command's code, or 0).
int _executeChangedPlan(string[] cmds) {
    Console.WriteLine("[test-changed] running...");
    Console.WriteLine("");

    int exitCode = 0;
    int pi = 0;
    while (pi < cmds.Length) {
        string cmd = cmds[pi];
        Console.WriteLine("──── " + cmd + " ────");
        int rc = _runPlanCmd(cmd);
        if (rc != 0) {
            exitCode = rc;
            Console.WriteLine("[test-changed] command failed: " + cmd
                + "  (exit " + exitCode.ToString() + ")");
            break;
        }
        Console.WriteLine("");
        pi = pi + 1;
    }

    if (exitCode == 0) {
        Console.WriteLine("[test-changed] result: ok");
    }
    return exitCode;
}

// Run one plan command in-process. Logical `xtask test …` re-enters the
// Std.Cli router via `_runCli` (argv[0] == "test"); raw `cargo …` runs via
// _exec. Returns the command's exit code (2 on an unrecognized prefix, which
// shouldn't occur given the mapping only ever emits these two shapes).
int _runPlanCmd(string cmd) {
    string[] toks = _splitWords(cmd);
    if (toks.Length == 0) { return 0; }
    if (toks[0] == "xtask") {
        // Drop the leading "xtask"; the remainder ("test", "vm", …) is the
        // _runCli argv (argv[0] == "test").
        string[] argv = new string[toks.Length - 1];
        int i = 1;
        while (i < toks.Length) { argv[i - 1] = toks[i]; i = i + 1; }
        return _runCli(argv);
    }
    if (toks[0] == "cargo") {
        Process p = new Process("cargo");
        int i = 1;
        while (i < toks.Length) { p = p.Arg(toks[i]); i = i + 1; }
        return _exec(p);
    }
    ConsoleError.WriteLine("[test-changed] internal error: unrecognized plan command: " + cmd);
    return 2;
}

// ── Mapping ──────────────────────────────────────────────────────────────

class _MapResult {
    public string[] commands;
    public bool needsFull;
    public bool touchedAny;

    public _MapResult() {
        this.commands = new string[0];
        this.needsFull = false;
        this.touchedAny = false;
    }
}

// _MapResult shorthands: _mapCmds = run this command list; _mapFull = full sweep;
// _mapSkip = no test impact. (touchedAny tracks "this file was classified at all".)
_MapResult _mapCmds(string[] cmds) {
    var r = new _MapResult();
    r.commands = cmds;
    r.touchedAny = true;
    return r;
}
_MapResult _mapFull() {
    var r = new _MapResult();
    r.needsFull = true;
    r.touchedAny = true;
    return r;
}
_MapResult _mapSkip() { return new _MapResult(); }

// src/libraries/<lib>/... → lib [+ vm] tests. Non-src/test/toml paths inside a
// lib (workspace.toml at root, README inside lib root, etc.) → no test impact.
_MapResult _mapLibraryFile(string f) {
    string lib = _segment(f, 2);
    if (f.Contains("/src/"))   { return _mapCmds(new string[]{ "xtask test lib " + lib, "xtask test vm" }); }
    if (f.Contains("/tests/")) { return _mapCmds(new string[]{ "xtask test lib " + lib }); }
    if (f.EndsWith(".toml"))   { return _mapCmds(new string[]{ "xtask test lib " + lib }); }
    return _mapSkip();
}

_MapResult _mapFile(string f) {
    // Docs / spec / claude state — no tests.
    if (f.EndsWith(".md") || f.StartsWith("docs/") || f.StartsWith(".claude/")
        || f == ".gitignore" || f == ".gitattributes"
        || f.StartsWith("LICENSE") || f.StartsWith("README")) { return _mapSkip(); }

    if (f.StartsWith("src/libraries/")) { return _mapLibraryFile(f); }

    // Runtime (Rust VM).
    if (f.StartsWith("src/runtime/src/") || f == "src/runtime/Cargo.toml"
        || f == "src/runtime/Cargo.lock" || f == "src/runtime/build.rs") {
        return _mapCmds(new string[]{ "cargo test --manifest-path src/runtime/Cargo.toml", "xtask test vm" });
    }
    if (f.StartsWith("src/runtime/tests/")) {
        return _mapCmds(new string[]{ "cargo test --manifest-path src/runtime/Cargo.toml" });
    }
    if (f.StartsWith("src/tests/cross-zpkg/")) { return _mapCmds(new string[]{ "xtask test cross-zpkg" }); }
    if (f.StartsWith("src/tests/"))            { return _mapCmds(new string[]{ "xtask test vm" }); }

    // z42c self-host compiler (src/z42c).
    if (f.StartsWith("src/z42c/")) {
        return _mapCmds(new string[]{ "xtask test compiler-z42", "xtask test vm" });
    }
    // Toolchain.
    if (f.StartsWith("src/toolchain/")) {
        return _mapCmds(new string[]{ "cargo test --manifest-path src/toolchain/test-runner/Cargo.toml", "xtask test lib" });
    }

    // All xtask CLI source is now ONE compiled xtask.zpkg (test-vm / regen / cross /
    // dist / stdlib logic all folded in), so any scripts/xtask* change rebuilds the
    // whole CLI → full sweep. Workspace config too.
    if (f.StartsWith("scripts/xtask") || f.EndsWith(".workspace.toml")) { return _mapFull(); }
    // Anything else under src/ → full sweep (defensive).
    if (f.StartsWith("src/")) { return _mapFull(); }

    // Examples / artifacts / bench — no test impact.
    if (f.StartsWith("examples/") || f.StartsWith("artifacts/") || f.StartsWith("bench/")) { return _mapSkip(); }

    // Unknown root-level file → full sweep (safe default).
    return _mapFull();
}

// ── Git helpers ──────────────────────────────────────────────────────────

bool _isInGitRepo() {
    try {
        ProcessResult r = new Process("git")
            .Arg("rev-parse").Arg("--is-inside-work-tree")
            .Stdout(Stdio.Null()).Stderr(Stdio.Null())
            .Run();
        return r.ExitCode == 0;
    } catch (Exception e) {
        return false;
    }
}

string _gitOutput(string[] args) {
    try {
        ProcessResult r = new Process("git")
            .Args(args)
            .Stderr(Stdio.Null())
            .Run();
        if (r.ExitCode != 0) return "";
        return r.Stdout;
    } catch (Exception e) {
        return "";
    }
}

// ── String / array helpers (module-private) ──────────────────────────────

// Prefix/suffix/substring tests use native String.StartsWith / EndsWith /
// Contains (z42.core String.z42) — the former hand-rolled CharAt loops were
// byte-equivalent. "LICENSE" / "README" matching is StartsWith (covers
// "LICENSE.md" / "LICENSE-MIT" style suffixes).

// Return the n-th path segment (0-based; '/'-split).
string _segment(string path, int n) {
    int idx = 0;
    int start = 0;
    int i = 0;
    while (i <= path.Length) {
        if (i == path.Length || path.CharAt(i) == '/') {
            if (idx == n) {
                return path.Substring(start, i - start);
            }
            idx = idx + 1;
            start = i + 1;
        }
        i = i + 1;
    }
    return "";
}

string[] _splitLines(string s) {
    string[] result = new string[8];
    int n = 0;
    int start = 0;
    int i = 0;
    while (i <= s.Length) {
        if (i == s.Length || s.CharAt(i) == '\n') {
            if (i > start) {
                result = _append(result, n, s.Substring(start, i - start));
                n = n + 1;
            }
            start = i + 1;
        }
        i = i + 1;
    }
    string[] tight = new string[n];
    int t = 0;
    while (t < n) { tight[t] = result[t]; t = t + 1; }
    return tight;
}

string[] _dedupeNonEmpty(string[] xs) {
    string[] result = new string[xs.Length];
    int n = 0;
    int i = 0;
    while (i < xs.Length) {
        if (xs[i].Length > 0 && !_contains(result, n, xs[i])) {
            result[n] = xs[i];
            n = n + 1;
        }
        i = i + 1;
    }
    // Tighten to exactly the deduped elements, then sort with the shared
    // arity-1 _sortStrings (xtask_golden.z42) which sorts the whole array.
    string[] tight = new string[n];
    int t = 0;
    while (t < n) { tight[t] = result[t]; t = t + 1; }
    _sortStrings(tight);
    return tight;
}

bool _contains(string[] arr, int count, string v) {
    int i = 0;
    while (i < count) {
        if (arr[i] == v) return true;
        i = i + 1;
    }
    return false;
}
