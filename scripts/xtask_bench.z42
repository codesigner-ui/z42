// xtask — e2e benchmarks (migrate-scripts-to-z42). Native port of
// the former scripts/bench-run.sh + scripts/_merge-bench-results.py. Compiles
// bench/scenarios/*.z42, runs hyperfine on z42vm per scenario, then merges the
// hyperfine JSONs into bench/results/e2e.json — parse with native Std.Json,
// output string-built (replacing python3). Same Z42Xtask namespace; calls
// _exec/_root/_buildRuntime/_utcNow in xtask.z42 / xtask_package.z42.
namespace Z42Xtask;

using Std;
using Std.IO;
using Std.Json;
using Std.Cli;

// `bench` (no subcommand) — e2e hyperfine scenario runner. The `stdlib`
// subcommand (per-lib [Benchmark]) routes via _dispatchBench → _testLib, and
// `--diff` routes via _benchE2e → _benchDiff (both in xtask_cli.z42). This
// handler is the bare-e2e path; args from a Std.Cli ParseResult.
int _bench(ParseResult r) {
    bool quick = r.GetFlag("quick");
    string warmup = quick ? "1" : "3";
    string runs = quick ? "3" : "10";
    string root = _root();
    string scenDir = Path.Join(root, "bench/scenarios");
    string resultsDir = Path.Join(root, "bench/results");
    Directory.Create(resultsDir);
    string vm = _builtVm(root, "release");
    if (!File.Exists(vm)) { int rc = _buildRuntime(); if (rc != 0) { return rc; } }
    string libs = _libsDir(root);
    // 2026-06-05: bench scenarios `using Std.IO.Console` so stdlib must be
    // built and present at `libs` before z42vm runs the .zbc. CI bench
    // workflow only bootstraps xtask itself (against nightly .z42/libs), so
    // the source-built `libs` dir starts empty — build it here.
    if (!File.Exists(Path.Join(libs, "z42.core.zpkg"))) {
        int sc = _buildStdlib();
        if (sc != 0) { return sc; }
    }
    // remove-dotnet-from-builds: scenarios compile via z42c (z42vm + driver),
    // not `dotnet run`. Ensure the z42c seed is built, then assemble alllibs flat
    // (stdlib + z42c 7 siblings) as the single Z42_LIBS dir for the compile —
    // z42c.driver needs its own siblings resolvable at runtime, scenario stdlib
    // deps resolve from the same dir.
    int czc = _buildCompiler(); if (czc != 0) { return czc; }
    string driverZpkg = Path.Join(root, "artifacts/build/z42c/z42c.driver/release/dist/z42c.driver.zpkg");
    string flat = _assembleAllLibs(root, "release");
    string work = Directory.CreateTempDir("xtask-bench");

    string benchmarks = "";
    int count = 0;
    foreach (var f in Directory.Enumerate(scenDir)) {
        if (!f.EndsWith(".z42")) { continue; }
        if (quick && count >= 2) { break; }
        string name = f.Substring(0, f.Length - 4);
        string src = Path.Join(scenDir, f);
        string ns = _extractNamespace(File.ReadAllText(src));
        if (ns.Length == 0) { ConsoleError.WriteLine("error: no namespace in " + f); return 2; }
        string zbc = Path.Join(work, name + ".zbc");
        int cc = _exec(new Process(vm).Arg(driverZpkg).Arg("--mode").Arg("interp").Arg("--")
            .Arg("--emit-zbc").Arg(src).Arg(zbc).Env("Z42_LIBS", flat));
        if (cc != 0) { return cc; }
        string outJson = Path.Join(work, name + "-bench.json");
        Console.WriteLine("→ Benchmarking " + name + " (warmup=" + warmup + ", runs=" + runs + ")...");
        int hc = _exec(new Process("hyperfine")
            .Arg("--warmup").Arg(warmup).Arg("--runs").Arg(runs)
            .Arg("--export-json").Arg(outJson).Arg("--shell=none").Arg("--command-name").Arg(name)
            .Arg(vm + " " + zbc + " " + ns + ".Main").Env("Z42_LIBS", libs));
        if (hc != 0) { return hc; }
        if (benchmarks.Length > 0) { benchmarks = benchmarks + ",\n"; }
        benchmarks = benchmarks + _benchObj(outJson, name, runs);
        count = count + 1;
    }

    string commit = _gitOut(root, "rev-parse", "--short", "HEAD");
    string branch = _gitOut(root, "rev-parse", "--abbrev-ref", "HEAD");
    string doc = "{\n  \"schema_version\": 1,\n  \"commit\": \"" + commit
        + "\",\n  \"branch\": \"" + branch + "\",\n  \"os\": \"" + _osTag()
        + "\",\n  \"timestamp\": \"" + _utcNow() + "\",\n  \"benchmarks\": [\n"
        + benchmarks + "\n  ]\n}\n";
    string outFile = Path.Join(resultsDir, "e2e.json");
    File.WriteAllText(outFile, doc);
    Console.WriteLine("✅ E2E bench complete. Results: " + outFile);
    return 0;
}

// `bench --diff [--current P] [--baseline P] [--threshold-time T] [--threshold-memory M] [--quiet]`
// Native port of the former scripts/bench-diff.sh. Compares current bench results
// against a baseline (both conform to bench/baseline-schema.json): per-benchmark
// delta = (cur - base) / base; a time delta > --threshold-time (default 0.05) or
// a memory delta > --threshold-memory (default 0.10) is a regression. Exit codes:
// 0 = no regression, 1 = regression above threshold, 2 = tool error.
int _benchDiff(ParseResult r) {
    string root = _root();
    string current = r.GetOption("current");
    if (current.Length == 0) { current = "bench/results/e2e.json"; }
    string baseline = r.GetOption("baseline");
    double thrTime = 0.05;
    string tt = r.GetOption("threshold-time");
    if (tt.Length > 0) { thrTime = Double.Parse(tt); }
    double thrMem = 0.10;
    string tm = r.GetOption("threshold-memory");
    if (tm.Length > 0) { thrMem = Double.Parse(tm); }
    bool quiet = r.GetFlag("quiet");
    if (baseline.Length == 0) { baseline = "bench/baselines/main-" + _osTag() + ".json"; }
    string curPath  = _absUnder(root, current);
    string basePath = _absUnder(root, baseline);
    if (!File.Exists(curPath))  { ConsoleError.WriteLine("error: current results not found: " + current); return 2; }
    if (!File.Exists(basePath)) { ConsoleError.WriteLine("error: baseline not found: " + baseline); return 2; }

    JsonValue cur  = JsonValue.Parse(File.ReadAllText(curPath));
    JsonValue base_ = JsonValue.Parse(File.ReadAllText(basePath));
    JsonValue curBs  = cur.Get("benchmarks");
    JsonValue baseBs = base_.Get("benchmarks");

    if (!quiet) {
        Console.WriteLine("Comparing:");
        Console.WriteLine("  current:  " + cur.Get("commit").AsString() + " on " + cur.Get("os").AsString() + "  (" + current + ")");
        Console.WriteLine("  baseline: " + base_.Get("commit").AsString() + " on " + base_.Get("os").AsString() + " (" + baseline + ")");
        Console.WriteLine("  thresholds: time>" + thrTime.ToString() + "=fail, memory>" + thrMem.ToString() + "=fail");
        Console.WriteLine("");
    }

    int regressions = 0;
    int total = 0;
    // current-driven diff (matches baseline by name+metric; (new) when absent).
    int j = 0;
    while (j < curBs.Count()) {
        JsonValue c = curBs.At(j);
        string name   = c.Get("name").AsString();
        string metric = c.Get("metric").AsString();
        double curV   = c.Get("value").AsDouble();
        string unit   = c.Get("unit").AsString();
        total = total + 1;
        string label = name + " [" + metric + "]";
        double baseV = _findBenchValue(baseBs, name, metric);
        if (baseV < 0.0) {
            if (!quiet) { Console.WriteLine("  " + label + "  (new)  " + curV.ToString() + " " + unit); }
            j = j + 1; continue;
        }
        if (baseV == 0.0) {
            if (!quiet) { Console.WriteLine("  " + label + "  baseline=0 (skip)"); }
            j = j + 1; continue;
        }
        double delta = (curV - baseV) / baseV;
        bool isMem = (metric == "memory" || unit == "bytes" || unit == "KB" || unit == "MB");
        double thr = isMem ? thrMem : thrTime;
        string sym = "≈";
        if (delta > thr) { sym = "↑"; regressions = regressions + 1; }
        else if (delta < (0.0 - thr)) { sym = "↓"; }
        if (!quiet || delta > thr) {
            Console.WriteLine("  " + label + "  " + baseV.ToString() + " " + unit
                + " → " + curV.ToString() + " " + unit + "  " + sym + " " + (delta * 100.0).ToString() + "%");
        }
        j = j + 1;
    }
    // baseline-only (removed) annotations — informational, never a regression.
    if (!quiet) {
        int k = 0;
        while (k < baseBs.Count()) {
            JsonValue b = baseBs.At(k);
            string name   = b.Get("name").AsString();
            string metric = b.Get("metric").AsString();
            if (_findBenchValue(curBs, name, metric) < 0.0) {
                Console.WriteLine("  " + name + " [" + metric + "]  (removed)  "
                    + b.Get("value").AsDouble().ToString() + " " + b.Get("unit").AsString());
            }
            k = k + 1;
        }
    }

    Console.WriteLine("");
    if (regressions > 0) {
        Console.WriteLine("❌ " + regressions.ToString() + " regression(s) above threshold (out of " + total.ToString() + " benchmarks)");
        return 1;
    }
    Console.WriteLine("✅ no regression above threshold (" + total.ToString() + " benchmarks compared)");
    return 0;
}

// value of the benchmark with matching name+metric, or -1.0 if absent.
double _findBenchValue(JsonValue benchmarks, string name, string metric) {
    int i = 0;
    while (i < benchmarks.Count()) {
        JsonValue b = benchmarks.At(i);
        if (b.Get("name").AsString() == name && b.Get("metric").AsString() == metric) {
            return b.Get("value").AsDouble();
        }
        i = i + 1;
    }
    return -1.0;
}

// resolve a possibly-relative path under the repo root (absolute paths unchanged).
string _absUnder(string root, string p) {
    if (p.StartsWith("/")) { return p; }
    return Path.Join(root, p);
}

// one benchmark object from a hyperfine export JSON (time values are seconds → ms).
string _benchObj(string hjson, string name, string runs) {
    JsonValue r0 = JsonValue.Parse(File.ReadAllText(hjson)).Get("results").At(0);
    string val = (r0.Get("mean").AsDouble() * 1000.0).ToString();
    string lo  = (r0.Get("min").AsDouble()  * 1000.0).ToString();
    string hi  = (r0.Get("max").AsDouble()  * 1000.0).ToString();
    return "    {\n      \"name\": \"" + name + "\",\n      \"tier\": \"z42-e2e\""
        + ",\n      \"metric\": \"time\",\n      \"value\": " + val
        + ",\n      \"unit\": \"ms\",\n      \"ci_lower\": " + lo
        + ",\n      \"ci_upper\": " + hi + ",\n      \"samples\": " + runs + "\n    }";
}

string _gitOut(string root, string a, string b, string c) {
    ProcessResult r = new Process("git").Arg(a).Arg(b).Arg(c).WorkingDirectory(root).Run();
    if (r.ExitCode == 0) { return r.Stdout.Trim(); }
    return "unknown";
}

string _osTag() {
    ProcessResult r = new Process("uname").Arg("-sm").Run();
    if (r.ExitCode != 0) { return "unknown"; }
    return r.Stdout.Trim().ToLower().Replace(" ", "-");
}
