// xtask — test orchestration (split from xtask.z42 for the 500-line code-org
// limit). Same Z42Xtask namespace; these call _exec/_root/_z42vm/_build*/
// _regenCore/_at defined in xtask.z42 (cross-file, same namespace).
namespace Z42Xtask;

using Std;
using Std.IO;

// ── test vm ─────────────────────────────────────────────────────────────────

// `test vm [interp|jit] [--no-rebuild] [--jobs=N]` — native, bash-free.
// Mirrors the former scripts/test-vm.sh: regen (rebuild stdlib + compiler + golden zbc)
// unless --no-rebuild, build the DEBUG z42vm + compression cdylib (the VM runner
// resolves artifacts/build/runtime/debug/z42vm and JIT dlopens the compressor),
// then run the in-process golden runner (_runVmGoldens, xtask_test_vm.z42) with
// the parsed modes/jobs — no separate compile + zpkg spawn.
int _testVm(string[] argv) {
    string modes = "interp jit";
    bool rebuild = true;
    string jobs = "1";
    bool gotMode = false;
    int i = 2;
    while (i < argv.Length) {
        string a = argv[i];
        if (a == "--no-rebuild")        { rebuild = false; }
        else if (a.StartsWith("--jobs=")) { jobs = a.Substring(7); }
        else if (!a.StartsWith("-")) { if (!gotMode) { modes = a; gotMode = true; } }
        i = i + 1;
    }
    if (rebuild) { int c = _regenCore(false, true); if (c != 0) { return c; } }
    int cd = _exec(new Process("cargo").Arg("build").Arg("-q")
        .Arg("--manifest-path").Arg("src/runtime/Cargo.toml"));
    if (cd != 0) { return cd; }
    int cc = _exec(new Process("cargo").Arg("build").Arg("-q")
        .Arg("--manifest-path").Arg("src/runtime/crates/z42-compression/Cargo.toml"));
    if (cc != 0) { return cc; }
    // modes is a space-separated token string (e.g. "interp jit"); split to the
    // string[] _runVmGoldens expects. jobs parses to int (default 1 on garbage).
    string[] modeList = _splitWords(modes);
    int jobsN = 1;
    try { jobsN = int.Parse(jobs); } catch (Exception e) { jobsN = 1; }
    return _runVmGoldens(modeList, jobsN);
}

// ── test cross-zpkg ─────────────────────────────────────────────────────────

// `test cross-zpkg [interp|jit]` — native, bash-free. Mirrors
// the former scripts/test-cross-zpkg.sh: build compiler (slnx) + DEBUG runtime,
// ensure stdlib present, then run the in-process cross-zpkg driver
// (_testCrossZpkgImpl, xtask_test_cross.z42) with the parsed mode — no separate
// compile + zpkg spawn.
int _testCrossZpkg(string[] argv) {
    string mode = _at(argv, 2);
    if (mode.Length == 0) { mode = "interp"; }
    int c = _buildCompiler(); if (c != 0) { return c; }
    int cr = _exec(new Process("cargo").Arg("build").Arg("-q")
        .Arg("--manifest-path").Arg("src/runtime/Cargo.toml"));
    if (cr != 0) { return cr; }
    string root = _root();
    if (!File.Exists(Path.Join(root, "artifacts/build/libraries/dist/release/z42.core.zpkg"))) {
        int cs = _buildStdlib(); if (cs != 0) { return cs; }
    }
    return _testCrossZpkgImpl(mode);
}

// ── test dist (packaged-distribution e2e) ────────────────────────────────────

// `test dist [interp|jit]` — native port of the former scripts/test-dist.sh.
// Build the toolchain + a host release package (if absent), then run the
// in-process dist e2e (_testDistRun, xtask_test_dist.z42) which drives the
// PACKAGED z42c/z42vm against the goldens + a launcher smoke — no separate
// compile + zpkg spawn. Not in the default GREEN gate (run on demand).
int _testDist(string[] argv) {
    string root = _root();
    int c = _buildCompiler(); if (c != 0) { return c; }
    c = _exec(new Process("cargo").Arg("build").Arg("--release").Arg("-q")
        .Arg("--manifest-path").Arg("src/runtime/Cargo.toml")); if (c != 0) { return c; }
    if (!File.Exists(Path.Join(root, "artifacts/build/libraries/dist/release/z42.core.zpkg"))) {
        c = _buildStdlib(); if (c != 0) { return c; }
    }
    // Ensure a host release package exists (build it if absent).
    if (!_hasReleasePkg(root)) {
        string[] pa = new string[3]; pa[0] = "build"; pa[1] = "package"; pa[2] = "release";
        c = _buildPackage(pa); if (c != 0) { return c; }
    }
    return _testDistRun(argv);
}

bool _hasReleasePkg(string root) {
    string pkgs = Path.Join(root, "artifacts/packages");
    if (!Directory.Exists(pkgs)) { return false; }
    foreach (var name in Directory.Enumerate(pkgs)) {
        if (name.StartsWith("z42-") && name.EndsWith("-release")) { return true; }
    }
    return false;
}

// latest artifacts/packages/z42-*-release dir (absolute path), or "" if none.
// Lives here alongside _hasReleasePkg; called by _testDistRun (xtask_test_dist.z42).
string _latestReleasePkg(string root) {
    string pkgs = Path.Join(root, "artifacts/packages");
    if (!Directory.Exists(pkgs)) { return ""; }
    string best = "";
    foreach (var name in Directory.Enumerate(pkgs)) {
        if (name.StartsWith("z42-") && name.EndsWith("-release")) {
            string full = Path.Join(pkgs, name);
            if (Directory.Exists(full)) {
                // Prefer the lexicographically-greatest (stable; usually one host pkg).
                if (best.Length == 0 || name.CompareTo(Path.GetFileName(best)) > 0) { best = full; }
            }
        }
    }
    return best;
}

// ── test all (unified GREEN gate) ───────────────────────────────────────────

// `test` (no target) — the full GREEN gate, sequential: build once, then run
// compiler + VM goldens + cross-zpkg + stdlib, short-circuiting on first
// failure. Mirrors the former scripts/test-all.sh's stage set (the --parallel wave +
// --scope auto-narrow optimizations are a later increment).
int _testAll() {
    // build wave (once): stdlib + compiler driver + release runtime + golden zbc
    int c = _regenCore(false, true); if (c != 0) { return c; }
    // extra tooling the test stages need
    c = _exec(new Process("cargo").Arg("build").Arg("-q").Arg("--manifest-path").Arg("src/runtime/Cargo.toml")); if (c != 0) { return c; }            // debug z42vm
    c = _exec(new Process("cargo").Arg("build").Arg("-q").Arg("--manifest-path").Arg("src/runtime/crates/z42-compression/Cargo.toml")); if (c != 0) { return c; }
    c = _exec(new Process("cargo").Arg("build").Arg("--release").Arg("-q").Arg("--manifest-path").Arg("src/toolchain/test-runner/Cargo.toml")); if (c != 0) { return c; }
    c = _exec(new Process("dotnet").Arg("build").Arg("src/compiler/z42.slnx").Arg("--nologo").Arg("-v").Arg("quiet")); if (c != 0) { return c; }
    // stage 1: compiler (dotnet test)
    Console.WriteLine("\n=== stage: compiler tests ===");
    c = _exec(new Process("dotnet").Arg("test").Arg("src/compiler/z42.Tests/z42.Tests.csproj").Arg("--nologo")); if (c != 0) { return c; }
    // stage 2: VM goldens (both modes, no rebuild)
    Console.WriteLine("\n=== stage: VM goldens ===");
    string[] vmA = new string[4]; vmA[0] = "test"; vmA[1] = "vm"; vmA[2] = "--no-rebuild"; vmA[3] = "--jobs=4";
    c = _testVm(vmA); if (c != 0) { return c; }
    // stage 3: cross-zpkg
    Console.WriteLine("\n=== stage: cross-zpkg ===");
    string[] cA = new string[2]; cA[0] = "test"; cA[1] = "cross-zpkg";
    c = _testCrossZpkg(cA); if (c != 0) { return c; }
    // stage 4: stdlib [Test] (no build)
    Console.WriteLine("\n=== stage: stdlib [Test] ===");
    string[] lA = new string[4]; lA[0] = "test"; lA[1] = "lib"; lA[2] = "--no-build"; lA[3] = "--jobs=4";
    c = _testLib(lA); if (c != 0) { return c; }
    Console.WriteLine("\n✅ GREEN — all stages passed (compiler + vm + cross-zpkg + stdlib)");
    return 0;
}

// ── test lib (stdlib [Test] harness) ────────────────────────────────────────

// `test lib|stdlib [lib...] [--no-build] [-k filter]` — native stdlib [Test]
// harness. Mirrors the former scripts/test-lib.sh (sequential; --jobs parallel batching is
// a later optimization). Each src/libraries/<lib>/tests/*.z42 is compiled to
// .zbc via z42c then run through z42-test-runner; results aggregated.
int _testLib(string[] argv) {
    bool noBuild = false;
    string filter = "";
    string jobs = "1";   // forwarded to z42-test-runner ([Test]-method parallelism)
    string[] reqLibs = new string[64];
    int nReq = 0;
    int i = 2;
    while (i < argv.Length) {
        string a = argv[i];
        if (a == "--no-build") { noBuild = true; }
        else if (a.StartsWith("-k")) {
            if (a.Length > 2) { filter = a.Substring(2); }
            else { i = i + 1; if (i < argv.Length) { filter = argv[i]; } }
        }
        else if (a.StartsWith("--jobs=")) { jobs = a.Substring(7); }
        else if (a == "--jobs" || a == "-j") { i = i + 1; if (i < argv.Length) { jobs = argv[i]; } }
        else if (a.StartsWith("-j")) { jobs = a.Substring(2); }
        else if (!a.StartsWith("-")) { reqLibs[nReq] = a; nReq = nReq + 1; }
        i = i + 1;
    }
    string root = _root();
    if (!noBuild) {
        Console.WriteLine("→ Preparing tooling (stdlib + z42vm + z42-test-runner; release)...");
        int c = _buildStdlib(); if (c != 0) { return c; }
        c = _buildRuntime(); if (c != 0) { return c; }
        c = _exec(new Process("cargo").Arg("build").Arg("--release")
            .Arg("--manifest-path").Arg("src/toolchain/test-runner/Cargo.toml"));
        if (c != 0) { return c; }
        c = _exec(new Process("dotnet").Arg("build").Arg("src/compiler/z42.Driver/z42.Driver.csproj")
            .Arg("-c").Arg("Release").Arg("--nologo").Arg("-v").Arg("quiet"));
        if (c != 0) { return c; }
    }
    string runner = Path.Join(root, "artifacts/build/runtime/release/z42-test-runner");
    if (!File.Exists(runner)) {
        ConsoleError.WriteLine("error: z42-test-runner not found at " + runner + " (run without --no-build)");
        return 2;
    }
    string work = Directory.CreateTempDir("xtask-testlib");
    string libsRoot = Path.Join(root, "src/libraries");
    string[] libList;
    if (nReq > 0) {
        libList = new string[nReq];
        int k = 0;
        while (k < nReq) { libList[k] = reqLibs[k]; k = k + 1; }
    } else {
        libList = Directory.Enumerate(libsRoot);
    }
    int totalFailed = 0;
    int totalFiles = 0;
    int libsTested = 0;
    foreach (var lib in libList) {
        string testsDir = Path.Join(libsRoot, lib + "/tests");
        if (!Directory.Exists(testsDir)) { continue; }
        string[] files = Directory.Enumerate(testsDir);
        int matched = 0;
        foreach (var f in files) {
            if (f.EndsWith(".z42") && (filter.Length == 0 || f.Contains(filter))) { matched = matched + 1; }
        }
        if (matched == 0) { continue; }
        libsTested = libsTested + 1;
        Console.WriteLine("");
        Console.WriteLine("════════════════════════════════════════════════");
        Console.WriteLine("  " + lib + "  (" + matched.ToString() + " test file(s))");
        Console.WriteLine("════════════════════════════════════════════════");
        foreach (var f in files) {
            if (!f.EndsWith(".z42")) { continue; }
            if (filter.Length > 0 && !f.Contains(filter)) { continue; }
            totalFiles = totalFiles + 1;
            string testFile = Path.Join(testsDir, f);
            string zbc = Path.Join(work, lib + "_" + f + ".zbc");
            int cc = _exec(new Process("dotnet")
                .Arg("run").Arg("--no-build").Arg("--project").Arg("src/compiler/z42.Driver").Arg("-c").Arg("Release")
                .Arg("--").Arg(testFile).Arg("--emit").Arg("zbc").Arg("-o").Arg(zbc));
            if (cc != 0) {
                Console.WriteLine("✗ COMPILE ERROR: " + f);
                totalFailed = totalFailed + 1;
            } else {
                Process rp = new Process(runner);
                if (jobs != "1") { rp = rp.Arg("--jobs").Arg(jobs); }
                int rc = _exec(rp.Arg(zbc));
                if (rc != 0) { totalFailed = totalFailed + 1; }
            }
        }
    }
    Console.WriteLine("");
    Console.WriteLine("════════════════════════════════════════════════");
    if (totalFailed > 0) {
        Console.WriteLine("  ❌ stdlib tests: " + totalFailed.ToString()
            + " file(s) failed (of " + totalFiles.ToString() + " in " + libsTested.ToString() + " lib(s))");
        return 1;
    }
    Console.WriteLine("  ✅ stdlib tests: all " + totalFiles.ToString()
        + " file(s) passed (in " + libsTested.ToString() + " lib(s))");
    return 0;
}

