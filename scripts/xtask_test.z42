// xtask — test orchestration (split from xtask.z42 for the 500-line code-org
// limit). Same Z42Xtask namespace; these call _exec/_root/_z42vm/_build*/
// _regenCore/_at defined in xtask.z42 (cross-file, same namespace).
namespace Z42Xtask;

using Std;
using Std.IO;
using Std.Toml;

// ── test vm ─────────────────────────────────────────────────────────────────

// `test vm [interp|jit] [--no-rebuild] [--jobs=N]` — native, bash-free.
// Mirrors the former scripts/test-vm.sh: regen (rebuild stdlib + compiler + golden zbc)
// unless --no-rebuild, build the DEBUG z42vm + compression cdylib (the VM runner
// resolves artifacts/build/runtime/debug/z42vm and JIT dlopens the compressor),
// then run the in-process golden runner (_runVmGoldens, xtask_test_vm.z42) with
// the parsed modes/jobs — no separate compile + zpkg spawn.
int _testVm(ParseResult r) {
    string modeArg = r.GetPositional(0);         // "" | interp | jit
    string modes = modeArg.Length > 0 ? modeArg : "interp jit";
    return _testVmCore(modes, !r.GetFlag("no-rebuild"), r.GetFlag("no-build"), r.GetOption("jobs"), r.GetOption("shard"));
}

// regen goldens for a test stage: --toolchain active OR --no-build set → z42c+stdlib
// already present, only regen the golden .zbc (_regenGolden, --toolchain-aware);
// else full _regenCore (rebuild stdlib + runtime + goldens). Shared: _testVmCore + _testAll.
int _regenForTest(bool haveTc, bool noBuild) {
    return (haveTc || noBuild) ? _regenGolden() : _regenCore(false, true);
}

// cargo-build the DEBUG z42vm + z42-compression cdylib — the runtime the VM golden
// runner resolves (artifacts/build/runtime/debug/z42vm; JIT dlopens the compressor).
// Shared: _testVmCore + _testAll.
int _buildDebugVmAndCompression() {
    int cd = _exec(new Process("cargo").Arg("build").Arg("-q").Arg("--manifest-path").Arg(_runtimeManifest()));
    if (cd != 0) { return cd; }
    return _exec(new Process("cargo").Arg("build").Arg("-q").Arg("--manifest-path").Arg("src/runtime/crates/z42-compression/Cargo.toml"));
}

int _testVmCore(string modes, bool rebuild, bool noBuild, string jobs, string shard) {
    if (jobs.Length == 0) { jobs = "1"; }
    // --toolchain (compile-once P3) / --no-build (compile-once A1): consume an
    // already-built z42c+stdlib → regen goldens only; else full rebuild.
    bool haveTc = _toolchainDir(_root()).Length > 0;
    if (rebuild) {
        int c = _regenForTest(haveTc, noBuild);
        if (c != 0) { return c; }
    }
    if (!haveTc) {
        int cb = _buildDebugVmAndCompression();
        if (cb != 0) { return cb; }
    }
    // modes is a space-separated token string (e.g. "interp jit"); split to the
    // string[] _runVmGoldens expects. jobs parses to int (default 1 on garbage).
    string[] modeList = _splitWords(modes);
    int jobsN = 1;
    try { jobsN = int.Parse(jobs); } catch (Exception e) { jobsN = 1; }
    int[] sh = _parseShard(shard);
    return _runVmGoldens(modeList, jobsN, sh[0], sh[1]);
}

// ── test cross-zpkg ─────────────────────────────────────────────────────────

// `test cross-zpkg [interp|jit]` — native, bash-free. Mirrors
// the former scripts/test-cross-zpkg.sh: build compiler (slnx) + DEBUG runtime,
// ensure stdlib present, then run the in-process cross-zpkg driver
// (_testCrossZpkgImpl, xtask_test_cross.z42) with the parsed mode — no separate
// compile + zpkg spawn.
int _testCrossZpkg(ParseResult r) {
    string mode = r.GetPositional(0);
    if (mode.Length == 0) { mode = "interp"; }
    return _testCrossZpkgCore(mode, false);
}

// noBuild=true: skip the debug-vm/stdlib/z42c rebuild — `test all` already prepared
// them in its build wave (z42c was being self-built a 2nd time here). Standalone
// `test cross-zpkg` passes false.
int _testCrossZpkgCore(string mode, bool noBuild) {
    // --toolchain (compile-once P3): an active toolchain supplies z42c+stdlib+z42vm,
    // so skip the build-tree rebuild entirely (consume path: nothing to build).
    bool haveTc = _toolchainDir(_root()).Length > 0;
    // replace-csharp Phase C：cross-zpkg 全程 C#-free。debug z42vm（cargo）跑 fixtures；
    // z42c（C#-free 种子自建）编 fixtures。
    if (!noBuild && !haveTc) {
        int cr = _exec(new Process("cargo").Arg("build").Arg("-q")
            .Arg("--manifest-path").Arg(_runtimeManifest()));
        if (cr != 0) { return cr; }
        string root = _root();
        if (!File.Exists(Path.Join(_libsDir(root), "z42.core.zpkg"))) {
            int cs = _buildStdlib(); if (cs != 0) { return cs; }
        }
        int cz = _buildCompiler(); if (cz != 0) { return cz; }   // C#-free z42c 自建（种子）
    }
    return _testCrossZpkgImpl(mode);
}

// ── test dist (packaged-distribution e2e) ────────────────────────────────────

// `test dist [interp|jit]` — native port of the former scripts/test-dist.sh.
// Build the toolchain + a host release package (if absent), then run the
// in-process dist e2e (_testDistRun, xtask_test_dist.z42) which drives the
// PACKAGED z42c/z42vm against the goldens + a launcher smoke — no separate
// compile + zpkg spawn. Not in the default GREEN gate (run on demand).
int _testDist(ParseResult r) {
    string root = _root();
    int c = _buildCompiler(); if (c != 0) { return c; }   // C#-free 自举编译器（z42c 种子自建）
    c = _exec(_cargoRelease().Arg("-q")
        .Arg("--manifest-path").Arg(_runtimeManifest())); if (c != 0) { return c; }
    if (!File.Exists(Path.Join(_libsDir(root), "z42.core.zpkg"))) {
        c = _buildStdlib(); if (c != 0) { return c; }
    }
    // Ensure a host release package exists (build it if absent).
    if (!_hasReleasePkg(root)) {
        c = _buildPackageCore("release", "", "", false); if (c != 0) { return c; }
    }
    return _testDistRun(r.GetPositional(0));
}

bool _hasReleasePkg(string root) {
    string pkgs = _packagesDir(root);
    if (!Directory.Exists(pkgs)) { return false; }
    foreach (var name in Directory.Enumerate(pkgs)) {
        if (name.StartsWith("z42-") && name.EndsWith("-release")) { return true; }
    }
    return false;
}

// latest artifacts/packages/z42-*-release dir (absolute path), or "" if none.
// Lives here alongside _hasReleasePkg; called by _testDistRun (xtask_test_dist.z42).
string _latestReleasePkg(string root) {
    string pkgs = _packagesDir(root);
    if (!Directory.Exists(pkgs)) { return ""; }
    string best = "";
    foreach (var name in Directory.Enumerate(pkgs)) {
        if (name.StartsWith("z42-") && name.EndsWith("-release")) {
            string full = Path.Join(pkgs, name);
            if (Directory.Exists(full)) {
                // Prefer the lexicographically-greatest (stable; usually one host pkg).
                if (best.Length == 0 || name.CompareTo(Path.GetFileName(best)) > 0) { best = full; }
            }
        }
    }
    return best;
}

// ── test all (unified GREEN gate) ───────────────────────────────────────────

// `test` (no target) — the full GREEN gate, sequential: build once, then run
// compiler + VM goldens + cross-zpkg + stdlib, short-circuiting on first
// failure. Mirrors the former scripts/test-all.sh's stage set (the --parallel wave +
// --scope auto-narrow optimizations are a later increment).
int _testAll(bool noBuild) {
    // build wave (once): stdlib + compiler driver + release runtime + golden zbc.
    // compile-once consume: skip the redundant z42c+stdlib rebuild when they're
    // already present — either a --toolchain is set (CI downloads current-sdk) OR
    // --no-build is passed (the CI bootstrap step already built the canonical
    // z42c+stdlib). In both cases only regen the goldens (the bootstrap doesn't
    // produce them); the stages below already run --no-build. This removes the CI
    // build-wave redundancy (~12-15 min/leg) — `xtask test all` locally still does
    // the full build by default (noBuild=false).
    bool haveTc = _toolchainDir(_root()).Length > 0;
    int c = _regenForTest(haveTc, noBuild);
    if (c != 0) { return c; }
    // extra tooling the test stages need: debug z42vm + compression cdylib + test-runner
    c = _buildDebugVmAndCompression(); if (c != 0) { return c; }
    c = _exec(_cargoRelease().Arg("-q").Arg("--manifest-path").Arg("src/toolchain/test-runner/Cargo.toml")); if (c != 0) { return c; }
    // replace-csharp Phase C：删除 dotnet build/test stage——z42c 编译器正确性由 stage「compiler」
    // （自举不动点 gen1==gen2 + units）保证，golden 编译已全程 z42c（_regenGolden）。GREEN gate C#-free。
    // stage 2: VM goldens — INTERP only. JIT is gated by the dedicated
    // vm-jit-consistency CI job (linux-x64): cranelift JIT behaviour is
    // host-independent, so running jit here on every build-and-test OS leg was
    // redundant (5× the slow per-case cranelift compile). Splitting interp (here,
    // all OS) from jit (one linux job) keeps full coverage while taking the slow
    // jit stage off every host leg's critical path.
    Console.WriteLine("\n=== stage: VM goldens (interp; jit → vm-jit-consistency) ===");
    c = _testVmCore("interp", false, false, "4", ""); if (c != 0) { return c; }
    // stage 3: cross-zpkg
    Console.WriteLine("\n=== stage: cross-zpkg ===");
    c = _testCrossZpkgCore("interp", true); if (c != 0) { return c; }
    // stage 4: stdlib [Test] (no build)
    Console.WriteLine("\n=== stage: stdlib [Test] ===");
    c = _testLibCore("test", new string[0], true, "", "4", "interp"); if (c != 0) { return c; }
    // stage 5: z42c self-host byte-identical (0.3.10 gate)
    Console.WriteLine("\n=== stage: compiler ===");
    c = _testCompiler(true); if (c != 0) { return c; }
    Console.WriteLine("\n✅ GREEN — all stages passed (vm + cross-zpkg + stdlib + compiler; C#-free)");
    return 0;
}

// ── test lib (stdlib [Test] harness) ────────────────────────────────────────

// `test lib|stdlib [lib...] [--no-build] [-k filter]` — native stdlib [Test]
// harness. Mirrors the former scripts/test-lib.sh (sequential; --jobs parallel batching is
// a later optimization). Each src/libraries/<lib>/tests/*.z42 is compiled to
// .zbc via z42c then run through z42-test-runner; results aggregated.
// ParseResult wrapper: single optional [lib] positional + --no-build / -k
// filter / --jobs flags (declared on the stdlib/bench leaf in xtask_cli.z42).
// Note: the legacy multi-lib form (`test stdlib a b c`) narrows to a single
// lib here — Std.Cli positionals are fixed-arity. Pass one lib or none (all).
// Parse a `--shard k/n` spec → [k, n]; returns [0,0] for empty/invalid (= no
// sharding). Used to split the slow jit suites across N parallel CI machines.
int[] _parseShard(string s) {
    int[] r = new int[2]; r[0] = 0; r[1] = 0;
    if (s.Length == 0) { return r; }
    int slash = -1;
    int i = 0;
    while (i < s.Length) { if (s.CharAt(i) == '/') { slash = i; break; } i = i + 1; }
    if (slash <= 0) { return r; }
    if (slash >= s.Length - 1) { return r; }
    try {
        int k = int.Parse(s.Substring(0, slash));
        int n = int.Parse(s.Substring(slash + 1, s.Length - slash - 1));
        if (k >= 1 && n >= 1 && k <= n) { r[0] = k; r[1] = n; }
    } catch (Exception e) { r[0] = 0; r[1] = 0; }
    return r;
}

// Count a lib's [Test] units (single-file tests/*.z42 + dir-mode tests/<name>/
// source.z42) — drives shard load balancing.
int _libUnitCount(string root, string lib) {
    string td = Path.Join(Path.Join(root, "src/libraries/" + lib), "tests");
    if (!Directory.Exists(td)) { return 0; }
    int c = Path.Glob(td, "*.z42").Length;
    string[] entries = Path.Glob(td, "*");
    int i = 0;
    while (i < entries.Length) {
        if (File.Exists(Path.Join(entries[i], "source.z42"))) { c = c + 1; }
        i = i + 1;
    }
    return c;
}

// Libs assigned to shard k of n, balanced by [Test] unit count: sort libs by
// count desc, then round-robin sorted positions across shards (longest-first
// keeps the heavy libs in distinct shards → even load).
string[] _shardLibs(string root, int k, int n) {
    string[] all = _stdlibList(root);
    int m = all.Length;
    int[] cnt = new int[m];
    int[] idx = new int[m];
    int i = 0;
    while (i < m) { cnt[i] = _libUnitCount(root, all[i]); idx[i] = i; i = i + 1; }
    int a = 0;
    while (a < m) {
        int best = a;
        int b = a + 1;
        while (b < m) { if (cnt[idx[b]] > cnt[idx[best]]) { best = b; } b = b + 1; }
        int t = idx[a]; idx[a] = idx[best]; idx[best] = t;
        a = a + 1;
    }
    string[] picked = new string[m];
    int oc = 0;
    int p = 0;
    while (p < m) {
        if ((p % n) == (k - 1)) { picked[oc] = all[idx[p]]; oc = oc + 1; }
        p = p + 1;
    }
    string[] sized = new string[oc];
    i = 0;
    while (i < oc) { sized[i] = picked[i]; i = i + 1; }
    return sized;
}

int _testLib(ParseResult r, string kind) {
    string lib = r.GetPositional(0);
    string[] libs;
    int[] sh = _parseShard(r.GetOption("shard"));
    if (sh[1] > 0) {
        libs = _shardLibs(_root(), sh[0], sh[1]);
        Console.WriteLine("→ shard " + sh[0].ToString() + "/" + sh[1].ToString()
            + ": " + libs.Length.ToString() + " libs");
    } else if (lib.Length > 0) {
        libs = new string[1]; libs[0] = lib;
    } else {
        libs = new string[0];
    }
    return _testLibCore(kind, libs, r.GetFlag("no-build"), r.GetOption("filter"), r.GetOption("jobs"), r.GetOption("mode"));
}

int _testLibCore(string kind, string[] reqLibsIn, bool noBuild, string filter, string jobs, string mode) {
    // kind = "test" → discover <lib>/tests/, merge [tests.dependencies], emit
    // <lib>.test.<unit> to <lib>/release/tests/. "bench" → <lib>/bench/,
    // [bench.dependencies], <lib>.bench.<unit> to <lib>/release/bench/. The
    // z42-test-runner runs both [Test] and [Benchmark] regardless.
    string subdir = (kind == "bench") ? "bench" : "tests";
    string label  = (kind == "bench") ? "bench" : "test";
    if (jobs.Length == 0) { jobs = "1"; }   // forwarded to z42-test-runner
    string[] reqLibs = reqLibsIn;
    int nReq = reqLibsIn.Length;
    string root = _root();
    if (!noBuild) {
        Console.WriteLine("→ Preparing tooling (stdlib + z42vm + z42-test-runner; release)...");
        int c = _buildStdlib(); if (c != 0) { return c; }
        c = _buildRuntime(); if (c != 0) { return c; }
        c = _exec(_cargoRelease()
            .Arg("--manifest-path").Arg("src/toolchain/test-runner/Cargo.toml"));
        if (c != 0) { return c; }
        // C#-free (remove-dotnet-from-builds): test units compile through z42c
        // (z42vm + z42c.driver.zpkg), not `dotnet z42c.dll`. Ensure the z42c
        // self-build seed is fresh here instead of building the C# driver.
        c = _buildCompiler(); if (c != 0) { return c; }
    }
    string runner = _builtBin(root, "release", "z42-test-runner");
    if (!File.Exists(runner)) {
        ConsoleError.WriteLine("error: z42-test-runner not found at " + runner + " (run without --no-build)");
        return 2;
    }
    // add-tests-bench-manifest-config §6 (2026-06-07): test artifacts persist
    // under each lib's output_dir in a parallel `tests/` subtree
    // (<lib>/<profile>/tests/{dist,cache}/) instead of a throwaway temp dir, so
    // they're inspectable, incrementally cached, and visible to the CI
    // release-guard. _compileTestUnit derives the path from root + lib.
    // C#-free compile toolchain: z42vm + z42c.driver.zpkg + a single flat
    // Z42_LIBS dir. z42c.driver runs as a packed zpkg whose OWN siblings
    // (z42c.project / z42c.semantics / …) must be resolvable at runtime, AND
    // the stdlib the test units depend on must live in the SAME dir (the VM
    // takes one dir, not a colon-list). Mirror _testCompilerUnits' alllibs
    // flat: link the stdlib dist + the 7 z42c members into one dir. Computed
    // once; threaded through _runUnitsBatched → _compilePrep so every unit
    // compiles via z42c, not `dotnet z42c.dll`.
    string vm = _builtVm(root, "release");
    string driverZpkg = Path.Join(root, "artifacts/build/z42c/z42c.driver/release/dist/z42c.driver.zpkg");
    string libs = _assembleAllLibs(root, "release");
    string libsRoot = Path.Join(root, "src/libraries");
    string[] libList;
    if (nReq > 0) {
        libList = new string[nReq];
        int k = 0;
        while (k < nReq) { libList[k] = reqLibs[k]; k = k + 1; }
    } else {
        // add-tests-bench-manifest-config Phase 3.3 (2026-06-06): sort
        // Directory.Enumerate output so first-wins downstream behaviour is
        // platform-stable (common-pitfalls.md §1 — macOS APFS vs Linux ext4
        // give different orderings; CI on Linux blew up here before).
        libList = _sortedStrings(Directory.Enumerate(libsRoot));
    }
    int totalFailed = 0;
    int totalFiles = 0;
    int libsTested = 0;
    // parallelize-and-jit-stdlib-tests A: `jobs` now means unit-level batch
    // width (how many units compile+run concurrently), not the runner's
    // within-unit --jobs. Default 1 = serial. `test all` passes 4.
    int jobsN = 1;
    try { jobsN = int.Parse(jobs); } catch (Exception e) { jobsN = 1; }
    if (jobsN < 1) { jobsN = 1; }
    // mode forwarded to z42-test-runner: "" / "interp" → in-process interp;
    // "jit" → runner forces subprocess fork of z42vm --mode jit.
    if (mode.Length == 0) { mode = "interp"; }
    foreach (var lib in libList) {
        string testsDir = Path.Join(libsRoot, lib + "/" + subdir);
        if (!Directory.Exists(testsDir)) { continue; }
        // Phase 3.1.1: discover BOTH single-file tests (tests/*.z42) and
        // dir-mode tests (tests/<name>/source.z42). Sort for determinism.
        string[] rawEntries = _sortedStrings(Directory.Enumerate(testsDir));
        TestUnit[] units = _discoverTestUnits(testsDir, rawEntries, filter);
        if (units.Length == 0) { continue; }
        libsTested = libsTested + 1;
        Console.WriteLine("");
        Console.WriteLine("════════════════════════════════════════════════");
        Console.WriteLine("  " + lib + "  (" + units.Length.ToString() + " " + label + " unit(s))");
        Console.WriteLine("════════════════════════════════════════════════");
        // Phase 3.1.3: read parent <lib>.z42.toml once to harvest [dependencies]
        // + [<subdir>.dependencies] for synthetic manifest dep merge.
        string parentToml = Path.Join(libsRoot, lib + "/" + lib + ".z42.toml");
        DepBundle parentDeps = _harvestParentDeps(parentToml, subdir);
        totalFiles = totalFiles + units.Length;
        // parallelize-and-jit-stdlib-tests A: this lib's units compile+run in
        // batches of `jobsN` (unit-level parallelism, mirrors _runVmBatch).
        // Each runner runs serially within its unit (no --jobs) so [Setup]/
        // [Teardown] still execute — the parallelism is across units, not
        // within. The per-unit z42.core bootstrap (the dominant cost) overlaps.
        totalFailed = totalFailed + _runUnitsBatched(root, runner, lib, units, parentDeps, kind, jobsN, mode,
                                                     vm, driverZpkg, libs);
    }
    Console.WriteLine("");
    Console.WriteLine("════════════════════════════════════════════════");
    if (totalFailed > 0) {
        Console.WriteLine("  ❌ stdlib " + label + ": " + totalFailed.ToString()
            + " file(s) failed (of " + totalFiles.ToString() + " in " + libsTested.ToString() + " lib(s))");
        return 1;
    }
    Console.WriteLine("  ✅ stdlib " + label + ": all " + totalFiles.ToString()
        + " file(s) passed (in " + libsTested.ToString() + " lib(s))");
    return 0;
}

// ── add-tests-bench-manifest-config Phase 3 helpers ─────────────────────────
//
// Phase 3 enables BOTH single-file tests (tests/foo.z42) and dir-mode tests
// (tests/<name>/source.z42 + optional sibling files). Single-file goes
// through the legacy z42c emit-zbc path (cheap; no manifest); dir-mode
// synthesises a tiny mini-manifest and calls `z42c build` so the
// compiler's regular project pipeline handles the multi-file package.
//
// Synthetic manifest content per dir-mode unit:
//   [project] name = "<lib>.test.<unit>"  kind = "exe"  version = "0.1.0"
//   [sources] include = ["<absolute>/<unit>/**/*.z42"]
//   [dependencies] = parent.[dependencies] ∪ parent.[tests.dependencies]
//   [build] output_dir = "<work>/<lib>/<unit>"  (Phase 3.1.4 forced isolation)
// The merged deps make z42.test resolvable after Phase 4 moves it from
// [dependencies] to [tests.dependencies]: this xtask reads BOTH sections so
// the migration is safe regardless of which section a parent puts a dep in.

/// One test compilation unit. UnitName = produced zpkg basename suffix
/// (`<lib>.test.<UnitName>`); SourceFile = entry .z42 (single-file mode)
/// or directory path (dir-mode); IsDirMode flips the compile path.
class TestUnit {
    public string UnitName { get; set; }
    public string SourceFile { get; set; }
    public string DirPath { get; set; }
    public bool   IsDirMode { get; set; }
}

/// Parent toml's two dep sections, kept separate so the synthetic-manifest
/// writer can emit a single merged [dependencies] block. Stored as
/// (name, version) string pairs to avoid coupling xtask to z42.Project
/// internals.
class DepBundle {
    public string[] Names { get; set; }
    public string[] Versions { get; set; }
    public int Count { get; set; }
}

// _sortedStrings moved to xtask_common.z42 (shared string/collection helpers).

/// Discover test units in `testsDir`. Single-file convention: a top-level
/// `*.z42` file becomes one unit. Dir-mode convention (Phase 3.1.1):
/// a sub-directory containing `source.z42` becomes one unit (the directory
/// name supplies UnitName). `filter` matches against the unit's display
/// name (file basename or dir basename) — substring match.
TestUnit[] _discoverTestUnits(string testsDir, string[] entries, string filter) {
    int n = entries.Length;
    TestUnit[] tmp = new TestUnit[n];
    int count = 0;
    int i = 0;
    while (i < n) {
        string e = entries[i];
        string full = Path.Join(testsDir, e);
        bool isDir = Directory.Exists(full);
        if (isDir) {
            string sourceZ42 = Path.Join(full, "source.z42");
            // A tests/<name>/source.z42 dir is a [Test] unit ONLY when it
            // actually declares [Test] methods. Main-based dirs (source.z42 with
            // void Main()) are VM golden cases — run by `test vm` from
            // src/libraries/<lib>/tests/<name>/source.zbc, NOT [Test] units. The
            // z42-test-runner reports "no tests found" (exit 3) on a Main-based
            // zpkg, which _testLib would otherwise miscount as a failure.
            if (File.Exists(sourceZ42) && _dirHasTestMethods(full)) {
                string display = e;
                if (filter.Length == 0 || display.Contains(filter)) {
                    TestUnit u = new TestUnit();
                    u.UnitName = display;
                    u.SourceFile = sourceZ42;
                    u.DirPath = full;
                    u.IsDirMode = true;
                    tmp[count] = u;
                    count = count + 1;
                }
            }
        } else if (e.EndsWith(".z42")) {
            if (filter.Length == 0 || e.Contains(filter)) {
                TestUnit u = new TestUnit();
                // Trim ".z42" (4 chars) for UnitName so zpkg becomes
                // <lib>.test.<basename> rather than <lib>.test.<basename>.z42.
                u.UnitName = e.Substring(0, e.Length - 4);
                u.SourceFile = full;
                u.DirPath = "";
                u.IsDirMode = false;
                tmp[count] = u;
                count = count + 1;
            }
        }
        i = i + 1;
    }
    TestUnit[] result = new TestUnit[count];
    int k = 0;
    while (k < count) { result[k] = tmp[k]; k = k + 1; }
    return result;
}

/// True iff any top-level `.z42` file in `dir` declares a `[Test]` method —
/// the marker the z42-test-runner discovers via the zpkg's TIDX section.
/// Distinguishes dir-mode [Test] units (e.g. z42.crypto/tests/secp256k1) from
/// Main-based golden cases (which the runner would reject with "no tests found").
bool _dirHasTestMethods(string dir) {
    foreach (var f in Directory.Enumerate(dir)) {
        if (!f.EndsWith(".z42")) { continue; }
        try {
            if (File.ReadAllText(Path.Join(dir, f)).Contains("[Test]")) { return true; }
        } catch (Exception) { /* unreadable → not a test source */ }
    }
    return false;
}

/// Read parent `<lib>.z42.toml` and harvest the union of
/// `[dependencies]` + `[tests.dependencies]` as a single merged list.
/// Returns an empty bundle when the toml is missing or has no dep
/// sections (z42.test stdlib itself doesn't depend on anything).
DepBundle _harvestParentDeps(string tomlPath, string section) {
    DepBundle b = new DepBundle();
    b.Names = new string[32];
    b.Versions = new string[32];
    b.Count = 0;
    if (!File.Exists(tomlPath)) { return b; }
    TomlValue root;
    try {
        root = TomlValue.Parse(File.ReadAllText(tomlPath));
    } catch (TomlException) {
        return b;
    }
    if (root.ContainsKey("dependencies")) {
        _appendDeps(b, root.Get("dependencies"));
    }
    // section = "tests" → merge [tests.dependencies]; "bench" → [bench.dependencies].
    if (root.ContainsKey(section)) {
        TomlValue sec = root.Get(section);
        if (sec.ContainsKey("dependencies")) {
            _appendDeps(b, sec.Get("dependencies"));
        }
    }
    return b;
}

/// Append a `[X.dependencies]` sub-table into the bundle, deduping by
/// name so a key appearing in both [dependencies] and [tests.dependencies]
/// keeps the first version seen.
void _appendDeps(DepBundle b, TomlValue depsTable) {
    string[] keys = depsTable.Keys();
    int i = 0;
    while (i < keys.Length) {
        string name = keys[i];
        bool seen = false;
        int j = 0;
        while (j < b.Count) {
            if (b.Names[j] == name) { seen = true; }
            j = j + 1;
        }
        if (!seen) {
            // Grow if at capacity.
            if (b.Count == b.Names.Length) {
                int newCap = b.Names.Length * 2;
                string[] nn = new string[newCap];
                string[] nv = new string[newCap];
                int k = 0;
                while (k < b.Count) { nn[k] = b.Names[k]; nv[k] = b.Versions[k]; k = k + 1; }
                b.Names = nn;
                b.Versions = nv;
            }
            TomlValue v = depsTable.Get(name);
            string ver = "*";
            if (v.IsString()) { ver = v.AsString(); }
            b.Names[b.Count] = name;
            b.Versions[b.Count] = ver;
            b.Count = b.Count + 1;
        }
        i = i + 1;
    }
}

/// Run a lib's test units in batches of `jobs`, parallelizing the dominant
/// per-unit z42.core bootstrap across units (parallelize-and-jit-stdlib-tests
/// A). Each batch: spawn `jobs` compiles → wait → spawn `jobs` runners → wait
/// + print captured TAP in batch order. Returns the failure count. Mirrors
/// `_runVmBatch` (xtask_test_vm.z42). Each runner runs serially within its
/// unit (no --jobs) so [Setup]/[Teardown] still execute.
int _runUnitsBatched(string root, string runner, string lib, TestUnit[] units,
                     DepBundle parentDeps, string kind, int jobs, string mode,
                     string vm, string driverZpkg, string libs) {
    int failed = 0;
    int i = 0;
    while (i < units.Length) {
        int bsz = jobs;
        if (i + bsz > units.Length) { bsz = units.Length - i; }

        // ── compile phase: spawn bsz compiles, wait, collect artifacts ──
        ProcessHandle[] ch    = new ProcessHandle[bsz];
        string[]        tomls = new string[bsz];
        string[]        arts  = new string[bsz];
        bool[]          okc   = new bool[bsz];
        int b = 0;
        while (b < bsz) {
            string toml = "";
            string art  = "";
            Process cp = _compilePrep(root, lib, units[i + b], parentDeps, kind,
                                      vm, driverZpkg, libs,
                                      ref toml, ref art);
            tomls[b] = toml;
            arts[b]  = art;
            ch[b]    = cp.WorkingDirectory(root).Spawn();
            b = b + 1;
        }
        b = 0;
        while (b < bsz) {
            ProcessResult cr = ch[b].Wait();
            // delete the dir-mode synthetic toml regardless of outcome
            if (tomls[b].Length > 0) { try { File.Delete(tomls[b]); } catch (Exception e) {} }
            okc[b] = (cr.ExitCode == 0);
            if (!okc[b]) {
                Console.WriteLine("✗ COMPILE ERROR: " + units[i + b].UnitName);
                Console.Write(cr.Stdout);
                Console.Write(cr.Stderr);
                failed = failed + 1;
            }
            b = b + 1;
        }

        // ── run phase: spawn runners for compiled units, wait, print TAP ──
        ProcessHandle[] rh = new ProcessHandle[bsz];
        b = 0;
        while (b < bsz) {
            if (okc[b]) {
                rh[b] = new Process(runner).Arg(arts[b]).Arg("--mode").Arg(mode)
                    .Env("Z42_LIBS", libs)
                    .WorkingDirectory(root).Spawn();
            }
            b = b + 1;
        }
        b = 0;
        while (b < bsz) {
            if (okc[b]) {
                ProcessResult rr = rh[b].Wait();
                Console.Write(rr.Stdout);
                if (rr.Stderr.Length > 0) { Console.Write(rr.Stderr); }
                if (rr.ExitCode != 0) { failed = failed + 1; }
            }
            b = b + 1;
        }
        i = i + bsz;
    }
    return failed;
}

/// Prepare (but don't spawn) the driver compile for one test unit. Computes
/// output paths and, for dir-mode units, writes the synthetic mini-manifest;
/// `outToml` is that manifest to delete after the build ("" for flat-mode),
/// `outArtifact` the runnable bytecode path the runner consumes. Factored
/// from the former _compileTestUnit so units compile in parallel batches.
/// Single-file mode → `z42c <file> --emit zbc -o <out.zbc>`; dir-mode →
/// `z42c build <synthetic>` producing `<dist>/<name>.zpkg`.
Process _compilePrep(string root, string lib, TestUnit u,
                     DepBundle parentDeps, string kind,
                     string vm, string driverZpkg, string libs,
                     ref string outToml, ref string outArtifact) {
    // kind = "test" → <lib>.test.<unit> under tests/; "bench" → <lib>.bench.<unit>
    // under bench/. Both run through the same z42-test-runner (which dispatches
    // [Test] and [Benchmark] identically).
    string subdir = (kind == "bench") ? "bench" : "tests";
    string projName = lib + "." + kind + "." + u.UnitName;
    // Persistent per-lib subtree (add-tests-bench-manifest-config §6):
    //   <root>/artifacts/build/libraries/<lib>/release/<subdir>/{dist,cache/<unit>}/
    // dist/ is shared across the lib's units; cache/ is per-unit to avoid
    // source.zbc collisions between two dir-mode units.
    string testsBase = Path.Join(root,
        "artifacts/build/libraries/" + lib + "/release/" + subdir);
    string distDir = Path.Join(testsBase, "dist");
    Directory.Create(distDir);
    if (!u.IsDirMode) {
        string zbc = Path.Join(distDir, projName + ".zbc");
        outToml = "";
        outArtifact = zbc;
        // C#-free (remove-dotnet-from-builds): z42c (z42vm + z42c.driver.zpkg)
        // emits the unit to zbc. interp mode is fastest for these many-short
        // single-file compiles — JIT would re-warm the whole z42c closure per
        // unit. Z42_LIBS supplies the stdlib the test references (Assert, the
        // lib under test, …).
        return new Process(vm).Arg(driverZpkg).Arg("--mode").Arg("interp")
            .Arg("--").Arg("--emit-zbc").Arg(u.SourceFile).Arg(zbc)
            .Env("Z42_LIBS", libs);
    }
    // Dir-mode: Microsoft.Extensions.FileSystemGlobbing.Matcher resolves
    // include patterns relative to the manifest's projectDir and doesn't
    // accept `..` or absolute paths in globs. To keep `include = "**/*.z42"`
    // simple and stable, the synthetic toml is written NEXT TO the test
    // source files (inside `tests/<unit>/`) using a unique name; the
    // `[build].output_dir` is set to the persistent <lib>/release/tests
    // subtree so the .zpkg lands in the shared `tests/dist/`. The unique name
    // `.xtask-<projName>.z42.toml` prefixes a `.` so the file is naturally
    // git-ignored on most setups and won't collide with user manifests; it is
    // per-unit unique so parallel-batch compiles don't clobber each other.
    string syntheticToml = Path.Join(u.DirPath, ".xtask-" + projName + ".z42.toml");
    File.WriteAllText(syntheticToml,
        _renderSyntheticManifest(projName, "**/*.z42", testsBase, u.UnitName, parentDeps));
    outToml = syntheticToml;
    // PackageCompiler emits `<output_dir>/dist/<name>.zpkg` (dist_dir defaults
    // to ${output_dir}/dist; synthetic toml omits dist_dir → shared
    // <testsBase>/dist/, cache_dir overridden to a per-unit subdir).
    outArtifact = Path.Join(distDir, projName + ".zpkg");
    return new Process(vm).Arg(driverZpkg).Arg("--mode").Arg("interp")
        .Arg("--").Arg("build").Arg(syntheticToml)
        .Env("Z42_LIBS", libs);
}

/// Serialise a synthetic mini-manifest to TOML text. Kept hand-rolled
/// (no Std.Toml serializer round-trip) because the schema is tiny and
/// fixed-shape; this also avoids any quoting / ordering surprises in
/// generated output that diff would flag during reproducibility checks.
string _renderSyntheticManifest(string projName, string includeGlob,
                                 string outputDir, string cacheSubdir, DepBundle deps) {
    string body = "# Auto-generated by xtask test (add-tests-bench-manifest-config Phase 3, 2026-06-06).\n"
        + "# Synthesised per-test mini-manifest; not committed to source control.\n"
        + "# kind=lib: test files don't have Main(); [Test]-annotated methods\n"
        + "# get discovered by the z42-test-runner via the produced zpkg's TIDX\n"
        + "# section the same way single-file emit-zbc tests do.\n"
        + "\n"
        + "[project]\n"
        + "name    = \"" + projName + "\"\n"
        + "version = \"0.1.0\"\n"
        + "kind    = \"lib\"\n"
        + "\n"
        + "[sources]\n"
        + "include = [\"" + includeGlob + "\"]\n"
        + "\n"
        + "[build]\n"
        + "# output_dir is xtask-controlled; [[test]] entries cannot override it\n"
        + "# (synthetic manifest is regenerated each run). cache_dir is a per-unit\n"
        + "# subdir so two dir-mode units' source.zbc don't collide; dist_dir is\n"
        + "# omitted → shared ${output_dir}/dist (all <lib>.test.*.zpkg together).\n"
        + "output_dir = \"" + outputDir + "\"\n"
        + "cache_dir  = \"${output_dir}/cache/" + cacheSubdir + "\"\n"
        + "\n"
        + "# Force packed-mode zpkg in both profiles: the in-process VM (and the\n"
        + "# z42-test-runner that drives it) can only load packed zpkgs; default\n"
        + "# debug pack=false would land us with an indexed zpkg + scattered .zbc\n"
        + "# files which the runner refuses with `indexed zpkg cannot be loaded\n"
        + "# directly by the VM; use packed mode`.\n"
        + "[profile.debug]\n"
        + "pack = true\n"
        + "[profile.release]\n"
        + "pack = true\n";
    if (deps.Count > 0) {
        body = body + "\n[dependencies]\n";
        int i = 0;
        while (i < deps.Count) {
            body = body + "\"" + deps.Names[i] + "\" = \"" + deps.Versions[i] + "\"\n";
            i = i + 1;
        }
    }
    return body;
}

