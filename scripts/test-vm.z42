// port-test-vm (2026-05-27): the former scripts/test-vm.sh → z42 self-host.
//
// Runs VM golden tests in interp / jit mode. Each golden case lives at one of:
//   src/tests/<cat>/<name>/source.zbc        (dir mode) + expected_output.txt
//   src/libraries/<lib>/tests/<name>/source.zbc
//   src/tests/<cat>/<name>.zbc               (flat mode) + <name>.expected_output.txt
//
// For each case: derive entry name from the .z42 source (mirrors the C#
// GoldenTests resolution: `<namespace>.Main` > `Main` > `<namespace>.main` >
// `main`), then run `z42vm <artifact> <entry> --mode <mode>` and diff stdout
// against the expected file.
//
// Parallel mode: spawn JOBS subprocesses per batch via Process.Spawn,
// wait on the batch, then aggregate. Output is collected into per-job
// strings and printed in original order so the terminal stays readable.
//
// Invoked via `z42 xtask.zpkg test vm [interp|jit] [--no-rebuild] [--jobs=N]`,
// which bootstraps stdlib + golden zbc (unless --no-rebuild), builds z42vm, then
// runs this compiled zpkg with parameters passed via env vars (see _envOpt /
// _envOptInt).
namespace Z42TestVmScript;

using Std;
using Std.IO;
using Std.Text;

void Main() {
    string root = Environment.GetCurrentDirectory();

    // ── Resolve env-var params from bash wrapper ─────────────────────────
    // Modes: space-separated list (default "interp jit").
    string modesStr = _envOpt("Z42_VM_MODES", "interp jit");
    string[] modes = _splitWords(modesStr);
    int jobs = _envOptInt("Z42_VM_JOBS", 1);
    if (jobs < 1) { jobs = 1; }

    string vmBin = Path.Join(root, "artifacts/build/runtime/debug/z42vm");
    if (!File.Exists(vmBin)) {
        ConsoleError.WriteLine("error: VM binary not found at " + vmBin);
        ConsoleError.WriteLine("       Build via: cargo build --manifest-path src/runtime/Cargo.toml");
        Environment.Exit(1);
        return;
    }

    int overallPass = 0;
    int overallFail = 0;

    int mi = 0;
    while (mi < modes.Length) {
        string mode = modes[mi];
        Console.WriteLine("══════════════════════════════════════");
        Console.WriteLine(" Mode: " + mode);
        Console.WriteLine("══════════════════════════════════════");

        // Enumerate cases for this mode.
        _Case[] cases = _enumerateCases(root, mode);
        if (cases.Length == 0) {
            ConsoleError.WriteLine("❌ no runnable golden fixtures found.");
            ConsoleError.WriteLine("   Hint: run `z42 xtask.zpkg regen` first.");
            Environment.Exit(1);
            return;
        }

        int pass = 0;
        int fail = 0;
        string[] failures = new string[8];
        int      failCount = 0;

        if (jobs <= 1) {
            int i = 0;
            while (i < cases.Length) {
                bool ok = _runOneCase(vmBin, cases[i], mode);
                if (ok) {
                    pass = pass + 1;
                } else {
                    fail = fail + 1;
                    failures = _append(failures, failCount, cases[i].name);
                    failCount = failCount + 1;
                }
                i = i + 1;
            }
        } else {
            int i = 0;
            while (i < cases.Length) {
                int batchSize = jobs;
                if (i + batchSize > cases.Length) { batchSize = cases.Length - i; }

                ProcessHandle[] handles = new ProcessHandle[batchSize];
                _Case[]         batch   = new _Case[batchSize];
                int b = 0;
                while (b < batchSize) {
                    batch[b] = cases[i + b];
                    handles[b] = _spawnCase(vmBin, batch[b], mode);
                    b = b + 1;
                }

                // Wait + aggregate in original order.
                b = 0;
                while (b < batchSize) {
                    ProcessResult r = handles[b].Wait();
                    bool ok = _judgeResult(batch[b], r);
                    if (ok) {
                        pass = pass + 1;
                    } else {
                        _printFailLine(batch[b], r);
                        fail = fail + 1;
                        failures = _append(failures, failCount, batch[b].name);
                        failCount = failCount + 1;
                    }
                    b = b + 1;
                }
                i = i + batchSize;
            }
        }

        Console.WriteLine("");
        Console.WriteLine("  Result: " + pass.ToString() + " passed, "
            + fail.ToString() + " failed");
        Console.WriteLine("");

        overallPass = overallPass + pass;
        overallFail = overallFail + fail;
        mi = mi + 1;
    }

    Console.WriteLine("══════════════════════════════════════");
    Console.WriteLine(" Total: " + overallPass.ToString() + " passed, "
        + overallFail.ToString() + " failed");
    Console.WriteLine("══════════════════════════════════════");

    if (overallFail > 0) {
        Environment.Exit(1);
        return;
    }
}

// ── Case shape ───────────────────────────────────────────────────────────

class _Case {
    public string name;
    public string artifact;     // .zbc path
    public string expected;     // expected_output.txt path
    public string entryName;    // <ns>.Main / Main / <ns>.main / main

    public _Case(string name, string artifact, string expected, string entryName) {
        this.name = name;
        this.artifact = artifact;
        this.expected = expected;
        this.entryName = entryName;
    }
}

// ── Execution ────────────────────────────────────────────────────────────

bool _runOneCase(string vmBin, _Case c, string mode) {
    ProcessResult r;
    try {
        r = new Process(vmBin)
            .Arg(c.artifact).Arg(c.entryName).Arg("--mode").Arg(mode)
            .Run();
    } catch (Exception e) {
        Console.WriteLine("  FAIL: " + c.name);
        Console.WriteLine("    (spawn error: " + e.Message + ")");
        return false;
    }
    bool ok = _judgeResult(c, r);
    if (!ok) { _printFailLine(c, r); }
    return ok;
}

ProcessHandle _spawnCase(string vmBin, _Case c, string mode) {
    return new Process(vmBin)
        .Arg(c.artifact).Arg(c.entryName).Arg("--mode").Arg(mode)
        .Stdout(Stdio.Pipe())
        .Stderr(Stdio.Pipe())
        .Spawn();
}

bool _judgeResult(_Case c, ProcessResult r) {
    // bash: actual=$(... 2>&1) — merge stderr into stdout. We approximate
    // with concatenation (stderr-empty on pass, so ordering doesn't matter).
    // bash $(...) also strips trailing newlines from both sides — mirror that.
    string actual = _stripTrailingNewlines(r.Stdout + r.Stderr);
    string expected = "";
    if (File.Exists(c.expected)) {
        expected = _stripTrailingNewlines(File.ReadAllText(c.expected));
    }
    return actual == expected;
}

string _stripTrailingNewlines(string s) {
    int end = s.Length;
    while (end > 0 && (s.CharAt(end - 1) == '\n' || s.CharAt(end - 1) == '\r')) {
        end = end - 1;
    }
    if (end == s.Length) return s;
    return s.Substring(0, end);
}

void _printFailLine(_Case c, ProcessResult r) {
    Console.WriteLine("  FAIL: " + c.name);
    string actual = r.Stdout + r.Stderr;
    string expected = "";
    if (File.Exists(c.expected)) { expected = File.ReadAllText(c.expected); }
    if (expected.Length == 0) {
        Console.WriteLine("    expected: <empty>");
    } else {
        Console.WriteLine("    expected: " + _firstLine(expected));
    }
    Console.WriteLine("    actual:   " + _firstLine(actual));
}

// ── Enumeration ──────────────────────────────────────────────────────────

_Case[] _enumerateCases(string root, string mode) {
    _Case[] cases = new _Case[64];
    int n = 0;

    // Dir mode part 1: src/tests/<cat>/<name>/
    string testsDir = Path.Join(root, "src/tests");
    string[] cats = _enumDirsSorted(testsDir);
    int ci = 0;
    while (ci < cats.Length) {
        string catDir = Path.Join(testsDir, cats[ci]);
        if (_isExcludedCat(cats[ci])) { ci = ci + 1; continue; }
        string[] names = _enumDirsSorted(catDir);
        int ni = 0;
        while (ni < names.Length) {
            string dir = Path.Join(catDir, names[ni]);
            if (_isExcludedDirName(cats[ci], names[ni])) { ni = ni + 1; continue; }
            string artifact = Path.Join(dir, "source.zbc");
            if (File.Exists(artifact)) {
                if (mode == "jit" && File.Exists(Path.Join(dir, "interp_only"))) {
                    ni = ni + 1;
                    continue;
                }
                string expected = Path.Join(dir, "expected_output.txt");
                string entry = _deriveEntry(Path.Join(dir, "source.z42"));
                _Case c = new _Case(names[ni], artifact, expected, entry);
                cases = _appendCase(cases, n, c);
                n = n + 1;
            }
            ni = ni + 1;
        }
        ci = ci + 1;
    }

    // Dir mode part 2: src/libraries/<lib>/tests/<name>/
    string libsRoot = Path.Join(root, "src/libraries");
    string[] libs = _enumDirsSorted(libsRoot);
    int li = 0;
    while (li < libs.Length) {
        string libTests = Path.Join(libsRoot, libs[li] + "/tests");
        if (Directory.Exists(libTests)) {
            string[] names = _enumDirsSorted(libTests);
            int ni = 0;
            while (ni < names.Length) {
                string dir = Path.Join(libTests, names[ni]);
                string artifact = Path.Join(dir, "source.zbc");
                if (File.Exists(artifact)) {
                    if (mode == "jit" && File.Exists(Path.Join(dir, "interp_only"))) {
                        ni = ni + 1;
                        continue;
                    }
                    string expected = Path.Join(dir, "expected_output.txt");
                    string entry = _deriveEntry(Path.Join(dir, "source.z42"));
                    _Case c = new _Case(names[ni], artifact, expected, entry);
                    cases = _appendCase(cases, n, c);
                    n = n + 1;
                }
                ni = ni + 1;
            }
        }
        li = li + 1;
    }

    // Flat mode: src/tests/<cat>/<name>.zbc
    ci = 0;
    while (ci < cats.Length) {
        if (_isExcludedCat(cats[ci])) { ci = ci + 1; continue; }
        string catDir = Path.Join(testsDir, cats[ci]);
        string[] hits = Path.Glob(catDir, "*.zbc");
        int hi = 0;
        while (hi < hits.Length) {
            string artifact = hits[hi];
            string name = Path.GetFileNameWithoutExtension(artifact);
            string interpMarker = Path.Join(catDir, name + ".interp_only");
            if (mode == "jit" && File.Exists(interpMarker)) {
                hi = hi + 1;
                continue;
            }
            string expected = Path.Join(catDir, name + ".expected_output.txt");
            string srcFile = Path.Join(catDir, name + ".z42");
            string entry = _deriveEntry(srcFile);
            _Case c = new _Case(name, artifact, expected, entry);
            cases = _appendCase(cases, n, c);
            n = n + 1;
            hi = hi + 1;
        }
        ci = ci + 1;
    }

    // Trim to exact length.
    _Case[] tight = new _Case[n];
    int t = 0;
    while (t < n) { tight[t] = cases[t]; t = t + 1; }
    return tight;
}

bool _isExcludedCat(string cat) {
    return cat == "cross-zpkg" || cat == "zbc-format" || cat == "zpkg-format";
}

// Pre-existing known-deferred cases (cross-zpkg static-init bug).
bool _isExcludedDirName(string cat, string name) {
    if (cat == "gc" && name == "composite_ref_weak_mode") return true;
    if (cat == "delegates" && name == "multicast_subscription_refs") return true;
    return false;
}

// Mirror bash derive_entry: priority `<ns>.Main > Main > <ns>.main > main`.
string _deriveEntry(string srcFile) {
    if (!File.Exists(srcFile)) return "Main";
    string content = File.ReadAllText(srcFile);
    string ns = _extractNamespace(content);
    bool hasUpper = _hasMain(content, "Main");
    bool hasLower = _hasMain(content, "main");
    string fnName = "Main";
    if (hasUpper) { fnName = "Main"; }
    else if (hasLower) { fnName = "main"; }
    if (ns.Length > 0) { return ns + "." + fnName; }
    return fnName;
}

// Find first `namespace <Identifier>;` line; return the identifier (or "").
string _extractNamespace(string content) {
    int i = 0;
    while (i < content.Length) {
        // Skip leading whitespace on a line.
        int lineStart = i;
        while (i < content.Length && (content.CharAt(i) == ' ' || content.CharAt(i) == '\t')) { i = i + 1; }
        // Check for "namespace ".
        if (i + 10 <= content.Length
                && content.Substring(i, 10) == "namespace "
                && _isWordEnd(content, i + 9)) {
            int n = i + 10;
            // Skip whitespace.
            while (n < content.Length && (content.CharAt(n) == ' ' || content.CharAt(n) == '\t')) { n = n + 1; }
            int idStart = n;
            while (n < content.Length && _isIdentChar(content.CharAt(n))) { n = n + 1; }
            if (n > idStart) {
                return content.Substring(idStart, n - idStart);
            }
        }
        // Advance to next line.
        while (i < content.Length && content.CharAt(i) != '\n') { i = i + 1; }
        if (i < content.Length) { i = i + 1; }
    }
    return "";
}

bool _isWordEnd(string s, int i) {
    if (i >= s.Length) return true;
    char c = s.CharAt(i);
    return c == ' ' || c == '\t';
}

bool _isIdentChar(char c) {
    return (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')
        || (c >= '0' && c <= '9') || c == '_' || c == '.';
}

// Bash: `grep -c '\bvoid\s+<name>\s*('` — count > 0 means found.
bool _hasMain(string content, string name) {
    int i = 0;
    while (i < content.Length) {
        int idx = _indexOfFrom(content, "void", i);
        if (idx < 0) return false;
        // Require `\b` before void (start of string or non-ident).
        if (idx > 0 && _isIdentChar(content.CharAt(idx - 1))) {
            i = idx + 1;
            continue;
        }
        int p = idx + 4;
        // Require whitespace after "void".
        if (p >= content.Length
            || (content.CharAt(p) != ' ' && content.CharAt(p) != '\t')) {
            i = idx + 1;
            continue;
        }
        while (p < content.Length
            && (content.CharAt(p) == ' ' || content.CharAt(p) == '\t')) { p = p + 1; }
        // Check name (case-sensitive).
        if (p + name.Length > content.Length
            || content.Substring(p, name.Length) != name) {
            i = idx + 1;
            continue;
        }
        int after = p + name.Length;
        // Boundary after name + optional whitespace + '('.
        if (after < content.Length && _isIdentChar(content.CharAt(after))) {
            i = idx + 1;
            continue;
        }
        int q = after;
        while (q < content.Length
            && (content.CharAt(q) == ' ' || content.CharAt(q) == '\t')) { q = q + 1; }
        if (q < content.Length && content.CharAt(q) == '(') {
            return true;
        }
        i = idx + 1;
    }
    return false;
}

int _indexOfFrom(string s, string needle, int start) {
    int n = needle.Length;
    int limit = s.Length - n;
    int i = start;
    while (i <= limit) {
        if (s.Substring(i, n) == needle) return i;
        i = i + 1;
    }
    return -1;
}

// ── String / array helpers ───────────────────────────────────────────────

string _firstLine(string s) {
    int i = 0;
    while (i < s.Length && s.CharAt(i) != '\n') { i = i + 1; }
    return s.Substring(0, i);
}

string[] _splitWords(string s) {
    // Split on ASCII whitespace.
    string[] result = new string[4];
    int n = 0;
    int i = 0;
    while (i < s.Length) {
        while (i < s.Length
            && (s.CharAt(i) == ' ' || s.CharAt(i) == '\t' || s.CharAt(i) == '\n')) {
            i = i + 1;
        }
        if (i >= s.Length) break;
        int start = i;
        while (i < s.Length
            && s.CharAt(i) != ' ' && s.CharAt(i) != '\t' && s.CharAt(i) != '\n') {
            i = i + 1;
        }
        result = _append(result, n, s.Substring(start, i - start));
        n = n + 1;
    }
    string[] tight = new string[n];
    int t = 0;
    while (t < n) { tight[t] = result[t]; t = t + 1; }
    return tight;
}

string _envOpt(string name, string fallback) {
    string? v = Environment.GetEnvironmentVariable(name);
    if (v == null) return fallback;
    string nonNull = v ?? "";
    if (nonNull.Length == 0) return fallback;
    return nonNull;
}

int _envOptInt(string name, int fallback) {
    string s = _envOpt(name, "");
    if (s.Length == 0) return fallback;
    try { return int.Parse(s); } catch (Exception e) { return fallback; }
}

string[] _enumDirsSorted(string dir) {
    if (!Directory.Exists(dir)) { return new string[0]; }
    string[] entries = Directory.Enumerate(dir);
    int n = 0;
    int i = 0;
    while (i < entries.Length) {
        if (Directory.Exists(Path.Join(dir, entries[i]))) { n = n + 1; }
        i = i + 1;
    }
    string[] subs = new string[n];
    int j = 0;
    i = 0;
    while (i < entries.Length) {
        if (Directory.Exists(Path.Join(dir, entries[i]))) {
            subs[j] = entries[i];
            j = j + 1;
        }
        i = i + 1;
    }
    _sortStrings(subs);
    return subs;
}

void _sortStrings(string[] arr) {
    int i = 1;
    while (i < arr.Length) {
        string key = arr[i];
        int j = i - 1;
        while (j >= 0 && key.CompareTo(arr[j]) < 0) {
            arr[j + 1] = arr[j];
            j = j - 1;
        }
        arr[j + 1] = key;
        i = i + 1;
    }
}

string[] _append(string[] arr, int count, string v) {
    if (count < arr.Length) {
        arr[count] = v;
        return arr;
    }
    int newCap = arr.Length * 2;
    if (newCap < 4) { newCap = 4; }
    string[] bigger = new string[newCap];
    int i = 0;
    while (i < count) { bigger[i] = arr[i]; i = i + 1; }
    bigger[count] = v;
    return bigger;
}

_Case[] _appendCase(_Case[] arr, int count, _Case v) {
    if (count < arr.Length) {
        arr[count] = v;
        return arr;
    }
    int newCap = arr.Length * 2;
    if (newCap < 4) { newCap = 4; }
    _Case[] bigger = new _Case[newCap];
    int i = 0;
    while (i < count) { bigger[i] = arr[i]; i = i + 1; }
    bigger[count] = v;
    return bigger;
}
