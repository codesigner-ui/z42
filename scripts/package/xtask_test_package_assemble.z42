// xtask — packages.toml assembly engine self-check (add-package-layout-config,
// 阶段 4.1b).
//
// Same rationale as xtask_test_packages_config.z42 / xtask_test_stage_components.z42:
// xtask is an exe, so the [Test]-attribute reflection runner can't see it — this
// is a plain throw-on-mismatch self-check wired into `test`, not [Test]-discovered.
//
// Exercises _pkgAssembleFromStaging against a hand-built _PackagesConfig (two
// throwaway fake components, not scripts/packages.toml's real ones) so the test
// never touches real staged artifacts:
//   - merge: two components' staged subtrees land in the same pkgDir
//   - copy order: `include` order determines which component wins on a
//     same-path collision (design.md Decision 5 — include order only affects
//     copy order)
//   - error path: a package that includes a component with no staged directory
//     fails loudly instead of silently assembling a partial package
namespace Z42Xtask;

using Std;
using Std.IO;

void _asmAssert(string what, bool cond) {
    if (!cond) { throw new Exception("packages-assemble: " + what + ": failed"); }
}

_PkgComponent _asmFakeComponent(string name) {
    _PkgComponent comp = new _PkgComponent();
    comp.name = name;
    comp.kind = "fake";
    return comp;
}

_PackagesConfig _asmFakeConfig(string pkgName, string[] include, string[] compNames) {
    _PkgPackage pkg = new _PkgPackage();
    pkg.name = pkgName;
    pkg.include = include;
    _PkgComponent[] comps = new _PkgComponent[compNames.Length];
    int i = 0;
    while (i < compNames.Length) {
        comps[i] = _asmFakeComponent(compNames[i]);
        i = i + 1;
    }
    _PackagesConfig cfg = new _PackagesConfig();
    cfg.packages = new _PkgPackage[1];
    cfg.packages[0] = pkg;
    cfg.components = comps;
    return cfg;
}

int _testPackagesAssemble() {
    string root = _root();
    string stagingRoot = _pubStagingRoot(root);
    string aDir = Path.Join(stagingRoot, "assemble-test-a");
    string bDir = Path.Join(stagingRoot, "assemble-test-b");
    string pkgDir = Path.Join(root, "artifacts/tmp/assemble-test-pkg");
    if (Directory.Exists(aDir)) { Directory.Delete(aDir, true); }
    if (Directory.Exists(bDir)) { Directory.Delete(bDir, true); }
    if (Directory.Exists(pkgDir)) { Directory.Delete(pkgDir, true); }
    Directory.Create(Path.Join(aDir, "sub"));
    Directory.Create(bDir);
    File.WriteAllText(Path.Join(aDir, "only-in-a.txt"), "a");
    File.WriteAllText(Path.Join(aDir, "sub/nested.txt"), "a-nested");
    File.WriteAllText(Path.Join(aDir, "shared.txt"), "from-a");
    File.WriteAllText(Path.Join(bDir, "only-in-b.txt"), "b");
    File.WriteAllText(Path.Join(bDir, "shared.txt"), "from-b");

    // merge + copy-order: b listed after a in `include` → b's shared.txt wins,
    // and both components' unique files (including a's subdirectory) survive.
    string[] include = new string[2];
    include[0] = "assemble-test-a";
    include[1] = "assemble-test-b";
    string[] compNames = new string[2];
    compNames[0] = "assemble-test-a";
    compNames[1] = "assemble-test-b";
    _PackagesConfig cfg = _asmFakeConfig("assemble-test-pkg", include, compNames);
    Directory.Create(pkgDir);
    int c = _pkgAssembleFromStaging(cfg, root, "assemble-test-pkg", pkgDir);
    _asmAssert("assemble ok", c == 0);
    _asmAssert("only-in-a.txt merged", File.ReadAllText(Path.Join(pkgDir, "only-in-a.txt")) == "a");
    _asmAssert("sub/nested.txt merged (recursive)", File.ReadAllText(Path.Join(pkgDir, "sub/nested.txt")) == "a-nested");
    _asmAssert("only-in-b.txt merged", File.ReadAllText(Path.Join(pkgDir, "only-in-b.txt")) == "b");
    _asmAssert("shared.txt: later include wins", File.ReadAllText(Path.Join(pkgDir, "shared.txt")) == "from-b");

    // error path: package includes a component with no staged directory.
    string[] missingInclude = new string[1];
    missingInclude[0] = "assemble-test-missing";
    string[] missingCompNames = new string[1];
    missingCompNames[0] = "assemble-test-missing";
    _PackagesConfig missingCfg = _asmFakeConfig("assemble-test-missing-pkg", missingInclude, missingCompNames);
    string missingPkgDir = Path.Join(root, "artifacts/tmp/assemble-test-missing-pkg");
    if (Directory.Exists(missingPkgDir)) { Directory.Delete(missingPkgDir, true); }
    Directory.Create(missingPkgDir);
    int missingC = _pkgAssembleFromStaging(missingCfg, root, "assemble-test-missing-pkg", missingPkgDir);
    _asmAssert("unstaged component fails loudly", missingC != 0);

    Directory.Delete(aDir, true);
    Directory.Delete(bDir, true);
    Directory.Delete(pkgDir, true);
    Directory.Delete(missingPkgDir, true);
    Console.WriteLine("packages-assemble: PASS (merge + copy-order + unstaged-component error path)");
    return 0;
}
