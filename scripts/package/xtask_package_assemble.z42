// xtask — packages.toml assembly engine (add-package-layout-config, 阶段 4.1b).
//
// The "② 发行组装" half of design.md's architecture: given a package name
// (sdk / runtime / ...), resolve its `include` list (xtask_packages_config.z42)
// and merge each component's already-staged subtree (artifacts/publish/<comp>/,
// produced by either `z42b publish` for apphost components or the fixed
// handlers in xtask_stage_components.z42) into the package directory. This
// function never builds or publishes anything itself — by the time it runs,
// every included component must already be staged (Decision 6: "include 解析
// 永远只是「读一个目录树、拷贝」，不知道怎么产出").
namespace Z42Xtask;

using Std;
using Std.IO;

// Merge every resolved [package.<packageName>] component's staged subtree
// into pkgDir, in include order (Decision 5: include order only affects copy
// order, never build order — build order is each component's own concern).
int _pkgAssembleFromStaging(_PackagesConfig cfg, string root, string packageName, string pkgDir) {
    _PkgComponent[] comps = _pkgcfgResolveInclude(cfg, packageName);
    string stagingRoot = _pubStagingRoot(root);
    int i = 0;
    while (i < comps.Length) {
        string stagingDir = Path.Join(stagingRoot, comps[i].name);
        if (!Directory.Exists(stagingDir)) {
            ConsoleError.WriteLine("error: [package." + packageName + "] needs component '" + comps[i].name
                + "' but it is not staged at " + stagingDir);
            return 1;
        }
        Directory.Copy(stagingDir, pkgDir, true);
        i = i + 1;
    }
    return 0;
}
