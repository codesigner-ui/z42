// port-audit-missing-usings (2026-05-17)：第二个 .z42 实现的 build script。
//
// 行为对齐 scripts/audit-missing-usings.sh（100 LOC bash）：扫 src/tests +
// src/libraries 下所有 source.z42，根据 type 使用启发式插入缺失 `using` 声明。
// 幂等：已存在的 using 跳过。
//
// 入口：`z42c run scripts/audit-missing-usings.z42`；CWD 必须 repo root。
namespace Z42AuditMissingUsingsScript;

using Std;
using Std.IO;
using Std.Regex;

void Main() {
    string root = Environment.GetCurrentDirectory();

    // 收集所有 source.z42（src/tests + src/libraries/*/tests 递归）
    string[] testsFiles = _findSourceFiles(Path.Join(root, "src/tests"));
    string[] libsFiles  = _findSourceFiles(Path.Join(root, "src/libraries"));

    int patched = 0;
    int i = 0;
    while (i < testsFiles.Length) {
        if (_patchOne(testsFiles[i], root)) { patched = patched + 1; }
        i = i + 1;
    }
    i = 0;
    while (i < libsFiles.Length) {
        if (_patchOne(libsFiles[i], root)) { patched = patched + 1; }
        i = i + 1;
    }

    Console.WriteLine("");
    Console.WriteLine("audit-missing-usings: " + patched.ToString() + " file(s) patched");
}

// 返回 root 下所有名为 "source.z42" 的全路径（递归）。
string[] _findSourceFiles(string root) {
    if (!Directory.Exists(root)) {
        string[] empty = new string[0];
        return empty;
    }
    string[] all = Directory.EnumerateRecursive(root);
    // 过滤 basename == "source.z42"
    int n = 0;
    int i = 0;
    while (i < all.Length) {
        if (Path.GetFileName(all[i]) == "source.z42") { n = n + 1; }
        i = i + 1;
    }
    string[] hits = new string[n];
    int j = 0;
    i = 0;
    while (i < all.Length) {
        string rel = all[i];
        if (Path.GetFileName(rel) == "source.z42") {
            // EnumerateRecursive 返回相对 root 的子路径；要全路径
            hits[j] = Path.Join(root, rel);
            j = j + 1;
        }
        i = i + 1;
    }
    return hits;
}

// 返回 true 当文件被实际修改。
bool _patchOne(string path, string repoRoot) {
    if (!File.Exists(path)) { return false; }
    string content = File.ReadAllText(path);

    string[] needed = _detectNeeded(content);
    if (needed.Length == 0) { return false; }

    // 过滤已存在的
    string[] missing = _filterMissing(content, needed);
    if (missing.Length == 0) { return false; }

    string updated = _insertUsings(content, missing);
    File.WriteAllText(path, updated);

    // 输出 "patched: <relpath> (+ns ns)"
    string rel = path;
    if (path.StartsWith(repoRoot)) {
        rel = path.Substring(repoRoot.Length + 1, path.Length - repoRoot.Length - 1);
    }
    string suffix = "";
    int i = 0;
    while (i < missing.Length) { suffix = suffix + " " + missing[i]; i = i + 1; }
    Console.WriteLine("  patched: " + rel + " (+" + suffix.Substring(1, suffix.Length - 1) + ")");
    return true;
}

// 按 type 使用模式启发式检测需要的 using namespaces。
// 同 bash 版的 5 条规则（List/Dictionary/KeyValuePair 在 z42.core prelude，不报）。
//
// z42.regex 当前无 `\b` 字边界支持（escape `\b` 解析为字面 'b'）；用
// `(^|[^A-Za-z0-9_])` 模拟左边界，type 名后的 `.` 或 `\s*\(` 充当右边界。
// 罕见 false positive（MyConsole.X 等用户类名）可接受 —— 多加 using 不破坏编译。
string[] _detectNeeded(string content) {
    // capacity 5（max 同时需要 5 个 namespace）
    string[] buf = new string[5];
    int n = 0;

    string wb = "(^|[^A-Za-z0-9_])";

    // Std.IO: Console. / File. / Directory. / Path.
    if (_hasMatch(content, wb + "(Console|File|Directory|Path)\\.")) {
        buf[n] = "Std.IO"; n = n + 1;
    }
    // Std.Math: Math. / Random. / new Random(...
    if (_hasMatch(content, wb + "(Math|Random)\\.") ||
        _hasMatch(content, wb + "new Random\\s*\\(")) {
        buf[n] = "Std.Math"; n = n + 1;
    }
    // Std.Collections: new Queue( / new Stack(
    if (_hasMatch(content, wb + "new (Queue|Stack)\\s*\\(")) {
        buf[n] = "Std.Collections"; n = n + 1;
    }
    // Std.Text: StringBuilder
    if (_hasMatch(content, wb + "StringBuilder(\\s|\\.|\\(|;|$)")) {
        buf[n] = "Std.Text"; n = n + 1;
    }
    // Std.Test: TestRunner / new Test(
    if (_hasMatch(content, wb + "TestRunner(\\s|\\.|\\(|;|$)") ||
        _hasMatch(content, wb + "new Test\\s*\\(")) {
        buf[n] = "Std.Test"; n = n + 1;
    }

    string[] result = new string[n];
    int i = 0;
    while (i < n) { result[i] = buf[i]; i = i + 1; }
    return result;
}

bool _hasMatch(string text, string pattern) {
    Regex r = Regex.Compile(pattern);
    return r.IsMatch(text);
}

// 返回 needed 中尚未在 content 顶部声明的部分。
string[] _filterMissing(string content, string[] needed) {
    string[] buf = new string[needed.Length];
    int n = 0;
    int i = 0;
    while (i < needed.Length) {
        string ns = needed[i];
        // pattern: ^\s*using\s+<ns>;     （escape '.' in ns）
        string nsEscaped = _escapeDots(ns);
        string pat = "^\\s*using\\s+" + nsEscaped + ";";
        Regex r = Regex.Compile(pat);
        // 注意：现在 Regex 没有 multiline flag；用按行扫描代替
        bool found = false;
        string[] lines = content.Split("\n");
        int j = 0;
        while (j < lines.Length) {
            if (r.IsMatch(lines[j])) { found = true; break; }
            j = j + 1;
        }
        if (!found) { buf[n] = ns; n = n + 1; }
        i = i + 1;
    }
    string[] result = new string[n];
    int k = 0;
    while (k < n) { result[k] = buf[k]; k = k + 1; }
    return result;
}

string _escapeDots(string s) {
    string acc = "";
    int i = 0;
    while (i < s.Length) {
        char c = s.CharAt(i);
        if (c == '.') { acc = acc + "\\."; } else { acc = acc + c.ToString(); }
        i = i + 1;
    }
    return acc;
}

// 插入 missing usings：若有 `namespace ...;` 行，插到其后；否则文件顶端。
string _insertUsings(string content, string[] missing) {
    string[] lines = content.Split("\n");
    Regex nsLine = Regex.Compile("^\\s*namespace\\s+");

    int nsIdx = -1;
    int i = 0;
    while (i < lines.Length) {
        if (nsLine.IsMatch(lines[i])) { nsIdx = i; break; }
        i = i + 1;
    }

    string usingsBlock = "";
    int j = 0;
    while (j < missing.Length) {
        usingsBlock = usingsBlock + "using " + missing[j] + ";\n";
        j = j + 1;
    }

    if (nsIdx < 0) {
        // 顶端插入
        return usingsBlock + content;
    }

    // namespace line 后插入：拼 [0..nsIdx] + usings + [nsIdx+1..end]
    string acc = "";
    int k = 0;
    while (k <= nsIdx) {
        acc = acc + lines[k];
        // Split 丢了 \n；末行无 newline 由 _joinLines 处理
        if (k < lines.Length - 1) { acc = acc + "\n"; }
        k = k + 1;
    }
    acc = acc + usingsBlock;
    k = nsIdx + 1;
    while (k < lines.Length) {
        acc = acc + lines[k];
        if (k < lines.Length - 1) { acc = acc + "\n"; }
        k = k + 1;
    }
    return acc;
}
