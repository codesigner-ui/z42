// xtask — `build compiler` / `test compiler` impl
// (scaffold-z42c-selfhost, 2026-06-07).
//
// Builds the z42 self-host compiler workspace (src/compiler — 7 子包 1:1 镜像 C#
// bootstrap 的 7 项目) and smoke-tests that all 7 z42c.<sub>.zpkg are produced.
// Mirrors xtask_stdlib.z42 (_buildStdlibCore) but targets src/compiler →
// artifacts/build/z42c.
//
// NO Z42_LIBS needed: the C# z42c resolves declared workspace siblings from the
// CURRENT workspace — WorkspaceBuildOrchestrator threads each member's dist dir
// into BuildLibsDirs (scaffold-z42c-selfhost dogfood #1 root-cause fix). So a
// plain `build --workspace` finds z42c.core → z42c.syntax → … → z42c.driver.
//
// 0.3.x: this is opt-in soak (NOT in the default `test` GREEN gate). byte-identical
// 对账留待 0.3.3 起子系统有真实产物时上；本期只做 build + 产物存在性 smoke。
namespace Z42Xtask;

using Std;
using Std.IO;

// z42c 自建走自种子路径（z42c builds z42c）。
// 种子 = 现有 canonical z42c dist（self-seed；clean/CI 由下载 nightly 提供）。
// 缺种子 → 明确报错指引 bootstrap。
int _buildCompiler() {
    string root = _root();
    string profile = "release";
    string seedDriver = Path.Join(root, "artifacts/build/z42c/z42c.driver/" + profile + "/dist/z42c.driver.zpkg");
    if (!File.Exists(seedDriver) || File.GetSize(seedDriver) <= 0L) {
        ConsoleError.WriteLine("error: no z42c seed at " + seedDriver);
        ConsoleError.WriteLine("       seed z42c first: install the nightly toolchain (`z42 install`)");
        return 1;
    }
    int rc = _buildRuntime(); if (rc != 0) { return rc; }   // cargo release z42vm（C#-free）跑种子 driver
    string vm = _builtVm(root, "release");
    string stdlibFlat = Path.Join(root, "artifacts/build/libraries/dist/" + profile);
    if (!File.Exists(Path.Join(stdlibFlat, "z42.core.zpkg"))) {
        int sc = _buildStdlib(); if (sc != 0) { return sc; }   // C#-free（A1 warm 种子路径）
    }
    string[] members = _compilerMembers(root);
    return _buildCompilerViaZ42c(root, profile, members, vm, stdlibFlat);
}

// C#-free z42c self-build (replace-csharp S5 Phase A): rebuild the 7 z42c.* from
// CURRENT source using an EXISTING z42c.driver.zpkg as the seed compiler (z42c
// builds z42c), with NO dotnet. Single-toml per member in topo order, accumulating
// freshly-built siblings (avoids the `build --workspace` self-build E0402 wrinkle).
// Writes to the canonical dist (artifacts/build/z42c/<m>/release/dist), overwriting
// the seed. `stdlibFlat` (existing stdlib) is needed at runtime to run the seed z42c.
// Precondition: caller verified the seed driver + stdlib exist.
int _buildCompilerViaZ42c(string root, string profile, string[] members, string vm, string stdlibFlat) {
    Console.WriteLine("  building z42c via z42c (C#-free, single-toml topo)");
    string seedDriver = Path.Join(root, "artifacts/build/z42c/z42c.driver/" + profile + "/dist/z42c.driver.zpkg");
    // runlibs = stdlib (run z42c.driver) + seed z42c siblings; fresh members accumulate here.
    string runlibs = Path.Join(root, "artifacts/build/z42c/selfbuild-runlibs/" + profile);
    _resetDir(runlibs);
    _copyAll(stdlibFlat, runlibs, "*.zpkg");
    int i = 0;
    while (i < members.Length) {
        _copyAll(Path.Join(root, "artifacts/build/z42c/" + members[i] + "/" + profile + "/dist"), runlibs, "*.zpkg");
        i = i + 1;
    }
    i = 0;
    while (i < members.Length) {
        string m = members[i];
        string outDir = Path.Join(root, "artifacts/build/z42c/" + m + "/" + profile + "/dist");
        int rc = new Process(vm).Arg(seedDriver).Arg("--mode").Arg("interp").Arg("--")
            .Arg("build").Arg(Path.Join(root, "src/compiler/" + m + "/" + m + ".z42.toml"))
            .Arg("--release").Arg("--output-dir").Arg(outDir)
            .Env("Z42_LIBS", runlibs)
            .Stdout(Stdio.Inherit()).Stderr(Stdio.Inherit()).Run().ExitCode;
        if (rc != 0) { ConsoleError.WriteLine("  ✗ z42c self-build failed: " + m); return 1; }
        _copyAll(outDir, runlibs, m + ".zpkg");   // accumulate fresh sibling for later members
        i = i + 1;
    }
    return 0;
}

// 防 zpkg 版本 skew 假失败（2026-06-10）：z42c 测试单元先被 C# driver 编成 zpkg，
// 再交 z42-test-runner 的 *in-process VM*（链 libz42）运行。三者写/读的 zpkg 格式版本
// 必须一致。完整 `xtask test` 在跑前重建 stdlib+runtime+test-runner+driver，但
// `test compiler` 原本只检查 runner 存在、从不重建 —— 一旦某并行变更 bump 了 zpkg
// 格式（如 add-attribute-reflection-methods 把 minor 撞到 0.13），停在旧版的 test-runner
// 会在加载期把每个 unit 全判 "cannot read zpkg metadata"（空输出＝假失败）。
// 故此处显式重建 runtime(z42vm+libz42) + test-runner + driver。cached 时近 no-op，
// 仅当真有源码改动才付构建代价 —— 正是需要它的时刻。
int _ensureCompilerTooling() {
    Console.WriteLine("  ensuring tooling fresh (z42vm + z42-test-runner; release; C#-free)");
    int c = _buildRuntime();   // z42vm + libz42（in-process VM 的实现）
    if (c != 0) { return c; }
    // replace-csharp Phase C：不再 dotnet build C# driver——_buildCompiler 已 C#-free（种子自建）。
    return _exec(_cargoRelease().Arg("--manifest-path").Arg("src/toolchain/test-runner/Cargo.toml"));
}

// smoke: build + assert each z42c.<sub>.zpkg product exists & is non-empty.
// member list derives from the workspace manifest's default-members (single
// source of truth; cf. _stdlibList). member name == [project].name == zpkg
// basename, so the product path is build/z42c/<name>/release/dist/<name>.zpkg.
// noBuild=true: skip the tooling + z42c rebuild (the caller — `test all` — already
// built z42c fresh in its build wave; rebuilding here was z42c's 2nd/3rd full
// self-build in one gate run). Standalone `test compiler` passes false.
int _testCompiler(bool noBuild) {
    if (!noBuild) {
        int tc = _ensureCompilerTooling();   // 重建 runtime+runner+driver，防版本 skew 假失败
        if (tc != 0) { return tc; }
        int bc = _buildCompiler();
        if (bc != 0) { return bc; }
    }

    string root = _root();
    string profile = "release";
    string buildRoot = Path.Join(root, "artifacts/build/z42c");
    string[] members = _compilerMembers(root);

    int ok = 0;
    int fail = 0;
    int i = 0;
    while (i < members.Length) {
        string zpkg = Path.Join(buildRoot,
            members[i] + "/" + profile + "/dist/" + members[i] + ".zpkg");
        if (File.Exists(zpkg) && File.GetSize(zpkg) > 0L) {
            long size = File.GetSize(zpkg);
            Console.WriteLine("    ✓ " + members[i] + ".zpkg (" + size.ToString() + " bytes)");
            ok = ok + 1;
        } else {
            Console.WriteLine("    ✗ " + members[i] + ".zpkg — workspace product missing at " + zpkg);
            fail = fail + 1;
        }
        i = i + 1;
    }

    Console.WriteLine("");
    Console.WriteLine("test compiler: " + ok.ToString() + "/"
        + members.Length.ToString() + " zpkg present");
    if (fail > 0) { return 1; }

    // ── z42c [Test] units ────────────────────────────────────────────────
    return _testCompilerUnits(root, profile, members);
}

// reset 一个私有目录（删后建）。
void _resetDir(string d) {
    if (Directory.Exists(d)) { Directory.Delete(d, true); }
    Directory.Create(d);
}

// COPY（非 hard-link）srcDir 下匹配文件到 dstDir。私有目录 + 拷贝避免 _linkAll
// 的 hard-link inode 别名污染（共享目录被 rebuild 会把 per-member 源弄坏）。
void _copyAll(string srcDir, string dstDir, string pattern) {
    if (!Directory.Exists(srcDir)) { return; }
    string[] hits = Path.Glob(srcDir, pattern);
    int i = 0;
    while (i < hits.Length) {
        try { File.Copy(hits[i], Path.Join(dstDir, Path.GetFileName(hits[i]))); }
        catch (Exception e) { /* skip */ }
        i = i + 1;
    }
}

// replace-csharp-compiler S2.1：z42c dogfood 编 stdlib + 功能验证（additive，C# 不动）。
// 全私有目录 + 拷贝（不碰 alllibs / 不 hard-link），bootstrap-safe：z42c 运行靠
// C#-built stdlib，产物落独立 dogfood 目录。
int _testCompilerStdlib() {
    string root = _root();
    string profile = "release";
    Console.WriteLine("");
    Console.WriteLine("══ replace-csharp-compiler S2.1: z42c dogfood-builds stdlib ══");
    // replace-csharp Phase C：C# 已删——用 C#-free warm 路径建 fresh stdlib + z42c（种子来自
    // 下载 nightly / 现有 dist）。_buildStdlib 顺带 z42c 自建；下面再用 z42c 编到独立 dogfood 目录。
    int tc = _ensureCompilerTooling(); if (tc != 0) { return tc; }
    int sc = _buildStdlib(); if (sc != 0) { return sc; }

    string[] members = _compilerMembers(root);
    string vm = _builtVm(root, "release");
    string stdlibFlat = Path.Join(root, "artifacts/build/libraries/dist/" + profile);
    string dogfoodRoot = Path.Join(root, "artifacts/build/z42c/dogfood");

    // runDir = z42c 7 包 + stdlib（拷贝；运行 z42c.driver 用）。
    string runDir = Path.Join(dogfoodRoot, "run-" + profile);
    _resetDir(runDir);
    _copyAll(stdlibFlat, runDir, "*.zpkg");
    int mi = 0;
    while (mi < members.Length) {
        _copyAll(Path.Join(root, "artifacts/build/z42c/" + members[mi] + "/" + profile + "/dist"), runDir, "*.zpkg");
        mi = mi + 1;
    }
    string z42cDriver = Path.Join(runDir, "z42c.driver.zpkg");
    if (!File.Exists(z42cDriver) || File.GetSize(z42cDriver) <= 0L) {
        ConsoleError.WriteLine("  ✗ z42c.driver.zpkg invalid in " + runDir);
        return 1;
    }

    // z42c build --workspace stdlib → outDir（兄弟自累积，无 seed）。
    string outDir = Path.Join(dogfoodRoot, "stdlib-" + profile);
    _resetDir(outDir);
    Console.WriteLine("  z42c build --workspace (CWD=src/libraries, interp) → " + outDir);
    int bc = new Process(vm).Arg(z42cDriver).Arg("--mode").Arg("interp").Arg("--")
        .Arg("build").Arg("--workspace").Arg("--output-dir").Arg(outDir).Arg("--release")
        .WorkingDirectory(Path.Join(root, "src/libraries"))
        .Env("Z42_LIBS", runDir)
        .Stdout(Stdio.Inherit()).Stderr(Stdio.Inherit()).Run().ExitCode;
    if (bc != 0) { ConsoleError.WriteLine("  ✗ z42c build --workspace stdlib failed (" + bc.ToString() + ")"); return 1; }
    int nBuilt = Path.Glob(outDir, "*.zpkg").Length;

    // 功能验证：z42c 7 包（C#-built）+ z42c-built stdlib → 跑 z42c --emit-zbc。
    string verDir = Path.Join(dogfoodRoot, "verify-" + profile);
    _resetDir(verDir);
    _copyAll(outDir, verDir, "*.zpkg");          // z42c-built stdlib
    mi = 0;
    while (mi < members.Length) {                 // z42c 7 包
        _copyAll(Path.Join(root, "artifacts/build/z42c/" + members[mi] + "/" + profile + "/dist"), verDir, "*.zpkg");
        mi = mi + 1;
    }
    string probeSrc = Path.Join(root, "src/libraries/z42.math/tests/math_basics.z42");
    string probeOut = Path.Join(verDir, "_probe.zbc");
    Console.WriteLine("  functional: z42c --emit-zbc against z42c-built stdlib");
    int rc = new Process(vm).Arg(Path.Join(verDir, "z42c.driver.zpkg")).Arg("--mode").Arg("interp").Arg("--")
        .Arg("--emit-zbc").Arg(probeSrc).Arg(probeOut)
        .Env("Z42_LIBS", verDir)
        .Stdout(Stdio.Inherit()).Stderr(Stdio.Inherit()).Run().ExitCode;
    if (rc != 0 || !File.Exists(probeOut) || File.GetSize(probeOut) <= 0L) {
        ConsoleError.WriteLine("  ✗ z42c-built stdlib functional check failed (emit rc=" + rc.ToString() + ")");
        return 1;
    }
    Console.WriteLine("");
    Console.WriteLine("  ✅ z42c dogfood: built " + nBuilt.ToString() + " stdlib pkgs + functional (emit OK)");
    return 0;
}

// Build + run each z42c [Test] unit through z42-test-runner.
//
// RUNTIME 关键：z42vm 的 Z42_LIBS 是 *单个* 目录（非 colon-list），且必须含全部
// 依赖 zpkg。故先组装一个「z42c 7 包 + stdlib」合并 flat 目录，编译期与运行期
// 都指向它（dogfood：跨包方法调用与静态字段在运行时完全可用，只要 lib 全在一个
// flat 目录里——这正是当初误用 colon-list Z42_LIBS 导致 "VCall not found" 的根因）。
//
// 测试单元布局：src/compiler/<member>/tests/<unit>/{<name>.z42.toml + *.z42}。
// kind=lib（runner 按 [Test] 方法 fork z42vm，不需 Main）；z42.test 自动可用。
int _testCompilerUnits(string root, string profile, string[] members) {
    // stdlib（z42.test / z42.core prelude / ...）+ z42c 7 包 → 单一 Z42_LIBS flat 目录
    string flat = _assembleAllLibs(root, profile);

    string vm     = _builtVm(root, "release");
    string driverZpkg = Path.Join(root, "artifacts/build/z42c/z42c.driver/" + profile + "/dist/z42c.driver.zpkg");
    string runner = _builtBin(root, "release", "z42-test-runner");
    if (!File.Exists(runner)) {
        ConsoleError.WriteLine("error: z42-test-runner not found at " + runner
            + " (cargo build --release --manifest-path src/toolchain/test-runner/Cargo.toml)");
        return 2;
    }

    int totalFailed = 0;
    int totalUnits = 0;
    int i = 0;
    while (i < members.Length) {
        string testsDir = Path.Join(root, "src/compiler/" + members[i] + "/tests");
        if (Directory.Exists(testsDir)) {
            foreach (var unit in _sortedStrings(Directory.Enumerate(testsDir))) {
                string unitDir = Path.Join(testsDir, unit);
                if (!Directory.Exists(unitDir)) { continue; }
                string[] tomls = Path.Glob(unitDir, "*.z42.toml");
                if (tomls.Length == 0) { continue; }
                totalUnits = totalUnits + 1;
                Console.WriteLine("");
                Console.WriteLine("── z42c test: " + members[i] + " / " + unit + " ──");
                // compile (release/packed) with z42c（C#-free）；Z42_LIBS=flat 含 stdlib+z42c.* 兄弟，
                // z42c.driver 依赖与单元 deps 同从 flat 解析；输出落单元 toml 的 [build] output_dir 镜像。
                ProcessResult br = new Process(vm)
                    .Arg(driverZpkg).Arg("--mode").Arg("interp").Arg("--")
                    .Arg("build").Arg(tomls[0]).Arg("--release")
                    .Env("Z42_LIBS", flat)
                    .Stdout(Stdio.Inherit()).Stderr(Stdio.Inherit()).Run();
                if (br.ExitCode != 0) {
                    Console.WriteLine("  ✗ compile failed: " + unit);
                    totalFailed = totalFailed + 1;
                    continue;
                }
                // Build output → artifacts mirror via the unit toml's [build]
                // output_dir (mirror-build-output-per-component, 2026-06-16):
                //   src/compiler/<member>/tests/<unit> → artifacts/build/z42c/<member>/tests/<unit>
                // so the produced .zpkg lands in <mirror>/dist/, NOT beside source.
                string mirrorDist = Path.Join(
                    Path.Join(root, "artifacts/build/z42c/" + members[i] + "/tests/" + unit),
                    "dist");
                string[] zps = Path.Glob(mirrorDist, "*.zpkg");
                // Guard against a recurrence of the prior false-green: before
                // commit 7870db60 z42c ignored [build] output_dir and wrote to
                // <projectDir>/dist, so this Glob found 0 zpkgs → the run loop
                // ran 0 times → "all passed" was reported without any unit ever
                // executing. Treat "compiled OK but no product at mirror" as a
                // failure so a path mismatch can never masquerade as success.
                if (zps.Length == 0) {
                    Console.WriteLine("  ✗ no zpkg produced at " + mirrorDist);
                    totalFailed = totalFailed + 1;
                    continue;
                }
                // Run each produced test zpkg through the test-runner. z42c now
                // emits the TIDX (test-index) section (port-z42c-tidx, 2026-06-25),
                // so the runner discovers + executes [Test] methods just like for
                // C#-built units. (Pre-TIDX this was a loud SKIP — z42c-built
                // zpkgs had no TIDX → runner exit 3, no discovery.)
                int j = 0;
                while (j < zps.Length) {
                    int rc = new Process(runner)
                        .Arg(zps[j])
                        .Env("Z42_PORTABLE_VM", vm)
                        .Env("Z42_LIBS", flat)
                        .Stdout(Stdio.Inherit()).Stderr(Stdio.Inherit()).Run().ExitCode;
                    if (rc != 0) { totalFailed = totalFailed + 1; }
                    j = j + 1;
                }
            }
        }
        i = i + 1;
    }

    Console.WriteLine("");
    if (totalFailed > 0) {
        Console.WriteLine("❌ z42c [Test]: " + totalFailed.ToString() + " unit(s) failed (of "
            + totalUnits.ToString() + ")");
        return 1;
    }
    Console.WriteLine("✅ z42c [Test]: all " + totalUnits.ToString() + " unit(s) passed (compiled + run via TIDX)");
    int ec = _testCompilerE2e(root, vm, flat);
    if (ec != 0) { return ec; }
    return _testSelfHostByteIdentical(root, vm, flat, members, profile);
}


// 0.3.10 gate：z42c driver (built by C#) recompiles each of the 7 z42c packages;
// output must be byte-identical to the C#-built artifacts.
// Z42_LIBS=flat (stdlib + C#-built z42c) for dep resolution of each build.
int _testSelfHostByteIdentical(string root, string vm, string flat, string[] members, string profile) {
    Console.WriteLine("");
    Console.WriteLine("── z42c self-host byte-identical: z42c compiles z42c packages ──");

    string driverZpkg = Path.Join(root, "artifacts/build/z42c/z42c.driver/" + profile + "/dist/z42c.driver.zpkg");
    string outDir = Path.Join(root, "artifacts/build/z42c/selfhost-out");
    Directory.Create(outDir);
    _cleanGlob(outDir, "*.zpkg");

    int ok = 0;
    int fail = 0;
    int i = 0;
    while (i < members.Length) {
        string member = members[i];
        string tomlPath = Path.Join(root, "src/compiler/" + member + "/" + member + ".z42.toml");
        string expected = Path.Join(root, "artifacts/build/z42c/" + member + "/" + profile + "/dist/" + member + ".zpkg");

        ProcessResult br = new Process(vm)
            .Arg(driverZpkg).Arg("--")
            .Arg("build").Arg(tomlPath).Arg("--release").Arg("--output-dir").Arg(outDir)
            .Env("Z42_LIBS", flat)
            .Stdout(Stdio.Null()).Stderr(Stdio.Inherit()).Run();
        if (br.ExitCode != 0) {
            Console.WriteLine("  ✗ z42c build failed: " + member);
            fail = fail + 1;
            i = i + 1;
            continue;
        }

        string produced = Path.Join(outDir, member + ".zpkg");
        if (!File.Exists(produced)) {
            Console.WriteLine("  ✗ output not found: " + produced);
            fail = fail + 1;
            i = i + 1;
            continue;
        }

        byte[] got = File.ReadAllBytes(produced);
        byte[] want = File.ReadAllBytes(expected);
        // Section-level compare: ignore BLID (16B BLAKE3-128 build_id tail).
        // gen1 (canonical = _buildCompiler 自建) vs gen2 (gen1 编 source) 全段须一致。
        if (!_sectionsEqualIgnoreBlid(got, want)) {
            Console.WriteLine("  ✗ sections mismatch: " + member + " (gen2 " + got.Length.ToString() + "B vs gen1 " + want.Length.ToString() + "B)");
            fail = fail + 1;
        } else {
            Console.WriteLine("  ✓ " + member + " (sections byte-identical, BLID ignored)");
            ok = ok + 1;
        }
        i = i + 1;
    }

    Console.WriteLine("");
    if (fail > 0) {
        Console.WriteLine("❌ z42c self-host 不动点: " + fail.ToString() + "/" + members.Length.ToString() + " packages gen1≠gen2");
        return 1;
    }
    Console.WriteLine("✅ z42c self-host 不动点: " + ok.ToString() + "/" + members.Length.ToString() + " packages gen1==gen2 (C#-free)");
    return 0;
}

bool _bytesEqual(byte[] a, byte[] b) {
    if (a.Length != b.Length) { return false; }
    int i = 0;
    while (i < a.Length) {
        if (a[i] != b[i]) { return false; }
        i = i + 1;
    }
    return true;
}

// Compare zpkg files section-by-section, ignoring BLID (deferred in z42c).
// Header: "ZPK\0"[4]+major[2]+minor[2]+flags[2]+secCount[2]+reserved[4] = 16B.
// Directory: secCount * 12B (tag[4]+offset[4]+size[4]), starting at byte 16.
// BLID = bytes [66,76,73,68] ('B','L','I','D' in ASCII).
bool _sectionsEqualIgnoreBlid(byte[] got, byte[] want) {
    if (got.Length < 16 || want.Length < 16) { return false; }
    int gotSec  = _zpkgU16(got, 10);
    int wantSec = _zpkgU16(want, 10);
    // For each section in got, find matching section in want and compare data
    int gi = 0;
    while (gi < gotSec) {
        int gd   = 16 + gi * 12;
        int goff = _zpkgU32(got, gd + 4);
        int gsiz = _zpkgU32(got, gd + 8);
        bool found = false;
        int wi = 0;
        while (wi < wantSec) {
            int wd = 16 + wi * 12;
            if (got[gd] == want[wd] && got[gd+1] == want[wd+1] && got[gd+2] == want[wd+2] && got[gd+3] == want[wd+3]) {
                found = true;
                if (_zpkgU32(want, wd + 8) != gsiz) { return false; }
                int woff = _zpkgU32(want, wd + 4);
                int bi = 0;
                while (bi < gsiz) {
                    if (got[goff + bi] != want[woff + bi]) { return false; }
                    bi = bi + 1;
                }
            }
            wi = wi + 1;
        }
        if (!found) { return false; }
        gi = gi + 1;
    }
    // Verify want has no extra sections besides BLID
    int wi2 = 0;
    while (wi2 < wantSec) {
        int wd = 16 + wi2 * 12;
        bool isBlid = want[wd] == 66 && want[wd+1] == 76 && want[wd+2] == 73 && want[wd+3] == 68;
        if (!isBlid) {
            bool foundInGot = false;
            int gi2 = 0;
            while (gi2 < gotSec) {
                int gd = 16 + gi2 * 12;
                if (got[gd] == want[wd] && got[gd+1] == want[wd+1] && got[gd+2] == want[wd+2] && got[gd+3] == want[wd+3]) {
                    foundInGot = true;
                }
                gi2 = gi2 + 1;
            }
            if (!foundInGot) { return false; }
        }
        wi2 = wi2 + 1;
    }
    return true;
}

int _zpkgU16(byte[] data, int off) {
    return (int)data[off] | ((int)data[off + 1] << 8);
}

int _zpkgU32(byte[] data, int off) {
    int lo = (int)data[off] | ((int)data[off+1] << 8);
    int hi = (int)data[off+2] | ((int)data[off+3] << 8);
    return lo | (hi << 16);
}
