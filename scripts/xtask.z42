// xtask — the z42 repo's unified dev CLI (add-xtask-cli, 2026-06-04).
//
// Run via the launcher:  z42 xtask.zpkg <command> [args]
//
//   build  runtime | compiler | stdlib [lib] | launcher | package [--rid R] | all
//   test   (empty=all) | stdlib [lib] | vm [interp|jit] | cross-zpkg | compiler | changed
//   run    <app.zpkg|script.z42> [-- args]
//   deps   check | install
//   bench  [--diff]
//   help   (also -h / --help)
//
// MVP (Stream 3): each subcommand cd's to the repo root and delegates to the
// existing script/.z42, forwarding stdout/stderr + exit code. Stream 2
// (migrate-scripts-to-z42) replaces each delegation with native z42 and
// deletes the corresponding .sh.
// migrate-xtask-launcher-to-std-cli (2026-06-10): Main delegates to the
// Std.Cli nested router in xtask_cli.z42 (_runCli). The command tree, every
// leaf's flags/positionals, per-level `-h` help, and unknown-command errors
// are all handled there. `package` / `feature-matrix` are now top-level
// (were under `build`); the `test lib` / `bench lib` aliases are dropped
// (use `stdlib`). Handlers below read their args from a Std.Cli ParseResult.
namespace Z42Xtask;

using Std;
using Std.IO;
using Std.Cli;

void Main() {
    string[] argv = Environment.GetCommandLineArgs();
    _ensureDriverVm();
    Environment.Exit(_runCli(argv));
}

// ── run (thin passthrough to the launcher) ──────────────────────────────────

// Forwards `<app.zpkg|script.z42> [-- args]` verbatim to `z42 run`. Raw
// passthrough (intercepted in _runCli before Resolve) — the launcher itself
// handles the `--` app-args tail.
int _run(string[] argv) {
    return _sh("z42 run " + _join(argv, 1));
}

// ── build ─────────────────────────────────────────────────────────────────

int _buildRuntime() {
    return _exec(_cargoRelease()
        .Arg("--manifest-path").Arg(_runtimeManifest()));
}

// replace-csharp Phase C：_buildCompiler（dotnet build z42.slnx）已删——C# 编译器移除。
// 自举编译器用 _buildCompilerZ42（C#-free 种子自建）。

// feature-matrix (CI P4.1): verify each Cargo feature combo compiles (host target).
int _featureMatrix() {
    int c = _cargoFeature("interp-only"); if (c != 0) { return c; }
    c = _cargoFeature("wasm");            if (c != 0) { return c; }
    c = _cargoFeature("ios");             if (c != 0) { return c; }
    return _cargoFeature("android");
}

int _cargoFeature(string feat) {
    Console.WriteLine("== cargo build --no-default-features --features " + feat + " ==");
    return _exec(_cargoRelease()
        .Arg("--manifest-path").Arg(_runtimeManifest())
        .Arg("--no-default-features").Arg("--features").Arg(feat));
}

// `build stdlib` — in-process (unify-scripts-into-xtask). Folded from the former
// standalone scripts/build-stdlib.z42 into xtask_stdlib.z42 (_buildStdlibCore):
// z42c build --workspace (release) + verify + flat-view (no namespace index —
// the VM + embedding hosts read each zpkg's NSPC section). No primer
// here — `build --workspace` compiles stdlib from source, so it's self-sufficient
// once xtask is running. The COLD bootstrap (CI composite / fresh clone) keeps a
// raw `dotnet -- build --workspace` primer BEFORE compiling xtask (to satisfy
// xtask's own `using Std.*`), then runs `xtask build stdlib` afterward.
int _buildStdlib() {
    return _buildStdlibCore();
}

// ── test ──────────────────────────────────────────────────────────────────
//
// The test command tree (vm / cross-zpkg / dist / stdlib / compiler /
// compiler / changed / all) + the "no subcommand = full gate" default
// live in xtask_cli.z42 (_runCli / _dispatchTest). The leaf handlers
// (_testVm / _testLib / _testCrossZpkg / _testDist / _testChanged) read
// their args from a Std.Cli ParseResult.

// `test changed` — native, bash-free, in-process. Reads base-ref positional +
// --dry-run from the ParseResult; env `Z42_TEST_CHANGED_BASE` is the fallback
// when no positional given; default HEAD. Mapped `xtask test …` plan commands
// re-enter the in-process router; raw `cargo …` runs via `_exec`.
int _testChanged(ParseResult r) {
    string base_ = r.GetPositional(0);
    if (base_.Length == 0) {
        base_ = Environment.GetEnvironmentVariable("Z42_TEST_CHANGED_BASE") ?? "";
    }
    if (base_.Length == 0) { base_ = "HEAD"; }
    return _testChangedRun(base_, r.GetFlag("dry-run"));
}

// ── deps ──────────────────────────────────────────────────────────────────
//
// deps check / install routing lives in xtask_cli.z42 (_dispatchDeps).

// `deps check` — the versions.toml ↔ projection-file drift check. The logic is
// folded into xtask itself (xtask_deps.z42 :: _checkVersionsDrift), so this is a
// direct in-process call — no dotnet-run-build + z42vm-run of a separate zpkg.
// CI runs it in build-and-test.
int _depsCheck() {
    // in-process (unify-scripts-into-xtask): folded from the former standalone
    // scripts/check-versions-drift.z42 into xtask_deps.z42 (_checkVersionsDrift);
    // no per-invocation dotnet-run-build + z42vm-run dance.
    return _checkVersionsDrift();
}

// `audit` is dispatched directly to `_auditRun` (xtask_audit.z42) from
// _dispatch — no wrapper needed.

// ── regen-golden ────────────────────────────────────────────────────────────

// `regen` — native, bash-free (migrate-scripts-to-z42). Rebuild stdlib (unless
// --no-stdlib) + compiler driver + runtime, then regen the golden .zbc
// fixtures. `release` positional → release config. Args from ParseResult.
int _regen(ParseResult r) {
    bool release = r.GetPositional(0) == "release";
    bool rebuildStdlib = !r.GetFlag("no-stdlib");
    return _regenCore(release, rebuildStdlib);
}

int _regenCore(bool release, bool rebuildStdlib) {
    // replace-csharp Phase C：golden 编译走 z42c（不再 dotnet build C# driver）。
    // _buildStdlib（warm C#-free 路径）顺带把 z42c per-member dist 建好，_regenGolden 据此组 driver-home。
    if (rebuildStdlib) { int c = _buildStdlib(); if (c != 0) { return c; } }
    int cr = _buildRuntime(); if (cr != 0) { return cr; }   // cargo build --release (launcher runtime needs z42vm)
    // in-process (unify-scripts-into-xtask): regen logic folded into xtask_regen.z42（_regenGolden，z42c）。
    return _regenGolden();
}

// ── clean (add-tests-bench-manifest-config Phase 3.4) ───────────────────────
//
// Output-dir matrix (proposal §6.4):
//   clean         delete each <lib>/<profile>/{cache,dist} + the aggregate
//                 libraries/dist/ — production artifacts; KEEPS tests/ + bench/.
//   clean tests   delete each <lib>/<profile>/tests/   (built by `test stdlib`)
//   clean bench   delete each <lib>/<profile>/bench/   (built by `bench stdlib`)
//   clean all     delete the whole artifacts/build/    (full reset)
int _clean(ParseResult r) {
    string root = _root();
    string sub  = r.GetPositional(0);   // "" | tests | bench | all
    if (sub == "all") {
        string bd = Path.Join(root, "artifacts/build");
        if (Directory.Exists(bd)) { Directory.Delete(bd, true); }
        Console.WriteLine("✅ clean all: removed artifacts/build/");
        return 0;
    }
    if (sub != "" && sub != "tests" && sub != "bench") {
        ConsoleError.WriteLine("xtask clean: unknown target '" + sub
            + "'  (empty=production cache/dist | tests | bench | all)");
        return 2;
    }
    string libsRoot = Path.Join(root, "artifacts/build/libraries");
    if (!Directory.Exists(libsRoot)) {
        Console.WriteLine("clean: nothing under artifacts/build/libraries/");
        return 0;
    }
    int n = 0;
    foreach (var entry in _sortedStrings(Directory.Enumerate(libsRoot))) {
        string entryDir = Path.Join(libsRoot, entry);
        if (entry == "dist") {
            // The aggregate libraries/dist/<profile>/ — production only.
            if (sub == "") { n = n + _rmIfExists(entryDir); }
            continue;
        }
        foreach (var prof in _sortedStrings(Directory.Enumerate(entryDir))) {
            string pd = Path.Join(entryDir, prof);
            if (sub == "tests" || sub == "bench") {
                n = n + _rmIfExists(Path.Join(pd, sub));
            } else {
                n = n + _rmIfExists(Path.Join(pd, "cache"));
                n = n + _rmIfExists(Path.Join(pd, "dist"));
            }
        }
    }
    string label = (sub == "") ? "production cache/dist" : sub;
    Console.WriteLine("✅ clean " + sub + ": removed " + n.ToString() + " dir(s) [" + label + "]");
    return 0;
}

int _rmIfExists(string dir) {
    if (Directory.Exists(dir)) { Directory.Delete(dir, true); return 1; }
    return 0;
}

// ── helpers ─────────────────────────────────────────────────────────────────
// The shared process / path / exec infrastructure (_root / _exec / _execIn /
// _sh / _ensureDriverVm / _z42vm / _at / _join) + the artifact/source paths +
// the cargo/driver bin-invocation builders all live in xtask_common.z42.
// The command tree + per-level help live in xtask_cli.z42 (Std.Cli router;
// help is generated by ArgParser/SubcommandRouter, no hand-written _help()).
