// xtask — ios packaging (migrate-scripts-to-z42; runtime/workload split for
// version management — impl-workload-install B2, 2026-06-17).
//
// Splits into TWO artifacts (mirrors desktop's SDK + runtime split):
//   _buildRuntimePackageIos → z42-runtime-<ver>-<rid>/  (native libs + Z42VM.xcframework
//                              + headers + libs/) — the platform VM runtime, version-managed
//                              independently; installed under runtimes/<rid>/<ver>/.
//   _packageIos             → workload tooling (Sources/ + Package.swift + manifest);
//                              Package.swift binaryTarget = __Z42_RUNTIME_XCFRAMEWORK__ placeholder,
//                              resolved by `z42 workload install` to the installed runtime's xcframework.
//
// Package.swift .iOS/.macOS deployment versions are read from versions.toml
// [platform.ios] (SoT). Same Z42Xtask namespace; reuses _exec/_root/_ridToCargo/...
namespace Z42Xtask;

using Std;
using Std.IO;

// ── runtime pack (z42-runtime-<ver>-<rid>): native VM lib + xcframework + libs ──
int _buildRuntimePackageIos(string root, string rid, string version, string profile) {
    string cargoTarget = _ridToCargo(rid);
    bool rel = (profile == "release");
    string iosMin = _vReadOr(root, "platform.ios.min_ios", "16.0");
    string pkgName = "z42-runtime-" + version + "-" + rid + (rel ? "" : "-" + profile);
    string pkgDir = Path.Join(_packagesDir(root), pkgName);
    Console.WriteLine("Runtime package: " + pkgName);
    if (Directory.Exists(pkgDir)) { Directory.Delete(pkgDir, true); }
    Directory.Create(Path.Join(pkgDir, "native/include"));
    Directory.Create(Path.Join(pkgDir, "libs"));

    // libz42.a (iOS slice staticlib)
    Console.WriteLine("  [1/4] libz42.a (cargo " + cargoTarget + ", " + profile + ")");
    int c = _exec(_iosRustc(root, rel, cargoTarget, "staticlib", iosMin));
    if (c != 0) { ConsoleError.WriteLine("error: cargo rustc staticlib for " + cargoTarget + " failed"); return 1; }
    string cargoOut = Path.Join(root, "artifacts/build/runtime/" + cargoTarget + "/" + profile);
    string lib = Path.Join(cargoOut, "libz42.a");
    if (!File.Exists(lib)) { ConsoleError.WriteLine("error: " + lib + " not produced"); return 1; }
    File.Copy(lib, Path.Join(pkgDir, "native/libz42.a"));

    // libz42_compression.a
    Console.WriteLine("  [2/4] libz42_compression.a");
    Process pc = new Process("cargo").Arg("build");
    if (rel) { pc = pc.Arg("--release"); }
    pc = pc.Arg("-p").Arg("z42-compression").Arg("--manifest-path").Arg(Path.Join(root, _runtimeManifest()))
        .Arg("--target").Arg(cargoTarget).Arg("--quiet").Env("IPHONEOS_DEPLOYMENT_TARGET", iosMin);
    c = _exec(pc);
    if (c != 0) { return c; }
    string compLib = Path.Join(cargoOut, "libz42_compression.a");
    if (File.Exists(compLib)) { File.Copy(compLib, Path.Join(pkgDir, "native/libz42_compression.a")); }

    // C ABI headers
    File.Copy(Path.Join(root, "src/runtime/include/z42_abi.h"), Path.Join(pkgDir, "native/include/z42_abi.h"));
    File.Copy(Path.Join(root, "src/runtime/include/z42_host.h"), Path.Join(pkgDir, "native/include/z42_host.h"));

    // Z42VM.xcframework (single slice wrapping libz42.a)
    Console.WriteLine("  [3/4] Z42VM.xcframework");
    string xcf = Path.Join(pkgDir, "native/Z42VM.xcframework");
    if (Directory.Exists(xcf)) { Directory.Delete(xcf, true); }
    c = _exec(new Process("xcodebuild").Arg("-create-xcframework")
        .Arg("-library").Arg(lib)
        .Arg("-headers").Arg(Path.Join(pkgDir, "native/include"))
        .Arg("-output").Arg(xcf)
        .Stdout(Stdio.Null()).Stderr(Stdio.Null()));
    if (c != 0) { ConsoleError.WriteLine("error: xcodebuild -create-xcframework failed"); return 1; }
    if (!Directory.Exists(xcf)) { ConsoleError.WriteLine("error: xcframework not created at " + xcf); return 1; }

    // stdlib libs (loaded by the embedded VM at runtime)
    Console.WriteLine("  [4/4] libs/");
    c = _pkgCopyLibs(_libsDir(root), pkgDir); if (c != 0) { return c; }
    Console.WriteLine("  ✓ runtime package: " + pkgDir);
    return 0;
}

// ── workload tooling: Sources/ + Package.swift (placeholder) + manifest ──
int _packageIos(string root, string pkgDir, string rid, string version, string profile, string hostRid) {
    bool rel = (profile == "release");
    string iosMin = _vReadOr(root, "platform.ios.min_ios", "16.0");
    string macMin = _vReadOr(root, "platform.ios.min_macos", "13.0");
    string iosMajor = _nthDot(iosMin, 0);
    string macMajor = _nthDot(macMin, 0);

    // [1/4] build the separate runtime pack first (native VM lib lives there, not here).
    int c = _buildRuntimePackageIos(root, rid, version, profile);
    if (c != 0) { return c; }

    // [2/4] bin/ placeholder
    Console.WriteLine("[1/3] bin/ placeholder");
    File.WriteAllText(Path.Join(pkgDir, "bin/README.md"),
        "# bin/\n\nReserved for future iOS cross tools. Mobile workloads do NOT ship the\n"
        + "host compiler (z42c). The VM runtime is a separate runtime pack\n"
        + "(z42-runtime-<ver>-<rid>); install via `z42 workload install ios`.\n");

    // [2/3] Sources/ + Package.swift (binaryTarget = install-resolved placeholder)
    Console.WriteLine("[2/3] Sources/Z42VM + Package.swift (tooling)");
    string iosSrc = Path.Join(root, "src/toolchain/workload/ios/platform");
    Directory.Create(Path.Join(pkgDir, "Sources/Z42VM"));
    Directory.Create(Path.Join(pkgDir, "Sources/Z42VMC/include"));
    foreach (var f in Directory.Enumerate(Path.Join(iosSrc, "Sources/Z42VM"))) {
        if (f.EndsWith(".swift")) { File.Copy(Path.Join(iosSrc, "Sources/Z42VM/" + f), Path.Join(pkgDir, "Sources/Z42VM/" + f)); }
    }
    File.Copy(Path.Join(iosSrc, "Sources/Z42VMC/dummy.c"), Path.Join(pkgDir, "Sources/Z42VMC/dummy.c"));
    // Z42VMC headers must be SELF-CONTAINED in the package: copy the real runtime
    // headers (not the source-tree forwarding stubs, whose `#include "../../.."`
    // relative path only resolves inside the repo). SwiftPM auto-generates the
    // clang module map from publicHeadersPath. (impl-workload-install B2: verified
    // by `swift build` on the installed workload.)
    File.Copy(Path.Join(root, "src/runtime/include/z42_abi.h"), Path.Join(pkgDir, "Sources/Z42VMC/include/z42_abi.h"));
    File.Copy(Path.Join(root, "src/runtime/include/z42_host.h"), Path.Join(pkgDir, "Sources/Z42VMC/include/z42_host.h"));
    // binaryTarget path is a placeholder; `z42 workload install` rewrites it to the
    // installed runtime pack's Z42VM.xcframework absolute path (runtime/workload split).
    string pkg = "// swift-tools-version: 5.9\n// Generated by `z42 xtask.zpkg build package --rid " + rid + "`; do not edit.\n"
        + "// binaryTarget path is resolved by `z42 workload install ios` (runtime pack is separate).\n\n"
        + "import PackageDescription\n\n"
        + "let package = Package(\n"
        + "    name: \"Z42VM\",\n"
        + "    platforms: [\n"
        + "        .iOS(.v" + iosMajor + "),\n"
        + "        .macOS(.v" + macMajor + "),\n"
        + "    ],\n"
        + "    products: [\n"
        + "        .library(name: \"Z42VM\", targets: [\"Z42VM\"]),\n"
        + "    ],\n"
        + "    targets: [\n"
        + "        .target(name: \"Z42VM\", dependencies: [\"Z42VMC\", \"Z42VMBinary\"], path: \"Sources/Z42VM\"),\n"
        + "        .target(name: \"Z42VMC\", path: \"Sources/Z42VMC\", sources: [\"dummy.c\"], publicHeadersPath: \"include\"),\n"
        + "        .binaryTarget(name: \"Z42VMBinary\", path: \"__Z42_RUNTIME_XCFRAMEWORK__\"),\n"
        + "    ]\n"
        + ")\n";
    File.WriteAllText(Path.Join(pkgDir, "Package.swift"), pkg);
    Console.WriteLine("      ✓ Sources/ + Package.swift (placeholder binaryTarget)");

    // [3/3] manifest.toml (tooling — references the separate runtime pack)
    Console.WriteLine("[3/3] manifest.toml");
    string m = "[package]\n";
    m = m + "name        = \"z42-workload-ios\"\n";
    m = m + "kind        = \"workload-tooling\"\n";
    m = m + "version     = \"" + version + "\"\n";
    m = m + "abi-version = 1\n";
    m = m + "rid         = \"" + rid + "\"\n";
    m = m + "profile     = \"" + profile + "\"\n";
    m = m + "build-date  = \"" + _utcNow() + "\"\n";
    m = m + "build-host  = \"" + hostRid + "\"\n\n";
    m = m + "[contents.platform]\n";
    m = m + "swiftpm-manifest = \"Package.swift\"\n";
    m = m + "swift-sources    = \"Sources/Z42VM\"\n";
    m = m + "runtime-pack     = \"z42-runtime-" + version + "-" + rid + "\"  # separate; install resolves binaryTarget\n\n";
    m = m + "[compat]\n";
    m = m + "host-min-version      = \"" + version + "\"\n";
    m = m + "ios-deployment-target = \"" + iosMin + "\"\n";
    File.WriteAllText(Path.Join(pkgDir, "manifest.toml"), m);
    Console.WriteLine("      ✓ manifest.toml (workload tooling)");
    return 0;
}

// cargo rustc for an iOS target with the `ios` feature + IPHONEOS_DEPLOYMENT_TARGET.
Process _iosRustc(string root, bool rel, string cargoTarget, string crateType, string iosMin) {
    Process p = new Process("cargo").Arg("rustc");
    if (rel) { p = p.Arg("--release"); }
    p = p.Arg("--lib").Arg("--crate-type=" + crateType)
        .Arg("--manifest-path").Arg(Path.Join(root, _runtimeManifest()))
        .Arg("--target").Arg(cargoTarget)
        .Arg("--no-default-features").Arg("--features").Arg("ios")
        .Arg("--quiet")
        .Env("IPHONEOS_DEPLOYMENT_TARGET", iosMin);
    return p;
}
