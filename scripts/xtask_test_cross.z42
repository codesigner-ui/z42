// xtask — cross-zpkg e2e runner (folded from the former scripts/test-cross-zpkg.z42
// by the unify-scripts-into-xtask cross-zpkg fold). Same Z42Xtask namespace; the
// generic helpers it relies on (_enumDirsSorted / _sortStrings / _append) live in
// xtask_golden.z42, and _root / _z42vm come from xtask.z42 (cross-file, same ns).
//
// Each test under src/tests/cross-zpkg/<name>/ ships three z42.toml packages
// (target / ext / main) plus expected_output.txt. We build them in
// dependency order, populating each one's <pkg>/libs/ with prior zpkgs so
// PackageCompiler's lib lookup resolves cross-package symbols. Then run
// main's zpkg through z42vm with a temp libs dir that bundles stdlib +
// our two test packages, capture stdout, and diff against expected.
//
// Build / run sequence per test (C#-free — z42c.driver.zpkg on z42vm):
//   1. z42vm z42c.driver.zpkg build <target>/z42.toml   (no deps)
//   2. z42vm z42c.driver.zpkg build <ext>/z42.toml      (deps on target)
//   3. z42vm z42c.driver.zpkg build <main>/z42.toml     (deps on target + ext)
//   4. z42vm <main>.zpkg --mode <interp|jit>            (run + capture stdout)
//
// `mode` arrives as the function parameter (resolved by _testCrossZpkg in
// xtask_test.z42), replacing the former Z42_VM_MODE env hop.
namespace Z42Xtask;

using Std;
using Std.IO;

// Returns 0 if every cross-zpkg case passes, 1 on any failure (or setup error).
int _testCrossZpkgImpl(string mode) {
    string root = _root();

    string testsDir = Path.Join(root, "src/tests/cross-zpkg");
    // --toolchain (compile-once P3): when an active toolchain is selected, locate
    // z42c.driver + its siblings + stdlib + z42vm from that `.z42` set (the
    // downloaded current-sdk consumed cross-job) instead of the build-tree.
    // The toolchain ships RELEASE z42vm (not debug) — acceptable for the consume
    // path; the debug-vm assertion coverage stays in the build-tree test legs.
    string tc = _toolchainDir(root);
    string stdlibDist;
    string driverHome;
    string vmBin;
    if (tc.Length > 0) {
        stdlibDist = _toolchainLibs(tc);
        driverHome = _toolchainDriverHome(tc);   // driver + 7 siblings colocated
        vmBin = _toolchainVm(tc);
    } else {
        stdlibDist = _libsDir(root);
        // replace-csharp Phase B：cross-zpkg gate 改用 z42c（z42vm + z42c.driver.zpkg），
        // 不再依赖 dotnet。driverHome = 含 z42c.driver.zpkg + 7 个 z42c.* 兄弟的目录
        // （z42vm 从 entry zpkg 所在目录解析其依赖；compilation 的 fixture deps + stdlib 走 Z42_LIBS）。
        driverHome = _assembleZ42cDriverHome(root);
        vmBin = _builtVm(root, "debug");
    }
    if (driverHome.Length == 0) {
        ConsoleError.WriteLine("error: z42c driver not built (artifacts/build/z42c/z42c.*/release/dist)");
        ConsoleError.WriteLine("       Build it via: ./xtask test compiler-z42  (or build stdlib)");
        return 1;
    }
    string driverZpkg = Path.Join(driverHome, "z42c.driver.zpkg");
    if (!File.Exists(vmBin)) {
        ConsoleError.WriteLine("error: z42vm not found at " + vmBin);
        ConsoleError.WriteLine("       Build it via: cargo build --manifest-path src/runtime/Cargo.toml");
        return 1;
    }

    // ── Enumerate test directories ───────────────────────────────────────
    string[] names = _enumDirsSorted(testsDir);

    int pass = 0;
    int fail = 0;
    string[] failures = new string[8];
    int      failCount = 0;

    int i = 0;
    while (i < names.Length) {
        string name = names[i];
        string dir = Path.Join(testsDir, name);
        string expectedPath = Path.Join(dir, "expected_output.txt");
        if (!File.Exists(expectedPath)) {
            i = i + 1;
            continue;
        }

        Console.WriteLine("── Test: " + name + " ──");

        string targetDir = Path.Join(dir, "target");
        string extDir    = Path.Join(dir, "ext");
        string mainDir   = Path.Join(dir, "main");

        // Stage 1: target (no deps).
        if (!_buildPkgZ42c(vmBin, driverZpkg, stdlibDist, targetDir, "")) {
            fail = fail + 1;
            failures = _append(failures, failCount, name + " (target build)");
            failCount = failCount + 1;
            i = i + 1;
            continue;
        }

        // Stage 2: ext (deps on target/dist).
        if (!_buildPkgZ42c(vmBin, driverZpkg, stdlibDist, extDir, Path.Join(Path.Join(Path.Join(targetDir, "artifacts"), "debug"), "dist"))) {
            fail = fail + 1;
            failures = _append(failures, failCount, name + " (ext build)");
            failCount = failCount + 1;
            i = i + 1;
            continue;
        }

        // Stage 3: main (deps on target + ext). _buildPkgZ42c only seeds from a
        // single dir; main needs both, so populate libs manually here.
        string mainLibs = Path.Join(mainDir, "libs");
        if (Directory.Exists(mainLibs)) { Directory.Delete(mainLibs, true); }
        Directory.Create(mainLibs);
        _copyZpkgs(Path.Join(Path.Join(Path.Join(targetDir, "artifacts"), "debug"), "dist"), mainLibs);
        _copyZpkgs(Path.Join(Path.Join(Path.Join(extDir,    "artifacts"), "debug"), "dist"), mainLibs);
        string mainToml = _findToml(mainDir);
        if (mainToml.Length == 0 || !_invokeBuildZ42c(vmBin, driverZpkg, stdlibDist, mainDir, mainToml)) {
            Console.WriteLine("    main build failed");
            fail = fail + 1;
            failures = _append(failures, failCount, name + " (main build)");
            failCount = failCount + 1;
            i = i + 1;
            continue;
        }

        // Stage 4: run main zpkg through z42vm.
        string mainZpkg = _firstZpkg(Path.Join(Path.Join(Path.Join(mainDir, "artifacts"), "debug"), "dist"));
        if (mainZpkg.Length == 0) {
            Console.WriteLine("    main produced no zpkg");
            fail = fail + 1;
            failures = _append(failures, failCount, name + " (no zpkg)");
            failCount = failCount + 1;
            i = i + 1;
            continue;
        }

        // Per-test libs dir: stdlib zpkgs + target + ext.
        string testLibs = File.CreateTempDir("z42-xpkg-");
        _copyStdlibZpkgs(stdlibDist, testLibs);
        _copyZpkgs(Path.Join(Path.Join(Path.Join(targetDir, "artifacts"), "debug"), "dist"), testLibs);
        _copyZpkgs(Path.Join(Path.Join(Path.Join(extDir,    "artifacts"), "debug"), "dist"), testLibs);

        string actual = "";
        bool runErr = false;
        try {
            ProcessResult vmResult = new Process(vmBin)
                .Arg(mainZpkg)
                .Arg("--mode").Arg(mode)
                .Env("Z42_LIBS", testLibs)
                .Run();
            // bash: `$(... 2>&1)` — merge stderr into stdout. We approximate
            // by concatenating; a passing VM run produces no stderr, so for
            // successful tests the order doesn't matter.
            actual = vmResult.Stdout + vmResult.Stderr;
        } catch (Exception e) {
            runErr = true;
        }
        Directory.Delete(testLibs, true);

        string expected = File.ReadAllText(expectedPath);
        if (!runErr && actual == expected) {
            pass = pass + 1;
            Console.WriteLine("  PASS");
        } else {
            fail = fail + 1;
            failures = _append(failures, failCount, name);
            failCount = failCount + 1;
            Console.WriteLine("  FAIL");
            Console.WriteLine("    expected: " + _firstLines(expected, 3));
            Console.WriteLine("    actual:   " + _firstLines(actual,   3));
        }

        i = i + 1;
    }

    Console.WriteLine("");
    Console.WriteLine("══════════════════════════════════════");
    Console.WriteLine(" Total: " + pass.ToString() + " passed, "
        + fail.ToString() + " failed");
    Console.WriteLine("══════════════════════════════════════");

    if (failCount > 0) {
        Console.WriteLine("");
        Console.WriteLine("Failed tests:");
        int fi = 0;
        while (fi < failCount) {
            Console.WriteLine("  - " + failures[fi]);
            fi = fi + 1;
        }
        return 1;
    }
    return 0;
}

// ── z42c build path (replace-csharp Phase B：cross-zpkg gate 脱 dotnet) ──────

// 组装 z42c driver-home：含 z42c.driver.zpkg + 7 个 z42c.* 兄弟（从 per-member dist）。
// z42vm 从 entry zpkg 所在目录解析其依赖，故 driver 的 z42c.* 依赖放这里，与
// compilation 的 Z42_LIBS（stdlib + fixture deps）隔离，避免单-libs 目录污染。
// 返回 driver-home 目录路径；z42c 未构建（缺任一成员 dist）返回 ""。
string _assembleZ42cDriverHome(string root) {
    string baseDir = Path.Join(root, "artifacts/build/z42c");
    string[] members = new string[7];
    members[0] = "z42c.core"; members[1] = "z42c.ir"; members[2] = "z42c.project";
    members[3] = "z42c.syntax"; members[4] = "z42c.semantics"; members[5] = "z42c.pipeline";
    members[6] = "z42c.driver";
    string home = File.CreateTempDir("z42-xpkg-driver-");
    int i = 0;
    while (i < members.Length) {
        string m = members[i];
        string src = Path.Join(Path.Join(Path.Join(Path.Join(baseDir, m), "release"), "dist"), m + ".zpkg");
        if (!File.Exists(src)) { return ""; }
        try { File.Copy(src, Path.Join(home, m + ".zpkg")); } catch (Exception e) { return ""; }
        i = i + 1;
    }
    return home;
}

// 用 z42c 编译一个 package（z42vm 跑 z42c.driver.zpkg）。先把上一阶段产物 copy 进
// <pkgDir>/libs，再 build → <pkgDir>/artifacts/debug/dist（与 C# 路径一致 → 下游
// run/diff 不变）。
bool _buildPkgZ42c(string vmBin, string driverZpkg, string stdlibDist, string pkgDir, string srcLibsDir) {
    string pkgLibs = Path.Join(pkgDir, "libs");
    if (Directory.Exists(pkgLibs)) { Directory.Delete(pkgLibs, true); }
    Directory.Create(pkgLibs);
    if (srcLibsDir.Length > 0) { _copyZpkgs(srcLibsDir, pkgLibs); }
    string toml = _findToml(pkgDir);
    if (toml.Length == 0) {
        Console.WriteLine("    error: no toml in " + pkgDir);
        return false;
    }
    return _invokeBuildZ42c(vmBin, driverZpkg, stdlibDist, pkgDir, toml);
}

// 单次 z42c build。outDir = <pkgDir>/artifacts/debug/dist。Z42_LIBS = temp(stdlib +
// pkgDir/libs)；z42c.* 由 driver-home 解析。WorkingDirectory=pkgDir（镜像手验）。
bool _invokeBuildZ42c(string vmBin, string driverZpkg, string stdlibDist, string pkgDir, string toml) {
    string outDir = Path.Join(Path.Join(Path.Join(pkgDir, "artifacts"), "debug"), "dist");
    Directory.Create(outDir);
    string libs = File.CreateTempDir("z42-xpkg-libs-");
    _copyStdlibZpkgs(stdlibDist, libs);
    _copyZpkgs(Path.Join(pkgDir, "libs"), libs);
    bool ok = false;
    try {
        ProcessResult br = new Process(vmBin)
            .Arg(driverZpkg).Arg("--mode").Arg("interp")
            .Arg("--").Arg("build").Arg(toml)
            .Arg("--output-dir").Arg(outDir).Arg("--release")
            .WorkingDirectory(pkgDir)
            .Env("Z42_LIBS", libs)
            .Stdout(Stdio.Null())
            .Stderr(Stdio.Null())
            .Run();
        ok = br.ExitCode == 0;
    } catch (Exception e) {
        ok = false;
    }
    Directory.Delete(libs, true);
    return ok;
}

// ── Path / file helpers (cross-specific) ─────────────────────────────────

void _copyZpkgs(string srcDir, string dstDir) {
    if (!Directory.Exists(srcDir)) return;
    string[] zpkgs = Path.Glob(srcDir, "*.zpkg");
    int i = 0;
    while (i < zpkgs.Length) {
        string dst = Path.Join(dstDir, Path.GetFileName(zpkgs[i]));
        try { File.Copy(zpkgs[i], dst); } catch (Exception e) { /* skip */ }
        i = i + 1;
    }
}

// Stdlib artifacts live in the FLAT dist view at
// artifacts/build/libraries/dist/release (the same layout Z42_LIBS / _z42vm
// consume). Copy *.zpkg + *.zsym from there.
void _copyStdlibZpkgs(string distDir, string dstDir) {
    if (!Directory.Exists(distDir)) return;
    string[] entries = Directory.Enumerate(distDir);
    int i = 0;
    while (i < entries.Length) {
        string fname = entries[i];
        if (fname.EndsWith(".zpkg") || fname.EndsWith(".zsym")) {
            string src = Path.Join(distDir, fname);
            string dst = Path.Join(dstDir, fname);
            try { File.Copy(src, dst); } catch (Exception e) { /* skip */ }
        }
        i = i + 1;
    }
}

string _findToml(string dir) {
    if (!Directory.Exists(dir)) return "";
    string[] hits = Path.Glob(dir, "*.toml");
    if (hits.Length == 0) return "";
    return hits[0];
}

string _firstZpkg(string dir) {
    if (!Directory.Exists(dir)) return "";
    string[] hits = Path.Glob(dir, "*.zpkg");
    if (hits.Length == 0) return "";
    return hits[0];
}

// Return first `n` lines joined by '|' — matches bash `head -3 | tr '\n' '|'`.
string _firstLines(string s, int n) {
    string result = "";
    int count = 0;
    int start = 0;
    int i = 0;
    while (i < s.Length && count < n) {
        if (s.CharAt(i) == '\n') {
            if (result.Length > 0) { result = result + "|"; }
            result = result + s.Substring(start, i - start);
            count = count + 1;
            start = i + 1;
        }
        i = i + 1;
    }
    if (count < n && start < s.Length) {
        if (result.Length > 0) { result = result + "|"; }
        result = result + s.Substring(start, s.Length - start);
    }
    return result;
}
