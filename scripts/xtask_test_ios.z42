// xtask — iOS platform backend (add-platform-test-pipeline, 2026-06-15).
// Implements IPlatformBackend, porting src/toolchain/host/platforms/ios/build.sh:
//   ① BuildProject : cargo build × (ios targets + macOS host slice) → xcframework
//   ② Assets       : fixtures → Tests/.../test-fixtures; stdlib → Resources/stdlib (+ test bundle)
//   ③ RunTests     : `swift test` (XCTest R1–R7 on macOS host slice)
//
// iOS Simulator execution + JUnit conversion deferred (CI change). swift test
// runs on the macOS host slice (build.ios.extra_rust_targets). Needs Xcode.
namespace Z42Xtask;

using Std;
using Std.IO;

public class IosBackend : IPlatformBackend {
    public string Name() { return "ios"; }

    public AssetLayout Assets(string root) {
        string here = Path.Join(root, "src/toolchain/host/platforms/ios");
        string[] stdlibDirs = new string[2];
        stdlibDirs[0] = Path.Join(here, "Resources/stdlib");
        stdlibDirs[1] = Path.Join(here, "Tests/Z42VMTests/Resources/stdlib");
        return new AssetLayout(Path.Join(here, "Tests/Z42VMTests/Resources/test-fixtures"),
                               stdlibDirs, false);
    }

    // ① cargo build each target → assemble Z42VM.xcframework (device + sim + macOS).
    public int BuildProject(string root) {
        if (Process.Which("xcodebuild") == null) {
            ConsoleError.WriteLine("error: xcodebuild not found (Xcode required for iOS build)");
            return 1;
        }
        if (Process.Which("cargo") == null) {
            ConsoleError.WriteLine("error: cargo not found (https://rustup.rs)");
            return 1;
        }
        string here = Path.Join(root, "src/toolchain/host/platforms/ios");
        string manifest = Path.Join(here, "rust/Cargo.toml");
        string targetDir = Path.Join(root, "artifacts/build/runtime");
        string libName = "libz42_platform_ios.a";

        TomlValue toml = _vparse(root);
        string[] iosTargets = _vgetList(toml, "platform.ios.rust_targets");
        string[] extra      = _vgetList(toml, "build.ios.extra_rust_targets");

        int c = this._cargoTargets(manifest, targetDir, iosTargets);  if (c != 0) { return c; }
        c = this._cargoTargets(manifest, targetDir, extra);           if (c != 0) { return c; }

        // Assemble xcframework from device + simulator + macOS slices.
        string dev = Path.Join(targetDir, Path.Join("aarch64-apple-ios/release", libName));
        string sim = Path.Join(targetDir, Path.Join("aarch64-apple-ios-sim/release", libName));
        string mac = Path.Join(targetDir, Path.Join("aarch64-apple-darwin/release", libName));
        string xcf = Path.Join(here, "Z42VM.xcframework");
        if (Directory.Exists(xcf)) { Directory.Delete(xcf, true); }

        Console.WriteLine("  xcodebuild -create-xcframework -> " + xcf);
        return _exec(new Process("xcodebuild").Arg("-create-xcframework")
            .Arg("-library").Arg(dev)
            .Arg("-library").Arg(sim)
            .Arg("-library").Arg(mac)
            .Arg("-output").Arg(xcf));
    }

    // ③ swift test on the macOS host slice. (Simulator + JUnit report → CI change.)
    public int RunTests(string root) {
        string here = Path.Join(root, "src/toolchain/host/platforms/ios");
        Console.WriteLine("  swift test  (XCTest R1–R7, macOS host slice)");
        return _execIn(new Process("swift").Arg("test"), here);
    }

    int _cargoTargets(string manifest, string targetDir, string[] targets) {
        foreach (var t in targets) {
            Console.WriteLine("  cargo build --release --target " + t);
            int c = _exec(new Process("cargo").Arg("build").Arg("--release")
                .Arg("--manifest-path").Arg(manifest)
                .Arg("--target-dir").Arg(targetDir)
                .Arg("--target").Arg(t));
            if (c != 0) { return c; }
        }
        return 0;
    }
}
