// xtask — iOS platform backend (add-platform-test-pipeline, 2026-06-15).
// Implements IPlatformBackend (logic ported from the former
// src/toolchain/host/platforms/ios/build.sh, now removed):
//   ① BuildProject : cargo build × (ios targets + macOS host slice) → xcframework
//   ② Assets       : fixtures → Tests/.../test-fixtures; stdlib → Resources/stdlib (+ test bundle)
//   ③ RunTests     : `swift test` (XCTest R1–R7 on macOS host slice)
//
// iOS Simulator execution + JUnit conversion deferred (CI change). swift test
// runs on the macOS host slice (build.ios.extra_rust_targets). Needs Xcode.
namespace Z42Xtask;

using Std;
using Std.IO;

public class IosBackend : IPlatformBackend {
    public string Name() { return "ios"; }

    public AssetLayout Assets(string root) {
        string here = Path.Join(root, "src/toolchain/host/platforms/ios");
        string[] stdlibDirs = new string[2];
        stdlibDirs[0] = Path.Join(here, "Resources/stdlib");
        stdlibDirs[1] = Path.Join(here, "Tests/Z42VMTests/Resources/stdlib");
        return new AssetLayout(Path.Join(here, "Tests/Z42VMTests/Resources/test-fixtures"),
                               stdlibDirs, false);
    }

    // ① cargo build each target → assemble Z42VM.xcframework (device + sim + macOS).
    public int BuildProject(string root) {
        if (Process.Which("xcodebuild") == null) {
            ConsoleError.WriteLine("error: xcodebuild not found (Xcode required for iOS build)");
            return 1;
        }
        if (Process.Which("cargo") == null) {
            ConsoleError.WriteLine("error: cargo not found (https://rustup.rs)");
            return 1;
        }
        string here = Path.Join(root, "src/toolchain/host/platforms/ios");
        string manifest = Path.Join(here, "rust/Cargo.toml");
        string targetDir = Path.Join(root, "artifacts/build/runtime");
        string libName = "libz42_platform_ios.a";

        TomlValue toml = _vparse(root);
        string[] iosTargets = _vgetList(toml, "platform.ios.rust_targets");
        string[] extra      = _vgetList(toml, "build.ios.extra_rust_targets");
        // Match packaging's _iosRustc: pin the iOS deployment target so the C
        // deps (zlib-ng in z42-compression) compile for the same min version as
        // the rlibs — otherwise the device link fails (___chkstk_darwin / 10.0
        // vs 18.5 mismatch).
        string iosMin = _vReadOr(root, "platform.ios.min_ios", "16.0");

        int c = this._cargoTargets(manifest, targetDir, iosTargets, iosMin);  if (c != 0) { return c; }
        c = this._cargoTargets(manifest, targetDir, extra, iosMin);           if (c != 0) { return c; }

        // Assemble xcframework from device + simulator + macOS slices.
        string dev = Path.Join(targetDir, Path.Join("aarch64-apple-ios/release", libName));
        string sim = Path.Join(targetDir, Path.Join("aarch64-apple-ios-sim/release", libName));
        string mac = Path.Join(targetDir, Path.Join("aarch64-apple-darwin/release", libName));
        string xcf = Path.Join(here, "Z42VM.xcframework");
        if (Directory.Exists(xcf)) { Directory.Delete(xcf, true); }

        Console.WriteLine("  xcodebuild -create-xcframework -> " + xcf);
        return _exec(new Process("xcodebuild").Arg("-create-xcframework")
            .Arg("-library").Arg(dev)
            .Arg("-library").Arg(sim)
            .Arg("-library").Arg(mac)
            .Arg("-output").Arg(xcf));
    }

    // ③ xcodebuild test on a real iOS Simulator (R1–R7), JUnit derived from the
    // xcodebuild "Test Case ... passed/failed" lines. Z42_IOS_DEST overrides the
    // destination; default = first available iPhone simulator (xcrun simctl).
    public int RunTests(string root) {
        string here = Path.Join(root, "src/toolchain/host/platforms/ios");
        string dest = Environment.GetEnvironmentVariable("Z42_IOS_DEST") ?? "";
        if (dest.Length == 0) {
            string udid = this._firstSimulatorUdid();
            if (udid.Length == 0) {
                ConsoleError.WriteLine("error: no iOS Simulator available (xcrun simctl list devices available)");
                return 1;
            }
            dest = "id=" + udid;
        }
        Console.WriteLine("  xcodebuild test -scheme Z42VM -destination '" + dest + "' (iOS Simulator R1–R7)");
        ProcessResult r = new Process("xcodebuild").Arg("test")
            .Arg("-scheme").Arg("Z42VM")
            .Arg("-destination").Arg(dest)
            .WorkingDirectory(here).Run();
        this._writeJUnit(root, r.Stdout);
        if (r.ExitCode != 0) {
            // Surface the failing test-case lines (xcodebuild is verbose).
            foreach (var line in this._splitLines(r.Stdout)) {
                if (line.IndexOf("' failed") >= 0 || line.IndexOf(" error:") >= 0) { ConsoleError.WriteLine(line.Trim()); }
            }
        }
        return r.ExitCode;
    }

    // First available iPhone simulator UDID (first parenthesised group on the line).
    string _firstSimulatorUdid() {
        ProcessResult r = new Process("xcrun").Arg("simctl").Arg("list").Arg("devices").Arg("available").Run();
        foreach (var line in this._splitLines(r.Stdout)) {
            string t = line.Trim();
            if (!t.StartsWith("iPhone")) { continue; }
            int lp = t.IndexOf("(");
            if (lp < 0) { continue; }
            int rp = t.IndexOf(")");
            if (rp <= lp) { continue; }
            return t.Substring(lp + 1, rp - lp - 1);
        }
        return "";
    }

    // Parse xcodebuild `Test Case '-[Z42VMTests testX]' passed/failed` lines → JUnit
    // at the uniform report dir (artifacts/test-reports/ios/junit.xml).
    void _writeJUnit(string root, string stdout) {
        int tests = 0; int failures = 0; string cases = "";
        foreach (var line in this._splitLines(stdout)) {
            string t = line.Trim();
            if (t.IndexOf("Test Case '") < 0) { continue; }
            bool passed = t.IndexOf("' passed") >= 0;
            bool failed = t.IndexOf("' failed") >= 0;
            if (!passed && !failed) { continue; }
            string name = this._xcCaseName(t);
            tests = tests + 1;
            if (passed) {
                cases = cases + "  <testcase name=\"" + name + "\" classname=\"ios.Z42VMTests\"/>\n";
            } else {
                failures = failures + 1;
                cases = cases + "  <testcase name=\"" + name + "\" classname=\"ios.Z42VMTests\">\n"
                      + "    <failure message=\"failed\"/>\n  </testcase>\n";
            }
        }
        string xml = "<testsuites tests=\"" + tests + "\" failures=\"" + failures + "\">\n"
                   + "<testsuite name=\"ios.Z42VMTests\" tests=\"" + tests + "\" failures=\"" + failures + "\">\n"
                   + cases + "</testsuite>\n</testsuites>\n";
        File.WriteAllText(Path.Join(_reportDir(root, "ios"), "junit.xml"), xml);
        Console.WriteLine("  junit.xml (" + tests + " cases, " + failures + " failed)");
    }

    // Extract the test method name from `... '-[Z42VMTests testFoo]' ...`.
    string _xcCaseName(string line) {
        int b = line.IndexOf("-[");
        int e = line.IndexOf("]");
        if (b < 0 || e <= b) { return "case"; }
        string inner = line.Substring(b + 2, e - b - 2);   // "Z42VMTests testFoo"
        int sp = inner.IndexOf(" ");
        if (sp >= 0) { return inner.Substring(sp + 1); }
        return inner;
    }

    string[] _splitLines(string s) {
        return s.Replace("\r\n", "\n").Split("\n");
    }

    int _cargoTargets(string manifest, string targetDir, string[] targets, string iosMin) {
        foreach (var t in targets) {
            Console.WriteLine("  cargo build --release --target " + t + " (IPHONEOS_DEPLOYMENT_TARGET=" + iosMin + ")");
            int c = _exec(new Process("cargo").Arg("build").Arg("--release")
                .Arg("--manifest-path").Arg(manifest)
                .Arg("--target-dir").Arg(targetDir)
                .Arg("--target").Arg(t)
                .Env("IPHONEOS_DEPLOYMENT_TARGET", iosMin));
            if (c != 0) { return c; }
        }
        return 0;
    }
}
