// xtask — z42c self-hosting e2e oracle suite (split from xtask_compiler.z42,
// 2026-06-30, for the 500-line code-org limit). Same Z42Xtask namespace; called
// by _testCompilerUnits (xtask_compiler.z42) cross-file.
//
// Self-compiled .zbc / .zpkg runs on z42vm, gated by a div-by-zero oracle:
// arithmetic/compare/branch all correct → ok=1 → 100/1 clean exit 0; any byte
// miscoding → ok=0 → DivideByZeroException → non-zero. divzero is the negative
// case proving the oracle itself is valid. Functional (not byte-identical —
// z42c self byte-identity is covered by the fixpoint in xtask_compiler.z42).
namespace Z42Xtask;

using Std;
using Std.IO;

// e2e（port-z42c-zbc-writer ZW-1B）：z42c 自举编译器产 .zbc → z42vm 真实执行。
// 自检程序用 div-by-zero oracle：算术/比较/分支全对 → ok=1 → 100/1 干净退出 0；
// 任一字节编码错 → ok=0 → DivideByZeroException → 非零退出。负向用例验证 oracle 本身有效
//（防"VM 不管对错都退 0"的假绿）。功能性验证（非 byte-identical——DBUG 阻塞见 zbc-writer tasks）。
// 表驱动 e2e oracle 用例（z42c --emit-zbc → z42vm 跑 → div-by-zero oracle 验算术/比较/分支）。
// emitLibs 解析编译期依赖（z42c.* + stdlib，通常 = flat）；runLibs 解析运行期 stdlib（stdlib-only
// 用例用 libraries/dist/release，含 z42c 链的用 flat）。expectTrap=true 为负向用例（程序必然
// div-zero，须非零退出，验 oracle 本身有效）。返回 0=通过 / 1=失败（已打印 ✓/✗）。
int _e2eOracle(string vm, string driverZpkg, string e2eDir, string emitLibs, string runLibs,
               string name, bool expectTrap, string source) {
    string src = Path.Join(e2eDir, name + ".z42");
    File.WriteAllText(src, source);
    string zbc = Path.Join(e2eDir, name + ".zbc");
    int rc = new Process(vm).Arg(driverZpkg).Arg("--").Arg("--emit-zbc").Arg(src).Arg(zbc)
        .Env("Z42_LIBS", emitLibs).Stdout(Stdio.Null()).Stderr(Stdio.Inherit()).Run().ExitCode;
    if (rc != 0) { Console.WriteLine("  ✗ " + name + " emit failed (" + rc.ToString() + ")"); return 1; }
    rc = new Process(vm).Arg(zbc).Arg("Main")
        .Env("Z42_LIBS", runLibs).Stdout(Stdio.Null()).Stderr(Stdio.Null()).Run().ExitCode;
    if (expectTrap) {
        if (rc == 0) { Console.WriteLine("  ✗ " + name + ".zbc exited 0 — oracle invalid (VM should trap)"); return 1; }
        Console.WriteLine("  ✓ " + name + ".zbc: trapped as expected (oracle valid)");
        return 0;
    }
    if (rc != 0) { Console.WriteLine("  ✗ " + name + ".zbc trapped on z42vm (exit " + rc.ToString() + ") — miscomputation"); return 1; }
    Console.WriteLine("  ✓ " + name + ".zbc: computed correctly, clean exit");
    return 0;
}

int _testCompilerE2e(string root, string vm, string flat) {
    Console.WriteLine("");
    Console.WriteLine("── z42c e2e: self-compiled .zbc runs on z42vm ──");
    string driverZpkg = Path.Join(root, "artifacts/build/z42c/z42c.driver/release/dist/z42c.driver.zpkg");
    string e2eDir = Path.Join(root, "artifacts/build/z42c/e2e");
    Directory.Create(e2eDir);

    string libsRel = Path.Join(root, "artifacts/build/libraries/dist/release");
    int rc = 0;

    // 正向：自检程序（const/mul/add/le/eq/copy/div + while 回边 + if 嵌套 = ZW-1A/1B 全 opcode）
    if (_e2eOracle(vm, driverZpkg, e2eDir, flat, flat, "selfcheck", false,
        "int Main() {\n"
        + "    int x = 6 * 7;\n"
        + "    int sum = 0;\n"
        + "    int i = 1;\n"
        + "    while (i <= 5) { sum = sum + i; i = i + 1; }\n"
        + "    int ok = 0;\n"
        + "    if (x == 42) { if (sum == 15) { ok = 1; } }\n"
        + "    return 100 / ok;\n"
        + "}\n") != 0) { return 1; }

    // 正向 #2（ZW-1C/1D）：自由调用 + 对象/字段（new/vcall/field_get·set）+ 字符串（const.str/concat/eq）
    if (_e2eOracle(vm, driverZpkg, e2eDir, flat, flat, "callcheck", false,
        "int Twice(int a) { return a + a; }\n"
        + "class Counter { int v; int Bump(int d) { v = v + d; return v; } }\n"
        + "int Main() {\n"
        + "    var c = new Counter();\n"
        + "    c.Bump(20);\n"
        + "    c.Bump(1);\n"
        + "    int x = Twice(c.Bump(0));\n"
        + "    string s = \"h\" + \"i\";\n"
        + "    int ok = 0;\n"
        + "    if (x == 42) { if (s == \"hi\") { ok = 1; } }\n"
        + "    return 100 / ok;\n"
        + "}\n") != 0) { return 1; }

    // 正向 #3（ZW-1E）：浮点字面量（IEEE754 bits）+ is/as + 继承（TYPE base 链）
    if (_e2eOracle(vm, driverZpkg, e2eDir, flat, flat, "typecheck", false,
        "class A { }\n"
        + "class B : A { }\n"
        + "int Main() {\n"
        + "    double d = 1.5;\n"
        + "    double e = d * 4.0;\n"
        + "    int ok = 0;\n"
        + "    if (e == 6.0) { ok = ok + 1; }\n"
        + "    A a = new B();\n"
        + "    if (a is B) { ok = ok + 1; }\n"
        + "    B b = a as B;\n"
        + "    if (b is B) { ok = ok + 1; }\n"
        + "    int good = 0;\n"
        + "    if (ok == 3) { good = 1; }\n"
        + "    return 100 / good;\n"
        + "}\n") != 0) { return 1; }

    // 负向（oracle 有效性）：必然 div-zero 的程序必须非零退出
    if (_e2eOracle(vm, driverZpkg, e2eDir, flat, flat, "divzero", true,
        "int Main() { int z = 0; return 1 / z; }\n") != 0) { return 1; }

    // charcheck（port-z42c-char）：char 字面量/比较 + div-zero oracle
    if (_e2eOracle(vm, driverZpkg, e2eDir, flat, libsRel, "charcheck", false,
        "int Main() {\n"
        + "    char a = 'A';\n"
        + "    char d = '.';\n"
        + "    int ok = 0;\n"
        + "    if (a == 'A') { if (a != d) { if (d < a) { ok = 1; } } }\n"
        + "    return 100 / ok;\n"
        + "}\n") != 0) { return 1; }

    // trycheck（port-z42c-try）：本地异常类 + throw/catch/finally + oracle
    if (_e2eOracle(vm, driverZpkg, e2eDir, flat, libsRel, "trycheck", false,
        "class Exception { public string Message; }\n"
        + "class MyErr : Exception { }\n"
        + "\n"
        + "int Main() {\n"
        + "    int ok = 0;\n"
        + "    int fin = 0;\n"
        + "    try {\n"
        + "        throw new MyErr();\n"
        + "    } catch (MyErr e) {\n"
        + "        ok = 1;\n"
        + "    } finally {\n"
        + "        fin = 1;\n"
        + "    }\n"
        + "    int total = 0;\n"
        + "    if (ok == 1) { if (fin == 1) { total = 1; } }\n"
        + "    return 100 / total;\n"
        + "}\n") != 0) { return 1; }

    // ifacecheck（port-z42c-interface）：接口声明/实现/接口参数分派 + oracle
    if (_e2eOracle(vm, driverZpkg, e2eDir, flat, libsRel, "ifacecheck", false,
        "interface IShape {\n"
        + "    int Area();\n"
        + "}\n\n"
        + "class Box : IShape {\n"
        + "    public int W;\n"
        + "    public int H;\n"
        + "    public int Area() { return W * H; }\n"
        + "}\n\n"
        + "int Compute(IShape s) {\n"
        + "    return s.Area();\n"
        + "}\n\n"
        + "int Main() {\n"
        + "    var b = new Box();\n"
        + "    b.W = 6;\n"
        + "    b.H = 7;\n"
        + "    IShape s = b;\n"
        + "    int ok = 0;\n"
        + "    if (Compute(s) == 42) { ok = 1; }\n"
        + "    return 100 / ok;\n"
        + "}\n") != 0) { return 1; }

    // sacheck（port-z42c-statics-arrays）：静态类常量（__static_init__）+ 数组创建/下标/Length + oracle
    if (_e2eOracle(vm, driverZpkg, e2eDir, flat, libsRel, "sacheck", false,
        "static class Sev {\n"
        + "    public static int Warn = 1;\n"
        + "    public static int Error = 2;\n"
        + "}\n\n"
        + "int Main() {\n"
        + "    int[] xs = new int[3];\n"
        + "    xs[0] = 40;\n"
        + "    xs[1] = Sev.Error;\n"
        + "    int ok = 0;\n"
        + "    if (xs[0] + xs[1] == 42) { if (xs.Length == 3) { if (Sev.Warn == 1) { ok = 1; } } }\n"
        + "    return 100 / ok;\n"
        + "}\n") != 0) { return 1; }

    // replace-csharp Phase C：删 per-construct byte-compare-vs-C#（C# 已删，无 oracle）。
    // 功能正确性由上方 div-by-zero e2e oracle（selfcheck/callcheck/typecheck/...）保证；
    // z42c 自身的 byte-identical 由 self-host 不动点（gen1==gen2）覆盖（见 _testSelfHostByteIdentical）。

    // build e2e（port-z42c-zpkg-build）：z42c build 产 packed zpkg → z42vm 直跑（entry 烤入）。
    // zpkg 级 byte-compare 对真 C# CLI 还差 TSIG/IMPL（follow-up change）；此处验证可执行性
    // + 核心七段（META/NSPC/EXPT/DEPS 已与 C# 逐字节一致，SIGS/MODS 同尺寸仅池索引移位）。
    string bdir = Path.Join(e2eDir, "buildapp");
    Directory.Create(bdir);
    string bsrc = Path.Join(bdir, "app.z42");
    File.WriteAllText(bsrc, "namespace Check.App;\n\nint Twice(int a) { return a + a; }\n\nclass Counter {\n    int v;\n    int Bump(int d) { v = v + d; return v; }\n}\n\nvoid Main() {\n    var c = new Counter();\n    c.Bump(20);\n    c.Bump(1);\n    int x = Twice(c.Bump(0));\n    int ok = 0;\n    if (x == 42) { ok = 1; }\n    int dummy = 100 / ok;\n}\n");
    string btoml = Path.Join(bdir, "check.app.z42.toml");
    File.WriteAllText(btoml, "[project]\nname    = \"check.app\"\nversion = \"0.1.0\"\nkind    = \"exe\"\npack    = true\n\n[sources]\ninclude = [\"*.z42\"]\n");
    rc = new Process(vm).Arg(driverZpkg).Arg("--").Arg("build").Arg(btoml)
        .Env("Z42_LIBS", flat).Stdout(Stdio.Null()).Stderr(Stdio.Inherit()).Run().ExitCode;
    if (rc != 0) { Console.WriteLine("  ✗ z42c build failed"); return 1; }
    string appZpkg = Path.Join(bdir, "dist/check.app.zpkg");
    rc = new Process(vm).Arg(appZpkg)
        .Env("Z42_LIBS", Path.Join(root, "artifacts/build/libraries/dist/release"))
        .Stdout(Stdio.Null()).Stderr(Stdio.Null()).Run().ExitCode;
    if (rc != 0) { Console.WriteLine("  ✗ z42c-built zpkg failed to run (exit " + rc.ToString() + ")"); return 1; }
    Console.WriteLine("  ✓ build e2e: z42c-built check.app.zpkg runs directly on z42vm (entry baked)");

    // zpkg 全文件 byte-compare（port-z42c-tsig）：同工程 z42c vs C# CLI（--strip-symbols=false
    // 关 sidecar/BLID）→ 逐字节 diff。两工程：check.app（exe，调用/对象/字段）+ demo.minimal
    // （namespaced 单类，packed-minimal 同构）。这是 .zpkg 包级对账 gate。
    string ddir = Path.Join(e2eDir, "buildns");
    Directory.Create(ddir);
    File.WriteAllText(Path.Join(ddir, "demo.z42"),
        "namespace Demo.Minimal;\n\nclass Greeter {\n    string Hello() { return \"hi\"; }\n}\n\nvoid Main() {\n    var g = new Greeter();\n    g.Hello();\n}\n");
    File.WriteAllText(Path.Join(ddir, "demo.minimal.z42.toml"),
        "[project]\nname    = \"demo.minimal\"\nversion = \"0.1.0\"\nkind    = \"exe\"\npack    = true\n\n[sources]\ninclude = [\"*.z42\"]\n");
    // hello-stdlib（port-z42c-import）：using Std + Console.WriteLine——跨包消费链对账工程。
    // ⚠ 放 /tmp（仓库外）：C# BuildLibsDirs 会 walk-up 仓库布局并按成员目录字母序扫
    // （z42.cli < z42.core，两者都声明 ns Std）→ 仓库内 DEPS 解析 Std→z42.cli.zpkg；
    // /tmp 下只剩 Z42_LIBS 单目录 → prelude-first → Std→z42.core.zpkg，两侧编译器环境等价。
    string hdir = "/tmp/z42c-e2e-buildhello";
    Directory.Create(hdir);
    File.WriteAllText(Path.Join(hdir, "hello.z42"),
        "using Std;\n\nvoid Main() {\n    Console.WriteLine(\"hi\");\n}\n");
    File.WriteAllText(Path.Join(hdir, "hello.app.z42.toml"),
        "[project]\nname    = \"hello.app\"\nversion = \"0.1.0\"\nkind    = \"exe\"\npack    = true\n\n[sources]\ninclude = [\"*.z42\"]\n");
    // textapp（port-z42c-instance-import）：StringBuilder（imported 类 VCall+DEPS）+
    // string.Substring（prim receiver → DepIndex instance 捷径 FQ Call）——实例跨包链对账工程
    string tdir = "/tmp/z42c-e2e-buildtext";
    Directory.Create(tdir);
    File.WriteAllText(Path.Join(tdir, "app.z42"),
        "using Std;\nusing Std.Text;\n\nvoid Main() {\n    var sb = new StringBuilder();\n    sb.Append(\"ab\");\n    sb.Append(\"cd\");\n    string s = sb.ToString();\n    string sub = s.Substring(0, 2);\n    Console.WriteLine(sub);\n}\n");
    File.WriteAllText(Path.Join(tdir, "text.app.z42.toml"),
        "[project]\nname    = \"text.app\"\nversion = \"0.1.0\"\nkind    = \"exe\"\npack    = true\n\n[sources]\ninclude = [\"*.z42\"]\n");
    // closcheck（port-z42c-closures）：无捕获/捕获 lambda + Func 形参 + 间接调用 + oracle。
    // 注意逃逸形态（Apply 传参）：C# 逃逸分析对非逃逸闭包发 stackAlloc=1（z42c 恒 0 延后）。
    string cdir = "/tmp/z42c-e2e-buildclos";
    Directory.Create(cdir);
    File.WriteAllText(Path.Join(cdir, "app.z42"),
        "int Apply(Func<int, int> f, int v) {\n"
        + "    return f(v);\n"
        + "}\n\n"
        + "int Main() {\n"
        + "    Func<int, int> dbl = x => x * 2;\n"
        + "    int k = 3;\n"
        + "    Func<int, int> mul = x => x * k;\n"
        + "    int ok = 0;\n"
        + "    if (dbl(21) == 42) { if (Apply(mul, 14) == 42) { ok = 1; } }\n"
        + "    return 100 / ok;\n"
        + "}\n");
    File.WriteAllText(Path.Join(cdir, "clos.app.z42.toml"),
        "[project]\nname    = \"clos.app\"\nversion = \"0.1.0\"\nkind    = \"exe\"\npack    = true\n\n[sources]\ninclude = [\"*.z42\"]\n");
    // multifile（port-z42c-package-symbols）：同包跨文件互引（namespaced——C# no-ns 多文件互引自身有
    // pre-existing VCall 缺陷 `main.Pair.Sum not found`，挂账上游）
    string mdir = "/tmp/z42c-e2e-buildmulti";
    Directory.Create(mdir);
    File.WriteAllText(Path.Join(mdir, "types.z42"),
        "namespace App;\n\nclass Pair {\n    public int A;\n    public int B;\n    public int Sum() { return A + B; }\n}\n");
    File.WriteAllText(Path.Join(mdir, "main.z42"),
        "namespace App;\n\nint Main() {\n    var p = new Pair();\n    p.A = 40;\n    p.B = 2;\n    int ok = 0;\n    if (p.Sum() == 42) { ok = 1; }\n    return 100 / ok;\n}\n");
    File.WriteAllText(Path.Join(mdir, "multi.app.z42.toml"),
        "[project]\nname    = \"multi.app\"\nversion = \"0.1.0\"\nkind    = \"exe\"\npack    = true\n\n[sources]\ninclude = [\"*.z42\"]\n");
    string[] cmpTomls = new string[6];
    cmpTomls[0] = btoml;
    cmpTomls[1] = Path.Join(ddir, "demo.minimal.z42.toml");
    cmpTomls[2] = Path.Join(hdir, "hello.app.z42.toml");
    cmpTomls[3] = Path.Join(tdir, "text.app.z42.toml");
    cmpTomls[4] = Path.Join(cdir, "clos.app.z42.toml");
    cmpTomls[5] = Path.Join(mdir, "multi.app.z42.toml");
    // replace-csharp Phase C：删 zpkg byte-compare-vs-C#（C# 已删）。改为 z42c build 6 工程
    // 验可建（功能性）；z42c 自身 byte-identical 由 self-host 不动点覆盖。
    int pi = 0;
    while (pi < 6) {
        string pdir = Path.GetDirectoryName(cmpTomls[pi]);
        rc = new Process(vm).Arg(driverZpkg).Arg("--").Arg("build").Arg(cmpTomls[pi])
            .Env("Z42_LIBS", flat).Stdout(Stdio.Null()).Stderr(Stdio.Inherit()).Run().ExitCode;
        if (rc != 0) { Console.WriteLine("  ✗ z42c build failed: " + cmpTomls[pi]); return 1; }
        string[] zOut = Path.Glob(Path.Join(pdir, "dist"), "*.zpkg");
        if (zOut.Length != 1) { Console.WriteLine("  ✗ expected 1 zpkg in " + pdir + "/dist"); return 1; }
        pi = pi + 1;
    }
    Console.WriteLine("  ✓ z42c build: 6/6 projects built (multi-file packages; functional)");
    // hello-stdlib 直跑（跨包 Call 链可执行性）
    rc = new Process(vm).Arg(Path.Join(cdir, "dist/clos.app.zpkg"))
        .Env("Z42_LIBS", Path.Join(root, "artifacts/build/libraries/dist/release"))
        .Stdout(Stdio.Null()).Stderr(Stdio.Null()).Run().ExitCode;
    if (rc != 0) { Console.WriteLine("  ✗ clos.app.zpkg failed to run (exit " + rc.ToString() + ")"); return 1; }
    rc = new Process(vm).Arg(Path.Join(tdir, "dist/text.app.zpkg"))
        .Env("Z42_LIBS", Path.Join(root, "artifacts/build/libraries/dist/release"))
        .Stdout(Stdio.Null()).Stderr(Stdio.Null()).Run().ExitCode;
    if (rc != 0) { Console.WriteLine("  ✗ text.app.zpkg failed to run (exit " + rc.ToString() + ")"); return 1; }
    rc = new Process(vm).Arg(Path.Join(hdir, "dist/hello.app.zpkg"))
        .Env("Z42_LIBS", Path.Join(root, "artifacts/build/libraries/dist/release"))
        .Stdout(Stdio.Null()).Stderr(Stdio.Null()).Run().ExitCode;
    if (rc != 0) { Console.WriteLine("  ✗ hello.app.zpkg failed to run (exit " + rc.ToString() + ")"); return 1; }
    Console.WriteLine("  ✓ import e2e: z42c-built hello.app.zpkg (using Std; Console.WriteLine) runs on z42vm");
    Console.WriteLine("✅ z42c e2e: self-compiled .zbc executes on z42vm");
    return 0;
}
