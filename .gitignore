# Build artifacts (all redirected to artifacts/)
artifacts/

# .NET / C#
*.user
*.suo
.vs/
*.nupkg
*.snupkg
*.lock.json
!packages.lock.json
# Build intermediates — always redirected to artifacts/ via Directory.Build.props
obj/
bin/

# Rust
Cargo.lock
*.rlib
*.rmeta

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# z42 build outputs
*.z42c
*.zbc
*.zlib
*.zmod
*.zasm
*.z42ir.json
dist/
.cache/

# zbc-format wire-format fixtures: source.zbc are checked-in byte goldens
# (regen via src/tests/zbc-format/generate-fixtures.sh after a writer minor bump).
# Negate the *.zbc rule for this directory only.
!src/tests/zbc-format/**/source.zbc

# Cross-zpkg e2e test build artifacts (per-package libs/ populated by test driver).
src/tests/cross-zpkg/*/*/libs/

# BenchmarkDotNet output (auto-created in CWD when running `dotnet run` from any dir)
BenchmarkDotNet.Artifacts/

# Bench output / baseline files (only .gitkeep tracked; CI publishes real baselines elsewhere)
bench/results/*.json
bench/baselines/*.json

# Claude scheduler local state
.claude/scheduled_tasks.lock

# dotnet test runner output
TestResults/
.z42/

# Generated dev-CLI apphost at the repo root (scripts/build-xtask.sh).
# Native, platform-specific — regenerate, don't commit.
/xtask
